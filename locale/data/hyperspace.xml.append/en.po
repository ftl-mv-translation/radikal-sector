#: src-en/data/hyperspace.xml.append:509
msgid ""
"data/hyperspace.xml.append$/dummyroot/FTL/mod:findLike[3]/mod:findLike[1]/mod-"
"append:shipIcon/tooltip"
msgstr ""
"PERSISTENCE SHIELD:\n"
"\t\t\tThis enemy is protected by an Energy Shield. Hacking, Mind Control, Teleportation, Boarding Drones, and all hull-damaging or ion weapons will all be blocked until disabled. This specific shield also increased shield recharge rate, and the enemy is capable of regenerating their Energy Shield once!"

#: src-en/data/hyperspace.xml.append:518
msgid ""
"data/hyperspace.xml.append$/dummyroot/FTL/mod:findLike[3]/mod:findLike[2]/mod-"
"append:shipIcon/tooltip"
msgstr ""
"CHOKING F.I.N.E.:\n"
"\t\t\tThis ship's crew take 0.75x suffocation damage.\n"
"\t\t\tWhile suffocating, they move, sabotage, repair and fight 1.5x better."

#: src-en/data/hyperspace.xml.append:527
msgid ""
"data/hyperspace.xml.append$/dummyroot/FTL/mod:findLike[3]/mod:findLike[3]/mod-"
"append:shipIcon/tooltip"
msgstr ""
"PERSISTENCE SHIELD:\n"
"\t\t\tThis enemy is protected by an Energy Shield. Hacking, Mind Control, Teleportation, Boarding Drones, and all hull-damaging or ion weapons will all be blocked until disabled. This specific shield also increased shield recharge rate, and the enemy is capable of regenerating their Energy Shield once!"

#: src-en/data/hyperspace.xml.append:534
msgid ""
"data/hyperspace.xml.append$/dummyroot/FTL/mod:findLike[3]/mod:findLike[4]/mod-"
"append:shipIcon/tooltip"
msgstr ""
"CHOKING F.I.N.E.:\n"
"\t\t\tThis ship's crew take 0.75x suffocation damage.\n"
"\t\t\tWhile suffocating, they move, sabotage, repair and fight 1.5x better."

#: src-en/data/hyperspace.xml.append:543
msgid ""
"data/hyperspace.xml.append$/dummyroot/FTL/mod:findLike[3]/mod:findLike[5]/mod-"
"append:shipIcon/tooltip"
msgstr ""
"DEMICLONERS:\n"
"\t\t\tDark energies try to resurrect this ship's crew if they die (not in events) without a real Clonebay.\n"
"\t\t\tAt best, they become their own lesser version (Soldier = default Human, etc.) If no lesser version exists, they become Morphs. When Morphs die, nothing happens."

#: src-en/data/hyperspace.xml.append:553
msgid ""
"data/hyperspace.xml.append$/dummyroot/FTL/mod:findLike[3]/mod:findLike[6]/mod-"
"append:shipIcon/tooltip"
msgstr ""
"PUNK HARMONY:\n"
"\t\t\tThis ship's Engis are more resistant and immune to Mind Control. They're also exponentially better at repairs, faster and stronger for each active level of Hacking and Mind Control on their ship!"

#: src-en/data/hyperspace.xml.append:562
msgid ""
"data/hyperspace.xml.append$/dummyroot/FTL/mod:findLike[3]/mod:findLike[7]/mod-"
"append:shipIcon/tooltip"
msgstr ""
"DEFENSE KITS:\n"
"\t\t\tOn their ship, this ship's crew resist combat damage, repair and move faster, and heal over time if they are idle (not manning)."

#: src-en/data/hyperspace.xml.append:569
msgid ""
"data/hyperspace.xml.append$/dummyroot/FTL/mod:findLike[3]/mod:findLike[8]/mod-"
"append:shipIcon/tooltip"
msgstr ""
"DEMICLONERS:\n"
"\t\t\tDark energies try to resurrect this ship's crew if they die (not in events) without a real Clonebay.\n"
"\t\t\tAt best, they become their own lesser version (Soldier = default Human, etc.) If no lesser version exists, they become Morphs. When Morphs die, nothing happens."

#: src-en/data/hyperspace.xml.append:578
msgid ""
