#: src-en/data/hyperspace.xml.append:1904
msgid ""
"data/hyperspace.xml.append$//mod-"
"append:race[@name=\"rk_weaponlike\"]/powerEffect[3]/buttonText"
msgstr "BOMB IN"

#: src-en/data/hyperspace.xml.append:1905
msgid ""
"data/hyperspace.xml.append$//mod-"
"append:race[@name=\"rk_weaponlike\"]/powerEffect[3]/tooltip"
msgstr ""
"Detonate the bomb, dealing 1 damage in the current room and causing a "
"breach. Get 1 charge per jump"

#: src-en/data/hyperspace.xml.append:2022
msgid ""
"data/hyperspace.xml.append$//mod-"
"append:race[@name=\"unique_rk_defromorius\"]/powerEffect/buttonText"
msgstr "DECUBITUS"

#: src-en/data/hyperspace.xml.append:2023
msgid ""
"data/hyperspace.xml.append$//mod-"
"append:race[@name=\"unique_rk_defromorius\"]/powerEffect/tooltip"
msgstr ""
"[COOLDOWN:10s  DURATION:10s]\n"
"\t\t\t\tAllied crew in the same ship including Defromorius take 0.7x damage from everything, and deal 1.5x damage."

#: src-en/data/hyperspace.xml.append:2133
msgid ""
"data/hyperspace.xml.append$//mod-"
"append:race[@name=\"rk_fireghost\"]/powerEffect/buttonText"
msgstr "YFLARE"

#: src-en/data/hyperspace.xml.append:2134
msgid ""
"data/hyperspace.xml.append$//mod-"
"append:race[@name=\"rk_fireghost\"]/powerEffect/tooltip"
msgstr ""
"[COOLDOWN:10s -20HP]\n"
"\t\t\t\tStarts a fire in a random room on both ships."

#: src-en/data/hyperspace.xml.append:2211
msgid ""
"data/hyperspace.xml.append$//mod-"
"append:race[@name=\"rk_bottledoxygen\"]/powerEffect[1]/buttonText"
msgstr "LEAK AIR"

#: src-en/data/hyperspace.xml.append:2212
msgid ""
"data/hyperspace.xml.append$//mod-"
"append:race[@name=\"rk_bottledoxygen\"]/powerEffect[1]/tooltip"
msgstr "SHOULD NEVER BE SEEN, shows a cloud dissipating."

#: src-en/data/hyperspace.xml.append:2242
msgid ""
"data/hyperspace.xml.append$//mod-"
"append:race[@name=\"rk_bottledoxygen\"]/powerEffect[2]/buttonText"
msgstr "EXPLODE"

#: src-en/data/hyperspace.xml.append:2243
msgid ""
"data/hyperspace.xml.append$//mod-"
"append:race[@name=\"rk_bottledoxygen\"]/powerEffect[2]/tooltip"
msgstr ""
"[COOLDOWN:3s]\n"
"\t\t\t\tExplode for 30 crew damage to all crew in the room with a 60% chance to start a fire.\n"
"\t\t\t\tCannot activate while teleporting or under 15 Health."

