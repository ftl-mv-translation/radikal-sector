msgstr "BOMB OUT"

#: src-en/data/hyperspace.xml.append:1813
msgid ""
"data/hyperspace.xml.append$//mod-"
"append:race[@name=\"rk_weaponlike\"]/powerEffect[1]/tooltip"
msgstr ""
"Teleport the bomb to the other ship, dealing 1 damage and causing a breach. "
