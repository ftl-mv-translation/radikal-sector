#: src-en/data/events_special_storage.xml.append:4734
msgid ""
"data/events_special_storage.xml.append$//event[@name=\"DJMOD_HACK_FLEET_OUTCOME_NEUTRAL\"]/choice/text"
msgstr "Continue to the fight!"

#: src-en/data/events_special_storage.xml.append:4739
msgid ""
"data/events_special_storage.xml.append$//event[@name=\"DJMOD_HACK_FLEET_OUTCOME_BAD\"]/text"
msgstr ""
"This hack went terribly wrong, and their comms countered by giving away our "
"location!"

#: src-en/data/events_special_storage.xml.append:4742
msgid ""
"data/events_special_storage.xml.append$//event[@name=\"DJMOD_HACK_FLEET_OUTCOME_BAD\"]/choice/text"
msgstr "Continue to the fight!"

#: src-en/data/events_special_storage.xml.append:4747
msgid ""
"data/events_special_storage.xml.append$//event[@name=\"DJMOD_HACK_FLEET_OUTCOME_BOSS\"]/text"
msgstr ""
"This hack should have, but didn't delay the fleet... \n"
"\t\tSomeone interfered, and sent us strange coordinates with this attached: \"N00bs!!1!\"."

#: src-en/data/events_special_storage.xml.append:4752
msgid ""
"data/events_special_storage.xml.append$//event[@name=\"DJMOD_HACK_FLEET_OUTCOME_BOSS\"]/choice/text"
msgstr "Weird, but we'll deal with that later. Continue to the fight!"

#: src-en/data/events_special_storage.xml.append:4758
msgid ""
"data/events_special_storage.xml.append$//event[@name=\"DJMOD_HACK_FLEET_STOP\"]/text"
msgstr ""
"Excess damage to the enemy's hull ruined our hacking attempt to delay the "
"rebel fleet. These things require subtlety!"

#: src-en/data/events_special_storage.xml.append:4767
msgid ""
"data/events_special_storage.xml.append$//event[@name=\"DJMOD_HACK_FLEET_STOP\"]/choice/text"
msgstr "What a waste. But continue to the fight!"

#: src-en/data/events_special_storage.xml.append:4782
msgid ""
"data/events_special_storage.xml.append$//event[@name=\"RK_HACK_FLEET_BOSS\"]/beaconType/unvisitedTooltip"
msgstr ""
"Someone dangerous enough to stop a strong RK Enigmashin hack dares you to "
"come!"

#: src-en/data/events_special_storage.xml.append:4785
msgid ""
"data/events_special_storage.xml.append$//event[@name=\"RK_HACK_FLEET_BOSS\"]/text"
msgstr ""
"A very mean-looking elite rebel ship is here. Its captain is staring you down.\n"
"\n"
"\t\t\"When i heard someone was playing games with the fleet's comms, I knew i had to meet the fool! And here you are, noobs!\n"
"\t\tLet me show you how it's done! And then you die.\""

#: src-en/data/events_special_storage.xml.append:4793
msgid ""
"data/events_special_storage.xml.append$//event[@name=\"RK_HACK_FLEET_BOSS\"]/choice[1]/text"
msgstr "A challenge, then? Let's go!"

#: src-en/data/events_special_storage.xml.append:4795
msgid ""
"data/events_special_storage.xml.append$//event[@name=\"RK_HACK_FLEET_BOSS\"]/choice[1]/event/text"
msgstr ""
"The vicious smile on the enemy captain's face widens. \"Nyahaha, Here's a taste!\"\n"
"\t\t\t\tYou immediately notice malfunctions in many of your ship's systems! They must be using a combat augment! You probably expected that a hacker ship wouldn't play fair, but if you didn't, it might be time to consider a quick escape."

#: src-en/data/events_special_storage.xml.append:4804
msgid ""
"data/events_special_storage.xml.append$//event[@name=\"RK_HACK_FLEET_BOSS\"]/choice[1]/event/choice[1]/text"
msgstr "Continue..."

#: src-en/data/events_special_storage.xml.append:4809
msgid ""
"data/events_special_storage.xml.append$//event[@name=\"RK_HACK_FLEET_BOSS\"]/choice[1]/event/choice[@req=\"ANTI_VIRUS\"]/text"
msgstr "(Anti-Virus) Restore your systems."

#: src-en/data/events_special_storage.xml.append:4811
msgid ""
"data/events_special_storage.xml.append$//event[@name=\"RK_HACK_FLEET_BOSS\"]/choice[1]/event/choice[@req=\"ANTI_VIRUS\"]/event/text"
msgstr "Your systems are restored to full power."

#: src-en/data/events_special_storage.xml.append:4817
msgid ""
"data/events_special_storage.xml.append$//event[@name=\"RK_HACK_FLEET_BOSS\"]/choice[1]/event/choice[@req=\"ANTI_VIRUS\"]/event/choice/text"
msgstr "Continue..."

#: src-en/data/events_special_storage.xml.append:4826
msgid ""
"data/events_special_storage.xml.append$//event[@name=\"RK_HACK_FLEET_BOSS\"]/choice[2]/text"
msgstr "We have learned our lesson, we beg you to let us go!"

#: src-en/data/events_special_storage.xml.append:4838
msgid ""
"data/events_special_storage.xml.append$//ship[@name=\"SHIP_RK_HACK_FLEET_BOSS\"]/surrender/text"
msgstr ""
"\"Playing tough huh! How do you like this?\"\n"
