#: src-en/data/events_special_storage.xml.append:1899
msgid ""
"data/events_special_storage.xml.append$//event[@name=\"SHIPVORE_RAM_FP_OWN_OUTCOME_BAD_TRAITOR\"]/choice[13]/event/text"
msgstr "As your crew is lost alone in the void, the others look terrified!"

#: src-en/data/events_special_storage.xml.append:1902
msgid ""
"data/events_special_storage.xml.append$//event[@name=\"SHIPVORE_RAM_FP_OWN_OUTCOME_BAD_TRAITOR\"]/choice[13]/event/choice[@req=\"mind\""
