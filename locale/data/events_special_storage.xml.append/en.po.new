#: src-en/data/events_special_storage.xml.append:4139
msgid ""
"data/events_special_storage.xml.append$//event[@name=\"DJMOD_COMBAT_SCORCH_ENEMY_EFFECT\"]/text"
msgstr ""
"You make fire that the Plasma Teleporter immediately moves to the enemy.\n"
"\tTheir ship is ablaze!"

#: src-en/data/events_special_storage.xml.append:4150
msgid ""
"data/events_special_storage.xml.append$//event[@name=\"DJMOD_COMBAT_SCORCH_ENEMY_EFFECT\"]/choice/text"
msgstr "It's awful, but it will give us an edge. Continue to the fight!"

#: src-en/data/events_special_storage.xml.append:4159
msgid ""
"data/events_special_storage.xml.append$//event[@name=\"DJMOD_COMBAT_SCORCH_BOTH_EFFECT\"]/text"
msgstr ""
"A lot of fire is produced and mostly funneled through the Plasma Teleporter onto the enemy ship.\n"
"\tBoth ships are ablaze!"

#: src-en/data/events_special_storage.xml.append:4173
msgid ""
"data/events_special_storage.xml.append$//event[@name=\"DJMOD_COMBAT_SCORCH_BOTH_EFFECT\"]/choice/text"
msgstr ""
"Deal with the fire, but keep an eye on the enemy. Continue to the fight!"

#: src-en/data/events_special_storage.xml.append:4191
msgid ""
"data/events_special_storage.xml.append$//event[@name=\"DJMOD_OXYGENIZER_ACTIVATE\"]/text"
msgstr ""
"Are you sure you want to do this?\n"
"\t[Will envelop both ships in an O2 atmosphere, protecting fires and crew from venting and breaches. Costs 2}]"

#: src-en/data/events_special_storage.xml.append:4194
msgid ""
"data/events_special_storage.xml.append$//event[@name=\"DJMOD_OXYGENIZER_ACTIVATE\"]/choice[@req=\"loc_environment_atmosphere\""
" and @lvl=\"0\"]/text"
msgstr "Yes."

#: src-en/data/events_special_storage.xml.append:4196
msgid ""
"data/events_special_storage.xml.append$//event[@name=\"DJMOD_OXYGENIZER_ACTIVATE\"]/choice[@req=\"loc_environment_atmosphere\""
" and @lvl=\"0\"]/event/text"
msgstr ""
"You fire the flash-release ultracompressed O2 grenades, enveloping the whole"
" area in just enough atmosphere to breathe... or sustain fires!"

#: src-en/data/events_special_storage.xml.append:4205
msgid ""
"data/events_special_storage.xml.append$//event[@name=\"DJMOD_OXYGENIZER_ACTIVATE\"]/choice[@req=\"loc_environment_atmosphere\""
" and @lvl=\"0\"]/event/choice/text"
msgstr "This will give us the advantage!"

#: src-en/data/events_special_storage.xml.append:4211
msgid ""
"data/events_special_storage.xml.append$//event[@name=\"DJMOD_OXYGENIZER_ACTIVATE\"]/choice[@req=\"loc_environment_atmosphere\""
" and not(@lvl)]/text"
msgstr "You're already in atmosphere!"

#: src-en/data/events_special_storage.xml.append:4215
msgid ""
"data/events_special_storage.xml.append$//event[@name=\"DJMOD_OXYGENIZER_ACTIVATE\"]/choice[3]/text"
msgstr "Do something else instead."

#: src-en/data/events_special_storage.xml.append:4219
msgid ""
"data/events_special_storage.xml.append$//event[@name=\"DJMOD_OXYGENIZER_ACTIVATE\"]/choice[4]/text"
msgstr "Nevermind, let's fight!"

#: src-en/data/events_special_storage.xml.append:4263
msgid ""
"data/events_special_storage.xml.append$//event[@name=\"DJMOD_COMBAT_CHECK_AUTO_SYS_REPAIR\"]/text"
msgstr ""
"Are you sure you want to do this?\n"
"\t[If hull reaches 5 points or less, you get repairs and lose the augment. Uses 1 power.]"

