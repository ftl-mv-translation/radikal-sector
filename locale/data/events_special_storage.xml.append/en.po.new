msgid ""
"data/events_special_storage.xml.append$//event[@name=\"RK_BPS_SURVEYOR_ACTIVATE\"]/text"
msgstr ""
"Are you sure you want to do this?\n"
"\t[Spend resources to send out deep-scouting looter drones. They find a random weapon and augment.\n"
"\tYou can choose one to retrieve at the cost of 1 fleet acceleration, or leave with a small refund.]"

#: src-en/data/events_special_storage.xml.append:6668
msgid ""
"data/events_special_storage.xml.append$//event[@name=\"RK_BPS_SURVEYOR_ACTIVATE\"]/choice[@req=\"RK_BPS_SURVEYOR\"]/text"
msgstr "Yes"

#: src-en/data/events_special_storage.xml.append:6670
msgid ""
"data/events_special_storage.xml.append$//event[@name=\"RK_BPS_SURVEYOR_ACTIVATE\"]/choice[@req=\"RK_BPS_SURVEYOR\"]/event/text"
msgstr ""
"\"Fetch!\" You send out both special drones, fingers-or-equivalent-appendages crossed.\n"
"\t\t\t\tSome time later, they remotely report their findings.\n"
"\t\t\t\t\n"
"\t\t\t\tIf you choose to retrieve nothing, you get back what's left of both retrievers.\n"
"\t\t\t\t\n"
"\t\t\t\tIf you choose to retrieve anything, you get back what's left of 1 retriever, but the fleet will gain 1 turn on you."

#: src-en/data/events_special_storage.xml.append:6685
msgid ""
"data/events_special_storage.xml.append$//event[@name=\"RK_BPS_SURVEYOR_ACTIVATE\"]/choice[@req=\"RK_BPS_SURVEYOR\"]/event/choice[1]/text"
