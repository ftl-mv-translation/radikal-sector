#: src-en/data/events_special_storage.xml.append:6984
msgid ""
"data/events_special_storage.xml.append$//event[@name=\"STORAGE_CHECK_SYSTEM_DJMOD_RADIKAL\"]/text"
msgstr "What upgrade do you want to install?"

#: src-en/data/events_special_storage.xml.append:7002
msgid ""
"data/events_special_storage.xml.append$//event[@name=\"STORAGE_CHECK_SYSTEM_DJMOD_RADIKAL\"]/choice[@req=\"INTERNAL_RK_CALIBRATOR\""
" and @lvl=\"2\"]/text"
msgstr ""
"RK Bam \"Calibrator\": Your weapons have +10% accuracy and 4% increased fire rate.\n"
"\t\t\tCan be installed twice. [ALREADY INSTALLED: You already have the max of this upgrade]"

#: src-en/data/events_special_storage.xml.append:7007
msgid ""
"data/events_special_storage.xml.append$//event[@name=\"STORAGE_CHECK_SYSTEM_DJMOD_RADIKAL\"]/choice[@req=\"INTERNAL_RK_CALIBRATOR\""
" and @lvl=\"1\"]/text"
msgstr "Calibrator Lvl 2. [Cost: 40~]"

#: src-en/data/events_special_storage.xml.append:7011
msgid ""
"data/events_special_storage.xml.append$//event[@name=\"STORAGE_CHECK_SYSTEM_DJMOD_RADIKAL\"]/choice[@req=\"INTERNAL_RK_CALIBRATOR\""
" and @lvl=\"0\"]/text"
msgstr "Calibrator Lvl 1. [Cost: 40~]"

#: src-en/data/events_special_storage.xml.append:7016
msgid ""
"data/events_special_storage.xml.append$//event[@name=\"STORAGE_CHECK_SYSTEM_DJMOD_RADIKAL\"]/choice[@req=\"INTERNAL_RK_CHOKING_IS_FINE\""
" and @lvl=\"1\"]/text"
msgstr ""
"RK Bam \"Choking F.I.N.E.\": Your crew take 0.75x suffocation damage.\n"
"\t\tWhile suffocating, they move, sabotage, repair and fight 1.5x better. Suffocation immune can't suffocate. [ALREADY INSTALLED]"

#: src-en/data/events_special_storage.xml.append:7021
msgid ""
"data/events_special_storage.xml.append$//event[@name=\"STORAGE_CHECK_SYSTEM_DJMOD_RADIKAL\"]/choice[@req=\"INTERNAL_RK_CHOKING_IS_FINE\""
" and @lvl=\"0\"]/text"
msgstr "Choking F.I.N.E. [Cost: 55~, 1}, 1|]"

#: src-en/data/events_special_storage.xml.append:7026
msgid ""
"data/events_special_storage.xml.append$//event[@name=\"STORAGE_CHECK_SYSTEM_DJMOD_RADIKAL\"]/choice[@req=\"INTERNAL_DJMOD_DEMICLONER\""
" and @lvl=\"1\"]/text"
msgstr ""
"RK Punk \"Demicloners\": With no Clonebay, your dying crew resurrect as a lesser version (Soldier = default Human, etc.)\n"
"\t\t\tIf none exists, they become Morphs. When Morphs die, nothing happens. Does not work for event deaths. [ALREADY INSTALLED]"

#: src-en/data/events_special_storage.xml.append:7031
msgid ""
"data/events_special_storage.xml.append$//event[@name=\"STORAGE_CHECK_SYSTEM_DJMOD_RADIKAL\"]/choice[@req=\"INTERNAL_DJMOD_DEMICLONER\""
" and @lvl=\"0\"]/text"
msgstr "Demicloners. [Cost: 35~, 2|]"

#: src-en/data/events_special_storage.xml.append:7036
msgid ""
"data/events_special_storage.xml.append$//event[@name=\"STORAGE_CHECK_SYSTEM_DJMOD_RADIKAL\"]/choice[@req=\"INTERNAL_DJMOD_MC_PARALYZER\""
" and @lvl=\"1\"]/text"
msgstr ""
"RK Punk \"Mind Cooler\": When under the effects of Mind Control, your crew "
"cannot fight, sabotage, or teleport away. Works on both ships. [ALREADY "
"INSTALLED]"

#: src-en/data/events_special_storage.xml.append:7040
msgid ""
"data/events_special_storage.xml.append$//event[@name=\"STORAGE_CHECK_SYSTEM_DJMOD_RADIKAL\"]/choice[@req=\"INTERNAL_DJMOD_MC_PARALYZER\""
" and @lvl=\"0\"]/text"
msgstr "Mind Cooler. [Cost: 30~, 1|]"

#: src-en/data/events_special_storage.xml.append:7046
msgid ""
