#: src-en/data/events_special_storage.xml.append:1678
msgid ""
"data/events_special_storage.xml.append$/dummyroot/FTL/event[@name=\"SHIPVORE_RAM_OWN_OUTCOME_BAD_CREW\"]/choice[13]/text"
msgstr "...There's nothing we can do about it, focus on the fight!"

#: src-en/data/events_special_storage.xml.append:1680
msgid ""
"data/events_special_storage.xml.append$/dummyroot/FTL/event[@name=\"SHIPVORE_RAM_OWN_OUTCOME_BAD_CREW\"]/choice[13]/event/text"
msgstr ""
"As your crew is lost alone in the void, the others refuse to ram that ship "
