#: src-en/data/events_special_storage.xml.append:4716
msgid ""
"data/events_special_storage.xml.append$//event[@name=\"DJMOD_HACK_FLEET_OUTCOME_GOOD_CRITICAL\"]/text"
msgstr "Hehe, they really bought it! This hack gives us a solid advance."

#: src-en/data/events_special_storage.xml.append:4719
msgid ""
"data/events_special_storage.xml.append$//event[@name=\"DJMOD_HACK_FLEET_OUTCOME_GOOD_CRITICAL\"]/choice/text"
