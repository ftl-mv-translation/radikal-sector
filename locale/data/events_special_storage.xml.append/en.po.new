#: src-en/data/events_special_storage.xml.append:1105
msgid ""
"data/events_special_storage.xml.append$/dummyroot/FTL/event[@name=\"SHIPVORE_RAM_ATTACK_3DMG_NOTHING\"]/choice/text"
msgstr "...with this result on your own ship (75% chance good)."

#: src-en/data/events_special_storage.xml.append:1111
msgid ""
"data/events_special_storage.xml.append$/dummyroot/FTL/event[@name=\"SHIPVORE_RAM_ATTACK_3DMG_BREACH\"]/text"
msgstr "You rip out a small part of the enemy ship, dealing 3 damage..."

#: src-en/data/events_special_storage.xml.append:1117
msgid ""
"data/events_special_storage.xml.append$/dummyroot/FTL/event[@name=\"SHIPVORE_RAM_ATTACK_3DMG_BREACH\"]/choice/text"
