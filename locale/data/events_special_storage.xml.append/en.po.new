#: src-en/data/events_special_storage.xml.append:1306
msgid ""
"data/events_special_storage.xml.append$//event[@name=\"SHIPVORE_RAM_OWN_OUTCOME_BAD_CREW\"]/text"
msgstr ""
"The shock was terrible... It seems our crew was thrown into space through a "
"breach!"

#: src-en/data/events_special_storage.xml.append:1312
msgid ""
"data/events_special_storage.xml.append$//event[@name=\"SHIPVORE_RAM_OWN_OUTCOME_BAD_CREW\"]/choice[@req=\"DJMOD_CAN_TELEPORT_EJECTED_CREW\""
" and @lvl=\"1\"]/text"
msgstr "(Teleporter 3 + Reconstructive) Emergency teleport!"

#: src-en/data/events_special_storage.xml.append:1314
msgid ""
"data/events_special_storage.xml.append$//event[@name=\"SHIPVORE_RAM_OWN_OUTCOME_BAD_CREW\"]/choice[@req=\"DJMOD_CAN_TELEPORT_EJECTED_CREW\""
" and @lvl=\"1\"]/event/text"
msgstr ""
"Your preparation pays off as you easily teleport them back in good health."

#: src-en/data/events_special_storage.xml.append:1317
msgid ""
"data/events_special_storage.xml.append$//event[@name=\"SHIPVORE_RAM_OWN_OUTCOME_BAD_CREW\"]/choice[@req=\"DJMOD_CAN_TELEPORT_EJECTED_CREW\""
" and @lvl=\"1\"]/event/choice[@req=\"DJMOD_COMBAT_SHIPVORE_RAM_ANY\"]/text"
msgstr "Easy! Maybe we can go again?"

#: src-en/data/events_special_storage.xml.append:1323
msgid ""
"data/events_special_storage.xml.append$//event[@name=\"SHIPVORE_RAM_OWN_OUTCOME_BAD_CREW\"]/choice[@req=\"DJMOD_CAN_TELEPORT_EJECTED_CREW\""
" and @lvl=\"0\"]/text"
msgstr "Your teleportation equipment is insufficient."

#: src-en/data/events_special_storage.xml.append:1328
msgid ""
"data/events_special_storage.xml.append$//event[@name=\"SHIPVORE_RAM_OWN_OUTCOME_BAD_CREW\"]/choice[@req=\"DJMOD_SUFFICIENT_PILOTING_AND_SENSORS\""
" and not(@lvl)]/text"
msgstr "(Piloting 3, Sensors 2) Do a barrel roll!"

#: src-en/data/events_special_storage.xml.append:1330
msgid ""
"data/events_special_storage.xml.append$//event[@name=\"SHIPVORE_RAM_OWN_OUTCOME_BAD_CREW\"]/choice[@req=\"DJMOD_SUFFICIENT_PILOTING_AND_SENSORS\""
" and not(@lvl)]/event/text"
msgstr ""
"A precise AI-assisted maneuver puts your crew back in through the same "
"breach!"

#: src-en/data/events_special_storage.xml.append:1336
msgid ""
"data/events_special_storage.xml.append$//event[@name=\"SHIPVORE_RAM_OWN_OUTCOME_BAD_CREW\"]/choice[@req=\"DJMOD_SUFFICIENT_PILOTING_AND_SENSORS\""
" and not(@lvl)]/event/choice[@req=\"DJMOD_COMBAT_SHIPVORE_RAM_ANY\"]/text"
msgstr "That was close! Maybe we can go again?"

#: src-en/data/events_special_storage.xml.append:1342
msgid ""
"data/events_special_storage.xml.append$//event[@name=\"SHIPVORE_RAM_OWN_OUTCOME_BAD_CREW\"]/choice[@req=\"DJMOD_SUFFICIENT_PILOTING_AND_SENSORS\""
" and @lvl=\"0\"]/text"
msgstr "Your Piloting or Sensors system is too weak."

#: src-en/data/events_special_storage.xml.append:1347
msgid ""
"data/events_special_storage.xml.append$//event[@name=\"SHIPVORE_RAM_OWN_OUTCOME_BAD_CREW\"]/choice[@req=\"engines\""
" and @lvl=\"5\"]/text"
msgstr "(Engines 5) Quick, swerve!"

#: src-en/data/events_special_storage.xml.append:1349
msgid ""
"data/events_special_storage.xml.append$//event[@name=\"SHIPVORE_RAM_OWN_OUTCOME_BAD_CREW\"]/choice[@req=\"engines\""
" and @lvl=\"5\"]/event/text"
msgstr "With great speed you catch your crew mid-flight!"

#: src-en/data/events_special_storage.xml.append:1355
msgid ""
"data/events_special_storage.xml.append$//event[@name=\"SHIPVORE_RAM_OWN_OUTCOME_BAD_CREW\"]/choice[@req=\"engines\""
" and @lvl=\"5\"]/event/choice[@req=\"DJMOD_COMBAT_SHIPVORE_RAM_ANY\"]/text"
msgstr "That was close! Maybe we can go again?"

#: src-en/data/events_special_storage.xml.append:1361
msgid ""
"data/events_special_storage.xml.append$//event[@name=\"SHIPVORE_RAM_OWN_OUTCOME_BAD_CREW\"]/choice[@req=\"engines\""
" and not(@lvl)]/text"
msgstr "Your Engines system is too weak."

#: src-en/data/events_special_storage.xml.append:1366
msgid ""
"data/events_special_storage.xml.append$//event[@name=\"SHIPVORE_RAM_OWN_OUTCOME_BAD_CREW\"]/choice[7]/text"
msgstr "(Doctor Drone) Quick, drone rescue!"

#: src-en/data/events_special_storage.xml.append:1368
msgid ""
"data/events_special_storage.xml.append$//event[@name=\"SHIPVORE_RAM_OWN_OUTCOME_BAD_CREW\"]/choice[7]/event/text"
msgstr ""
"Your Dr. Drone quickly swiftly brings back the crew while protecting their "
"vital organs!"

#: src-en/data/events_special_storage.xml.append:1374
msgid ""
"data/events_special_storage.xml.append$//event[@name=\"SHIPVORE_RAM_OWN_OUTCOME_BAD_CREW\"]/choice[7]/event/choice[@req=\"DJMOD_COMBAT_SHIPVORE_RAM_ANY\"]/text"
msgstr "That was close! Maybe we can go again?"

#: src-en/data/events_special_storage.xml.append:1380
msgid ""
"data/events_special_storage.xml.append$//event[@name=\"SHIPVORE_RAM_OWN_OUTCOME_BAD_CREW\"]/choice[8]/text"
msgstr "You do not have the appropriate crew drone."

#: src-en/data/events_special_storage.xml.append:1385
msgid ""
"data/events_special_storage.xml.append$//event[@name=\"SHIPVORE_RAM_OWN_OUTCOME_BAD_CREW\"]/choice[@req=\"DJMOD_ANY_RESCUE_ARM\""
" and not(@lvl)]/text"
msgstr "(Appropriate ship Arm) Grab them with a makeshift lasso!"

#: src-en/data/events_special_storage.xml.append:1387
msgid ""
"data/events_special_storage.xml.append$//event[@name=\"SHIPVORE_RAM_OWN_OUTCOME_BAD_CREW\"]/choice[@req=\"DJMOD_ANY_RESCUE_ARM\""
" and not(@lvl)]/event/text"
msgstr ""
"With dubious logic, you get your crew back in through the same breach!"

#: src-en/data/events_special_storage.xml.append:1393
msgid ""
"data/events_special_storage.xml.append$//event[@name=\"SHIPVORE_RAM_OWN_OUTCOME_BAD_CREW\"]/choice[@req=\"DJMOD_ANY_RESCUE_ARM\""
" and not(@lvl)]/event/choice[@req=\"DJMOD_COMBAT_SHIPVORE_RAM_ANY\"]/text"
msgstr "That was close! Maybe we can go again?"

#: src-en/data/events_special_storage.xml.append:1399
msgid ""
"data/events_special_storage.xml.append$//event[@name=\"SHIPVORE_RAM_OWN_OUTCOME_BAD_CREW\"]/choice[@req=\"DJMOD_ANY_RESCUE_ARM\""
" and @lvl=\"0\"]/text"
msgstr "Your ship does not have an appropriate Arm."

#: src-en/data/events_special_storage.xml.append:1404
msgid ""
"data/events_special_storage.xml.append$//event[@name=\"SHIPVORE_RAM_OWN_OUTCOME_BAD_CREW\"]/choice[@req=\"DJMOD_SUM_ENGINEERS\""
