"data/events_special_storage.xml.append$/dummyroot/FTL/event[@name=\"SHIPVORE_RAM_OWN_OUTCOME_BAD_CREW\"]/choice[@req=\"DJMOD_SUM_ENGINEERS\""
" and @lvl=\"2\"]/event/text"
msgstr ""
"With dubious logic, you get your crew back in through the same breach! But "
"also take some hull damage."

#: src-en/data/events_special_storage.xml.append:1667
msgid ""
"data/events_special_storage.xml.append$/dummyroot/FTL/event[@name=\"SHIPVORE_RAM_OWN_OUTCOME_BAD_CREW\"]/choice[@req=\"DJMOD_SUM_ENGINEERS\""
" and @lvl=\"2\"]/event/choice[@req=\"DJMOD_COMBAT_SHIPVORE_RAM_ANY\"]/text"
msgstr "That was close! Maybe we can go again?"

#: src-en/data/events_special_storage.xml.append:1673
msgid ""
"data/events_special_storage.xml.append$/dummyroot/FTL/event[@name=\"SHIPVORE_RAM_OWN_OUTCOME_BAD_CREW\"]/choice[@req=\"DJMOD_SUM_ENGINEERS\""
" and not(@lvl)]/text"
