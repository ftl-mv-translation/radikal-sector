#: src-en/data/events_special_storage.xml.append:774
msgid ""
"data/events_special_storage.xml.append$//event[@name=\"DJMOD_COMBAT_CHECK_SHIPVORE_RAM\"]/text"
msgstr ""
"Are you sure you want to do this?\n"
"\t[Ram the enemy ship, high chance to repair your ship.\n"
"\tWARNING: may go wrong!]"

#: src-en/data/events_special_storage.xml.append:783
msgid ""
"data/events_special_storage.xml.append$//event[@name=\"DJMOD_COMBAT_CHECK_SHIPVORE_RAM\"]/choice[1]/text"
msgstr "Yes [Needs 10 seconds.]"

#: src-en/data/events_special_storage.xml.append:785
msgid ""
"data/events_special_storage.xml.append$//event[@name=\"DJMOD_COMBAT_CHECK_SHIPVORE_RAM\"]/choice[1]/event/text"
msgstr "You activate the augment..."

#: src-en/data/events_special_storage.xml.append:793
msgid ""
"data/events_special_storage.xml.append$//event[@name=\"DJMOD_COMBAT_CHECK_SHIPVORE_RAM\"]/choice[1]/event/choice/text"
msgstr "Continue..."

#: src-en/data/events_special_storage.xml.append:799
msgid ""
"data/events_special_storage.xml.append$//event[@name=\"DJMOD_COMBAT_CHECK_SHIPVORE_RAM\"]/choice[@req=\"DEBUG_GENERATOR\"]/text"
msgstr "(Emergency generator) Yes, using no fuel."

#: src-en/data/events_special_storage.xml.append:803
msgid ""
"data/events_special_storage.xml.append$//event[@name=\"DJMOD_COMBAT_CHECK_SHIPVORE_RAM\"]/choice[@req=\"FUEL_CONSERVER\"]/text"
msgstr "(Fuel Conserver) Yes, using no fuel."

#: src-en/data/events_special_storage.xml.append:808
msgid ""
"data/events_special_storage.xml.append$//event[@name=\"DJMOD_COMBAT_CHECK_SHIPVORE_RAM\"]/choice[@req=\"DJMOD_COMBAT_SHIPVORE_RAM_REINFORCED\"]/text"
msgstr ""
"(Reinforced Shipvore Ram) Yes, at full power!\n"
"\t\t[You'll [style[color:ff3377]]lose the reinforcement[[/style]]. [style[color:ff3377]]Can't ram again[[/style]] until you jump. Needs 7 seconds.]"

#: src-en/data/events_special_storage.xml.append:811
msgid ""
"data/events_special_storage.xml.append$//event[@name=\"DJMOD_COMBAT_CHECK_SHIPVORE_RAM\"]/choice[@req=\"DJMOD_COMBAT_SHIPVORE_RAM_REINFORCED\"]/event/text"
msgstr "You activate the augment at full power..."

#: src-en/data/events_special_storage.xml.append:820
msgid ""
"data/events_special_storage.xml.append$//event[@name=\"DJMOD_COMBAT_CHECK_SHIPVORE_RAM\"]/choice[@req=\"DJMOD_COMBAT_SHIPVORE_RAM_REINFORCED\"]/event/choice/text"
msgstr "Continue to the fight!"

#: src-en/data/events_special_storage.xml.append:826
msgid ""
"data/events_special_storage.xml.append$//event[@name=\"DJMOD_COMBAT_CHECK_SHIPVORE_RAM\"]/choice[@req=\"DJMOD_COMBAT_SHIPVORE_RAM_NOT_REINFORCED\"]/text"
msgstr ""
"Yes, at full power!\n"
"\t\t[The augment will [style[color:ff3377]]disintegrate[[/style]]. Needs 7 seconds.]"

#: src-en/data/events_special_storage.xml.append:829
msgid ""
"data/events_special_storage.xml.append$//event[@name=\"DJMOD_COMBAT_CHECK_SHIPVORE_RAM\"]/choice[@req=\"DJMOD_COMBAT_SHIPVORE_RAM_NOT_REINFORCED\"]/event/text"
msgstr "You activate the augment at full power..."

#: src-en/data/events_special_storage.xml.append:838
msgid ""
"data/events_special_storage.xml.append$//event[@name=\"DJMOD_COMBAT_CHECK_SHIPVORE_RAM\"]/choice[@req=\"DJMOD_COMBAT_SHIPVORE_RAM_NOT_REINFORCED\"]/event/choice/text"
msgstr "Continue to the fight!"

#: src-en/data/events_special_storage.xml.append:844
msgid ""
"data/events_special_storage.xml.append$//event[@name=\"DJMOD_COMBAT_CHECK_SHIPVORE_RAM\"]/choice[@req=\"LOCKED_DJMOD_COMBAT_SHIPVORE_RAM\"]/text"
msgstr ""
"Yes, at full power!\n"
"\t\t[Can't ram again until next jump. Needs 7 seconds.]"

#: src-en/data/events_special_storage.xml.append:847
msgid ""
"data/events_special_storage.xml.append$//event[@name=\"DJMOD_COMBAT_CHECK_SHIPVORE_RAM\"]/choice[@req=\"LOCKED_DJMOD_COMBAT_SHIPVORE_RAM\"]/event/text"
msgstr "You activate the augment at full power..."

#: src-en/data/events_special_storage.xml.append:857
msgid ""
"data/events_special_storage.xml.append$//event[@name=\"DJMOD_COMBAT_CHECK_SHIPVORE_RAM\"]/choice[@req=\"LOCKED_DJMOD_COMBAT_SHIPVORE_RAM\"]/event/choice/text"
msgstr "Continue to the fight!"

#: src-en/data/events_special_storage.xml.append:864
msgid ""
"data/events_special_storage.xml.append$//event[@name=\"DJMOD_COMBAT_CHECK_SHIPVORE_RAM\"]/choice[7]/text"
msgstr "Do something else instead."

#: src-en/data/events_special_storage.xml.append:868
msgid ""
"data/events_special_storage.xml.append$//event[@name=\"DJMOD_COMBAT_CHECK_SHIPVORE_RAM\"]/choice[8]/text"
msgstr "Nevermind, let's fight!"

#: src-en/data/events_special_storage.xml.append:870
msgid ""
"data/events_special_storage.xml.append$//event[@name=\"DJMOD_COMBAT_CHECK_SHIPVORE_RAM\"]/choice[8]/event/text"
msgstr "You decide not to do anything and prepare to fight."

#: src-en/data/events_special_storage.xml.append:883
msgid ""
"data/events_special_storage.xml.append$//event[@name=\"DJMOD_COMBAT_SHIPVORE_RAM_TIMER_START\"]/triggeredEvent/triggeredEventBox/tooltip"
msgstr "You will be ready to ram the enemy ship in this amount of time."

#: src-en/data/events_special_storage.xml.append:897
msgid ""
"data/events_special_storage.xml.append$//event[@name=\"DJMOD_COMBAT_SHIPVORE_RAM_TIMER_START_FULL_POWER\"]/triggeredEvent/triggeredEventBox/tooltip"
msgstr ""
"You will be fully powered to ram the enemy ship in this amount of time."

#: src-en/data/events_special_storage.xml.append:911
msgid ""
"data/events_special_storage.xml.append$//event[@name=\"DJMOD_COMBAT_SHIPVORE_RAM_TIMER_END\"]/text"
msgstr "Ready to ram! Proceed?"

#: src-en/data/events_special_storage.xml.append:914
msgid ""
"data/events_special_storage.xml.append$//event[@name=\"DJMOD_COMBAT_SHIPVORE_RAM_TIMER_END\"]/choice[1]/text"
msgstr "Let's go!"

#: src-en/data/events_special_storage.xml.append:919
msgid ""
"data/events_special_storage.xml.append$//event[@name=\"DJMOD_COMBAT_SHIPVORE_RAM_TIMER_END\"]/choice[@req=\"shipvore_ram_used_fuel\""
" and @lvl=\"0\"]/text"
msgstr "Abort. (No { was used)"

#: src-en/data/events_special_storage.xml.append:926
msgid ""
"data/events_special_storage.xml.append$//event[@name=\"DJMOD_COMBAT_SHIPVORE_RAM_TIMER_END\"]/choice[@req=\"shipvore_ram_used_fuel\""
" and @lvl=\"1\"]/text"
msgstr "Abort, and retrieve any non consumed {."

#: src-en/data/events_special_storage.xml.append:939
msgid ""
"data/events_special_storage.xml.append$//event[@name=\"DJMOD_COMBAT_SHIPVORE_RAM_TIMER_END_FULL_POWER\"]/text"
msgstr "Fully ready to ram! Proceed?"

#: src-en/data/events_special_storage.xml.append:942
msgid ""
"data/events_special_storage.xml.append$//event[@name=\"DJMOD_COMBAT_SHIPVORE_RAM_TIMER_END_FULL_POWER\"]/choice[@req=\"DJMOD_COMBAT_SHIPVORE_RAM_REINFORCED_AT_FULL_POWER\"]/text"
msgstr ""
"(Full power) Give it your all! [You'll [style[color:ff3377]]lose "
"reinforcement[[/style]] on the augment.]"

#: src-en/data/events_special_storage.xml.append:945
msgid ""
"data/events_special_storage.xml.append$//event[@name=\"DJMOD_COMBAT_SHIPVORE_RAM_TIMER_END_FULL_POWER\"]/choice[@req=\"DJMOD_COMBAT_SHIPVORE_RAM_REINFORCED_AT_FULL_POWER\"]/event/text"
msgstr "Your augment's reinforcement melts away..."

#: src-en/data/events_special_storage.xml.append:952
msgid ""
"data/events_special_storage.xml.append$//event[@name=\"DJMOD_COMBAT_SHIPVORE_RAM_TIMER_END_FULL_POWER\"]/choice[@req=\"DJMOD_COMBAT_SHIPVORE_RAM_REINFORCED_AT_FULL_POWER\"]/event/choice/text"
msgstr "Continue..."

#: src-en/data/events_special_storage.xml.append:958
msgid ""
"data/events_special_storage.xml.append$//event[@name=\"DJMOD_COMBAT_SHIPVORE_RAM_TIMER_END_FULL_POWER\"]/choice[@req=\"DJMOD_COMBAT_SHIPVORE_RAM_NOT_REINFORCED_AT_FULL_POWER\"]/text"
msgstr ""
"(Full power) Give it your all! [Reinforce the augment at empty beacons "
"first, or use it right now but it will "
"[style[color:ff3377]]disintegrate[[/style]].]"

#: src-en/data/events_special_storage.xml.append:961
msgid ""
"data/events_special_storage.xml.append$//event[@name=\"DJMOD_COMBAT_SHIPVORE_RAM_TIMER_END_FULL_POWER\"]/choice[@req=\"DJMOD_COMBAT_SHIPVORE_RAM_NOT_REINFORCED_AT_FULL_POWER\"]/event/text"
msgstr "Your augment disintegrates..."

#: src-en/data/events_special_storage.xml.append:968
msgid ""
"data/events_special_storage.xml.append$//event[@name=\"DJMOD_COMBAT_SHIPVORE_RAM_TIMER_END_FULL_POWER\"]/choice[@req=\"DJMOD_COMBAT_SHIPVORE_RAM_NOT_REINFORCED_AT_FULL_POWER\"]/event/choice/text"
msgstr "Continue..."

#: src-en/data/events_special_storage.xml.append:975
msgid ""
"data/events_special_storage.xml.append$//event[@name=\"DJMOD_COMBAT_SHIPVORE_RAM_TIMER_END_FULL_POWER\"]/choice[@req=\"locked_shipvore_ram_full_power\"]/text"
msgstr ""
"(Full power) It's us or them! [[style[color:ff3377]]Cannot ram "
"again[[/style]] until you jump.]"

#: src-en/data/events_special_storage.xml.append:978
msgid ""
"data/events_special_storage.xml.append$//event[@name=\"DJMOD_COMBAT_SHIPVORE_RAM_TIMER_END_FULL_POWER\"]/choice[@req=\"locked_shipvore_ram_full_power\"]/event/text"
msgstr "You strongly feel your engines charging up..."

#: src-en/data/events_special_storage.xml.append:984
msgid ""
"data/events_special_storage.xml.append$//event[@name=\"DJMOD_COMBAT_SHIPVORE_RAM_TIMER_END_FULL_POWER\"]/choice[@req=\"locked_shipvore_ram_full_power\"]/event/choice/text"
msgstr "Continue..."

#: src-en/data/events_special_storage.xml.append:991
msgid ""
"data/events_special_storage.xml.append$//event[@name=\"DJMOD_COMBAT_SHIPVORE_RAM_TIMER_END_FULL_POWER\"]/choice[4]/text"
msgstr "Abort, and retrieve any non consumed {."

#: src-en/data/events_special_storage.xml.append:1092
msgid ""
"data/events_special_storage.xml.append$/dummyroot/FTL/event[@name=\"SHIPVORE_RAM_ATTACK_2DMG_NOTHING\"]/text"
msgstr "You barely manage to hit the enemy, dealing 2 damage..."

#: src-en/data/events_special_storage.xml.append:1096
msgid ""
"data/events_special_storage.xml.append$/dummyroot/FTL/event[@name=\"SHIPVORE_RAM_ATTACK_2DMG_NOTHING\"]/choice/text"
