#: src-en/data/events_special_storage.xml.append:513
msgid ""
"data/events_special_storage.xml.append$/dummyroot/FTL/mod:findName[11]/mod-"
"append:choice/text"
msgstr "(Flammabilizer) Set the state of the augment. [Current mode: Immune]"

#: src-en/data/events_special_storage.xml.append:519
msgid ""
"data/events_special_storage.xml.append$/dummyroot/FTL/mod:findName[12]/mod-"
"append:choice/text"
msgstr "(Flammabilizer) Set the state of the augment. [Current mode: Damage]"

#: src-en/data/events_special_storage.xml.append:532
msgid ""
"data/events_special_storage.xml.append$/dummyroot/FTL/mod:findName[13]/mod-"
"append:choice/text"
msgstr ""
"(AERA Second Wind) Immediately repair for 1{. [style[color:ff3377]][Destroys"
" the augment!][[/style]]"

#: src-en/data/events_special_storage.xml.append:535
msgid ""
"data/events_special_storage.xml.append$/dummyroot/FTL/mod:findName[13]/mod-"
"append:choice/event/text"
msgstr "You jumpstart the augment with fuel..."

#: src-en/data/events_special_storage.xml.append:541
msgid ""
"data/events_special_storage.xml.append$/dummyroot/FTL/mod:findName[13]/mod-"
"append:choice/event/choice/text"
msgstr "Continue..."

#: src-en/data/events_special_storage.xml.append:550
msgid ""
"data/events_special_storage.xml.append$/dummyroot/FTL/mod:findName[14]/mod-"
"append:choice/text"
msgstr "(Persistence Shield) Regenerate your Supershields!"

#: src-en/data/events_special_storage.xml.append:557
msgid ""
"data/events_special_storage.xml.append$/dummyroot/FTL/mod:findName[15]/mod-"
"append:choice/text"
msgstr "(Scorched Earth series) Select what part of your ship to set on fire!"

#: src-en/data/events_special_storage.xml.append:570
msgid ""
"data/events_special_storage.xml.append$/dummyroot/FTL/mod:findName[16]/mod-"
"append:choice/text"
msgstr "(Shipvore Ram) See current bonuses and Combos"

#: src-en/data/events_special_storage.xml.append:576
msgid ""
"data/events_special_storage.xml.append$//event[@name=\"TOGGLEMENU_RK_SHIPVORE_RAM\"]/text"
msgstr ""
"Currently active Shipvore Ram bonuses and Combos below. (FP = Full Power)"

#: src-en/data/events_special_storage.xml.append:579
msgid ""
"data/events_special_storage.xml.append$//event[@name=\"TOGGLEMENU_RK_SHIPVORE_RAM\"]/choice[@req=\"cloaking\""
" and @lvl=\"2\"]/text"
msgstr "(Cloaking 2) More chances to deal high damage."

#: src-en/data/events_special_storage.xml.append:583
msgid ""
"data/events_special_storage.xml.append$//event[@name=\"TOGGLEMENU_RK_SHIPVORE_RAM\"]/choice[@req=\"cloaking\""
" and @lvl=\"3\"]/text"
msgstr "(Cloaking 3) More chances to deal high damage."

#: src-en/data/events_special_storage.xml.append:588
msgid ""
"data/events_special_storage.xml.append$//event[@name=\"TOGGLEMENU_RK_SHIPVORE_RAM\"]/choice[@req=\"engines\""
" and @lvl=\"2\"]/text"
msgstr "(Engines 2) Max damage +1. FP max damage +1."

#: src-en/data/events_special_storage.xml.append:592
msgid ""
"data/events_special_storage.xml.append$//event[@name=\"TOGGLEMENU_RK_SHIPVORE_RAM\"]/choice[@req=\"engines\""
" and @lvl=\"4\"]/text"
msgstr "(Engines 4) Minimum damage +1. FP minimum damage +1."

#: src-en/data/events_special_storage.xml.append:596
msgid ""
"data/events_special_storage.xml.append$//event[@name=\"TOGGLEMENU_RK_SHIPVORE_RAM\"]/choice[@req=\"engines\""
" and @lvl=\"6\"]/text"
msgstr "(Engines 6) Max damage +1. FP max damage +1."

#: src-en/data/events_special_storage.xml.append:600
msgid ""
"data/events_special_storage.xml.append$//event[@name=\"TOGGLEMENU_RK_SHIPVORE_RAM\"]/choice[@req=\"engines\""
" and @lvl=\"8\"]/text"
msgstr "(Engines 8) More chances to deal high damage."

#: src-en/data/events_special_storage.xml.append:605
msgid ""
"data/events_special_storage.xml.append$//event[@name=\"TOGGLEMENU_RK_SHIPVORE_RAM\"]/choice[@req=\"mind\"]/text"
msgstr ""
"(Mind Control) Crew can't refuse to ram again (or betray you) when scared."

#: src-en/data/events_special_storage.xml.append:610
msgid ""
"data/events_special_storage.xml.append$//event[@name=\"TOGGLEMENU_RK_SHIPVORE_RAM\"]/choice[@req=\"pilot\""
" and @lvl=\"2\"]/text"
msgstr "(Piloting 2) Rarer bad outcomes."

#: src-en/data/events_special_storage.xml.append:614
msgid ""
"data/events_special_storage.xml.append$//event[@name=\"TOGGLEMENU_RK_SHIPVORE_RAM\"]/choice[@req=\"pilot\""
" and @lvl=\"3\"]/text"
msgstr "(Piloting 3) No resource loss bad outcomes. Rarer FP bad outcomes."

#: src-en/data/events_special_storage.xml.append:619
msgid ""
"data/events_special_storage.xml.append$//event[@name=\"TOGGLEMENU_RK_SHIPVORE_RAM\"]/choice[@req=\"DEBUG_GENERATOR\"]/text"
msgstr "(Emergency Generator) Normal ramming is free (initial strike)."

#: src-en/data/events_special_storage.xml.append:623
msgid ""
"data/events_special_storage.xml.append$//event[@name=\"TOGGLEMENU_RK_SHIPVORE_RAM\"]/choice[@req=\"FUEL_CONSERVER\"]/text"
msgstr "(Fuel Conserver) Normal ramming is free (initial and repeat strikes)."

#: src-en/data/events_special_storage.xml.append:628
msgid ""
"data/events_special_storage.xml.append$//event[@name=\"TOGGLEMENU_RK_SHIPVORE_RAM\"]/choice[@req=\"DJMOD_ANY_RESCUE_ARM\"]/text"
msgstr "(Ship Arm) Can retrieve ejected crew."

#: src-en/data/events_special_storage.xml.append:633
msgid ""
"data/events_special_storage.xml.append$//event[@name=\"TOGGLEMENU_RK_SHIPVORE_RAM\"]/choice[13]/text"
msgstr "Return to the toggle menu."

#: src-en/data/events_special_storage.xml.append:677
msgid ""
"data/events_special_storage.xml.append$/dummyroot/FTL/mod:findName[17]/mod-"
"append:choice/text"
