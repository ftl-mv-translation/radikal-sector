msgid ""
"data/events_special_storage.xml.append$//event[@name=\"RK_BPS_SURVEYOR_ACTIVATE\"]/text"
msgstr ""
"Are you sure you want to do this?\n"
"\t[Spend resources to send out deep-scouting looter drones. They find a random weapon and augment.\n"
"\tYou can choose one to retrieve at the cost of 1 fleet acceleration, or leave with a small refund.]"

#: src-en/data/events_special_storage.xml.append:6662
msgid ""
"data/events_special_storage.xml.append$//event[@name=\"RK_BPS_SURVEYOR_ACTIVATE\"]/choice[@req=\"RK_BPS_SURVEYOR\"]/text"
