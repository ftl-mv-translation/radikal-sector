#: src-en/data/events_special_storage.xml.append:1904
msgid ""
"data/events_special_storage.xml.append$//event[@name=\"SHIPVORE_RAM_FP_OWN_OUTCOME_BAD_TRAITOR\"]/choice[13]/event/choice[@req=\"mind\""
" and @lvl=\"1\"]/event/text"
msgstr ""
"What's more, a friend of the victim has lost all trust in you!\n"
