"data/events_special_storage.xml.append$//event[@name=\"SHIPVORE_RAM_FP_OWN_OUTCOME_GETSCRAP\"]/choice/text"
msgstr "Good!"

#: src-en/data/events_special_storage.xml.append:1611
msgid ""
"data/events_special_storage.xml.append$//event[@name=\"SHIPVORE_RAM_FP_OWN_OUTCOME_GETSCRAP_2\"]/text"
msgstr ""
"Bad news, we didn't get any repairs.\n"
"\tGood news, we broke open a Huge Scrap Crate!! A fantastic outcome, even though some of the scrap was lost in space."

#: src-en/data/events_special_storage.xml.append:1615
msgid ""
"data/events_special_storage.xml.append$//event[@name=\"SHIPVORE_RAM_FP_OWN_OUTCOME_GETSCRAP_2\"]/choice/text"
