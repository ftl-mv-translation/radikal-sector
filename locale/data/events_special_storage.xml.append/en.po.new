"data/events_special_storage.xml.append$//event[@name=\"SHIPVORE_RAM_FP_OWN_OUTCOME_GETFUEL\"]/choice/text"
msgstr "Good!"

#: src-en/data/events_special_storage.xml.append:1650
msgid ""
"data/events_special_storage.xml.append$//event[@name=\"SHIPVORE_RAM_FP_OWN_OUTCOME_GETFUEL_SCALING\"]/text"
