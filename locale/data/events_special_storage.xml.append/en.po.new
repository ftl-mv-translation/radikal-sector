#: src-en/data/events_special_storage.xml.append:1122
msgid ""
"data/events_special_storage.xml.append$/dummyroot/FTL/event[@name=\"SHIPVORE_RAM_ATTACK_4DMG_BREACH\"]/text"
msgstr "You tear through the enemy ship's hull for a solid 4 damage..."

#: src-en/data/events_special_storage.xml.append:1126
msgid ""
"data/events_special_storage.xml.append$/dummyroot/FTL/event[@name=\"SHIPVORE_RAM_ATTACK_4DMG_BREACH\"]/choice/text"
msgstr "...with this result on your own ship (75% chance good)."

#: src-en/data/events_special_storage.xml.append:1131
msgid ""
"data/events_special_storage.xml.append$/dummyroot/FTL/event[@name=\"SHIPVORE_RAM_ATTACK_5DMG_BREACH\"]/text"
msgstr "You slam into the enemy ship's hull for a serious 5 damage..."

