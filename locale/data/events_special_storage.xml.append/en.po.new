#: src-en/data/events_special_storage.xml.append:396
msgid ""
"data/events_special_storage.xml.append$/dummyroot/FTL/mod:findName[1]/mod-"
"append:choice/text"
msgstr "(Shipvore Ram) Ram the enemy for repairs!"

#: src-en/data/events_special_storage.xml.append:404
msgid ""
"data/events_special_storage.xml.append$/dummyroot/FTL/mod:findName[2]/mod-"
"append:choice/text"
msgstr "(AERA Second Wind) Activate the emergency auto-repair!"

#: src-en/data/events_special_storage.xml.append:411
msgid ""
"data/events_special_storage.xml.append$/dummyroot/FTL/mod:findName[3]/mod-"
"append:choice[1]/text"
msgstr ""
"(Enigmashin) The rebels are already here, with Enigmashin jammers. No reason"
" to keep it."

#: src-en/data/events_special_storage.xml.append:415
msgid ""
"data/events_special_storage.xml.append$/dummyroot/FTL/mod:findName[3]/mod-"
"append:choice[2]/text"
msgstr "(Enigmashin) Try to delay the rebels!"

#: src-en/data/events_special_storage.xml.append:420
msgid ""
"data/events_special_storage.xml.append$/dummyroot/FTL/mod:findName[3]/mod-"
"append:choice[3]/text"
msgstr "(H.A.C.) Limit multiple enemy systems!"

#: src-en/data/events_special_storage.xml.append:429
msgid ""
"data/events_special_storage.xml.append$/dummyroot/FTL/mod:findName[4]/mod-"
"append:choice/text"
msgstr "(Offense Disabler) Disable the enemy's offense!"

#: src-en/data/events_special_storage.xml.append:438
msgid ""
"data/events_special_storage.xml.append$/dummyroot/FTL/mod:findName[5]/mod-"
"append:choice/text"
msgstr "(Vulnerabilizer) Start removing the enemy's defense!"

#: src-en/data/events_special_storage.xml.append:447
msgid ""
"data/events_special_storage.xml.append$/dummyroot/FTL/mod:findName[6]/mod-"
"append:choice/text"
msgstr "(Plasma Teleporter) Set the enemy ship on fire!"

#: src-en/data/events_special_storage.xml.append:454
msgid ""
"data/events_special_storage.xml.append$/dummyroot/FTL/mod:findName[7]/mod-"
"append:choice/text"
msgstr "(Oxygenizer) Create an atmosphere!"

#: src-en/data/events_special_storage.xml.append:493
msgid ""
"data/events_special_storage.xml.append$/dummyroot/FTL/mod:findName[8]/mod-"
"append:choice/text"
msgstr ""
"(Charged Belts) Turn it On. [style[color:ff3377]][Can't be turned "
"Off!][[/style]] [Current mode: Off]"

#: src-en/data/events_special_storage.xml.append:500
msgid ""
"data/events_special_storage.xml.append$/dummyroot/FTL/mod:findName[9]/mod-"
"append:choice/text"
msgstr "(Punk Harmony) Set the state of the augment. [Current mode: On]"

#: src-en/data/events_special_storage.xml.append:506
msgid ""
"data/events_special_storage.xml.append$/dummyroot/FTL/mod:findName[10]/mod-"
"append:choice/text"
