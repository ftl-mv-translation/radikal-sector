#: src-en/data/events_special_storage.xml.append:1629
msgid ""
"data/events_special_storage.xml.append$//event[@name=\"SHIPVORE_RAM_FP_OWN_OUTCOME_GETSCRAP_SCALING\"]/choice/text"
