#: src-en/data/events_special_storage.xml.append:1754
msgid ""
"data/events_special_storage.xml.append$//event[@name=\"SHIPVORE_RAM_FP_OWN_OUTCOME_BAD_FUEL_DAMAGE\"]/choice/text"
msgstr "Not good."

#: src-en/data/events_special_storage.xml.append:1764
msgid ""
"data/events_special_storage.xml.append$//event[@name=\"SHIPVORE_RAM_FP_OWN_OUTCOME_BAD_CRITICAL\"]/text"
msgstr ""
