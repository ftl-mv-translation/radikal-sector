msgid ""
"data/events.xml.append$//event[@name=\"ZOLTAN_POLICESTATION_RK\"]/choice[@req=\"DJMOD_WAS_SEIZED_RADIKAL_GEAR\"]/event/choice[@req=\"seized_crewarebombs\"]/text"
msgstr "Вернуть снаряжение на свой корабль."

#: src-en/data/events.xml.append:1710
msgid ""
