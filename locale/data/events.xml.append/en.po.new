#: src-en/data/events.xml.append:2370
msgid "data/events.xml.append$//event[@name=\"EMPTY_RADIKAL\"]/choice[2]/text"
msgstr "Do nothing."

#: src-en/data/events.xml.append:2375
msgid "data/events.xml.append$//textList[@name=\"EMPTY_RADIKAL\"]/text[1]"
msgstr ""
"You arrive at the beacon and are relieved to get a break, as nobody here "
"seems to care about what tech you do or don't have."

#: src-en/data/events.xml.append:2376
msgid "data/events.xml.append$//textList[@name=\"EMPTY_RADIKAL\"]/text[2]"
msgstr ""
"No other ships or interesting structures can be found here, a chance to do "
"some work on your ship, or chat with your crew maybe."

#: src-en/data/events.xml.append:2377
msgid "data/events.xml.append$//textList[@name=\"EMPTY_RADIKAL\"]/text[3]"
msgstr ""
"This sector isn't exactly what you'd call calm, but here at least there is "
"nothing going on here worthy of attention."

#: src-en/data/events.xml.append:2378
msgid "data/events.xml.append$//textList[@name=\"EMPTY_RADIKAL\"]/text[4]"
msgstr ""
"Looks like you've found a relatively peaceful spot, a rarity in this sector."

#: src-en/data/events.xml.append:2379
msgid "data/events.xml.append$//textList[@name=\"EMPTY_RADIKAL\"]/text[5]"
msgstr ""
"A weapons test seems to have gone catastrophically wrong around here "
"recently, and the place is currently abandoned."

#: src-en/data/events.xml.append:2385
msgid ""
"data/events.xml.append$//event[@name=\"NEBULA_EMPTY_RADIKAL\"]/choice[1]/text"
msgstr "Do something onboard the ship."

#: src-en/data/events.xml.append:2389
msgid ""
"data/events.xml.append$//event[@name=\"NEBULA_EMPTY_RADIKAL\"]/choice[2]/text"
msgstr "Do nothing."

#: src-en/data/events.xml.append:2394
msgid "data/events.xml.append$//textList[@name=\"NEBULA_EMPTY_RADIKAL\"]/text[1]"
msgstr ""
"No living thing here, just large autoships harvesting gases. Probably "
"ingredients for some deadly weapon, but it wouldn't be worth your time to "
"engage with them."

#: src-en/data/events.xml.append:2395
msgid "data/events.xml.append$//textList[@name=\"NEBULA_EMPTY_RADIKAL\"]/text[2]"
msgstr ""
"You won't find any special tech here, but nobody to bother you either, not "
"even ambushing pirates."

#: src-en/data/events.xml.append:2396
msgid "data/events.xml.append$//textList[@name=\"NEBULA_EMPTY_RADIKAL\"]/text[3]"
msgstr ""
"This beacon is closed off for security reasons, but that's all the computer "
"says. You can probably enjoy the mesmerizing nebula without getting hit by "
"some experimental weapon."

#: src-en/data/events.xml.append:2397
msgid "data/events.xml.append$//textList[@name=\"NEBULA_EMPTY_RADIKAL\"]/text[4]"
msgstr ""
"It looks like this nebula is a good hiding spot for now, no hostiles "
"detected."

#: src-en/data/events.xml.append:2516
msgid ""
"data/events.xml.append$//event[@name=\"RK_QUEST_LAB_PUNK\"]/beaconType/unvisitedTooltip"
msgstr ""
"You were told you can get great RadiKal Punk gear at this beacon, if you can"
" prove you're a customer."

#: src-en/data/events.xml.append:2519
msgid "data/events.xml.append$//event[@name=\"RK_QUEST_LAB_PUNK\"]/text"
msgstr ""
"[PLACEHOLDER QUEST] There is no ship here but someone from the nearby planet"
" is hailing you. \"You who dare come here, are you one of us RadiKals?\""

#: src-en/data/events.xml.append:2523
msgid ""
"data/events.xml.append$//event[@name=\"RK_QUEST_LAB_PUNK\"]/choice[@req=\"DJMOD_HAS_RADIKAL_GEAR\"]/text"
msgstr "(any piece of RK gear) Yes"

#: src-en/data/events.xml.append:2525
msgid ""
"data/events.xml.append$//event[@name=\"RK_QUEST_LAB_PUNK\"]/choice[@req=\"DJMOD_HAS_RADIKAL_GEAR\"]/event/text"
msgstr "You receive a delivery. \"Good. Do you support the Punk?\""

#: src-en/data/events.xml.append:2529
msgid ""
"data/events.xml.append$//event[@name=\"RK_QUEST_LAB_PUNK\"]/choice[@req=\"DJMOD_HAS_RADIKAL_GEAR\"]/event/choice[@req=\"DJMOD_HAS_RADIKAL_PUNK_GEAR\""
" and not(@lvl)]/text"
msgstr "(RK Punk equipment) Yes"

#: src-en/data/events.xml.append:2531
msgid ""
"data/events.xml.append$//event[@name=\"RK_QUEST_LAB_PUNK\"]/choice[@req=\"DJMOD_HAS_RADIKAL_GEAR\"]/event/choice[@req=\"DJMOD_HAS_RADIKAL_PUNK_GEAR\""
" and not(@lvl)]/event/text"
msgstr ""
"You receive another, larger delivery and a very rare augment. \"Excellent. Stay smart, captain.\"\n"
"\t\t\t\t\tYou would have asked for an explanation but they've blocked your hails. That went well enough overall."

#: src-en/data/events.xml.append:2538
msgid ""
"data/events.xml.append$//event[@name=\"RK_QUEST_LAB_PUNK\"]/choice[@req=\"DJMOD_HAS_RADIKAL_GEAR\"]/event/choice[@req=\"DJMOD_HAS_RADIKAL_PUNK_GEAR\""
" and not(@lvl)]/event/choice[1]/text"
msgstr "Do something onboard the ship."

#: src-en/data/events.xml.append:2542
msgid ""
"data/events.xml.append$//event[@name=\"RK_QUEST_LAB_PUNK\"]/choice[@req=\"DJMOD_HAS_RADIKAL_GEAR\"]/event/choice[@req=\"DJMOD_HAS_RADIKAL_PUNK_GEAR\""
" and not(@lvl)]/event/choice[2]/text"
msgstr "Do nothing."

#: src-en/data/events.xml.append:2549
msgid ""
"data/events.xml.append$//event[@name=\"RK_QUEST_LAB_PUNK\"]/choice[@req=\"DJMOD_HAS_RADIKAL_GEAR\"]/event/choice[@req=\"DJMOD_HAS_RADIKAL_PUNK_GEAR\""
" and @lvl=\"0\"]/text"
msgstr "You do not have any RK Punk gear."

#: src-en/data/events.xml.append:2554
msgid ""
"data/events.xml.append$//event[@name=\"RK_QUEST_LAB_PUNK\"]/choice[@req=\"DJMOD_HAS_RADIKAL_GEAR\"]/event/choice[3]/text"
msgstr "No"

#: src-en/data/events.xml.append:2556
msgid ""
"data/events.xml.append$//event[@name=\"RK_QUEST_LAB_PUNK\"]/choice[@req=\"DJMOD_HAS_RADIKAL_GEAR\"]/event/choice[3]/event/text"
msgstr "\"Then move along.\" Your hails are now blocked."

#: src-en/data/events.xml.append:2559
msgid ""
"data/events.xml.append$//event[@name=\"RK_QUEST_LAB_PUNK\"]/choice[@req=\"DJMOD_HAS_RADIKAL_GEAR\"]/event/choice[3]/event/choice[1]/text"
msgstr "Do something onboard the ship."

#: src-en/data/events.xml.append:2563
msgid ""
"data/events.xml.append$//event[@name=\"RK_QUEST_LAB_PUNK\"]/choice[@req=\"DJMOD_HAS_RADIKAL_GEAR\"]/event/choice[3]/event/choice[2]/text"
msgstr "Do nothing."

#: src-en/data/events.xml.append:2572
msgid "data/events.xml.append$//event[@name=\"RK_QUEST_LAB_PUNK\"]/choice[2]/text"
msgstr "Uhm... I don't know, maybe?"

#: src-en/data/events.xml.append:2574
msgid ""
"data/events.xml.append$//event[@name=\"RK_QUEST_LAB_PUNK\"]/choice[2]/event/text"
msgstr ""
"Your ship soon takes damage from a source you cannot identify. \"Begone, "
"tourist. You had been warned.\""

#: src-en/data/events.xml.append:2578
msgid ""
"data/events.xml.append$//event[@name=\"RK_QUEST_LAB_PUNK\"]/choice[2]/event/choice[1]/text"
msgstr "Do something onboard the ship."

#: src-en/data/events.xml.append:2582
msgid ""
"data/events.xml.append$//event[@name=\"RK_QUEST_LAB_PUNK\"]/choice[2]/event/choice[2]/text"
msgstr "Do nothing."

#: src-en/data/events.xml.append:2589
msgid "data/events.xml.append$//event[@name=\"RK_QUEST_LAB_PUNK\"]/choice[3]/text"
msgstr "No. Sorry for the intrusion. We're leaving."

#: src-en/data/events.xml.append:2591
msgid ""
"data/events.xml.append$//event[@name=\"RK_QUEST_LAB_PUNK\"]/choice[3]/event/text"
msgstr ""
"There is no answer. You figure you didn't give the worst possible answer but"
" it's still best not to stick around."

#: src-en/data/events.xml.append:2594
msgid ""
"data/events.xml.append$//event[@name=\"RK_QUEST_LAB_PUNK\"]/choice[3]/event/choice[1]/text"
msgstr "Do something onboard the ship."

#: src-en/data/events.xml.append:2598
msgid ""
"data/events.xml.append$//event[@name=\"RK_QUEST_LAB_PUNK\"]/choice[3]/event/choice[2]/text"
msgstr "Do nothing."

#: src-en/data/events.xml.append:2622
msgid "data/events.xml.append$//event[@name=\"EXIT_RADIKAL_PART2\"]/text"
msgstr ""
"You're arrived at the exit alive, which is no small feat, but three menacing ships have been waiting for you.\n"
"\t\tAccurately guessing that you don't have a choice, you answer the hail."

#: src-en/data/events.xml.append:2627
msgid ""
"data/events.xml.append$//event[@name=\"EXIT_RADIKAL_PART2\"]/choice[@req=\"RKS_TRYING_TO_SKIP_TRINITY\""
" and @lvl=\"0\"]/text"
msgstr "Continue..."

#: src-en/data/events.xml.append:2631
msgid ""
"data/events.xml.append$//event[@name=\"EXIT_RADIKAL_PART2\"]/choice[@req=\"RKS_TRYING_TO_SKIP_TRINITY\""
" and @lvl=\"1\"]/text"
msgstr "Continue..."

#: src-en/data/events.xml.append:2637
msgid ""
"data/events.xml.append$//event[@name=\"EXIT_RADIKAL_ACTIVATE_PIRATE_AMBUSH\"]/text"
msgstr ""
"You have this weird feeling like you've forgotten to do something "
"important... but you carry on."

#: src-en/data/events.xml.append:2641
msgid ""
"data/events.xml.append$//event[@name=\"EXIT_RADIKAL_ACTIVATE_PIRATE_AMBUSH\"]/choice/text"
msgstr "Continue..."

#: src-en/data/events.xml.append:2647
msgid "data/events.xml.append$//event[@name=\"EXIT_RADIKAL_MAIN\"]/text"
msgstr ""
"\"I'll make it simple for you, we have a reputation to uphold. If you're not able to beat one of our gatekeepers, we can't let you leave and make RadiKal gear look bad with your incompetence.\n"
"\tThink about it. Why do you think folks fund all of this? That's because you've never heard of subpar RadiKal equipment, and this is one way to do quality control.\n"
"\t\n"
"\tYou do get to pick your opponent, so choose wisely... yeah, that IS part of the skill test.\n"
"\tOh and, don't worry about killing crew in these ships, they're all purpose-grown illegal clones. In fact we'd like to see you try to kill them cleanly.\n"
"\t\n"
"\tSo, which Gatekeeper do you choose?\""

#: src-en/data/events.xml.append:2657
msgid ""
"data/events.xml.append$//event[@name=\"EXIT_RADIKAL_MAIN\"]/choice[@req=\"challenge_level\""
" and @lvl=\"0\"]/text"
msgstr "Bam, with the raw blunt damage and reinforcements"

#: src-en/data/events.xml.append:2659
msgid ""
"data/events.xml.append$//event[@name=\"EXIT_RADIKAL_MAIN\"]/choice[@req=\"challenge_level\""
" and @lvl=\"0\"]/event/text"
msgstr "You are taken to the Bam arena to prove your worth. Get ready!"

#: src-en/data/events.xml.append:2663
msgid ""
"data/events.xml.append$//event[@name=\"EXIT_RADIKAL_MAIN\"]/choice[@req=\"challenge_level\""
" and @lvl=\"0\"]/event/choice/text"
msgstr "Continue..."

#: src-en/data/events.xml.append:2669
msgid ""
"data/events.xml.append$//event[@name=\"EXIT_RADIKAL_MAIN\"]/choice[@req=\"challenge_level\""
" and @lvl=\"3\"]/text"
msgstr "Bam, with the raw blunt damage and reinforcements"

#: src-en/data/events.xml.append:2671
msgid ""
"data/events.xml.append$//event[@name=\"EXIT_RADIKAL_MAIN\"]/choice[@req=\"challenge_level\""
" and @lvl=\"3\"]/event/text"
msgstr "You are taken to the Bam arena to prove your worth. Get ready!"

#: src-en/data/events.xml.append:2675
msgid ""
"data/events.xml.append$//event[@name=\"EXIT_RADIKAL_MAIN\"]/choice[@req=\"challenge_level\""
" and @lvl=\"3\"]/event/choice/text"
msgstr "Continue..."

#: src-en/data/events.xml.append:2683
msgid "data/events.xml.append$//event[@name=\"EXIT_RADIKAL_MAIN\"]/choice[3]/text"
msgstr "Punk, with the fancy tricks and crew shenanigans"

#: src-en/data/events.xml.append:2685
msgid ""
"data/events.xml.append$//event[@name=\"EXIT_RADIKAL_MAIN\"]/choice[3]/event/text"
msgstr "You are taken to the Punk arena to prove your worth. Get ready!"

#: src-en/data/events.xml.append:2689
msgid ""
"data/events.xml.append$//event[@name=\"EXIT_RADIKAL_MAIN\"]/choice[3]/event/choice/text"
msgstr "Continue..."

#: src-en/data/events.xml.append:2695
msgid "data/events.xml.append$//event[@name=\"EXIT_RADIKAL_MAIN\"]/choice[4]/text"
msgstr "Scorch, with the fire weaponry and acceleration features"

#: src-en/data/events.xml.append:2697
msgid ""
"data/events.xml.append$//event[@name=\"EXIT_RADIKAL_MAIN\"]/choice[4]/event/text"
msgstr "You are taken to the Scorch arena to prove your worth. Get ready!"

#: src-en/data/events.xml.append:2701
msgid ""
"data/events.xml.append$//event[@name=\"EXIT_RADIKAL_MAIN\"]/choice[4]/event/choice/text"
msgstr "Continue..."

#: src-en/data/events.xml.append:2708
msgid ""
"data/events.xml.append$//event[@name=\"EXIT_RADIKAL_MAIN\"]/choice[@req=\"unique_alkali\"]/text"
msgstr "(Alkali) Have Alkali clear you for leaving."

#: src-en/data/events.xml.append:2710
msgid ""
"data/events.xml.append$//event[@name=\"EXIT_RADIKAL_MAIN\"]/choice[@req=\"unique_alkali\"]/event/text"
msgstr ""
"Fortunately, it only takes a few minutes before Alkali returns, and you're "
"allowed to leave. Guess it pays to have a genius scientist secretly working "
"with the RK Punk aboard your ship."

#: src-en/data/events.xml.append:2715
msgid ""
"data/events.xml.append$//event[@name=\"EXIT_RADIKAL_MAIN\"]/choice[@req=\"unique_ariadne\"]/text"
msgstr "(Ariadne) Have Ariadne clear you for leaving."

#: src-en/data/events.xml.append:2717
msgid ""
"data/events.xml.append$//event[@name=\"EXIT_RADIKAL_MAIN\"]/choice[@req=\"unique_ariadne\"]/event/text"
msgstr ""
"Fortunately, it only takes a few minutes before Ariadne returns, and you're "
"allowed to leave. Guess it pays to have a respected admiral in deep business"
" with the RK Scorch aboard your ship."

#: src-en/data/events.xml.append:2722
msgid ""
"data/events.xml.append$//event[@name=\"EXIT_RADIKAL_MAIN\"]/choice[@req=\"LIST_VARIANT_BILLY\"]/text"
msgstr "(Billy) Have Billy clear you for leaving."

#: src-en/data/events.xml.append:2724
msgid ""
"data/events.xml.append$//event[@name=\"EXIT_RADIKAL_MAIN\"]/choice[@req=\"LIST_VARIANT_BILLY\"]/event/text"
msgstr ""
"Fortunately, it only takes a few minutes before Billy returns, and you're "
"allowed to leave. Guess it pays to have the CEO of a military tech "
"corporation aboard your ship."

#: src-en/data/events.xml.append:2730
msgid ""
"data/events.xml.append$//event[@name=\"EXIT_RADIKAL_MAIN\"]/choice[@req=\"unique_dessius\"]/text"
msgstr "(Dessius) Have Dessius clear you for leaving."

#: src-en/data/events.xml.append:2732
msgid ""
"data/events.xml.append$//event[@name=\"EXIT_RADIKAL_MAIN\"]/choice[@req=\"unique_dessius\"]/event/text"
msgstr ""
"Fortunately, it only takes a few minutes before Dessius returns, and you're "
"allowed to leave. Guess it pays to have an ancestral leader trading a lot of"
" manpower to the RK aboard your ship."

#: src-en/data/events.xml.append:2737
msgid ""
"data/events.xml.append$//event[@name=\"EXIT_RADIKAL_MAIN\"]/choice[@req=\"unique_devorak\"]/text"
msgstr "(Devorak) Have Devorak clear you for leaving."

#: src-en/data/events.xml.append:2739
msgid ""
"data/events.xml.append$//event[@name=\"EXIT_RADIKAL_MAIN\"]/choice[@req=\"unique_devorak\"]/event/text"
msgstr ""
"Fortunately, it only takes a few minutes before Devorak returns, and you're "
"allowed to leave. Guess it pays to have a warrior with an endless record of "
"explosions studied by the RK Bam aboard your ship."

#: src-en/data/events.xml.append:2744
msgid ""
"data/events.xml.append$//event[@name=\"EXIT_RADIKAL_MAIN\"]/choice[@req=\"traitor\"]/text"
msgstr "(Metyunt) Have Metyunt clear you for leaving."

#: src-en/data/events.xml.append:2746
msgid ""
"data/events.xml.append$//event[@name=\"EXIT_RADIKAL_MAIN\"]/choice[@req=\"traitor\"]/event/text"
msgstr ""
"Fortunately, it only takes a few minutes before Metyunt returns, and you're "
"allowed to leave. Guess it pays to have the staff manager of a military tech"
" corporation aboard your ship."

#: src-en/data/events.xml.append:2781
msgid ""
"data/events.xml.append$//event[@name=\"RKS_EXIT_PIRATE_TRINITY_AMBUSH\"]/text"
msgstr ""
"Just as you were about to jump, a serious warship in pirate colors come out of hiding, followed by more pirates.\n"
"\t\t\"Forgetting something? A lil' business meeting that YOU asked for, maybe? Have you no honor??! You can't just make a bunch of cutthroats waste their time. Now die, fool!\""

#: src-en/data/events.xml.append:2793
msgid ""
"data/events.xml.append$//event[@name=\"RKS_EXIT_PIRATE_TRINITY_AMBUSH\"]/choice/text"
msgstr "Oh, that's what the weird feeling was about."

#: src-en/data/events.xml.append:2795
msgid ""
"data/events.xml.append$//event[@name=\"RKS_EXIT_PIRATE_TRINITY_AMBUSH\"]/choice/event/text"
msgstr ""
"Looks like the pirates really didn't appreciate you not coming to your own "
"Pirate Trinity reunion. They are somehow jamming your jump drive too! You'll"
" have to fight them to leave, as the RadiKals don't seem willing to pick a "
"side here."

#: src-en/data/events.xml.append:2799
msgid ""
"data/events.xml.append$//event[@name=\"RKS_EXIT_PIRATE_TRINITY_AMBUSH\"]/choice/event/choice/text"
msgstr "Nothing to do here but fight!"

#: src-en/data/events.xml.append:2820
msgid ""
"data/events.xml.append$//ship[@name=\"SHIP_RKS_EXIT_PIRATE_AMBUSHER\"]/destroyed/text"
msgstr ""
"\"NOOO-\" The pirate captain is cut off by their ship's explosion.\n"
"\n"
"\t\t\tMost of the RadiKals are not so pleased.\n"
"\t\t\t\"Didn't we tell you to make sure to pay these guys if you said you would? Now we're gonna have delivery issues for a while.\"\n"
"\t\t\t\n"
"\t\t\tThe others make signs of approbation, their faces remaining unhappy.\n"
"\t\t\t\"HAH, I mean this WAS such a good fight it would have been a shame to miss it, but at what cost?\" \"Yesss this asssshole had it coming, but he wassss alssso doing a lot of good work.\"\n"
"\t\t\t\n"
"\t\t\t\"Tell you what, you earned that wreck, so scrap it nice and clean. That will be your part of cleaning up this mess. We'll take care of the rest if you can just make yourself scarce until this dies down.\"\n"
"\t\t\tIt's clear that the news will spread regardless, but the RadiKals seem ready to spin this story in a neutral light. Your reputation among Pirates should not be ruined."

#: src-en/data/events.xml.append:2833
msgid ""
"data/events.xml.append$//ship[@name=\"SHIP_RKS_EXIT_PIRATE_AMBUSHER\"]/destroyed/choice/text"
msgstr "Time to leave before they change their minds."

#: src-en/data/events.xml.append:2838
msgid ""
"data/events.xml.append$//ship[@name=\"SHIP_RKS_EXIT_PIRATE_AMBUSHER\"]/deadCrew/text"
msgstr ""
"\"NOOOooo-\" The pirate captain dies before they can finish.\n"
"\n"
"\t\t\tMost of the RadiKals are not so pleased.\n"
"\t\t\t\"Didn't we tell you to make sure to pay these guys if you said you would? Now we're gonna have delivery issues for a while.\"\n"
"\t\t\t\n"
"\t\t\tThe others make signs of approbation, their faces remaining unhappy.\n"
"\t\t\t\"HAH, I mean this WAS such a good fight it would have been a shame to miss it, but at what cost?\" \"Yesss this asssshole had it coming, but he wassss alssso doing a lot of good work.\"\n"
"\t\t\t\n"
"\t\t\t\"Tell you what, you earned that wreck, so scrap it nice and clean. That will be your part of cleaning up this mess. We'll take care of the rest if you can just make yourself scarce until this dies down.\"\n"
"\t\t\tIt's clear that the news will spread regardless, but the RadiKals seem ready to spin this story in a neutral light. Your reputation among Pirates should not be ruined."

#: src-en/data/events.xml.append:2851
msgid ""
"data/events.xml.append$//ship[@name=\"SHIP_RKS_EXIT_PIRATE_AMBUSHER\"]/deadCrew/choice/text"
msgstr "Time to leave before they change their minds."
