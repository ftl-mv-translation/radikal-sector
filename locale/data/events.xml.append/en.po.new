msgstr "Sell them your BPS Messenger laser for 200~."

#: src-en/data/events.xml.append:854
msgid ""
"data/events.xml.append$//event[@name=\"RK_GEAR_BUYER_ROCKMAN\"]/choice[1]/event/choice/event/choice/event/choice/event/choice[@req=\"DJMOD_LASER_BPS\"]/event/text"
