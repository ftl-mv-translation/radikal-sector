msgstr "Sell them your Heavy Popper MK III laser for 210~."

#: src-en/data/events.xml.append:738
msgid ""
"data/events.xml.append$//event[@name=\"RK_GEAR_BUYER_ROCKMAN\"]/choice[1]/event/choice/event/choice/event/choice/event/choice[@req=\"RK_HEAVY_POPPER_3\"]/event/text"
msgstr ""
