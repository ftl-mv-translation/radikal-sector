msgid ""
"data/events.xml.append$/dummyroot/FTL[5]/event[@name=\"RK_SEIZE_ONE\"]/choice[@req=\"DJMOD_COMBAT_SHIPVORE_RAM\"]/text"
msgstr "'Shipvore Ram'"

#: src-en/data/events.xml.append:1245
msgid ""
"data/events.xml.append$/dummyroot/FTL[5]/event[@name=\"RK_SEIZE_ONE\"]/choice[@req=\"DJMOD_COMBAT_SHIPVORE_RAM\"]/event/text"
msgstr ""
"\"... yes indeed. Thank you for your cooperation. Remember to pass by the Police Station to cover the post-seizure administrative fees.\"\n"
"\t\t\tAs they finally leave you alone, you wonder whether it would be possible to get your gear back."

#: src-en/data/events.xml.append:1253
msgid ""
"data/events.xml.append$/dummyroot/FTL[5]/event[@name=\"RK_SEIZE_ONE\"]/choice[@req=\"DJMOD_COMBAT_SHIPVORE_RAM\"]/event/choice/text"
