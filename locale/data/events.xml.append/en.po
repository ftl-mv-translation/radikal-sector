#: src-en/data/events.xml.append:2012
msgid ""
"data/events.xml.append$//event[@name=\"THIEVES_RK_LASERS\"]/choice[@req=\"weapons\"]/text"
msgstr "(Upg. Weapons) Claim the prey for yourself."

#: src-en/data/events.xml.append:2014
msgid ""
"data/events.xml.append$//event[@name=\"THIEVES_RK_LASERS\"]/choice[@req=\"weapons\"]/event/text"
msgstr ""
"\"Woh hoh hoh, hey, wait, that's our-\" They quickly change their mind as "
"the rest of the crew pressures them. \"You know what, screw this, have fun "
"with you ill-gotten goods.\" Quite ironic, coming from a smuggler. The "
"surviving RadiKals are easily dealt with."

