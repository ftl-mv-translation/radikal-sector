msgstr "Ignore them."

#: src-en/data/events.xml.append:475
msgid ""
"data/events.xml.append$//event[@name=\"RADIKAL_ENSLAVED\"]/choice[3]/event/text"
msgstr ""
"Another ship comes in and buys the slave shortly afterwards. Then it starts going up in flames. Maybe you chose wisely.\n"
"\t\t\tYou have some time to yourself."

#: src-en/data/events.xml.append:478
msgid ""
"data/events.xml.append$//event[@name=\"RADIKAL_ENSLAVED\"]/choice[3]/event/choice[1]/text"
