#: src-en/data/events.xml.append:515
msgid ""
"data/events.xml.append$//event[@name=\"RADIKAL_ENSLAVED\"]/choice[2]/event/text"
msgstr ""
"Slavery is despicable! You prepare for combat, knowing the elite slave will "
