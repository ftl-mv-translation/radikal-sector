#: src-en/data/events.xml.append:1595
msgid ""
"data/events.xml.append$/dummyroot/FTL[5]/event[@name=\"RK_SEIZE_ONE\"]/choice[23]/text"
msgstr "Headshot that nosy lightbulb. (Risky)"

#: src-en/data/events.xml.append:1597
msgid ""
"data/events.xml.append$/dummyroot/FTL[5]/event[@name=\"RK_SEIZE_ONE\"]/choice[23]/event/text"
msgstr ""
"Quickly but accurately aiming through the hardlight, you splatter the chief inspector with your blaster, right before taking cover for the explosion! \n"
"\t\t\tVery satisfying ... but can you deal with the rest of them?"

#: src-en/data/events.xml.append:1603
msgid ""
"data/events.xml.append$/dummyroot/FTL[5]/event[@name=\"RK_SEIZE_ONE\"]/choice[23]/event/choice/text"
msgstr "Pop them all!"

#: src-en/data/events.xml.append:1611
