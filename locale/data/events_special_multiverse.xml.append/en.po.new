#: src-en/data/events_special_multiverse.xml.append:167
msgid ""
"data/events_special_multiverse.xml.append$//event[@name=\"JUDGE_AWARD_RK_BAM_CREW\"]/text"
msgstr ""
"\"On the surface... technological pursuit. Beneath, violent creatures... "
"with simplistic methods. Still they are... efficient and reliable. Well "
"done, traveler. Expect... rewards before your next journey.\""

#: src-en/data/events_special_multiverse.xml.append:172
msgid ""
"data/events_special_multiverse.xml.append$//event[@name=\"JUDGE_AWARD_RK_BAM_CREW\"]/choice/text"
msgstr "Continue..."

#: src-en/data/events_special_multiverse.xml.append:177
msgid ""
"data/events_special_multiverse.xml.append$//event[@name=\"JUDGE_AWARD_RK_PUNK_CREW\"]/text"
msgstr ""
"\"Twisted minds with a knack... for disrupting life and energy. I wouldn't "
"want to meet... any of them. But their genius... impresses me. Well done, "
"traveler. Expect... rewards before your next journey.\""

#: src-en/data/events_special_multiverse.xml.append:182
msgid ""
"data/events_special_multiverse.xml.append$//event[@name=\"JUDGE_AWARD_RK_PUNK_CREW\"]/choice/text"
msgstr "Continue..."

#: src-en/data/events_special_multiverse.xml.append:187
msgid ""
"data/events_special_multiverse.xml.append$//event[@name=\"JUDGE_AWARD_RK_SCORCH_CREW\"]/text"
msgstr ""
"\"Sadists... obsessed with heat and speed. They can't be trusted... to not "
"burn everything down. But the results... are valuable. Well done, traveler. "
"Expect... rewards before your next journey.\""

#: src-en/data/events_special_multiverse.xml.append:192
msgid ""
"data/events_special_multiverse.xml.append$//event[@name=\"JUDGE_AWARD_RK_SCORCH_CREW\"]/choice/text"
msgstr "Continue..."

