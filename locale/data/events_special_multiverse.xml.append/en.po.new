#: src-en/data/events_special_multiverse.xml.append:246
msgid ""
"data/events_special_multiverse.xml.append$//mod:findName[@name=\"THE_JUDGES_ROCKMAN_REAL\"]/mod-"
"append:choice[8]/text"
msgstr "Present RadiKal BPS tech."

#: src-en/data/events_special_multiverse.xml.append:253
msgid ""
"data/events_special_multiverse.xml.append$//event[@name=\"JUDGE_AWARD_RK_BAM_EQUIPMENT\"]/text"
msgstr ""
"\"Oh my... RADIKAL BAM Tech? Sure. This is tribute, I suppose. Great for "
"DESTRUCTION! And ENDURANCE, and asphyxiation. Not much else. HOW MANY ships "
"have you DESTROYED that you would have spared without this tech?... but I "
"DIGRESS. I shall BLESS you with the BLESSING OF RADIKAL TOUGHNESS. But have "
"PATIENCE. It is not for now, but for LATER!\""

#: src-en/data/events_special_multiverse.xml.append:258
msgid ""
"data/events_special_multiverse.xml.append$//event[@name=\"JUDGE_AWARD_RK_BAM_EQUIPMENT\"]/choice/text"
msgstr "Continue..."

#: src-en/data/events_special_multiverse.xml.append:263
msgid ""
"data/events_special_multiverse.xml.append$//event[@name=\"JUDGE_AWARD_RK_PUNK_EQUIPMENT\"]/text"
msgstr ""
"\"Oh my... RADIKAL PUNK Tech? Sure. This is tribute, I suppose. OUTSMARTING "
"your opponents. Turning your OWN crew into mere MURDER tools. HOW MANY "
"creatures have you KILLED that you would have spared without this tech?... "
"but I DIGRESS. I shall BLESS you with the BLESSING OF RADIKAL CUNNING. But "
"have PATIENCE. It is not for now, but for LATER!\""

#: src-en/data/events_special_multiverse.xml.append:268
msgid ""
"data/events_special_multiverse.xml.append$//event[@name=\"JUDGE_AWARD_RK_PUNK_EQUIPMENT\"]/choice/text"
msgstr "Continue..."

#: src-en/data/events_special_multiverse.xml.append:273
msgid ""
"data/events_special_multiverse.xml.append$//event[@name=\"JUDGE_AWARD_RK_SCORCH_EQUIPMENT\"]/text"
msgstr ""
"\"Oh my... RADIKAL SCORCH Tech? Sure. This is tribute, I suppose. I know the"
" power of FIRE very well. ALL power turns to heat, but THIS, only causes "
"MAYHEM. HOW MANY things BURNED in your wake to which you would have given a "
"QUICK end without this tech?... but I DIGRESS. I shall BLESS you with the "
"BLESSING OF RADIKAL FEVER. But have PATIENCE. It is not for now, but for "
"LATER!\""

#: src-en/data/events_special_multiverse.xml.append:278
msgid ""
"data/events_special_multiverse.xml.append$//event[@name=\"JUDGE_AWARD_RK_SCORCH_EQUIPMENT\"]/choice/text"
msgstr "Continue..."

#: src-en/data/events_special_multiverse.xml.append:283
msgid ""
"data/events_special_multiverse.xml.append$//event[@name=\"JUDGE_AWARD_RK_BPS_EQUIPMENT\"]/text"
msgstr ""
"\"Oh my... RADIKAL BPS Tech? Sure. This is tribute, I suppose. MULTIPLE "
"strengths, hoping to EXPLOIT one of the enemy's WEAKNESSES. Because ONE is "
"all it takes. Do you even CARE about the pain AND destruction, to create "
"THAT? For your sake, you better NOT... but I DIGRESS. I shall BLESS you with"
" the BLESSING OF RADIKAL PROJECTS. But have PATIENCE. It is not for now, but"
" for LATER!\""

#: src-en/data/events_special_multiverse.xml.append:288
msgid ""
"data/events_special_multiverse.xml.append$//event[@name=\"JUDGE_AWARD_RK_BPS_EQUIPMENT\"]/choice/text"
msgstr "Continue..."
