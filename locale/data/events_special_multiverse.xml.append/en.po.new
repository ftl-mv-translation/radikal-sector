"data/events_special_multiverse.xml.append$//event[@name=\"SYLVAN_RK_ONE_LINE_EACH_CATEGORY\"]/text"
msgstr ""
"\"Aaaaah. Ssstranger ssstranger, don't be mad but I'm ssselling you illegal,"
" unethical goodsss, don't get caught with those!\""

