#: src-en/data/events_sector_radikal.xml:460
msgid ""
"data/events_sector_radikal.xml$//ship[@name=\"SHIP_RKS_HIDEOUT_UNLOCKER\"]/surrender/text"
msgstr ""
"\"Captain, we are on the same side! Just stop and take everyth- ... "
"hrhmmrmh!... MHMRrMPH!!\" The captain was certainly trying to surrender, but"
" suddenly their lips and mouth... disappeared, and their body started "
"dancing like a ridiculous puppet hung by strings!"

#: src-en/data/events_sector_radikal.xml:464
msgid ""
"data/events_sector_radikal.xml$//ship[@name=\"SHIP_RKS_HIDEOUT_UNLOCKER\"]/surrender/choice[1]/text"
msgstr ""
"Abort, something's very wrong here! Is this what happens to hideout owners "
"who try to surrender when an invader wants to take over? Are we next?..."

#: src-en/data/events_sector_radikal.xml:469
msgid ""
"data/events_sector_radikal.xml$//ship[@name=\"SHIP_RKS_HIDEOUT_UNLOCKER\"]/surrender/choice[2]/text"
msgstr "Ignore this disturbing event and keep attacking..."

#: src-en/data/events_sector_radikal.xml:474
msgid ""
"data/events_sector_radikal.xml$//ship[@name=\"SHIP_RKS_HIDEOUT_UNLOCKER\"]/destroyed/text"
msgstr ""
"The Elite Federation previous owner of your spot breaks apart and you quickly salvage what you can.\n"
"\t\t\tA sort of urge presses you to move to a specific area on a small moon hidden in the nebula, where you find a few buildings that you destroy and burn down without hesitation. Then the fever subsides."

#: src-en/data/events_sector_radikal.xml:479
msgid ""
"data/events_sector_radikal.xml$//ship[@name=\"SHIP_RKS_HIDEOUT_UNLOCKER\"]/destroyed/choice/text"
