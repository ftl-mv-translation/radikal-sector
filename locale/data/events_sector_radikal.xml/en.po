#: src-en/data/events_sector_radikal.xml:1537
msgid ""
"data/events_sector_radikal.xml$//event[@name=\"RKS_SUSPICIOUS_SMUGGLER\"]/choice[4]/event/text"
msgstr ""
"You don't approach, but the ship seems aware that you noticed them. \"Hey, "
"uh, what are you looking at?\""

#: src-en/data/events_sector_radikal.xml:1539
msgid ""
"data/events_sector_radikal.xml$//event[@name=\"RKS_SUSPICIOUS_SMUGGLER\"]/choice[4]/event/choice/text"
msgstr "Oh, you know..."

#: src-en/data/events_sector_radikal.xml:1541
msgid ""
"data/events_sector_radikal.xml$//event[@name=\"RKS_SUSPICIOUS_SMUGGLER\"]/choice[4]/event/choice/event/text"
msgstr "\"Y-yeah? And what about it?\""

#: src-en/data/events_sector_radikal.xml:1543
msgid ""
"data/events_sector_radikal.xml$//event[@name=\"RKS_SUSPICIOUS_SMUGGLER\"]/choice[4]/event/choice/event/choice[1]/text"
msgstr "You got anything to trade?"

#: src-en/data/events_sector_radikal.xml:1545
msgid ""
"data/events_sector_radikal.xml$//event[@name=\"RKS_SUSPICIOUS_SMUGGLER\"]/choice[4]/event/choice/event/choice[1]/event/text"
msgstr "\"O-oh. Yeah, of course. Come aboard!\""

#: src-en/data/events_sector_radikal.xml:1550
msgid ""
"data/events_sector_radikal.xml$//event[@name=\"RKS_SUSPICIOUS_SMUGGLER\"]/choice[4]/event/choice/event/choice[2]/text"
