"data/events_sector_radikal.xml$//event[@name=\"RKS_QUEST_DEFROMORIUS_SHUTTLE\"]/choice[1]/event/choice/text"
msgstr "Вы убили энджи Защитников?"

#: src-en/data/events_sector_radikal.xml:1966
msgid ""
"data/events_sector_radikal.xml$//event[@name=\"RKS_QUEST_DEFROMORIUS_SHUTTLE\"]/choice[1]/event/choice/event/text"
msgstr ""
"\"Подтверждаю. Количество причин для лжи = 0. Я = аномалия. --БОЛЬ-- \n"
"\t\t\t\t\t\tСлучайная находка: металлическая плоть ланиуса: способна связываться с нанороботами энджи. Требования: вещество из запрещенных экспериментов ракушек + крайне маловероятный всплеск радиации. --СТАТИСТИЧЕСКИ НЕВОЗМОЖНО-- Вердикт Гармонии: отменить или устранить\".\n"
"\n"
"\t\t\t\t\t\tВы не выглядите особо убежденным, но существо продолжает.\n"
"\n"
"\t\t\t\t\t\t\"Решение для выживания: присоединиться к РадиКалам. --ЗАДАЧА ВЫПОЛНЕНА-- Однако Гармония = настойчива. Захватила меня. Попыталась перезагрузить с помощью: нейронных пыток. Решение для побега: убить. --ЗАДАЧА ВЫПОЛНЕНА-- Теперь: ваши намерения?\""

#: src-en/data/events_sector_radikal.xml:1975
