#: src-en/data/events_sector_radikal.xml:2514
msgid ""
"data/events_sector_radikal.xml$//event[@name=\"RKS_PIRATE_TRINITY_CHOOSE\"]/choice[@req=\"rks_pirate_trinity_count\"]/text"
msgstr "Поблагодарить их за сотрудничество и попрощаться."

#: src-en/data/events_sector_radikal.xml:2516
#, fuzzy
msgid ""
"data/events_sector_radikal.xml$//event[@name=\"RKS_PIRATE_TRINITY_CHOOSE\"]/choice[@req=\"rks_pirate_trinity_count\"]/event/text"
msgstr ""
"\"Ну-ну, ты и вправду по-нассстоящему богатый, мерзкий тип, которому плевать на всссех живых сссущессств, просссто фантассстичессский клиент во всссех сссмыссслах! Прими мои извинения за то, что усссомнилссся в тебе, и пусссть твои набеги приносссят огромную добычу! Дамы и господа, время вечеринки! Наркотики всссем, и давайте сссыграем в \"Ссстреляй по конечноссстям\" этого раба-человека, который сссегодня утром ссстранно на меня посссмотрел\".\n"
"\t\t\t\t\n"
"\t\t\t\tВас отпускают с небольшим подарком и широкими улыбками на лицах. Поздравляем,вы только что сделал галактику еще хуже."

#: src-en/data/events_sector_radikal.xml:2523
msgid ""
"data/events_sector_radikal.xml$//event[@name=\"RKS_PIRATE_TRINITY_CHOOSE\"]/choice[@req=\"rks_pirate_trinity_count\"]/event/choice/text"
msgstr "Продолжить..."

