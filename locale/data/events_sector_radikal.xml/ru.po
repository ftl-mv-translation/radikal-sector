"data/events_sector_radikal.xml$//event[@name=\"RKS_PIRATE_TRINITY_CHOOSE_SMUGGLER\"]/choice/event/choice[4]/event/choice/text"
msgstr "Продолжить..."

#: src-en/data/events_sector_radikal.xml:2768
msgid ""
"data/events_sector_radikal.xml$//event[@name=\"RKS_PIRATE_TRINITY_FIGHT_CURRENT_PIRATE\"]/text"
msgstr ""
"\"Конечно же, ты такой. Я же тебе говорил, Курт, гони мне мой лом, ты проиграл спор. Давай-ка прикончим этих чертовых клоунов\".\n"
"\t\tПохоже, вам придется пробивать себе путь!"

