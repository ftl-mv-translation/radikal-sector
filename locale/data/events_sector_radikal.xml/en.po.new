#: src-en/data/events_sector_radikal.xml:1049
msgid "data/events_sector_radikal.xml$//event[@name=\"RKS_QUEST_LAB_BAM_3\"]/text"
msgstr ""
"\"OK, now enjoy our best local store. I've got shit to take care of, ya know? Sounds kinda urgent. Bye.\"\n"
"\n"
"\t\tBefore you shop, you still have some time to do something else aboard the ship."

#: src-en/data/events_sector_radikal.xml:1057
msgid ""
"data/events_sector_radikal.xml$//event[@name=\"RKS_QUEST_LAB_BAM_3\"]/choice[1]/text"
msgstr "Do something onboard the ship."

#: src-en/data/events_sector_radikal.xml:1061
