msgid ""
"data/events_sector_radikal.xml$//event[@name=\"RKS_QUEST_LAB_PUNK\"]/choice[6]/text"
msgstr "We're just passing through here, don't mind us."

#: src-en/data/events_sector_radikal.xml:1210
msgid ""
"data/events_sector_radikal.xml$//event[@name=\"RKS_QUEST_LAB_PUNK\"]/choice[6]/event/text"
msgstr ""
"There is no answer. You move a safe distance away and figure you have time to do some maintenance.\n"
"\n"
"\t\t\tAfter some time, you detect some Orchid ships jumping in weapons hot, but you're safe here."

#: src-en/data/events_sector_radikal.xml:1215
msgid ""
"data/events_sector_radikal.xml$//event[@name=\"RKS_QUEST_LAB_PUNK\"]/choice[6]/event/choice[1]/text"
