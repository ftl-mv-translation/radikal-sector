#: src-en/data/events_sector_radikal.xml:1595
msgid ""
"data/events_sector_radikal.xml$//event[@name=\"RKS_QUEST_LAB_SCORCH_2\"]/choice[@req=\"orchid_caretaker\"]/event/text"
msgstr ""
"\"Quality material, yes. Here's greater payment.\"\n"
"\t\t\t\n"
"\t\t\t\tYou can feel the rest of your crew judging you."

#: src-en/data/events_sector_radikal.xml:1606
