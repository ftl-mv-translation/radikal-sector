#: src-en/data/events_sector_radikal.xml:1193
msgid ""
"data/events_sector_radikal.xml$//event[@name=\"RKS_QUEST_LAB_PUNK\"]/choice[5]/event/text"
msgstr ""
"Your ship soon takes damage from a source you cannot identify. \"Ha! Nice "
