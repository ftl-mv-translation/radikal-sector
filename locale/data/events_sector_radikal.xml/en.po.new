#: src-en/data/events_sector_radikal.xml:499
msgid ""
"data/events_sector_radikal.xml$//event[@name=\"RKS_PIRATE_TRINITY_CHOOSE_SMUGGLER\"]/choice/event/choice[3]/event/text"
msgstr "\"Use with caution!\""

#: src-en/data/events_sector_radikal.xml:507
msgid ""
"data/events_sector_radikal.xml$//event[@name=\"RKS_PIRATE_TRINITY_CHOOSE_SMUGGLER\"]/choice/event/choice[3]/event/choice/text"
msgstr "Continue..."

#: src-en/data/events_sector_radikal.xml:514
msgid ""
"data/events_sector_radikal.xml$//event[@name=\"RKS_PIRATE_TRINITY_CHOOSE_SMUGGLER\"]/choice/event/choice[4]/text"
msgstr "You know what, the funny thing is, we're broke..."

#: src-en/data/events_sector_radikal.xml:516
msgid ""
"data/events_sector_radikal.xml$//event[@name=\"RKS_PIRATE_TRINITY_CHOOSE_SMUGGLER\"]/choice/event/choice[4]/event/text"
msgstr ""
"\"Sad, I didn't take you for a joker. You should have brought that scrap.\" The pirate ship in front of you instantly makes itself combat ready, having clearly expected that. \n"
"\t\t\t\t\t\t\n"
"\t\t\t\t\t\tYou can't tell whether the slug overseer is furious, vindicated, or both. \"Hah! I knew it, you just wanted to take down a bunch of piratesss at once you wannabe hero. Guesss what, we're not that dumb! Hey Kurt, hand over the scrap, i won the bet.\"\n"
"\t\t\t\t\t\tWith that, they and the other pirate ships jump away, leaving you to deal with the smuggler!"

#: src-en/data/events_sector_radikal.xml:523
msgid ""
"data/events_sector_radikal.xml$//event[@name=\"RKS_PIRATE_TRINITY_CHOOSE_SMUGGLER\"]/choice/event/choice[4]/event/choice/text"
msgstr "Continue..."

#: src-en/data/events_sector_radikal.xml:534
msgid ""
"data/events_sector_radikal.xml$//event[@name=\"RKS_PIRATE_TRINITY_FIGHT_CURRENT_PIRATE\"]/text"
msgstr ""
"\"Of coursssse you are. Told you Kurt, hand over my sssscrap, you lost the bet. Let'ssss kill these damn clownssss.\"\n"
"\t\tLooks like you'll have to fight your way out!"

#: src-en/data/events_sector_radikal.xml:541
msgid ""
"data/events_sector_radikal.xml$//event[@name=\"RKS_PIRATE_TRINITY_FIGHT_CURRENT_PIRATE\"]/choice/text"
msgstr "Continue..."

#: src-en/data/events_sector_radikal.xml:548
msgid ""
"data/events_sector_radikal.xml$//ship[@name=\"SHIP_RKS_TRINITY_SLAVER\"]/destroyed/text"
msgstr ""
"The Slaver ship has been defeated. You scrap the remains.\n"
"\t\t\tIntentionally or not, you've made a mess disrupting pirate operations in this sector."

#: src-en/data/events_sector_radikal.xml:553
msgid ""
"data/events_sector_radikal.xml$//ship[@name=\"SHIP_RKS_TRINITY_SLAVER\"]/destroyed/choice/text"
msgstr "Continue..."

#: src-en/data/events_sector_radikal.xml:558
msgid ""
"data/events_sector_radikal.xml$//ship[@name=\"SHIP_RKS_TRINITY_SLAVER\"]/deadCrew/text"
msgstr ""
"The Slaver ship has been defeated. You scrap the interior and free a great slave from the cargo bay!\n"
"\t\t\tIntentionally or not, you've made a mess disrupting pirate operations in this sector."

#: src-en/data/events_sector_radikal.xml:564
