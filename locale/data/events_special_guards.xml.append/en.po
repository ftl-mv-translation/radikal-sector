#: src-en/data/events_special_guards.xml.append:6
msgid ""
"data/events_special_guards.xml.append$//textList[@name=\"TEXT_START_RADIKAL\"]/text[1]"
msgstr ""
"You have arrived in the RadiKal Sector, where specialists from everywhere come in search of highly efficient and illegal gear.\n"
"\t\t\n"
"\t\tWhile individual rebels or small groups certainly work with the RadiKals, the fleet will have trouble getting here, giving you some time to prepare for getting out of here alive.\n"
"\t\tAnd prepare you should."

#: src-en/data/events_special_guards.xml.append:11
msgid ""
"data/events_special_guards.xml.append$//textList[@name=\"TEXT_START_RADIKAL\"]/text[2]"
msgstr ""
"You have arrived in the RadiKal Sector, where one can find hazardous equipment of great power, if they're ready to make sacrifices.\n"
"\t\t\n"
"\t\tWhile individual rebels or small groups certainly work with the RadiKals, the fleet will have trouble getting here, giving you some time to prepare for getting out of here alive.\n"
"\t\tAnd prepare you should."

#: src-en/data/events_special_guards.xml.append:16
msgid ""
"data/events_special_guards.xml.append$//textList[@name=\"TEXT_START_RADIKAL\"]/text[3]"
msgstr ""
"You have arrived in the RadiKal Sector, which should be fine if you know what you're looking for, and when to avoid fights you might not win.\n"
"\t\t\n"
"\t\tWhile individual rebels or small groups certainly work with the RadiKals, the fleet will have trouble getting here, giving you some time to prepare for getting out of here alive.\n"
"\t\tAnd prepare you should."

#: src-en/data/events_special_guards.xml.append:39
msgid ""
"data/events_special_guards.xml.append$//event[@name=\"START_RADIKAL\"]/choice/text"
msgstr "Continue..."

#: src-en/data/events_special_guards.xml.append:46
msgid ""
"data/events_special_guards.xml.append$//event[@name=\"GUARD_RADIKAL\"]/text"
msgstr ""
"The beacon is guarded by a well armed vessel but it's not hostile just yet. In the distance you see pirate ship jumping away. From what you can tell, they're loaded with cargo and the guard just let them through, with no recent signs of battle.\n"
"\t\t\n"
"\t\tThe guard is hailing you."

#: src-en/data/events_special_guards.xml.append:50
msgid ""
"data/events_special_guards.xml.append$//event[@name=\"GUARD_RADIKAL\"]/choice[1]/text"
msgstr "Take the hail."

#: src-en/data/events_special_guards.xml.append:52
msgid ""
"data/events_special_guards.xml.append$//event[@name=\"GUARD_RADIKAL_HAIL\"]/text"
msgstr ""
"\"So. Rook or reg?\" The guard is nonchalantly awaiting your answer.\n"
"\t\t\t\tThis seems to be about your familiarity with this sector."

#: src-en/data/events_special_guards.xml.append:57
msgid ""
"data/events_special_guards.xml.append$//event[@name=\"GUARD_RADIKAL_HAIL\"]/choice[1]/text"
msgstr "Humbly ask for cheap repairs."

#: src-en/data/events_special_guards.xml.append:59
msgid ""
"data/events_special_guards.xml.append$//event[@name=\"GUARD_RADIKAL_HAIL\"]/choice[1]/event/text"
msgstr ""
"\"So you had some trouble getting here in one piece, huh? I feel you, we've all been there. Here's our customer-friendly welcome, you will need it!\"\n"
"\t\t\t\t\t\tFor a symbolic price, the RadiKals quickly perform extensive repairs on your ship! Apparently they'll do it as many times as you need."

#: src-en/data/events_special_guards.xml.append:68
msgid ""
"data/events_special_guards.xml.append$//event[@name=\"GUARD_RADIKAL_HAIL\"]/choice[1]/event/choice/text"
msgstr "Continue..."

#: src-en/data/events_special_guards.xml.append:75
msgid ""
"data/events_special_guards.xml.append$//event[@name=\"GUARD_RADIKAL_HAIL\"]/choice[@req=\"DJMOD_HAS_RADIKAL_GEAR\""
" and not(@lvl)]/text"
msgstr "(Any piece of RK gear) Reg. Hit me up!"

#: src-en/data/events_special_guards.xml.append:77
msgid ""
"data/events_special_guards.xml.append$//event[@name=\"GUARD_RADIKAL_HAIL\"]/choice[@req=\"DJMOD_HAS_RADIKAL_GEAR\""
" and not(@lvl)]/event/text"
msgstr ""
"\"Nice piece! Since you're already one of us, here are all the latest "
"coordinates, in case you want to diversify your options.\""

#: src-en/data/events_special_guards.xml.append:79
msgid ""
"data/events_special_guards.xml.append$//event[@name=\"GUARD_RADIKAL_HAIL\"]/choice[@req=\"DJMOD_HAS_RADIKAL_GEAR\""
" and not(@lvl)]/event/choice/text"
msgstr "Continue..."

#: src-en/data/events_special_guards.xml.append:81
msgid ""
"data/events_special_guards.xml.append$//event[@name=\"GUARD_RADIKAL_HAIL\"]/choice[@req=\"DJMOD_HAS_RADIKAL_GEAR\""
" and not(@lvl)]/event/choice/event/text"
msgstr ""
"\"Here's the current location of the RK Bam lab. if you have explodey stuff,"
" need more, or want to toughen up your ship, you know they'll be happy to "
"see you.\""

#: src-en/data/events_special_guards.xml.append:89
msgid ""
"data/events_special_guards.xml.append$//event[@name=\"GUARD_RADIKAL_HAIL\"]/choice[@req=\"DJMOD_HAS_RADIKAL_GEAR\""
" and not(@lvl)]/event/choice/event/choice/text"
msgstr "Continue..."

#: src-en/data/events_special_guards.xml.append:91
msgid ""
"data/events_special_guards.xml.append$//event[@name=\"GUARD_RADIKAL_HAIL\"]/choice[@req=\"DJMOD_HAS_RADIKAL_GEAR\""
" and not(@lvl)]/event/choice/event/choice/event/text"
msgstr ""
"\"Sly as always, the RK Punk have set camp at this beacon. For all your "
"fancy electric, bio, murderous needs and so on.\""

#: src-en/data/events_special_guards.xml.append:99
msgid ""
"data/events_special_guards.xml.append$//event[@name=\"GUARD_RADIKAL_HAIL\"]/choice[@req=\"DJMOD_HAS_RADIKAL_GEAR\""
" and not(@lvl)]/event/choice/event/choice/event/choice/text"
msgstr "Continue..."

#: src-en/data/events_special_guards.xml.append:101
msgid ""
"data/events_special_guards.xml.append$//event[@name=\"GUARD_RADIKAL_HAIL\"]/choice[@req=\"DJMOD_HAS_RADIKAL_GEAR\""
" and not(@lvl)]/event/choice/event/choice/event/choice/event/text"
msgstr ""
"\"... and here's the Scorch lab. They're in need of supplies. You know, the kind that burns really well...\n"
"\t\t\t\t\t\t\t\t\t\t\t\tSafe travels! Hahaha\"\n"
"\t\t\t\t\t\t\t\t\t\t\t\t\n"
"\t\t\t\t\t\t\t\t\t\t\t\tIf you had to guess, the \"supplies\" might be living creatures, which could mean all sorts of trouble.\n"
"\t\t\t\t\t\t\t\t\t\t\t\tYou'll decide what to do on the way, there's nothing left to do here but some maintenance."

#: src-en/data/events_special_guards.xml.append:114
msgid ""
"data/events_special_guards.xml.append$//event[@name=\"GUARD_RADIKAL_HAIL\"]/choice[@req=\"DJMOD_HAS_RADIKAL_GEAR\""
" and not(@lvl)]/event/choice/event/choice/event/choice/event/choice[1]/text"
msgstr "Check the storage."

#: src-en/data/events_special_guards.xml.append:118
msgid ""
"data/events_special_guards.xml.append$//event[@name=\"GUARD_RADIKAL_HAIL\"]/choice[@req=\"DJMOD_HAS_RADIKAL_GEAR\""
" and not(@lvl)]/event/choice/event/choice/event/choice/event/choice[2]/text"
msgstr "Do nothing."

#: src-en/data/events_special_guards.xml.append:131
msgid ""
"data/events_special_guards.xml.append$//event[@name=\"GUARD_RADIKAL_HAIL\"]/choice[@req=\"DJMOD_HAS_RADIKAL_GEAR\""
" and @lvl=\"0\"]/text"
msgstr ""
"You do not have any RadiKal gear. You're not flying an RK ship either."

#: src-en/data/events_special_guards.xml.append:136
msgid ""
"data/events_special_guards.xml.append$//event[@name=\"GUARD_RADIKAL_HAIL\"]/choice[4]/text"
msgstr "Rook."

#: src-en/data/events_special_guards.xml.append:138
msgid ""
"data/events_special_guards.xml.append$//event[@name=\"GUARD_RADIKAL_HAIL\"]/choice[4]/event/text"
msgstr ""
"\"Yeah no wonder. Your ship looks like it could use serious upgrades. Do you"
" even know what you're looking for in here?\""

#: src-en/data/events_special_guards.xml.append:140
msgid ""
"data/events_special_guards.xml.append$//event[@name=\"GUARD_RADIKAL_HAIL\"]/choice[4]/event/choice[1]/text"
msgstr "Yes."

#: src-en/data/events_special_guards.xml.append:142
msgid ""
"data/events_special_guards.xml.append$//event[@name=\"GUARD_RADIKAL_HAIL\"]/choice[4]/event/choice[1]/event/text"
msgstr ""
"\"Alright, what's it gonna be?.\" The guard has brought up a short list of "
"destinations on the comms, with only codenames and all the usual details are"
" missing. You are starting to wonder just how shady a place you just found "
"yourself in."

#: src-en/data/events_special_guards.xml.append:144
msgid ""
"data/events_special_guards.xml.append$//event[@name=\"GUARD_RADIKAL_HAIL\"]/choice[4]/event/choice[1]/event/choice[1]/text"
msgstr "Pick \"Bam\"."

#: src-en/data/events_special_guards.xml.append:146
msgid ""
"data/events_special_guards.xml.append$//event[@name=\"GUARD_RADIKAL_HAIL\"]/choice[4]/event/choice[1]/event/choice[1]/event/text"
msgstr ""
"\"Always reliable. 'When in doubt, make big holes in it until it's in "
"pieces' never fails.\" The guard transmits the coordinates to you, then "
"quickly cuts comms before you can answer."

#: src-en/data/events_special_guards.xml.append:154
msgid ""
"data/events_special_guards.xml.append$//event[@name=\"GUARD_RADIKAL_HAIL\"]/choice[4]/event/choice[1]/event/choice[1]/event/choice[1]/text"
msgstr "Check the storage."

#: src-en/data/events_special_guards.xml.append:158
msgid ""
"data/events_special_guards.xml.append$//event[@name=\"GUARD_RADIKAL_HAIL\"]/choice[4]/event/choice[1]/event/choice[1]/event/choice[2]/text"
msgstr "Do nothing."

#: src-en/data/events_special_guards.xml.append:164
msgid ""
"data/events_special_guards.xml.append$//event[@name=\"GUARD_RADIKAL_HAIL\"]/choice[4]/event/choice[1]/event/choice[2]/text"
msgstr "Pick \"Punk\"."

#: src-en/data/events_special_guards.xml.append:166
msgid ""
"data/events_special_guards.xml.append$//event[@name=\"GUARD_RADIKAL_HAIL\"]/choice[4]/event/choice[1]/event/choice[2]/event/text"
msgstr ""
"\"A timely choice, I heard they've got some new elaborate killing gear and "
"nerdy stuff available.\" The guard transmits the coordinates to you, then "
"quickly cuts comms before you can answer."

#: src-en/data/events_special_guards.xml.append:172
msgid ""
"data/events_special_guards.xml.append$//event[@name=\"GUARD_RADIKAL_HAIL\"]/choice[4]/event/choice[1]/event/choice[2]/event/choice[1]/text"
msgstr "Check the storage."

#: src-en/data/events_special_guards.xml.append:176
msgid ""
"data/events_special_guards.xml.append$//event[@name=\"GUARD_RADIKAL_HAIL\"]/choice[4]/event/choice[1]/event/choice[2]/event/choice[2]/text"
msgstr "Do nothing."

#: src-en/data/events_special_guards.xml.append:182
msgid ""
"data/events_special_guards.xml.append$//event[@name=\"GUARD_RADIKAL_HAIL\"]/choice[4]/event/choice[1]/event/choice[3]/text"
msgstr "Pick \"Scorch\"."

#: src-en/data/events_special_guards.xml.append:184
msgid ""
"data/events_special_guards.xml.append$//event[@name=\"GUARD_RADIKAL_HAIL\"]/choice[4]/event/choice[1]/event/choice[3]/event/text"
msgstr ""
"\"Looking for hot stuff, I see.\" The guard transmits the coordinates to "
"you, then quickly cuts comms before you can answer."

#: src-en/data/events_special_guards.xml.append:190
msgid ""
"data/events_special_guards.xml.append$//event[@name=\"GUARD_RADIKAL_HAIL\"]/choice[4]/event/choice[1]/event/choice[3]/event/choice[1]/text"
msgstr "Check the storage."

#: src-en/data/events_special_guards.xml.append:194
msgid ""
"data/events_special_guards.xml.append$//event[@name=\"GUARD_RADIKAL_HAIL\"]/choice[4]/event/choice[1]/event/choice[3]/event/choice[2]/text"
msgstr "Do nothing."

#: src-en/data/events_special_guards.xml.append:202
msgid ""
"data/events_special_guards.xml.append$//event[@name=\"GUARD_RADIKAL_HAIL\"]/choice[4]/event/choice[2]/text"
msgstr "Not in the least."

#: src-en/data/events_special_guards.xml.append:204
msgid ""
"data/events_special_guards.xml.append$//event[@name=\"GUARD_RADIKAL_HAIL\"]/choice[4]/event/choice[2]/event/text"
msgstr ""
"The guard frowns. \"Not sure how you people got here but this isn't a place for tourists. You better head for the exit without taking any detours, and there won't be trouble.\" You then hear the guard mutter something about \"needing to tighten security again\" before comms are cut and you realize that they're already dealing with next arrival.\n"
"\t\t\t\t\t\t\t\n"
"\t\t\t\t\t\t\tYou move on, confused and slightly worried."

#: src-en/data/events_special_guards.xml.append:208
msgid ""
"data/events_special_guards.xml.append$//event[@name=\"GUARD_RADIKAL_HAIL\"]/choice[4]/event/choice[2]/event/choice[1]/text"
msgstr "Check the storage."

#: src-en/data/events_special_guards.xml.append:212
msgid ""
"data/events_special_guards.xml.append$//event[@name=\"GUARD_RADIKAL_HAIL\"]/choice[4]/event/choice[2]/event/choice[2]/text"
msgstr "Do nothing."

#: src-en/data/events_special_guards.xml.append:221
msgid ""
"data/events_special_guards.xml.append$//event[@name=\"GUARD_RADIKAL_HAIL\"]/choice[@req=\"rks_pirate_trinity_active\"]/text"
msgstr ""
"This here the pirate haven, innit? We'ere for business. *Spit* [Stackable, "
"risky choice]"

#: src-en/data/events_special_guards.xml.append:223
msgid ""
"data/events_special_guards.xml.append$//event[@name=\"GUARD_RADIKAL_HAIL\"]/choice[@req=\"rks_pirate_trinity_active\"]/event/text"
msgstr ""
"\"Oh.\" The guard seems slightly annoyed, either tired of clearing things up every time or unimpressed by your overdone attitude. \"You are slightly mistaken, piracy isn't our focus, unbound progress is more like it. But yes you can conduct what others call illegal types of trade here. Very useful to source the kind of things we need.\n"
"\t\t\t\t\t\tI'll let your request be known to all interested parties, and you... make SURE to bring enough scrap. We like to avoid unnecessary messes.\"\n"
"\t\t\t\t\t\t\n"
"\t\t\t\t\t\tThey send you the coordinates and let you past. Despite the secrecy of this sector you can already tell that this will reflect poorly on your general reputation. Though if you can get everything you need by yourself and from pirates, it doesn't matter."

#: src-en/data/events_special_guards.xml.append:235
msgid ""
"data/events_special_guards.xml.append$//event[@name=\"GUARD_RADIKAL_HAIL\"]/choice[@req=\"rks_pirate_trinity_active\"]/event/choice/text"
msgstr "Piracy is kinda poggers. Worth it."

#: src-en/data/events_special_guards.xml.append:239
msgid ""
"data/events_special_guards.xml.append$//event[@name=\"DJMOD_REPUTATION_UPDATE_PIRATES_RKS_GUARD\"]/text"
msgstr ""
"[REPUTATION INCREASED - PIRATES]\n"
"\t\t\t\t\t\tYour actions have improved your reputation between pirates. Certain pirate clans might be more willing to offer you better or special deals, and will be more comfortable around you."

#: src-en/data/events_special_guards.xml.append:246
msgid ""
"data/events_special_guards.xml.append$//event[@name=\"DJMOD_REPUTATION_UPDATE_PIRATES_RKS_GUARD\"]/choice/text"
msgstr "Continue..."

#: src-en/data/events_special_guards.xml.append:256
msgid ""
"data/events_special_guards.xml.append$//event[@name=\"GUARD_RADIKAL\"]/choice[2]/text"
msgstr "Ignore them and try to fly past."

#: src-en/data/events_special_guards.xml.append:258
msgid ""
"data/events_special_guards.xml.append$//event[@name=\"GUARD_RADIKAL\"]/choice[2]/event/text"
msgstr ""
"Their weapons immediately come online, they've clearly been expecting this. This could probably have been avoided by exchanging a few words, but they've already called for backup.\n"
"\t\t\tSurprisingly, it seems that their ship's O2 system has caught fire..."

#: src-en/data/events_special_guards.xml.append:268
msgid ""
"data/events_special_guards.xml.append$//event[@name=\"GUARD_RADIKAL\"]/choice[2]/event/choice/text"
msgstr "Hah! What an idio-"

#: src-en/data/events_special_guards.xml.append:270
msgid ""
"data/events_special_guards.xml.append$//event[@name=\"GUARD_RADIKAL\"]/choice[2]/event/choice/event/text"
msgstr ""
"Suddenly, you hear strange teleportation sounds in your ship but detect no boarders, just heat signatures... Your ship is also on fire! And quite a bit more than theirs.\n"
"\t\t\t\t\tIf you survive this, you might just find out how what happened and how to take advantage of it."

#: src-en/data/events_special_guards.xml.append:279
msgid ""
"data/events_special_guards.xml.append$//event[@name=\"GUARD_RADIKAL\"]/choice[2]/event/choice/event/choice/text"
msgstr "Continue..."

#: src-en/data/events_special_guards.xml.append:303
msgid ""
"data/events_special_guards.xml.append$//event[@name=\"GUARD_RADIKAL_DESTROY\"]/text"
msgstr ""
"You have defeated the RadiKal guard. Whatever might have been in their cargo"
" has for certain been destroyed, but you can at least salvage some supplies "
"from the ship."

#: src-en/data/events_special_guards.xml.append:306
msgid ""
"data/events_special_guards.xml.append$//event[@name=\"GUARD_RADIKAL_DESTROY\"]/choice/text"
msgstr "Continue..."

#: src-en/data/events_special_guards.xml.append:311
msgid ""
"data/events_special_guards.xml.append$//event[@name=\"GUARD_RADIKAL_DEADCREW\"]/text"
msgstr ""
"You have defeated the RadiKal guard. Without crew on-board to stop you, you "
"can investigate their cargo. You find some loot to bring back to the ship, "
"and move on to scrap their hull."

#: src-en/data/events_special_guards.xml.append:317
msgid ""
"data/events_special_guards.xml.append$//event[@name=\"GUARD_RADIKAL_DEADCREW\"]/choice/text"
msgstr "Continue..."

#: src-en/data/events_special_guards.xml.append:319
msgid ""
"data/events_special_guards.xml.append$//event[@name=\"GUARD_RADIKAL_DEADCREW\"]/choice/event/text"
msgstr "You find spare RadiKal equipment!"

#: src-en/data/events_special_guards.xml.append:322
msgid ""
"data/events_special_guards.xml.append$//event[@name=\"GUARD_RADIKAL_DEADCREW\"]/choice/event/choice/text"
msgstr "Continue..."

#: src-en/data/events_special_guards.xml.append:344
msgid ""
"data/events_special_guards.xml.append$//event[@name=\"GUARD_RADIKAL_FOLLOWUP\"]/text"
msgstr ""
"By killing the RadiKal guard, you have no doubt caused them to dispatch "
"reinforcements to track you down. Watch your step as you explore the sector."

#: src-en/data/events_special_guards.xml.append:352
msgid ""
"data/events_special_guards.xml.append$//event[@name=\"GUARD_RADIKAL_FOLLOWUP\"]/choice[1]/text"
msgstr "Do something onboard the ship."

#: src-en/data/events_special_guards.xml.append:356
msgid ""
"data/events_special_guards.xml.append$//event[@name=\"GUARD_RADIKAL_FOLLOWUP\"]/choice[2]/text"
msgstr "Do nothing."

#: src-en/data/events_special_guards.xml.append:365
msgid ""
"data/events_special_guards.xml.append$//event[@name=\"REINFORCEMENTS_RADIKAL\"]/beaconType/unvisitedTooltip"
msgstr "An unvisited location."

#: src-en/data/events_special_guards.xml.append:366
msgid ""
"data/events_special_guards.xml.append$//event[@name=\"REINFORCEMENTS_RADIKAL\"]/beaconType/visitedTooltip"
msgstr "Explored location. Nothing left of interest."

#: src-en/data/events_special_guards.xml.append:367
msgid ""
"data/events_special_guards.xml.append$//event[@name=\"REINFORCEMENTS_RADIKAL\"]/beaconType/undiscoveredTooltip"
msgstr "An unvisited location."

#: src-en/data/events_special_guards.xml.append:369
msgid ""
"data/events_special_guards.xml.append$//event[@name=\"REINFORCEMENTS_RADIKAL\"]/text"
msgstr ""
"\"Someone has to be the guard. They were just doing their job, and knew the "
"risks. But so did you!\" The RadiKal ship attacks!"

#: src-en/data/events_special_guards.xml.append:373
msgid ""
"data/events_special_guards.xml.append$//event[@name=\"REINFORCEMENTS_RADIKAL\"]/choice/text"
msgstr "Continue..."

#: src-en/data/events_special_guards.xml.append:381
msgid ""
"data/events_special_guards.xml.append$//event[@name=\"NEBULA_REINFORCEMENTS_RADIKAL\"]/beaconType/unvisitedTooltip"
msgstr "An unvisited location."

#: src-en/data/events_special_guards.xml.append:382
msgid ""
"data/events_special_guards.xml.append$//event[@name=\"NEBULA_REINFORCEMENTS_RADIKAL\"]/beaconType/visitedTooltip"
msgstr "Explored location. Nothing left of interest."

#: src-en/data/events_special_guards.xml.append:383
msgid ""
"data/events_special_guards.xml.append$//event[@name=\"NEBULA_REINFORCEMENTS_RADIKAL\"]/beaconType/undiscoveredTooltip"
msgstr "An unvisited location."

#: src-en/data/events_special_guards.xml.append:385
msgid ""
"data/events_special_guards.xml.append$//event[@name=\"NEBULA_REINFORCEMENTS_RADIKAL\"]/text"
msgstr ""
"\"Someone has to be the guard, they were just doing their job and knew the "
"risks. But so did you!\" The RadiKal ship attacks!"

#: src-en/data/events_special_guards.xml.append:391
msgid ""
"data/events_special_guards.xml.append$//event[@name=\"NEBULA_REINFORCEMENTS_RADIKAL\"]/choice/text"
msgstr "Continue..."
