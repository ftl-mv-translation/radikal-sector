msgstr "跳过。"

#: src-en/data/events_special_guards.xml.append:128
msgid ""
"data/events_special_guards.xml.append$//event[@name=\"GUARD_RADIKAL\"]/choice[1]/event/choice[@req=\"DJMOD_HAS_RADIKAL_GEAR\""
" and @lvl=\"0\"]/text"
msgstr "你没有任何拉迪卡尔装备。你驾驶的也不是拉迪卡尔飞船。"

#: src-en/data/events_special_guards.xml.append:133
msgid ""
"data/events_special_guards.xml.append$//event[@name=\"GUARD_RADIKAL\"]/choice[1]/event/choice[@req=\"DJMOD_HAS_RADIKAL_GEAR\""
" and not(@lvl)]/text"
msgstr "（任何一件 RK 装备）常客。给我安排上！"

#: src-en/data/events_special_guards.xml.append:135
msgid ""
"data/events_special_guards.xml.append$//event[@name=\"GUARD_RADIKAL\"]/choice[1]/event/choice[@req=\"DJMOD_HAS_RADIKAL_GEAR\""
" and not(@lvl)]/event/text"
msgstr ""
"“好装备！既然你已经是我们中的一员了，这是所有最新的坐标，供你多元化选择。”说"
"完，守卫已经忙着应付下一艘船了。"

#: src-en/data/events_special_guards.xml.append:137
#, fuzzy
msgid ""
"data/events_special_guards.xml.append$//event[@name=\"GUARD_RADIKAL\"]/choice[1]/event/choice[@req=\"DJMOD_HAS_RADIKAL_GEAR\""
