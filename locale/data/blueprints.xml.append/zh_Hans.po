msgstr "所在的系统免疫火焰。所在的敌方系统受到的火焰伤害变为 1.6 倍"

#: src-en/data/blueprints.xml.append:171
msgid ""
"data/blueprints.xml.append$//crewBlueprint[@name=\"rk_fireghost\"]/powerList/power[5]"
