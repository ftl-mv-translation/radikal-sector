"data/blueprints.xml.append$//crewBlueprint[@name=\"human_soldier_operative\"]/powerList/power[1]"
msgstr "Наносит 1.2х урона в бою с экипажем"

#: src-en/data/blueprints.xml.append:62
msgid ""
"data/blueprints.xml.append$//crewBlueprint[@name=\"human_soldier_operative\"]/powerList/power[2]"
msgstr "Получает 0.7x урона в бою с экипажем и 0.6x от пожаров"

#: src-en/data/blueprints.xml.append:63
msgid ""
"data/blueprints.xml.append$//crewBlueprint[@name=\"human_soldier_operative\"]/powerList/power[3]"
