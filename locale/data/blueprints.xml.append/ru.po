"от повреждений. Кажется, испытывает боль?"

#: src-en/data/blueprints.xml.append:57
msgid ""
"data/blueprints.xml.append$//crewBlueprint[@name=\"human_soldier_operative\"]/title"
msgstr "Человек-Солдат"

