#: src-en/data/blueprints.xml.append:2651
msgid ""
"data/blueprints.xml.append$//weaponBlueprint[@name=\"RK_ARTILLERY_FLAK_QUICK\"]/desc"
msgstr ""
"Артиллерия: Выпускает серию из 4 осколочных снарядов, каждый из которых наносит 1 единицу урона.\n"
"\tБазовая перезарядка: 16"

#: src-en/data/blueprints.xml.append:2697
msgid ""
"data/blueprints.xml.append$//weaponBlueprint[@name=\"DJMOD_ARTILLERY_LASER_PARTICLE\"]/title"
msgstr "Частичная артиллерия"

