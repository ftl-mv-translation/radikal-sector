*********************************************************************************************************
				QUESTS
*********************************************************************************************************
 -->
<FTL>
<event name="RK_QUEST_LAB_BAM" unique="true">
	<preventQuest/>
	<preventFleet/>
	<quest>
		<nebulaBeacon>false</nebulaBeacon>
		<aggressive>2</aggressive>
	</quest>
	<beaconType id="map_icon_radikal_bam" global="true">
		<color r="150" g="150" b="150" a="1.0"/>
		<unvisitedTooltip>You were told you can get great RadiKal Bam gear at this beacon, if you can prove you're a customer.</unvisitedTooltip>
	</beaconType>

	<text>[PLACEHOLDER QUEST] There is no ship here but someone from the nearby planet is hailing you. "You who dare come here, are you one of us RadiKals?"</text>
	<img planet="PLANET_POPULATED"/>
	
	<choice req="DJMOD_HAS_RADIKAL_GEAR" hidden="true">
		<text>(any piece of RK gear) Yes</text>
		<event>
			<text>You receive a delivery. "Good. Do you support the Bam?"</text>
			<autoReward level="MED">standard</autoReward>
			
			<choice req="DJMOD_HAS_RADIKAL_BAM_GEAR" hidden="true">
				<text>(RK Bam equipment) Yes</text>
				<event>
					<text>You receive another, larger delivery and a very rare augment. "Excellent. Hit hard, homie."
					You would have asked for an explanation but they've blocked your hails. That went well enough overall.</text>
					<autoReward level="HIGH">stuff</autoReward>
					<augment name="DJMOD_AUG_AUTO_SYS_REPAIR"/>
					
					<choice>
						<text>Do something onboard the ship.</text>
						<event load="STORAGE_CHECK"/>
					</choice>
					<choice>
						<text>Do nothing.</text>
						<event/>
					</choice>
				</event>
			</choice>

			<choice req="DJMOD_HAS_RADIKAL_BAM_GEAR" lvl="0" max_lvl="0" hidden="true" blue="false">
				<text>You do not have any RK Bam gear.</text>
				<event load="OPTION_INVALID"/>
			</choice>
			
			<choice hidden="true">
				<text>No</text>
				<event>
					<text>"Then move along." Your hails are now blocked.</text>
					
					<choice>
						<text>Do something onboard the ship.</text>
						<event load="STORAGE_CHECK"/>
					</choice>
					<choice>
						<text>Do nothing.</text>
						<event/>
					</choice>
				</event>
			</choice>
		</event>
	</choice>
	
	<choice hidden="true">
		<text>Uhm... I don't know, maybe?</text>
		<event>
			<text>Your ship soon takes damage from a source you cannot identify. "Begone, tourist. You had been warned."</text>
			<damage amount="3" system="room" effect="breach"/>
			
			<choice>
				<text>Do something onboard the ship.</text>
				<event load="STORAGE_CHECK"/>
			</choice>
			<choice>
				<text>Do nothing.</text>
				<event/>
			</choice>
		</event>
	</choice>
	
	<choice hidden="true">
		<text>No. Sorry for the intrusion. We're leaving.</text>
		<event>
			<text>There is no answer. You figure you didn't give the worst possible answer but it's still best not to stick around.</text>
			
			<choice>
				<text>Do something onboard the ship.</text>
				<event load="STORAGE_CHECK"/>
			</choice>
			<choice>
				<text>Do nothing.</text>
				<event/>
			</choice>
		</event>
	</choice>
</event>

