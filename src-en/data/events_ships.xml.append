					<mod-append:box_white_engaged/>
				</mod:findLike>
			</mod:findName>
		</mod:findLike>
	</mod:findName>
</mod:findLike>

<mod:findName type = "event" name = "DISTRESS_PIRATE_CIVILIAN_BEACON">
<mod-append:choice req="coords_radikal" lvl="0" max_lvl="0" hidden="true" blue="true">
