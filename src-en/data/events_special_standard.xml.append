<mod:findName type = "eventList" name = "TRADELIST_AUGMENT_COMBAT">
	<mod-append:event>
		<text id="trade_purchase"/>
		<store>STORE_STANDARD</store>
		<item_modify>
			<item type="scrap" min="-60" max="-60"/>
		</item_modify>
		<augment name="DJMOD_COMBAT_SHIPVORE_RAM"/>
	</mod-append:event>
</mod:findName>