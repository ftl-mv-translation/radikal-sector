\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\
\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\
\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\
\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\
					CIVILIAN
\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\
\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\
\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\
\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\


<textList name="TEXT_START_CIVILIAN">
	<text>You have arrived in a Civilian sector. The Federation's promises to keep these sectors safe has fallen through, and now the civilians have turned to establishing their own militia. We shouldn't see too much trouble here.</text>
	<text>You have arrived in a Civilian sector. The civilian-run Militia here is competent enough, but they're a little suspicious of strangers. Keep your Federation ID ready just in case.</text>
</textList>
<event name="START_CIVILIAN">
	<preventQuest/>
	<beaconType id="map_icon_start" global="false">
		<color r="46" g="252" b="51" a="1"/>
	</beaconType>
	<text load="TEXT_START_CIVILIAN"/>
	<ship load="SHIP_GUARD_CIVILIAN" hostile="false"/>
	<changeBackground>BACK_SECTOR_CIVILIAN</changeBackground>
	<playSound>lightspeed</playSound>
	<choice hidden="true" req="rep_general" lvl="-2147483648" max_lvl="4" max_group="0" blue="false">
		<text>Continue...</text>
		<event load="GUARD_CIVILIAN"/>
	</choice>
	<choice hidden="true" req="rep_general" lvl="5" max_lvl="999" max_group="0" blue="false">
		<text>Continue...</text>
		<event load="GUARD_CIVILIAN_CRIMINAL"/>
	</choice>
</event>

<event name="GUARD_CIVILIAN_CRIMINAL">
	<text>Something seems off here. Usually, the Militia wouldn't bat an eye at ships like yours, but now, you catch suspicious chatter on the guard ship.</text>
	<choice hidden="true">
		<text>Continue...</text>
		<event>
			<text>It seems your track record has caught up to you. The guard's crew have heard enough of the crimes you've been committing, and they don't intend to let you into the sector!</text>
			<ship hostile="true"/>
			<choice hidden="true">
				<text>Continue...</text>
				<event load="COMBAT_CHECK"/>
			</choice>
		</event>
	</choice>
</event>

<event name="GUARD_CIVILIAN">
	<text>The Militia are tasked with protecting this sector, and have instated a guard to prevent unlawful entry to the sector. Luckily, you don't fall into this category.</text>
	<status type="limit" target="enemy" system="teleporter" amount="0"/>
	<choice>
		<text>Ignore the guard.</text>
		<event>
			<text>You now have some time to do something on the ship.</text>
			<choice>
				<text>Do something onboard the ship.</text>
				<event load="STORAGE_CHECK"/>
			</choice>
			<choice>
				<text>Do nothing.</text>
				<event/>
			</choice>
		</event>
	</choice>
	<choice hidden="true">
		<text>Contact the guard.</text>
		<event load="GUARD_CIVILIAN_INTERACT"/>
	</choice>
	<choice>
		<text>Attack the guard.</text>
		<event>
			<text id="text_guard_attack"/>
			<ship hostile="true"/>
			<choice hidden="true">
				<text>Continue...</text>
				<event load="COMBAT_CHECK"/>
			</choice>
		</event>
	</choice>
</event>

<textList name="TEXT_GUARD_CIVILIAN_CONTACT">
	<text>A gruff, bearded human captain responds. "Yes, we see you. What do you want?"</text>
	<text>A friendly, thin militia-man responds in a chipper tune. "Ah, hello! Always nice to see visitors."</text>
	<text>The Militia captain nods in response to your hail, but says nothing. His face bears an inquisitive look.</text>
</textList>
<event name="GUARD_CIVILIAN_INTERACT">
	<text load="TEXT_GUARD_CIVILIAN_CONTACT"/>
	<choice hidden="true">
		<text>Request supplies.</text>
		<event load="GUARD_CIVILIAN_REQUEST"/>
	</choice>
	<choice hidden="true">
		<text>Demand supplies.</text>
		<event load="GUARD_CIVILIAN_DEMAND"/>
	</choice>
	<choice req="weapons" lvl="5" hidden="true">
		<text>(Upg. Weapons) Threaten the guard.</text>
		<event load="GUARD_CIVILIAN_THREATEN"/>
	</choice>
	<choice req="human" hidden="true">
		<text>(Human Crew) Request assistance.</text>
		<event>
			<text>Your human sends over their Federation ID, which the Militiamen scan and, once verified, transfer over a crate of supplies.</text>
			<autoReward level="LOW">stuff</autoReward>
		</event>
	</choice>
	<choice req="LIST_CREW_MEDIC" hidden="true">
		<text>(Medic Crew) Request medical supplies.</text>
		<event>
			<text>Your medic calls the Militiamen and requests medical supplies, to which they respond by sending over a Medi-Cluster Bomb and some ammunition for it.</text>
			<autoReward level="LOW">missiles_only</autoReward>
			<weapon name="BOMB_HEAL"/>
		</event>
	</choice>
	<choice req="LIST_CREW_MILITIA_ELITE_RANDOM_PLAYER" hidden="true">
		<text>(Soldier/Peacekeeper crew) Request military supplies.</text>
		<event>
			<text>"A Federation soldier! You must be a very important vessel! I'm afraid we have little to give other than this spare Mine Launcher. I've never been a fan of the things myself, but maybe you'll find use in it."</text>
			<autoReward level="HIGH">missiles</autoReward>
			<weapon name="MINELAUNCHER_2"/>
		</event>
	</choice>
	<choice hidden="true">
		<text>Change your mind and leave the guard alone.</text>
		<event>
			<text>You apologize and end comms. The guard makes no attempts to communicate further.</text>
			<choice>
				<text>Do something onboard the ship.</text>
				<event load="STORAGE_CHECK"/>
			</choice>
			<choice>
				<text>Do nothing.</text>
				<event/>
			</choice>
		</event>
	</choice>
</event>

<eventList name="GUARD_CIVILIAN_REQUEST">
	<event>
		<text>"I apologize, but we do not have orders to provide assistance to other ships."</text>
	</event>
	<event>
		<text>The Militiamen agree to your request, and transfer over a small crate of supplies.</text>
		<autoReward level="LOW">stuff</autoReward>
	</event>
</eventList>
<eventList name="GUARD_CIVILIAN_DEMAND">
	<event>
		<text>The Militia guard refuses to give in to your demands. Instead, they raise their weapons and retaliate.</text>
		<ship hostile="true"/>
		<choice hidden="true">
			<text>Continue...</text>
			<event load="COMBAT_CHECK"/>
		</choice>
	</event>
	<event>
		<text>Reluctantly, the Militiamen transfer over some supplies, not wanting to battle you.</text>
		<autoReward level="MED">stuff</autoReward>
	</event>
</eventList>
<eventList name="GUARD_CIVILIAN_THREATEN">
	<event>
		<text>The Militia guard refuses to give in to your demands. Instead, they raise their weapons and retaliate.</text>
		<ship hostile="true"/>
		<choice hidden="true">
			<text>Continue...</text>
			<event load="COMBAT_CHECK"/>
		</choice>
	</event>
	<event>
		<text>Reluctantly, the Militiamen transfer over some supplies, not wanting to battle you.</text>
		<autoReward level="LOW">stuff</autoReward>
	</event>
	<event>
		<text>Reluctantly, the Militiamen transfer over some supplies, not wanting to battle you.</text>
		<autoReward level="LOW">stuff</autoReward>
	</event>
</eventList>

<ship name="SHIP_GUARD_CIVILIAN" auto_blueprint="MU_MILITIA_GUARD">
	<surrender min="7" max="8" load="GUARD_SIGNAL"/>
	<destroyed load="GUARD_CIVILIAN_DESTROY"/>
	<deadCrew load="GUARD_CIVILIAN_DEADCREW"/>
</ship>

<event name="GUARD_CIVILIAN_DESTROY">
	<text>You have defeated the Militia guard. Whatever might have been in their cargo has for certain been destroyed, but you can at least salvage some supplies from the ship.</text>
	<autoReward level="MED">standard</autoReward>
	<choice hidden="true">
		<text>Continue...</text>
		<event load="GUARD_CIVILIAN_FOLLOWUP"/>
	</choice>
</event>
<event name="GUARD_CIVILIAN_DEADCREW">
	<text>You have defeated the Militia guard. Without crew on-board to stop you, you can investigate their cargo. You find a weapon to bring back to the ship, and move on to scrap their hull.</text>
	<autoReward level="MED">standard</autoReward>
	<weapon name="GIFTLIST_CIVILIAN"/>
	<choice hidden="true">
		<text>Continue...</text>
		<event load="GUARD_CIVILIAN_FOLLOWUP"/>
	</choice>
</event>

<ship name="SHIP_CIVILIAN_REINFORCEMENTS" auto_blueprint="LIST_SHIPS_MILITIA_FIGHT">
	<destroyed load="DESTROYED_REINFORCEMENTS"/>
	<deadCrew load="DEADCREW_REINFORCEMENTS"/>
</ship>
<event name="GUARD_CIVILIAN_FOLLOWUP">
	<noQuestText/>
	<removeHazards/>
	<text>By killing the Militia guard, you have no doubt caused them to dispatch reinforcements to track you down. Watch your step as you explore the sector.</text>
	<quest event="REINFORCEMENTS_CIVILIAN"/>
	<choice>
		<text>Do something onboard the ship.</text>
		<event load="STORAGE_CHECK"/>
	</choice>
	<choice>
		<text>Do nothing.</text>
		<event/>
	</choice>
</event>
<event name="REINFORCEMENTS_CIVILIAN">
	<preventQuest/>
	<beaconType id="map_icon_reinforcements" global="true" req="LOOT_COMPASS">
		<color r="200" g="55" b="82" a="1"/>
		<unvisitedTooltip>An unvisited location.</unvisitedTooltip>
		<visitedTooltip>Explored location. Nothing left of interest.</visitedTooltip>
		<undiscoveredTooltip>An unvisited location.</undiscoveredTooltip>
	</beaconType>
	<text>A Militia ship moves in to attack! Based on the vengeful look in their captain's eye, this is no doubt the ship dispatched by the guard to hunt you down!</text>
	<ship load="SHIP_CIVILIAN_REINFORCEMENTS" hostile="true"/>
	<environment type="PDS" target="player"/>
	<choice hidden="true">
		<text>Continue...</text>
		<event load="COMBAT_CHECK"/>
	</choice>
</event>


