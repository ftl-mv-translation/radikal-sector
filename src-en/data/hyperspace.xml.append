	<!-- Scorched Earth
	Fire resist (WORKS)
	Systems fire resist aka FIRE_IMMUNITY (RETEST: WEIRD AF. T1 resists, T2 & T3 don't, no matter what.)
	=> FEATURE DISABLED until somebody figures out WTF is happening.
	extinguishing stats to allies (WORKS)
	and healing while extinguishing fire (WORKS)... which kinda looks like "drinking healing fire" TBH. -->

	<aug name="RK_SCORCH_SELF">
		<!-- <function name="FIRE_IMMUNITY" value="0.22" useForReqs="true"/> -->
		<!-- <function name="FIRE_IMMUNITY" value="0.78" useForReqs="true"/> -->
    	<statBoosts>
			<statBoost name="fireDamageMultiplier">
				<boostType>MULT</boostType>
				<shipTarget>ALL</shipTarget>
				<crewTarget>ORIGINAL_ALLIES</crewTarget>
				<droneTarget>CREW</droneTarget>
				<amount>0.6</amount>
				<priority>0</priority>
			</statBoost>
			<statBoost name="fireRepairMultiplier">
				<boostType>MULT</boostType>
				<shipTarget>ALL</shipTarget>
				<crewTarget>ORIGINAL_ALLIES</crewTarget>
				<droneTarget>CREW</droneTarget>
				<amount>3.0</amount>
				<priority>0</priority>
			</statBoost>

			<!-- Fire-dependent stats below -->

			<statBoost name="healAmount">
				<boostType>FLAT</boostType>
				<!-- <shipTarget>ALL</shipTarget> -->
				<shipTarget>ORIGINAL_SHIP</shipTarget>
				<crewTarget>ORIGINAL_ALLIES</crewTarget>
				<droneTarget>CREW</droneTarget>
				<amount>2</amount>
				<priority>0</priority>
				
				<extraConditions type="or">
					<firefighting>true</firefighting>
				</extraConditions>
				<systemPowerDependency>
					<oxygen/>
				</systemPowerDependency>
				<systemPowerScaling>
					<noSys>1</noSys>
					<noPwr>1</noPwr>
					<onePwr>2</onePwr>
					<twoPwr>3</twoPwr>
					<threePwr>4</threePwr>
					<morePwr>5</morePwr>
				</systemPowerScaling>
			</statBoost>
		</statBoosts>
		<icon>rk_icon_scorch_self1</icon>		<!-- This how to automate the augment icons now! -->
    </aug>
	
