				<icon>ach_rk_event_shipvore_ram_scrap</icon>
				<lockImage>ach_locked</lockImage>
				<multiDifficulty>false</multiDifficulty>
			</achievement>

			<achievement name="MUSIC_RKTRACKRADIKAL">
