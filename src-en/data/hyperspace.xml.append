		<deathEffect>
			<damage>0</damage>
			<fireChance>0</fireChance>
			<breachChance>0</breachChance>
			<stunChance>0</stunChance>
			<ion>0</ion>
			<sysDamage>0</sysDamage>
			<persDamage>1</persDamage> (zoltan value)
