				<priority>0</priority>
			</statBoost>
		</statBoosts>
		<statBoosts>
			<statBoost name="trueHealAmount">
				<boostType>FLAT</boostType>
				<shipTarget>ORIGINAL_SHIP</shipTarget>
				<crewTarget>ENEMIES</crewTarget>
				<droneTarget>DRONES</droneTarget>
				<amount>-3</amount>
				<priority>0</priority>
			</statBoost>
