	===================================================================================================
	-->

	<!-- Unique. Based on MV v5.5.1 blobrock aka "Morph imitating a Rockman":
	<race name="blobrock">
		<maxHealth>131</maxHealth>
		<crewSlots>0.5</crewSlots>
		<canBurn>false</canBurn>
		<fireRepairMultiplier>1.67</fireRepairMultiplier>
		<moveSpeedMultiplier>0.5</moveSpeedMultiplier>
		<animBase>rock</animBase>
		<canSuffocate>false</canSuffocate>
		<deathSounds>
			<deathSound>blobDeath</deathSound>
		</deathSounds>
		<shootingSounds>
			<shootingSound>rockThrow1</shootingSound>
			<shootingSound>rockThrow2</shootingSound>
			<shootingSound>rockThrow3</shootingSound>
		</shootingSounds>
		<repairSounds animSoundFrame="5">
		  <repairSound>rockThud1</repairSound>
		  <repairSound>rockThud2</repairSound>
		  <repairSound>rockThud3</repairSound>
		</repairSounds>
	</race>
	-->
	<mod-append:race name="unique_rk_defromorius">
		<essential>1</essential>
		<maxHealth>311</maxHealth>
		<lowHealthThreshold>2500.0</lowHealthThreshold>
		<lowHealthThresholdPercentage>0.25</lowHealthThresholdPercentage>
		<cloneSpeedMultiplier>0.5</cloneSpeedMultiplier>
		
		<repairSpeed>2.7</repairSpeed>
		<fireRepairMultiplier>1.67</fireRepairMultiplier>
		<moveSpeedMultiplier>0.5</moveSpeedMultiplier>

		<punchTimer min="250" max="325"/>		<!-- min="250" max="325" = 2x speed -->
		<stunMultiplier>0.5</stunMultiplier>

		<canBurn>true</canBurn>
		<fireDamageMultiplier>0.2</fireDamageMultiplier>
		<canSuffocate>true</canSuffocate>
		<suffocationModifier>0.2</suffocationModifier>
		<oxygenChangeSpeed>-0.5</oxygenChangeSpeed>

		<!-- REF: Turzil from MV v5.5.1:
		<powerEffect>
			<cooldown>20</cooldown>
			<jumpCooldown>full</jumpCooldown>
			<powerSounds>
				<powerSound>shieldsUp</powerSound>
			</powerSounds>
			<buttonText>SHIELD</buttonText>
			<tooltip>[COOLDOWN:20s  DURATION:15s]
				Each of your allied crew in the room will only take 0.25x damage from ANY source, and quadruples their repair speed.</tooltip>
			<cooldownColor r="0" g="186" b="255"/>
			<temporaryEffect>
				<duration>15</duration>
				<cooldownColor r="0" g="234" b="255"/>
				<finishSounds>
					<finishSound>shieldsDown</finishSound>
				</finishSounds>
				<animSheet>unique_turzil_shield</animSheet>
				<isTelepathic>true</isTelepathic>
				<statBoosts>
					<statBoost name="repairSpeed">
						<boostType>MULT</boostType>
						<amount>4</amount>
						<affectsSelf>true</affectsSelf>
						<shipTarget>CURRENT_ROOM</shipTarget>
						<crewTarget>ALLIES</crewTarget>
					</statBoost>
					<statBoost name="allDamageTakenMultiplier">
						<boostType>SET</boostType>
						<amount>0.25</amount>
						<shipTarget>CURRENT_ROOM</shipTarget>
						<crewTarget>ALLIES</crewTarget>
						<affectsSelf>true</affectsSelf>
						<priority>0</priority>
						<boostAnim>unique_turzil_shield_buff</boostAnim>
					</statBoost>
				</statBoosts>
			</temporaryEffect>
		</powerEffect> -->
		<powerEffect>
			<cooldown>10</cooldown>
			<jumpCooldown>full</jumpCooldown>
			<powerSounds>
				<powerSound>shieldsUp</powerSound>
			</powerSounds>
			<buttonText>DECUBITUS</buttonText>
			<tooltip>[COOLDOWN:10s  DURATION:10s]
				Allied crew in the same ship including Defromorius take 0.7x damage from everything, and deal 1.5x damage.
				</tooltip>
			<cooldownColor r="0" g="186" b="255"/>
			
			<req type="enemy">
				<inCombat/>
				<enemyInRoom/>
			</req>
			<activateWhenReady enemiesOnly="true">true</activateWhenReady>
			<!-- Sadly this affects the charge but also the buff: only suffocating allies get it.
			<chargeReq>
				<extraConditions type="and">
					<suffocating>true</suffocating>
				</extraConditions>
			</chargeReq> -->

			<temporaryEffect>
				<duration>10</duration>
				<cooldownColor r="0" g="234" b="255"/>
				<finishSounds>
					<finishSound>shieldsDown</finishSound>
				</finishSounds>
				<animSheet>unique_turzil_shield</animSheet>
				<statBoosts>
					<statBoost name="damageMultiplier">
						<boostType>MULT</boostType>
						<amount>1.5</amount>
						<shipTarget>CURRENT_SHIP</shipTarget>
						<crewTarget>ALLIES</crewTarget>
						<affectsSelf>true</affectsSelf>
					</statBoost>

					<statBoost name="allDamageTakenMultiplier">
						<boostType>MULT</boostType>
						<amount>0.7</amount>
						<shipTarget>CURRENT_SHIP</shipTarget>
						<crewTarget>ALLIES</crewTarget>
						<affectsSelf>true</affectsSelf>
						<priority>0</priority>
						<boostAnim>unique_turzil_shield_buff</boostAnim>
					</statBoost>
				</statBoosts>
			</temporaryEffect>
		</powerEffect>

		<deathSounds>
			<deathSound>blobDeath</deathSound>
		</deathSounds>
		<shootingSounds>
			<shootingSound>rockThrow1</shootingSound>
			<shootingSound>rockThrow2</shootingSound>
			<shootingSound>rockThrow3</shootingSound>
		</shootingSounds>
		
		<animBase>rock</animBase>
		<repairSounds animSoundFrame="5">
		  <repairSound>rockThud1</repairSound>
		  <repairSound>rockThud2</repairSound>
		  <repairSound>rockThud3</repairSound>
		</repairSounds>
	</mod-append:race>

