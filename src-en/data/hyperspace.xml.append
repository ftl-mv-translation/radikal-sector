</crew>
-->

<!-- <mod:findLike type="crew"> -->
<crew>
	<!-- HEALS (See hyperspace ref for more)
	<passiveHealAmount>1.0</passiveHealAmount>                                       Amount of health to heal over time, in HP/second. Affected by healSpeed, stops at full health.
	<truePassiveHealAmount>1.0</truePassiveHealAmount>                               Amount of health to heal over time, in HP/second. Unaffected by healSpeed, stops at full health.
	<passiveHealDelay>15</passiveHealDelay>              INTEGER OR MV NOT LOAD ! !      Time delay after taking damage for (true)passiveHealAmount, during which no healing will occur.
	<healAmount>2.0</healAmount>                                                     Amount of health to heal over time, in HP/second. Affected by healSpeed, continuous.
	<trueHealAmount>2.0</trueHealAmount>                                             Amount of health to heal over time, in HP/second. Unaffected by healSpeed, continuous. Use negative value for DoT.
	<healCrewAmount>0.0</healCrewAmount>                                             Amount of health to heal friendly crew in the same room over time, in HP/second. Affected by healSpeed of the respective crew. -->
		
	<mod-append:race name="human_soldier_operative">
		<!-- Buyable even at full crew, which gives away that it's special, but the text above it also hints (1 out of 3). -->
		<noSlot>true</noSlot>
		<noClone>true</noClone>
		<controllable>false</controllable>
		
		<damageMultiplier>1.2</damageMultiplier>
		<damageTakenMultiplier>0.7</damageTakenMultiplier>
		<fireDamageMultiplier>0.6</fireDamageMultiplier>
		<suffocationModifier>0.83</suffocationModifier>
		
		<!-- <passiveHealDelay>0.4</passiveHealDelay> CRASHES MV ON LOAD. NEEDS an integer value.-->
		<!-- UNTESTED (from augm lanius)
		<truePassiveHealAmount>-15.0</truePassiveHealAmount>
		<passiveHealDelay>0</passiveHealDelay> -->
		<trueHealAmount>-45.0</trueHealAmount>
		
		<deathEffect>
			<event>
				<loadEvent>DJMOD_OPERATIVE_DIES</loadEvent>
			</event>
		</deathEffect>
		
		<animBase>human</animBase>
		<deathSounds>
			<deathSound>death1</deathSound>
			<deathSound>death2</deathSound>
		</deathSounds>
		<skills>
			<piloting req="10"/>
			<engines req="10"/>
			<shields req="43"/>
			<weapons req="50"/>
			<repair req="12"/>
			<combat req="4"/>
		</skills>
	</mod-append:race>

	<!-- Based on MV v5.5.1 technoboarderion (also read hyperspace documentation for powerResource):
	<race name="technoboarderion">
		<canFight>false</canFight>
		<canSabotage>false</canSabotage>
		<canRepair>false</canRepair>
		<canSuffocate>false</canSuffocate>
		<canMan>false</canMan>
		<maxHealth>148</maxHealth>
		<crewSlots>0.5</crewSlots>
		<damageMultiplier>1.1</damageMultiplier>
		<fireDamageMultiplier>0.25</fireDamageMultiplier>
		<moveSpeedMultiplier>0.8</moveSpeedMultiplier>
		<stunMultiplier>0.25</stunMultiplier>
		<deathSounds>
			<deathSound>sysExplosion</deathSound>
		</deathSounds>
		<powerEffect>
			<cooldown>13</cooldown>
			<jumpCooldown>full</jumpCooldown>
			<powerSounds>
				<powerSound>ionHit1</powerSound>
			</powerSounds>
			<req>
				<systemInRoom/>
				<enemyShip/>
			</req>
			<friendlyFire>false</friendlyFire>
			<ion>3</ion>
			<stun>7</stun>
			<animFrame>-1</animFrame>
			<buttonText>ION</buttonText>
			<tooltip>Automatic: activates an ion pulse</tooltip>
			<cooldownColor r="0" g="235" b="255"/>
			<effectAnim>explosion_big1_ion</effectAnim>
			<activateWhenReady enemiesOnly="false">true</activateWhenReady>
			<temporaryEffect>
				<duration>2</duration>
				<cooldownColor r="10" g="255" b="255"/>
				<canFight>false</canFight>
				<canRepair>false</canRepair>
				<canSabotage>false</canSabotage>
				<canMan>false</canMan>
				<canMove>false</canMove>
				<snapToSlot>true</snapToSlot>
			</temporaryEffect>
		</powerEffect>
	</race> 
	-->
	<mod-append:race name="rk_weaponlike">
		<canFight>true</canFight>
		<canSabotage>false</canSabotage>
		<canRepair>false</canRepair>
		<canSuffocate>false</canSuffocate>
		<canMan>true</canMan>
		<maxHealth>75</maxHealth>
		<crewSlots>0.5</crewSlots>
		<!-- <damageMultiplier>1.1</damageMultiplier> -->
		<fireDamageMultiplier>0.25</fireDamageMultiplier>
		<moveSpeedMultiplier>0.8</moveSpeedMultiplier>
		<stunMultiplier>0.25</stunMultiplier>
		<deathSounds>
			<deathSound>sysExplosion</deathSound>
		</deathSounds>

		<powerEffect>
			<cooldown>3</cooldown>
			<jumpCooldown>reset</jumpCooldown>
			
			<powerCharges>1</powerCharges>
			<initialCharges>1</initialCharges>
			<chargesPerJump>1</chargesPerJump>

			<event load="RK_WEAPONLIKE_ABILITY"/>
			
			<!-- BUG: never refills on jump, so the crew can only shoot once ever.
			No refs exist, this was found in hyperspace documentation. Try debug again later.
			<powerResource name="rk_weaponlike_ammo">
                <sortOrder>0</sortOrder>
                <cooldown>3</cooldown>
                <jumpCooldown>reset</jumpCooldown>
                <powerCharges>1</powerCharges>
                <initialCharges>1</initialCharges>
                <chargesPerJump>1</chargesPerJump>
                <respawnCharges>1</respawnCharges>
                <cooldownColor r="133" g="231" b="237"/>
                <hideCooldown>false</hideCooldown>
                <hideCharges>false</hideCharges>
                <showTemporaryBars>false</showTemporaryBars>
                <showLinkedCooldowns>false</showLinkedCooldowns>
                <showLinkedCharges>false</showLinkedCharges>
            </powerResource> -->

			<!-- <powerSounds>
				<powerSound>ionHit1</powerSound>
			</powerSounds> -->
			<req>
				<inCombat/>                                             <!-- Hostile enemy ship is present. -->
			</req>
			<!-- <req type="player">
				<systemInRoom/>
				<enemyShip/>
			</req> -->

			<!-- REF: Forgemaster for MV v5.4
			<effectAnim>fm_plated_charge</effectAnim> -->
			<effectAnim>rk_weaponlike_charge</effectAnim>
			<animFrame>4</animFrame>
			<buttonText>BOMB OUT</buttonText>
			<tooltip>Teleport the bomb to the other ship, dealing 1 damage and causing a breach. Can be done once per jump.</tooltip>
			<cooldownColor r="0" g="235" b="255"/>
			<!-- <effectAnim>explosion_big1_ion</effectAnim> -->
			<!-- <activateWhenReady enemiesOnly="false">true</activateWhenReady> -->
			<temporaryEffect>
				<duration>2</duration>
				<cooldownColor r="255" g="0" b="0"/>
				<!--<controllable>false</controllable>-->
				
				<!-- Why MV adds these since it was already not possible?
				<canFight>false</canFight>
				<canRepair>false</canRepair>
				<canSabotage>false</canSabotage>
				<canMan>false</canMan> -->

				<!-- <canMove>false</canMove>
				<snapToSlot>true</snapToSlot> -->
			</temporaryEffect>
		</powerEffect>

		<powerEffect>
			<cooldown>3</cooldown>
			<jumpCooldown>reset</jumpCooldown>

			<powerCharges>1</powerCharges>
			<initialCharges>1</initialCharges>
			<chargesPerJump>1</chargesPerJump>
			
			<!-- Additional resources (cooldowns and charges) that can be shared between abilities, can use load and copy keywords. -->
			<!-- <powerResource load="rk_weaponlike_ammo"/> -->
			
			<friendlyFire>true</friendlyFire>
			<shipFriendlyFire>true</shipFriendlyFire>
			<damage>1</damage>
			<sysDamage>0</sysDamage>
			<persDamage>0</persDamage>
			<breachChance>10</breachChance>
			
			<req type="enemy">
				<inCombat/>
				<enemyInRoom/>
			</req>

			<effectAnim>rk_weaponlike_charge</effectAnim>
			<animFrame>4</animFrame>
			<buttonText>BOMB IN</buttonText>
			<tooltip>Detonate the bomb, dealing 1 damage in the current room and causing a breach. Can be done once per jump</tooltip>
			<cooldownColor r="0" g="235" b="255"/>
			<!-- <effectAnim>explosion_big1_ion</effectAnim> -->
			<!-- <activateWhenReady enemiesOnly="false">true</activateWhenReady> -->
			<temporaryEffect>
				<duration>2</duration>
				<cooldownColor r="255" g="0" b="0"/>

				<!--<controllable>false</controllable>-->
				<!-- Why MV adds these since it was already not possible?
				<canFight>false</canFight>
				<canRepair>false</canRepair>
				<canSabotage>false</canSabotage>
				<canMan>false</canMan> -->

				<!-- <canMove>false</canMove>
				<snapToSlot>true</snapToSlot> -->
			</temporaryEffect>
		</powerEffect>

		<skills>
			<!-- <piloting req="10"/>
			<engines req="10"/>
			<shields req="43"/> -->
			<weapons req="1"/>
			<!-- <repair req="12"/>
			<combat req="4"/> -->
		</skills>
	</mod-append:race>





	<!-- TESTED HERE adding crew without appending (just "<race" ), like Old Guard does. WORKED BUT NOT RECOMMENDED. -->
	<mod-append:race name="rk_fireghost">
		<lowHealthThreshold>2500.0</lowHealthThreshold>
		<lowHealthThresholdPercentage>0.25</lowHealthThresholdPercentage>
		<maxHealth>220</maxHealth>
		<canBurn>false</canBurn>
		<canSuffocate>false</canSuffocate>
		<canPhaseThroughDoors>true</canPhaseThroughDoors>
		<canRepair>false</canRepair>

		<sabotageSpeedMultiplier>2</sabotageSpeedMultiplier>
		<moveSpeedMultiplier>1.2</moveSpeedMultiplier>

		<damageMultiplier>1.5</damageMultiplier>
		<damageTakenMultiplier>1</damageTakenMultiplier>
		<fireDamageMultiplier>0.1</fireDamageMultiplier>	<!-- If immunity is just removed, is very resistant. -->
		<suffocationModifier>0.1</suffocationModifier>
		<deathSounds>
			<deathSound>ghostDeath</deathSound>
		</deathSounds>

		<powerEffect>
			<cooldown>9</cooldown>
			<jumpCooldown>full</jumpCooldown>
			<powerSounds>
				<powerSound>fire_blast</powerSound>
			</powerSounds>

			<req>
				<minHealth>36</minHealth>
			</req>

			<!-- <activateWhenReady enemiesOnly="true">true</activateWhenReady> -->
			<buttonText>YFLARE</buttonText>
			<tooltip>[COOLDOWN:9s -20HP]
				Starts a fire in a random room on both ships.
			</tooltip>
			<cooldownColor r="235" g="132" b="112"/>
			<selfHealth>-20</selfHealth>

			<event load="RK_FIREGHOST_FIRES"/>

			<!-- <temporaryEffect>
				<duration>15</duration>
				<cooldownColor r="198" g="198" b="198"/>
				<finishSounds>
					<finishSound>decloak</finishSound>
