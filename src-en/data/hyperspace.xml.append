	<!-- 
	******************************************************************************************************************
	JUDGES STUFF - end
	
	Mechanical stuff - start
	******************************************************************************************************************
	-->

	<!-- Makes Shipvore Ram not be disintegrated for 1 Full Power use. -->
	<mod-append:variable name="shipvore_ram_reinforcement" op="set" val="0"/>
	<!-- Keeps track of Persistence Shield SuperShields regeneration. Worked without this line, but can't hurt. -->
	<mod-append:variable name="rk_persistence_shield_capacitorneed" op="set" val="0"/>

	<!-- 
	******************************************************************************************************************
	Mechanical stuff - end

	Various stuff - start
	******************************************************************************************************************
	-->
	
	<mod:findName type="event" name="START_BEACON">
		<!-- This tells the game to give the hidden augment associated with your addon being installed to the player
			right at the beginning of the game. v5.5.1 IS THIS STILL A THING? -->
		<mod-append:hiddenAug>ADDON_INSTALLED_DJ0ZAUGMENTS</mod-append:hiddenAug>
	</mod:findName>
		
	<!-- Fix empty beacon "Use an augment" for MV 5.2.3+ and HS 1.0+.

	LIST_CHECK_AUGMENTS no longer in autoblueprints.xml.append (since HS v1.00 / MV v5.2.3) nor with a blueprintList type, 
	now in hyperspace.xml as a req list, inside the huge <events> tag.-->
	<mod:findName name = "LIST_CHECK_AUGMENTS">
		<mod-append:name>DJMOD_COMBAT_SHIPVORE_RAM</mod-append:name>
		<mod-append:name>RK_CREW_ARE_BOMBS_ON</mod-append:name>
		<mod-append:name>RK_LEAD_TITANS</mod-append:name>
		<mod-append:name>RK_PERSISTENCE_SHIELD</mod-append:name>
		
		<mod-append:name>RK_OWN_HARMONY_ANY</mod-append:name>

		<mod-append:name>DJMOD_COMBAT_SELF_FIRE_UPGRADABLE</mod-append:name>

		<mod-append:name>RK_BPS_SURVEYOR</mod-append:name>
    </mod:findName>

	<!-- FOR INTERNAL AUGMENTS -->
	<mod:findName type="req" name="LIST_UPG_ALL">
		<!-- REF Darkest Desires for MV 5.5.1
		<mod-append:name>DD_INTERNAL_AUGMENT1</mod-append:name> -->
		<mod-append:name>INTERNAL_RK_CALIBRATOR</mod-append:name>
		<mod-append:name>INTERNAL_RK_CHOKING_IS_FINE</mod-append:name>
		<mod-append:name>INTERNAL_DJMOD_DEMICLONER</mod-append:name>
		<mod-append:name>INTERNAL_DJMOD_MC_PARALYZER</mod-append:name>
		<mod-append:name>INTERNAL_RK_IN_FIRE_CREWBOOSTS</mod-append:name>
		<mod-append:name>INTERNAL_DJMOD_MC_IMMUNE_FROM_FIRE</mod-append:name>
	</mod:findName>

	<!-- 
	******************************************************************************************************************
	Various stuff - end
	
	Bluelist aka Blue Options stuff - Start
	******************************************************************************************************************
	-->

	<mod:findName type="req" name="BLUELIST_CREW_NO2">
		<mod-append:name>rk_weaponlike</mod-append:name>
		<mod-append:name>rk_fireghost</mod-append:name>
	</mod:findName>

	<mod:findName type="req" name="BLUELIST_CREW_STRONG">
		<mod-append:name>unique_rk_defromorius</mod-append:name>
	</mod:findName>
