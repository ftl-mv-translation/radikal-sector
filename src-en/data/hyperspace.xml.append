				If the countdown is interrupted by death, the ability will be cancelled. Cannot activate while stunned or teleporting.</tooltip>
			<effectAnim>duskbringer_detonation_anim</effectAnim>
			<animFrame followCrew="true">7</animFrame>
			<cooldownColor r="200" g="200" b="200"/>
			<activateWhenReady enemiesOnly="true">true</activateWhenReady>
			<friendlyFire>true</friendlyFire>
			<persDamage>2</persDamage>
			<statBoosts>
				<statBoost name="teleportMove">
					<boostType>SET</boostType>
					<value>false</value>
					<shipTarget>CURRENT_ROOM</shipTarget>
					<crewTarget>SELF</crewTarget>
					<duration>999999999</duration>
				</statBoost>
			</statBoosts>
			<selfHealth>-999999</selfHealth>
		</powerEffect> -->

		<passiveStatBoosts>
			<statBoost name="statBoost">
				<statBoost name="canMove">
                    <boostType>SET</boostType>
                    <value>true</value>
                    <shipTarget>CURRENT_ROOM</shipTarget>
                    <crewTarget>ALLIED</crewTarget>
                    <priority>0</priority>
					<whiteList>
						<rk_bottledoxygen/>
					</whiteList>
                </statBoost>
				<shipTarget>CURRENT_ROOM</shipTarget>
                <crewTarget>ALLIED</crewTarget>
				<affectsSelf>false</affectsSelf>
				<!-- Fixes "Can move with just friendly bottles in room" -->
				<blackList>
					<rk_bottledoxygen/>
				</blackList>
			</statBoost>
			<!-- Fixes "still can't move with allied crew in room" -->
			<statBoost name="statBoost">
