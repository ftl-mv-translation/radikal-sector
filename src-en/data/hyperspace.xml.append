<!--
////////////////////////////////////////////////////////////////////////////////////////////////////
////////////////////////////////////////////////////////////////////////////////////////////////////
//////////////AUGMENT EFFECTS based on HARDCODE or HYPERSPACE statBoosts
////////////////////////////////////////////////////////////////////////////////////////////////////
////////////////////////////////////////////////////////////////////////////////////////////////////
-->

<augments>
	
	<aug name="LOCKED_DJMOD_COMBAT_SHIPVORE_RAM">
    	<locked/>
		<function name="ROCK_ARMOR" value="0.09" useForReqs="false" warning="false"/>
		<function name="SHIELD_RECHARGE" value="0.09" useForReqs="true" warning="false"/>
    </aug>

	<!-- Lead Titans gives
	x2 crew slot WORK - try 1.5 too TEST
	Breaches while walking WORKS but inconsistent - TEST lower cooldown.
	Stat bonuses WORK
	-->
	<aug name="DJMOD_LEAD_TITANS">
		<statBoosts>

			<statBoost name="powerEffect">
				<boostType>ADD</boostType>
				<powerEffect>
					<activateWhenReady>true</activateWhenReady>
					<jumpCooldown>continue</jumpCooldown>
					<hideCooldown>true</hideCooldown>
					<disabledCooldown>pause</disabledCooldown>
					<initialCooldownFraction>0</initialCooldownFraction>
					<onDeath>cancel</onDeath>
					<cooldown>0.45</cooldown>

					<buttonText>WALKBREACH</buttonText>
					<tooltip>SHOULD NEVER BE SEEN, opens breach while walking.</tooltip>
					<cooldownColor r="172" g="210" b="112"/>
					<friendlyFire>true</friendlyFire>
					<shipFriendlyFire>true</shipFriendlyFire>
					<damage>0</damage>
					<breachChance>10</breachChance>
				</powerEffect>

				<!-- REFS MV v5.5.1: phantom_mare_alpha and the lab.
				<powerEffect>
					<chargeReq>
						<maxHealth>109</maxHealth>
					</chargeReq>
					<cooldown>13</cooldown>
					<jumpCooldown>continue</jumpCooldown>
					<buttonText>CORRODE</buttonText>
					<tooltip>Opens a breach in the current room.</tooltip>
					<cooldownColor r="172" g="210" b="112"/>
					<activateWhenReady>true</activateWhenReady>
					<breachChance>10</breachChance>
					<shipFriendlyFire>true</shipFriendlyFire>
				</powerEffect>
				
				LAB_VAGABOND_STABLE
				<powerEffect>
					<cooldown>20</cooldown>
					<jumpCooldown>continue</jumpCooldown>
					<buttonText>CORRODE</buttonText>
					<tooltip>[COOLDOWN:20s]
						Opens a breach in the current room.</tooltip>
					<cooldownColor r="172" g="210" b="112"/>
					<breachChance>10</breachChance>
					<shipFriendlyFire>true</shipFriendlyFire>
				</powerEffect> -->
				<shipTarget>ALL</shipTarget>
                <crewTarget>ORIGINAL_ALLIES</crewTarget>
				<whiteList load="RK_LIST_LEAD_TITANS"/>
				<extraConditions type="and">             
					<moving>true</moving>
				</extraConditions>
			</statBoost>
			
			<statBoost name="crewSlots">
				<boostType>MULT</boostType>
				<amount>2</amount>
				<shipTarget>ALL</shipTarget>
				<crewTarget>ORIGINAL_ALLIES</crewTarget>
				<whiteList load="RK_LIST_LEAD_TITANS"/>
			</statBoost>

			<statBoost name="allDamageTakenMultiplier">
				<boostType>MULT</boostType>
				<amount>0.5</amount>
				<shipTarget>ALL</shipTarget>
				<crewTarget>ORIGINAL_ALLIES</crewTarget>
				<droneTarget>CREW</droneTarget>
				<affectsSelf>true</affectsSelf>
				<!-- <boostAnim>energy_shield_buff</boostAnim> -->
				<boostAnim>rk_lead_titans_buff</boostAnim>
				<whiteList load="RK_LIST_LEAD_TITANS"/>
			</statBoost>
			<statBoost name="stunMultiplier">
				<boostType>MULT</boostType>
				<amount>0.5</amount>
				<shipTarget>ALL</shipTarget>
				<crewTarget>ORIGINAL_ALLIES</crewTarget>
				<droneTarget>CREW</droneTarget>
				<whiteList load="RK_LIST_LEAD_TITANS"/>
			</statBoost>
			
			<statBoost name="damageMultiplier">
				<boostType>MULT</boostType>
				<amount>3.0</amount>
				<shipTarget>ALL</shipTarget>
				<crewTarget>ORIGINAL_ALLIES</crewTarget>
				<droneTarget>CREW</droneTarget>
				<whiteList load="RK_LIST_LEAD_TITANS"/>
			</statBoost>
			<statBoost name="doorDamageMultiplier">
				<boostType>MULT</boostType>
				<amount>3.0</amount>
				<shipTarget>ALL</shipTarget>
				<crewTarget>ORIGINAL_ALLIES</crewTarget>
				<droneTarget>CREW</droneTarget>
				<whiteList load="RK_LIST_LEAD_TITANS"/>
			</statBoost>
			<statBoost name="sabotageSpeedMultiplier">
				<boostType>MULT</boostType>
				<amount>3.0</amount>
				<shipTarget>ALL</shipTarget>
				<crewTarget>ORIGINAL_ALLIES</crewTarget>
				<droneTarget>CREW</droneTarget>
				<whiteList load="RK_LIST_LEAD_TITANS"/>
			</statBoost>

			<statBoost name="repairSpeed">
				<boostType>MULT</boostType>
				<amount>1.4</amount>
				<shipTarget>ALL</shipTarget>
				<crewTarget>ORIGINAL_ALLIES</crewTarget>
				<droneTarget>CREW</droneTarget>
				<whiteList load="RK_LIST_LEAD_TITANS"/>
			</statBoost>
			<statBoost name="moveSpeedMultiplier">
				<boostType>MULT</boostType>
				<amount>1.4</amount>
				<shipTarget>ALL</shipTarget>
				<crewTarget>ORIGINAL_ALLIES</crewTarget>
				<droneTarget>CREW</droneTarget>
				<whiteList load="RK_LIST_LEAD_TITANS"/>
			</statBoost>
		</statBoosts>
    </aug>
	
	<!-- Zoltan shield extractor. 
	Give 1 supershield (WORKS), 
	can be replaced by a normal Zoltan Shield from the default Zoltan crewkill (TEST).

	REFS MV 5.5.1:

	 <aug name="ENERGY_SHIELD">				The default one, and only one sold in the Nexus.
    	<icon>icon_zoltan_shield</icon>
    </aug>
	<aug name="LOCKED_ENERGY_SHIELD">
    	<function name="ENERGY_SHIELD" value="2" stackable="false" useForReqs="true" warning="false"/>
		<locked/>
    </aug>

	<aug name="SYLVAN_SHIELD">				From killing Sylvan.
		<function name="SYLVAN_SHIELD_REWARD" useForReqs="true" stackable="false" warning="false"/>
		<function name="ENERGY_SHIELD" value="0" useForReqs="true" stackable="false"/>
		<superShield>
			<value>12</value>
			<color r="175" g="58" b="165" a="1.0"/>
			<shieldImage>ship/enemy_shields_white.png</shieldImage>
		</superShield>
		<icon>icon_zoltan_shield</icon>
    </aug>
	<aug name="LOCKED_SYLVAN_SHIELD">
		<function name="SYLVAN_SHIELD_REWARD" useForReqs="true" stackable="false" warning="false"/>
		<function name="ENERGY_SHIELD" value="0" useForReqs="true" stackable="false"/>
		<superShield>
			<value>12</value>
			<color r="175" g="58" b="165" a="1.0"/>
			<shieldImage>ship/shield_base_bubble_white.png</shieldImage>
		</superShield>
		<icon>icon_zoltan_shield</icon>
		<locked/>
    </aug>
	<aug name="SYLVAN_SHIELD_REWARD">
		<superShield>
			<value>12</value>
			<color r="175" g="58" b="165" a="1.0"/>
			<shieldImage>ship/shield_base_bubble_white.png</shieldImage>
		</superShield>
    </aug>
	-->
	<aug name="DJMOD_ZOLTAN_SHIELD_EXTRACTOR">
		<function name="SYLVAN_SHIELD_REWARD" useForReqs="false" stackable="false" warning="false"/>
