	<splitVictoryAchievement>true</splitVictoryAchievement>
	<!-- type is the unlock method 
	(0 = beat flagship, 1 = reach sector, 2 = any victory, 3 = other ship unlocks, 4 = for event unlocks, 5 = other ship victories)
	shipReq is the ship that you have to do it with to unlock it
	value is only used for 'reach sector' currently which defines which sector the player has to reach -->
