	<!-- Flammabilizer 
	5.5.1 REVIVAL: See the weapon in the Collector's Outcast cruiser from TRC, which also removes fire immunity.

	making all enemy types BURNABLE AT ALL (WORKS)
	scaling with power in the Oxygen system (WORKS)
	Console (press L) "EVENT ROCK_ATHEIST" for quick testing!
	NB: it counters Scorched Earth's resistance but not the heal and other boosts, as intended.
	-->

	<aug name="RK_ENEMIES_CAN_BURN">
    	<statBoosts>
			<!-- ************************ 
			For this toggle mode only
			************************ -->
			
			<!-- Make sure they can burn at all. Check priority. -->
			<statBoost name="canBurn">
				<boostType>SET</boostType>
				<shipTarget>ALL</shipTarget>
				<crewTarget>ENEMIES</crewTarget>
				<droneTarget>ALL</droneTarget>
				<value>true</value>
				<priority>-987654</priority>
				<boostAnim>rk_enemies_can_burn_debuff</boostAnim>
			</statBoost>
			
			<!-- Cap res of all enemies. In other words, floor their vulnerability. Already vulnerables are unchanged. -->
			<statBoost name="fireDamageMultiplier">
				<!-- <boostType>MIN</boostType> MIN definitely picks the lower value : 0.00 made all enemies immune to fire.-->
				<boostType>MAX</boostType>
				<amount>1.00</amount>
				<!-- <amount>0</amount> -->
				<shipTarget>ALL</shipTarget>
				<crewTarget>ENEMIES</crewTarget>
				<droneTarget>ALL</droneTarget>
				<!-- <priority>-9876543210</priority>		Seems to error on game startup. -->
				<priority>-987654321</priority>
				<systemRoomTarget>ALL</systemRoomTarget>
				<!-- <systemList>
					<all/>
				</systemList>
				<systemPowerDependency>
					<oxygen/>
				</systemPowerDependency>
				<systemPowerScaling>
					<noSys>0.10</noSys>
					<noPwr>0.10</noPwr>
					<onePwr>0.25</onePwr>
					<twoPwr>0.45</twoPwr>
					<threePwr>0.70</threePwr>
					<morePwr>1.00</morePwr>
				</systemPowerScaling> -->
			</statBoost>

			<!-- ************************ 
			Both toggle modes have this below - NOT SUPPOSED TO STACK.
			************************ -->
			
			<statBoost name="moveSpeedMultiplier" save="RK_O2_SCALING_SLOW_IN_FIRE">
				<boostType>MULT</boostType>
				<shipTarget>ALL</shipTarget>
				<crewTarget>ENEMIES</crewTarget>
				<droneTarget>ALL</droneTarget>

				<maxStacks>1</maxStacks>

				<amount>0.20</amount>						<!-- A MULT boostType of 1.0 is unscalable! except by 0, which disables it. -->
				<priority>-200</priority>
				<!-- Current room is on fire. -->
				<extraConditions type="and">             
					<burning>true</burning>                 
				</extraConditions>
				<systemRoomTarget>ALL</systemRoomTarget>
				<systemList>
					<all/>
				</systemList>
				<systemPowerDependency>
					<oxygen/>
				</systemPowerDependency>
				<systemPowerScaling>
					<!-- RETEST - WORKS - NB: at <threePwr>1.00</threePwr> the <amount>0.5</amount> is fully applied!
					</systemPowerScaling> can be COUNTER-INTUITIVE, make sure to check my reference.-->
					<noSys>0.25</noSys>
					<noPwr>0.25</noPwr>
					<onePwr>0.50</onePwr>
					<twoPwr>0.75</twoPwr>
					<!-- <threePwr>0.75</threePwr> -->
					<threePwr>1.00</threePwr>
					<!--<morePwr>1.00</morePwr> intended value here, test value below-->
					<morePwr>1.00</morePwr>
					<!--<morePwr>3.00</morePwr> makes them walk backwards! Probably means the MULT is interpreted as "remove 0.5 MS from enemy", so with x3.0 effect that's "1.0 (base) - 1.5 = -0.5 MS" !
					Sadly that makes them stuck in doorways, and moonwalk out of the ship when they die sometimes...-->
				</systemPowerScaling>
			</statBoost>
		</statBoosts>
		<icon>rk_icon_enemies_can_burn</icon>
    </aug>

	<!-- Flammabilizer making burnable enemy types MORE BURNABLE (WORKS!)
	scaling with power in the Oxygen system (WORKS!) -->
	<aug name="RK_ENEMIES_BURN_MORE">
		<statBoosts>
			<!-- ************************ 
			For this toggle mode only
			************************ -->
			
			<statBoost name="fireDamageMultiplier">
				<boostType>MULT</boostType>
				<shipTarget>ALL</shipTarget>
				<crewTarget>ENEMIES</crewTarget>
				<droneTarget>CREW</droneTarget>
				<amount>10.0</amount>
				<priority>0</priority>
				<boostAnim>rk_enemies_burn_more_debuff</boostAnim>
				<systemRoomTarget>ALL</systemRoomTarget>
				<systemList>
					<all/>
				</systemList>
				<systemPowerDependency>
					<oxygen/>
				</systemPowerDependency>
				<systemPowerScaling>
					<noSys>0.160</noSys>
					<noPwr>0.160</noPwr>
					<onePwr>0.220</onePwr>
					<twoPwr>0.280</twoPwr>
					<threePwr>0.340</threePwr>
					<!-- <morePwr>0.400</morePwr> intended value here, test value below-->
					<morePwr>0.400</morePwr>
				</systemPowerScaling>
			</statBoost>
			
			<!-- ************************ 
			Both toggle modes have this below
			************************ -->

			<statBoost name="moveSpeedMultiplier" load="RK_O2_SCALING_SLOW_IN_FIRE"/>
			<!-- REF: LASER_BIO. the effects are first saved in an unobtainable dummy weapon with no name!
			<statBoosts>
				<statBoost name="moveSpeedMultiplier" load="RAD_MOVE"/>
				<statBoost name="stunMultiplier" load="RAD_STUN"/>
				<statBoost name="repairSpeed" load="RAD_REPAIR"/>
			</statBoosts> -->
		</statBoosts>
		<icon>rk_icon_enemies_burn_more</icon>
    </aug>


	<!-- Defense Kits
	Gives repair speed (WORKS)
	and CDR (WORKS but power creep)
	and speed in every player ship room (WORKS)
	and healing at rest (WORKS)
	-->
	<aug name="RK_SUPER_DEFENDERS">
		<statBoosts>
			<statBoost name="damageTakenMultiplier">
				<boostType>MULT</boostType>
				<shipTarget>ORIGINAL_SHIP</shipTarget>
				<crewTarget>ORIGINAL_ALLIES</crewTarget>
				<droneTarget>CREW</droneTarget>
				<amount>0.75</amount>
				<priority>0</priority>
			</statBoost>
			
			<statBoost name="repairSpeed">
				<boostType>MULT</boostType>
				<shipTarget>ORIGINAL_SHIP</shipTarget>
				<crewTarget>ORIGINAL_ALLIES</crewTarget>
				<droneTarget>CREW</droneTarget>
				<amount>1.3</amount>
				<priority>0</priority>
			</statBoost>
			<!--DISABLED FOR BALANCE
			<statBoost name="powerRechargeMultiplier">
				<boostType>MULT</boostType>
				<shipTarget>ORIGINAL_SHIP</shipTarget>
				<crewTarget>ORIGINAL_ALLIES</crewTarget>
				<droneTarget>CREW</droneTarget>
				<amount>1.3</amount>
				<priority>0</priority>
			</statBoost>
			-->
			<statBoost name="moveSpeedMultiplier">
				<boostType>MULT</boostType>
				<amount>1.3</amount>
				<shipTarget>ORIGINAL_SHIP</shipTarget>
				<crewTarget>ORIGINAL_ALLIES</crewTarget>
				<droneTarget>CREW</droneTarget>
				<priority>999</priority>
			</statBoost>
			
			<!-- At rest stats. -->
			<statBoost name="healAmount">
				<boostType>FLAT</boostType>
				<shipTarget>ORIGINAL_SHIP</shipTarget>
				<crewTarget>ORIGINAL_ALLIES</crewTarget>
				<droneTarget>CREW</droneTarget>
				<amount>4.0</amount>
				<priority>0</priority>
				
				<extraConditions type="and">
					<idle>true</idle>				<!-- Crew not busy (not moving, fighting, or repairing; manning is separate). -->
					<manning>false</manning>
				</extraConditions>
			</statBoost>
		</statBoosts>
		<icon>rk_icon_super_defenders</icon>
    </aug>


	<!-- Demicloners aka half-cloner aka demoting-cloner. (about 3100 lines, minimize if not interested).
	Instantly spawn non-temporary, clonable crew on-death. WORKS
	Crew has 1 less "training tier". WORKS
	Anywhere on player ship, not just inside that medbay. WORKS
	Dependent on NOT having CloneBay. WORKS, with <systemPowerScaling>'s <noSys>1</noSys> and the other ones 0.
	NOT dependant on Medbay, for compatibility with any modded systems.

	REFS MV v5.5.1:

	<aug name="DEATH_VESTS">
		<statBoosts>
			<statBoost name="deathEffect">
				<boostType>ADD</boostType>
				<deathEffect>
					<persDamage>1</persDamage>
					<friendlyFire>false</friendlyFire> 
					<fireChance>5</fireChance>
				</deathEffect>
				<shipTarget>ALL</shipTarget>
				<crewTarget>ALLIES</crewTarget>
				<droneTarget>CREW</droneTarget>
				<blackList>
					<zoltan_osmian_hologram/>
					<hologram/>
					<bucket/>
					<eldritch_cat/>
					<eldritch_thing/>
					<eldritch_thing_weak/>
					<gnome/>
					<repair/> 		TRC
				</blackList>
				...

	<aug name="UPG_MEDBAY_NANO">
		<function name="NANO_MEDBAY" value="0" useForReqs="true" warning="false"/>
		<statBoosts>
			<statBoost name="healAmount">
				<boostType>FLAT</boostType>
				<shipTarget>ORIGINAL_SHIP</shipTarget>
				<crewTarget>ALLIES</crewTarget>
				<droneTarget>CREW</droneTarget>
				<amount>1.6</amount>
				<priority>0</priority>
				<systemPowerDependency>
					<medbay/>
				</systemPowerDependency>
				<systemPowerScaling>
					<noSys>0</noSys>
					<noPwr>0</noPwr>
					<onePwr>1</onePwr>
					<twoPwr>1.5</twoPwr>
					<threePwr>3</threePwr>
					<fourPwr>6</fourPwr>
				</systemPowerScaling>
				<systemRoomTarget>NONE</systemRoomTarget>
				<systemList>
					<medbay/>
				</systemList>
			</statBoost>
			...

	<aug name="EX_MEDBAY_RESISTANCE">
		<statBoosts>
			<statBoost name="canBurn">
				<boostType>SET</boostType>
				<shipTarget>ORIGINAL_SHIP</shipTarget>
				<crewTarget>ALLIES</crewTarget>
				<droneTarget>CREW</droneTarget>
				<value>false</value>
				<priority>999</priority>
				<systemRoomTarget>ALL</systemRoomTarget>
				<systemList>
				  	<medbay/>
				</systemList>
			</statBoost>
			...


	REFS Darkest Desire for MV v5.5.1:
				<deathEffect>
					<spawnCrew>
						<race>ddtempest_blight_guardian_seed</race>
