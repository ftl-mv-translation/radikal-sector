		<unlock variant="b" silent="false">
            <type>5</type>
            <victories>
				<victory>PLAYER_SHIP_DJMOD_PUNKER</victory>
			</victories>
			<silent/>
        </unlock>
	</mod-append:ship>
	<mod-append:customShip name="PLAYER_SHIP_DJMOD_PUNKER">
		<hiddenAug>SHIP_PIRATE</hiddenAug>
		<hiddenAug>FOR_MULTIVERSE</hiddenAug>
		<crewLimit>9</crewLimit>
		<systemLimit>9</systemLimit>
		<crew>
