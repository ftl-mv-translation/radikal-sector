				</extraConditions>
			</statBoost>

			<statBoost name="canFight">
				<boostType>SET</boostType>
				<value>false</value>
				<shipTarget>ALL</shipTarget>
				<crewTarget>ORIGINAL_ALLIES</crewTarget>
				<droneTarget>CREW</droneTarget>
				<priority>-9876</priority>

				<extraConditions type="and">             
					<mindControlled>true</mindControlled>
				</extraConditions>
			</statBoost>
		</statBoosts>
	</aug>


	<aug name="INTERNAL_DJMOD_MC_IMMUNE_FROM_FIRE">
		<statBoosts>
			<statBoost name="resistsMindControl">
				<boostType>SET</boostType>
				<value>TRUE</value>
				<shipTarget>ALL</shipTarget>
				<!-- <crewTarget>ALLIES</crewTarget> -->
				<crewTarget>ORIGINAL_ALLIES</crewTarget>
				<droneTarget>CREW</droneTarget>
				<!-- <priority>-1000</priority> -->
