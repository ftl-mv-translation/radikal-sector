<mod:findLike type="achievements" limit="1">
	<mod-append:page>
		<section text="RadiKal Events" hidden="false">
			<achievement name="ACH_RK_EVENT_HIDEOUT">
				<name>RadiKal Hideout</name>
				<secretName>???</secretName>
				<description>Take a deal with an eldritch deity to get your own place in the RadiKal Sector.</description>
				<secretDescription>Get involved with dark forces for comfort.</secretDescription>
				<icon>ach_rk_event_hideout</icon>
				<lockImage>ach_locked</lockImage>
			</achievement>

			<achievement name="ACH_RK_EVENT_DEFROMORIUS">
				<name>Tormented Amalgam</name>
				<secretName>???</secretName>
				<description>Rescue RK Defromorius from suffocating to death in space.</description>
				<secretDescription>Rescue a strange RK sector creature.</secretDescription>
				<!-- <header id="text_id">text</name> (if set, will play the ship unlock sound unless <sound> is specified) -->
				<icon>ach_rk_event_defromorius</icon>
				<lockImage>ach_locked</lockImage>
				<!-- 
				<variable name="varname" amount="100"/> (name of variable or meta-variable to track, optional)
				<hidden/> (don't show achievement on stats if locked)
				<multiDifficulty>true</multiDifficulty> (if true display the achieved difficulty, if false then don't)
				<sound>sound_id</sound> (replace the achievement sound with a custom sound) 
				-->
			</achievement>

			<achievement name="ACH_RK_EVENT_HACK_FLEET_BOSS_REBEL">
				<name>Fleet Hacker</name>
				<secretName>???</secretName>
				<description>Draw the attention of the Hacker MFK with Enigmashin, then defeat it.</description>
				<secretDescription>Abuse the fleet and deal with the consequences.</secretDescription>
				<icon>ach_rk_event_hack_fleet_boss_rebel</icon>
				<lockImage>ach_locked</lockImage>
				<multiDifficulty>true</multiDifficulty>
			</achievement>
			<achievement name="ACH_RK_EVENT_SHIPVORE_RAM_SCRAP">
				<name>Scrapvore Ram</name>
				<secretName>???</secretName>
				<description>Get a huge and very rare scrap payout from Shipvore Ram.</description>
