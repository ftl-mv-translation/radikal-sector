	</aug>

	<!-- Dread deck gives:
	Invaders take more damage on this ship: WORKS
	allies clone faster and lose no skills: WORKS
	allies heal faster or better: WORKS 
	crew in same room as any crew of this ship heal slower, non-stacking: IT'S STACKING
	crew in same room as any crew of this ship cant be cloned: WORKS
	-->
	<aug name="RK_DREAD_DECK">
		<statBoosts>
			<!-- intended: 1.7x -->
			<statBoost name="allDamageTakenMultiplier">
				<boostType>MULT</boostType>
				<shipTarget>ORIGINAL_SHIP</shipTarget>
				<crewTarget>ENEMIES</crewTarget>
				<droneTarget>ALL</droneTarget>
				<amount>1.7</amount>
				<priority>0</priority>
				<!-- Unfortunately debuff animation always shows, condition met or not -->
                <!-- <systemPowerDependency>
                    <engines/>
                </systemPowerDependency>
                <systemPowerScaling>
                    <noSys>1</noSys>
                    <hackedSys>1</hackedSys>
                    <noPwr>1</noPwr>
                    <onePwr>0</onePwr>
                    <twoPwr>0</twoPwr>
                    <threePwr>0</threePwr>
                    <morePwr>0</morePwr>
                </systemPowerScaling> -->
			</statBoost>

			<!-- WORKS. intended: 2x -->
			<statBoost name="cloneSpeedMultiplier">
				<boostType>MULT</boostType>
				<amount>2</amount>
				<shipTarget>ALL</shipTarget>
				<!-- <shipTarget>ORIGINAL_SHIP</shipTarget>		NO WORK, it's like in-clonings are on a different ship! -->
				<crewTarget>ALLIES</crewTarget>
				<droneTarget>CREW</droneTarget>
				<priority>9999</priority>
			</statBoost>

			<!-- WORKS -->
			<statBoost name="cloneLoseSkills">
				<boostType>SET</boostType>
				<value>false</value>
				<shipTarget>ALL</shipTarget>
				<!-- <crewTarget>SELF</crewTarget>				NO WORK -->
				<crewTarget>ALLIES</crewTarget>
				<affectsSelf>false</affectsSelf>
				<priority>0</priority>
			</statBoost>
			<!-- REF: MV v5.5.1's JUDGE_BOON_UNIQUE
			<statBoost name="cloneLoseSkills">
				<boostType>SET</boostType>
				<value>false</value>
				<shipTarget>ALL</shipTarget>
				<crewTarget>ALLIES</crewTarget>
				<priority>0</priority>
				<whiteList load="LIST_CREW_UNIQUE"/>
			</statBoost> -->

			<!-- WORKS. intended: 2.5x -->
			<statBoost name="healSpeed">
				<boostType>MULT</boostType>
				<shipTarget>ORIGINAL_SHIP</shipTarget>
				<crewTarget>ORIGINAL_ALLIES</crewTarget>
				<droneTarget>CREW</droneTarget>
				<amount>2.5</amount>
				<priority>9999</priority>
			</statBoost>
			<!-- WORKS but NOT ON MEDIC HEAL. NOTHING DOES. intended: 2.5x -->
			<statBoost name="persHealMultiplier">
				<boostType>MULT</boostType>
				<shipTarget>ORIGINAL_SHIP</shipTarget>
				<crewTarget>ORIGINAL_ALLIES</crewTarget>
				<droneTarget>CREW</droneTarget>
				<amount>2.5</amount>
				<priority>0</priority>
			</statBoost>
			
			<!-- REF: MV v5.5.1's human_legion
			<statBoost name="statBoost">
				<statBoost name="damageTakenMultiplier">
                    <boostType>FLAT</boostType>
					<amount>-0.13</amount>
                    <shipTarget>CURRENT_ROOM</shipTarget>
                    <crewTarget>ENEMIES</crewTarget>
					<whiteList>
						<human_legion/>
					</whiteList>
                </statBoost>
				<shipTarget>CURRENT_ROOM</shipTarget>
				<crewTarget>ENEMIES</crewTarget>
				<maxStacks>1</maxStacks>
			</statBoost>

			REF: MV v5.5.1's unique_ivar
			<statBoost name="statBoost">
				<statBoost name="damageTakenMultiplier">
                    <boostType>MULT</boostType>
                    <amount>1.15</amount>
                    <shipTarget>CURRENT_ROOM</shipTarget>
					<crewTarget>ENEMIES</crewTarget>
					<droneTarget>CREW</droneTarget>
					<affectsSelf>false</affectsSelf>
					<priority>0</priority>
				</statBoost>
				<shipTarget>CURRENT_ROOM</shipTarget>
                <crewTarget>ALLIES</crewTarget>
				<droneTarget>CREW</droneTarget>
			</statBoost>
			-->
			<statBoost name="statBoost">
				<statBoost name="noClone">
                    <boostType>SET</boostType>
					<value>true</value>
                    <!-- <shipTarget>ALL</shipTarget> -->
					<shipTarget>CURRENT_ROOM</shipTarget>
                    <!-- <crewTarget>SELF</crewTarget> -->
					<!-- WORKS -->
					<!-- <crewTarget>ENEMIES</crewTarget> -->
					<crewTarget>ALL</crewTarget>
					<affectsSelf>false</affectsSelf>
					<!-- <priority>0</priority> -->
					 <boostAnim>rk_dread_deck_debuff</boostAnim>
					<maxStacks>1</maxStacks>
                </statBoost>
				
				<boostType>ADD</boostType>
				<shipTarget>CURRENT_ROOM</shipTarget>
				<crewTarget>ORIGINAL_ALLIES</crewTarget>
				<!-- <affectsSelf>false</affectsSelf> -->
				<maxStacks>1</maxStacks>
			</statBoost>

			<statBoost name="statBoost">
				<statBoost name="healSpeed">
					<boostType>MULT</boostType>
					<shipTarget>CURRENT_ROOM</shipTarget>
					<crewTarget>ALL</crewTarget>
					<droneTarget>CREW</droneTarget>
					<affectsSelf>false</affectsSelf>
					<amount>0.5</amount>
					<!-- <priority>9999</priority> -->
					<maxStacks>1</maxStacks>
				</statBoost>
				
				<boostType>ADD</boostType>
				<shipTarget>CURRENT_ROOM</shipTarget>
				<crewTarget>ORIGINAL_ALLIES</crewTarget>
				<maxStacks>1</maxStacks>
			</statBoost>
			<statBoost name="statBoost">
				<statBoost name="persHealMultiplier">
					<boostType>MULT</boostType>
					<shipTarget>CURRENT_ROOM</shipTarget>
					<crewTarget>ALL</crewTarget>
					<droneTarget>CREW</droneTarget>
					<affectsSelf>false</affectsSelf>
					<amount>0.5</amount>
					<maxStacks>1</maxStacks>
				</statBoost>
				
				<boostType>ADD</boostType>
				<shipTarget>CURRENT_ROOM</shipTarget>
				<crewTarget>ORIGINAL_ALLIES</crewTarget>
				<maxStacks>1</maxStacks>
			</statBoost>
		</statBoosts>
		<icon>icon_rk_dread_deck</icon>
	</aug>

