			This ship's crew resists fire, is boosted in it, and heals while extinguishing.</tooltip>
		</mod-append:shipIcon>
	</mod:findLike>
	
	<mod:findLike type="shipOrder">
        <mod-append:ship>PLAYER_SHIP_DJMOD_RAMMER</mod-append:ship>
        <mod-append:ship>PLAYER_SHIP_DJMOD_PUNKER</mod-append:ship>
        <mod-append:ship>PLAYER_SHIP_DJMOD_SCORCH</mod-append:ship>
