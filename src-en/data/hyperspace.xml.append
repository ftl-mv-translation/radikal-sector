			<shieldImage>ship/enemy_shields_white.png</shieldImage>
		</superShield>
		<icon>icon_zoltan_shield</icon>
    </aug> -->
	<aug name="RK_PERSISTENCE_SHIELD">
		<function name="ENERGY_SHIELD" value="0" useForReqs="true" warning="false"/>
		<function name="SHIELD_RECHARGE" value="0.25" useForReqs="true" warning="false" />
		<superShield>
			<value>0</value>
			<add>4</add>
			<color r="120" g="210" b="50" a="1" />
			<shieldImage>ship/enemy_shields_white.png</shieldImage>
		</superShield>
		<icon>rk_icon_persistence_shield</icon>
	</aug>

