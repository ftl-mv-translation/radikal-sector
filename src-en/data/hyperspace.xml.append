	<!-- Punk Harmony
	Makes engis uncontrollable (WORKS) 
	and was supposed to work on drones too (NOT WORK else it affects ALL CREW) but unnecessary. MV has auto drone toggle now.
	and Gives repair speed (WORKS)
	and damage taken reduc (WORKS)
	and speeds (WORKS) 
	and combat damage (WORKS)

	TODO: 
	-add upgrade that makes it work on both ships, needs Sensors 3.
	-make all Separatists event-traitor you unless you have Mind Control?
	-->
	<aug name="RK_OWN_HARMONY_ON">
		<statBoosts>

			<!-- AI -->
			<statBoost name="controllable">
				<boostType>SET</boostType>
				<value>FALSE</value>
				<shipTarget>ORIGINAL_SHIP</shipTarget>
				<crewTarget>ALLIES</crewTarget>
				<droneTarget>CREW</droneTarget>
				<priority>0</priority>
				<whiteList load="LIST_CREW_ENGI"/>
				<!-- <whiteList load="LIST_CREW_ENGI_EXCEPT_NANO"/> This was the bug, the whitelist doesn't work properly. -->
			</statBoost>
			
			<statBoost name="resistsMindControl">
				<boostType>SET</boostType>
				<value>TRUE</value>
				<shipTarget>ORIGINAL_SHIP</shipTarget>
				<crewTarget>ALLIES</crewTarget>
				<droneTarget>CREW</droneTarget>
				<priority>-1000</priority>
				<whiteList load="LIST_CREW_ENGI"/>
			</statBoost>
			
			<!-- Harder -->
			<statBoost name="damageTakenMultiplier">
				<boostType>MULT</boostType>
				<shipTarget>ORIGINAL_SHIP</shipTarget>
				<crewTarget>ALLIES</crewTarget>
				<droneTarget>CREW</droneTarget>
				<amount>0.60</amount>
				<priority>0</priority>
				<whiteList load="LIST_CREW_ENGI"/>
			</statBoost>
			<statBoost name="fireDamageMultiplier">
				<boostType>MULT</boostType>
				<shipTarget>ORIGINAL_SHIP</shipTarget>
				<crewTarget>ALLIES</crewTarget>
				<droneTarget>CREW</droneTarget>
				<amount>0.60</amount>
				<priority>0</priority>
				<whiteList load="LIST_CREW_ENGI"/>
			</statBoost>
			<statBoost name="suffocationModifier">
				<boostType>MULT</boostType>
				<shipTarget>ORIGINAL_SHIP</shipTarget>
				<crewTarget>ALLIES</crewTarget>
				<droneTarget>CREW</droneTarget>
				<amount>0.60</amount>
				<priority>0</priority>
				<whiteList load="LIST_CREW_ENGI"/>
			</statBoost>
			<statBoost name="stunMultiplier">
				<boostType>MULT</boostType>
				<shipTarget>ORIGINAL_SHIP</shipTarget>
				<crewTarget>ALLIES</crewTarget>
				<droneTarget>CREW</droneTarget>
				<amount>0.60</amount>
				<priority>0</priority>
				<whiteList load="LIST_CREW_ENGI"/>
			</statBoost>
			
			<!-- Better. Exponential scaling. -->
			<statBoost name="repairSpeed">
				<boostType>MULT</boostType>
				<shipTarget>ORIGINAL_SHIP</shipTarget>
				<crewTarget>ALLIES</crewTarget>
				<droneTarget>CREW</droneTarget>
				<amount>1.05</amount>
				<priority>0</priority>
				<whiteList load="LIST_CREW_ENGI"/>
				<systemPowerDependency>
					<mind/>
					<hacking/>
				</systemPowerDependency>
				<systemPowerScaling>
					<noSys>0</noSys>
					<hackedSys>0</hackedSys>
					<noPwr>0</noPwr>
					<onePwr>1</onePwr>
					<twoPwr>2</twoPwr>
					<threePwr>4</threePwr>
					<fourPwr>8</fourPwr>
					<fivePwr>16</fivePwr>
					<sixPwr>32</sixPwr>
				</systemPowerScaling>
			</statBoost>
			
			<!-- Faster 
			REF:
			<aug name="UPG_MEDBAY_SPEED">
				<statBoosts>
					<statBoost name="moveSpeedMultiplier">
						<boostType>MULT</boostType>
						<shipTarget>ALL</shipTarget>
						<crewTarget>ALLIES</crewTarget>
						<droneTarget>CREW</droneTarget>
						<amount>1.25</amount>
						<priority>999</priority>
						<blackList>
							<human_technician_drone/>
							<zoltan_osmian_hologram/>
							<hologram/>
						</blackList>
						<systemPowerDependency>
							<medbay/>
						</systemPowerDependency>
						<systemPowerScaling>
							<noSys>0</noSys>
							<noPwr>0</noPwr>
							<onePwr>1</onePwr>
							<twoPwr>2</twoPwr>
							<threePwr>3</threePwr>
							<fourPwr>4</fourPwr>
						</systemPowerScaling>
					</statBoost>
				</statBoosts>
			</aug>
			-->

			<!-- Exponential scaling (except resistance). 
			Gives +160% at 6 power, not x33,6 which would look like instant movement. -->
			<statBoost name="moveSpeedMultiplier">
				<boostType>MULT</boostType>
				<amount>1.05</amount>
				<shipTarget>ORIGINAL_SHIP</shipTarget>
				<crewTarget>ALLIES</crewTarget>
				<droneTarget>CREW</droneTarget>
				<priority>0</priority>
				<whiteList load="LIST_CREW_ENGI"/>
				<systemPowerDependency>
					<mind/>
					<hacking/>
				</systemPowerDependency>
				<systemPowerScaling>
					<noSys>0</noSys>
					<hackedSys>0</hackedSys>
					<noPwr>0</noPwr>
					<onePwr>1</onePwr>
					<twoPwr>2</twoPwr>
					<threePwr>4</threePwr>
					<fourPwr>8</fourPwr>
					<fivePwr>16</fivePwr>
					<sixPwr>32</sixPwr>
				</systemPowerScaling>
			</statBoost>
			
			<!-- Stronger -->
			<statBoost name="damageMultiplier">
				<boostType>MULT</boostType>
				<shipTarget>ORIGINAL_SHIP</shipTarget>
				<crewTarget>ALLIES</crewTarget>
				<droneTarget>CREW</droneTarget>
				<amount>1.05</amount>
				<!-- <priority>0</priority> Overwritten to 1.0 by Combat Systems lab upgrade. -->
				<priority>9999</priority>
				<whiteList load="LIST_CREW_ENGI"/>
				<systemPowerDependency>
					<mind/>
					<hacking/>
				</systemPowerDependency>
				<systemPowerScaling>
					<noSys>0</noSys>
					<hackedSys>0</hackedSys>
					<noPwr>0</noPwr>
					<onePwr>1</onePwr>
					<twoPwr>2</twoPwr>
					<threePwr>4</threePwr>
					<fourPwr>8</fourPwr>
					<fivePwr>16</fivePwr>
					<sixPwr>32</sixPwr>
				</systemPowerScaling>
			</statBoost>
		</statBoosts>
		<icon>rk_icon_punk_harmony</icon>
    </aug>


	<!-- Charged Belts reducing own crew HP with a blacklist for the unaffected (WORKS)
 	and making crew deal system and hull damage on death (WORKS)
	with hullbust (WORKS)
	stacking with existing on-death effects, like DEATH_VESTS in MV 5.5.1 (WORKS).
	
	REFS:
	<clearDeathEvent name="LABEL"/>				Clears the deathEvent (either a given label, or all if not given). USE LABEL!
	-->
	<aug name="RK_CREW_ARE_BOMBS_ON">
		<statBoosts>
			<statBoost name="maxHealth">
				<boostType>MULT</boostType>
				<amount>0.90</amount>
				<shipTarget>ALL</shipTarget>
				<crewTarget>ALLIES</crewTarget>
				<droneTarget>CREW</droneTarget>
				<priority>0</priority>
			</statBoost>
			
			<!-- REF MV 5.5.1: updated Martyr Vests aka CURA's DEATH_VESTS
			<statBoost name="deathEffect">
				<boostType>ADD</boostType>
				<deathEffect>
					<persDamage>1</persDamage>
					<friendlyFire>false</friendlyFire> 
					<fireChance>5</fireChance>
				</deathEffect>
				<shipTarget>ALL</shipTarget>
                <crewTarget>ALLIES</crewTarget>
				<droneTarget>CREW</droneTarget>
				<blackList>
					<zoltan_osmian_hologram/>
					<hologram/>
					<bucket/>
					<eldritch_cat/>
					<eldritch_thing/>
					<eldritch_thing_weak/>
					<gnome/>
					<repair/>
				</blackList>
			</statBoost> -->
			<statBoost name="deathEffect">
				<boostType>ADD</boostType>
				<deathEffect>
					<damage>1</damage>
					<hullBust>true</hullBust>
					<shipFriendlyFire>true</shipFriendlyFire>	<!-- Can damage own ship -->
					<fireChance>100</fireChance>
				</deathEffect>
				<hasDeathExplosion>true</hasDeathExplosion>		<!-- Is invisible but spawning the fire is good enough VFX. -->
				<shipTarget>ALL</shipTarget>
                <crewTarget>ALLIES</crewTarget>
				<droneTarget>CREW</droneTarget>
				<blackList>
					<zoltan_osmian_hologram/>
					<hologram/>
					<bucket/>
					<eldritch_cat/>
					<eldritch_thing/>
					<eldritch_thing_weak/>
					<gnome/>
					<repair/>
				</blackList>
			</statBoost>
		</statBoosts>
    </aug>

	<aug name="RK_SCORCH_PREIGNITER">
		<!-- <function name="WEAPON_PREIGNITE" value="1" useForReqs="true"/>	Exploit: build Gatling without using this up -->
    	<function name="WEAPON_PREIGNITE" value="1" useForReqs="false"/>
		<!-- <function name="WEAPON_PREIGNITE" value="0.5" useForReqs="true"/> 	Exact same effect as value 1. -->
		<icon>rk_icon_scorch_preigniter</icon>
    </aug>

	<aug name="RK_WEAPONS_ON_FIRE">
		<function name="AUTO_COOLDOWN" value="0.25" useForReqs="true"/>
		<icon>rk_icon_weapons_on_fire</icon>
    </aug>
	<aug name="RK_WEAPONS_ON_FIRE_TEMP">
		<!-- intended: 0.01 -->
		<function name="AUTO_COOLDOWN" value="0.01" useForReqs="false"/>
    </aug>

	<!-- 
	//////////////////////////////////////////////////////////////////////////////////////////////////
	//////////////////////////////////////////////////////////////////////////////////////////////////
	////////////////		BPS augments 
	//////////////////////////////////////////////////////////////////////////////////////////////////
	//////////////////////////////////////////////////////////////////////////////////////////////////
	-->

	<aug name="RK_BPS_SHIELD_OVER_MATTER">
		<function name="ENERGY_SHIELD" value="0" useForReqs="true" warning="false"/>
		<!-- <function name="SHIELD_RECHARGE" value="0.25" useForReqs="true" warning="false" /> -->
		<superShield>
			<value>10</value>		<!-- intended: 10 -->
			<!-- <add>3</add> -->
			<color r="150" g="175" b="150" a="1" />
			<shieldImage>ship/enemy_shields_white.png</shieldImage>
		</superShield>
		<icon>rk_icon_persistence_shield</icon>
	</aug>

