	<!-- \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\ ENEMIES \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\
	renderlayers:
	0 - draws below everything including no o2 stripes, can't be seen when room has no vision
	1 - draws above o2 stripes but below crew, can't be seen when room has no vision
	2 - draws below crew but CAN be seen when room has no vision
	3 - draws above everything
	-->
	
	<mod-append:customShip name="DJMOD_RADIKAL_GUARD">
		<shipIcons>
			<shipIcon>icon_plasmateleporter</shipIcon>		
			<!-- Last one shows up topmost ingame. 
			Apparently augment icons are autogenerated for MV gear now. Just add the custom ones. -->
		</shipIcons>
	</mod-append:customShip>
	<mod-append:customShip name="DJMOD_RADIKAL_BOSS_SCORCH">
		<shipIcons>
			<shipIcon>icon_scorchself2</shipIcon>
		</shipIcons>
	</mod-append:customShip>
	<mod-append:customShip name="DJMOD_RADIKAL_BOSS_BAM">
		<shipIcons>
			<!-- <shipIcon>icon_scorchself2</shipIcon> put one for AERA 2nd Wind instead -->
		</shipIcons>
	</mod-append:customShip>
</mod:findLike>

