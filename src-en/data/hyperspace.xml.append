<mod:findLike type="ships" limit="1">
	<mod:findName type="customShip" name="CREW_SHIP_WITHER">
		<mod:findLike type="crew">
			<mod-append:trash_eater room="27" name="Trash Eater"/>
			<mod-append:scrapper_zog room="27" name="Zog"/>
			<mod-append:unique_black_rose room="26" name="Black Rose"/>
			<mod-append:sergal_cheese room="26" name="Cheese"/>
			<mod-append:protogen_tracker room="23" name="Tracker"/>
			<mod-append:primagen_raptor room="23" name="Raptor"/>
			<mod-append:protogen_pete room="15" name="Pete"/>
			<mod-append:clonefail_lancer room="15" name="Lancer"/>
			<mod-append:polyester room="24" name="Polyster"/>
			<mod-append:unique_skygirr room="24" name="Skygirr"/>
