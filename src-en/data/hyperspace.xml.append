<!-- Sniper girl (HARD DISTRESS). Fixed list of all mv-stealth (no cloak timer reduction while firing) MV and RK weapons,
plus any cloak-friendly/cloak-like augs. -->
<mod:findLike type="store">
	<mod-append:customStore id="STORE_RKS_SNIPER">
		
		<itemPurchaseLimit>3</itemPurchaseLimit>
		
