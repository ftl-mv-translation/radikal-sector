	<!-- 
	===================================================================================================
	Fake / Dummy crew
	===================================================================================================
	-->

	<mod-append:race name="rk_bottledoxygen">
		<noSlot>true</noSlot>
		<crewSlots>0</crewSlots>
		<noWarning>true</noWarning>
		<noClone>true</noClone>

		<canRepair>false</canRepair>
		<canFight>false</canFight>
		<canSabotage>false</canSabotage>
		<canMan>false</canMan>
		<canBurn>false</canBurn>
		<canSuffocate>false</canSuffocate>

		<canMove>false</canMove>
		<snapToSlot>true</snapToSlot>

		<!-- <validTarget>false</validTarget> 				Enemy crew can't target this. -->
		<validTarget>true</validTarget>
		<!-- <controllable>false</controllable>				Can't be selected either, unless that was from noSlot -->
		<controllable>true</controllable>
		<resistsMindControl>true</resistsMindControl>

		<maxHealth>50</maxHealth>
		<trueHealAmount>-1.0</trueHealAmount> 				<!-- Whatever creates it must still give it limited duration. -->
		<healSpeed>0.0</healSpeed>
		<persHealMultiplier>0.0</persHealMultiplier>
		<lowHealthThreshold>-1</lowHealthThreshold>
		<deathSounds>
			<deathSound>energyDeath</deathSound>
		</deathSounds>

		<moveSpeedMultiplier>0.75</moveSpeedMultiplier>
		<oxygenChangeSpeed>3.0</oxygenChangeSpeed>

		<powerEffect>
			<activateWhenReady>true</activateWhenReady>
			<jumpCooldown>continue</jumpCooldown>
			<hideCooldown>true</hideCooldown>
			<disabledCooldown>pause</disabledCooldown>
			<initialCooldownFraction>0</initialCooldownFraction>
			<onDeath>cancel</onDeath>
			<cooldown>0.9</cooldown>

			<hideButton>true</hideButton>
			<buttonText>LEAK AIR</buttonText>
			<tooltip>SHOULD NEVER BE SEEN, shows a cloud dissipating.</tooltip>
			<cooldownColor r="172" g="210" b="112"/>
			<friendlyFire>true</friendlyFire>
			<shipFriendlyFire>true</shipFriendlyFire>
			<damage>0</damage>
			<effectAnim>rk_bottledoxygen_charge</effectAnim>
		</powerEffect>

		<powerEffect>
			<cooldown>3</cooldown>
			<!-- <onDeath>cancel</onDeath> -->
			<onDeath>reset</onDeath>						<!-- Should allow it to complete while dying? -->
			<!-- <onDeath>continue</onDeath>			This is for crew who respawn. -->
			<!-- <jumpCooldown>reset</jumpCooldown> -->
			<jumpCooldown>continue</jumpCooldown>
			<req type="player">
				<minHealth>15</minHealth>
				<extraConditions type="or" textId="power_not_ready_teleporting_or_stunned">
					<!-- <stunned>false</stunned> -->
					<teleporting>false</teleporting>
				</extraConditions>
			</req>
			<req type="enemy">
				<minHealth>15</minHealth>
				<enemyInRoom/>
				<inCombat/>
				<extraConditions type="or" textId="power_not_ready_teleporting_or_stunned">
					<teleporting>false</teleporting>
				</extraConditions>
			</req>
			<buttonText>EXPLODE</buttonText>
			<tooltip>[COOLDOWN:3s]
				Explode for 30 crew damage to all crew in the room with a 60% chance to start a fire.
				Cannot activate while teleporting or under 15 Health.</tooltip>
			
			<effectAnim>explosion_random</effectAnim>
			<animFrame followCrew="true">-1</animFrame>
			<!-- <animFrame followCrew="true">7</animFrame> -->

			<cooldownColor r="200" g="200" b="200"/>
			<activateWhenReady enemiesOnly="true">true</activateWhenReady>
			<friendlyFire>true</friendlyFire>
			<shipFriendlyFire>true</shipFriendlyFire>
			<persDamage>2</persDamage>
			<fireChance>6</fireChance>
			<selfHealth>-999999</selfHealth>
		</powerEffect>
		<!-- REF: MV v5.5.1 Duskbringer aka zoltan_devotee
		<powerEffect>
			<cooldown>7</cooldown>
			<onDeath>cancel</onDeath>
			<jumpCooldown>reset</jumpCooldown>
			<powerSounds enemy="true">
				<powerSound>duskCountdown</powerSound>
			</powerSounds>
			<req type="player">
				<extraConditions type="or" textId="power_not_ready_teleporting_or_stunned">
					<stunned>false</stunned>
					<teleporting>false</teleporting>
				</extraConditions>
			</req>
			<req type="enemy">
				<enemyInRoom/>
