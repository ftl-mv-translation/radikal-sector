<!--
////////////////////////////////////////////////////////////////////////////////////////////////////
////////////////////////////////////////////////////////////////////////////////////////////////////
//////////////	AUGMENT EFFECTS based on HARDCODE or HYPERSPACE statBoosts
////////////////////////////////////////////////////////////////////////////////////////////////////
////////////////////////////////////////////////////////////////////////////////////////////////////
-->

<augments>
	
	<aug name="LOCKED_DJMOD_COMBAT_SHIPVORE_RAM">
    	<locked/>
		<function name="ROCK_ARMOR" value="0.09" useForReqs="false" warning="false"/>
		<function name="SHIELD_RECHARGE" value="0.09" useForReqs="true" warning="false"/>
    </aug>

	<aug name="INTERNAL_RK_CALIBRATOR">
		<!-- intended: 0.04 -->
		<function name="AUTO_COOLDOWN" value="0.04" useForReqs="false"/>
		<icon>icon_rk_calibrator</icon>
    </aug>

	<!-- Choking FINE gives:
	Slower choking: WORKS
	Higher stats while choking: WORKS
	Stacks with Internal: WORKS
	Lower stats while bored ABANDONED, avoids messing with immunes blacklists that may involve other add-ons.
	-->
	<aug name="EX_RK_CHOKING_IS_FINE">
		<statBoosts>
			<statBoost name="suffocationModifier">
				<boostType>MULT</boostType>
				<amount>0.75</amount>
				<shipTarget>ALL</shipTarget>
				<crewTarget>ORIGINAL_ALLIES</crewTarget>
				<droneTarget>CREW</droneTarget>
			</statBoost>

			<statBoost name="damageMultiplier">
				<boostType>MULT</boostType>
				<amount>1.5</amount>
				<shipTarget>ALL</shipTarget>
				<crewTarget>ORIGINAL_ALLIES</crewTarget>
				<droneTarget>CREW</droneTarget>

				<extraConditions type="or">
					<suffocating>true</suffocating>
				</extraConditions>
				<!-- Can both LIST and individually at once. REF: unique_obyn MV v5.5.1:
				<blackList load="LIST_CREW_OBYN">
					<blobsalt/>
				</blackList> -->
			</statBoost>
			<statBoost name="doorDamageMultiplier">
				<boostType>MULT</boostType>
				<amount>1.5</amount>
				<shipTarget>ALL</shipTarget>
				<crewTarget>ORIGINAL_ALLIES</crewTarget>
				<droneTarget>CREW</droneTarget>

				<extraConditions type="or">
					<suffocating>true</suffocating>
				</extraConditions>
			</statBoost>
			<statBoost name="sabotageSpeedMultiplier">
				<boostType>MULT</boostType>
				<amount>1.5</amount>
				<shipTarget>ALL</shipTarget>
				<crewTarget>ORIGINAL_ALLIES</crewTarget>
				<droneTarget>CREW</droneTarget>

				<extraConditions type="or">
					<suffocating>true</suffocating>
				</extraConditions>
			</statBoost>

			<statBoost name="repairSpeed">
				<boostType>MULT</boostType>
				<amount>1.5</amount>
				<shipTarget>ALL</shipTarget>
				<crewTarget>ORIGINAL_ALLIES</crewTarget>
				<droneTarget>CREW</droneTarget>

				<extraConditions type="or">
					<suffocating>true</suffocating>
				</extraConditions>
			</statBoost>
			<statBoost name="moveSpeedMultiplier">
				<boostType>MULT</boostType>
				<amount>1.5</amount>
				<shipTarget>ALL</shipTarget>
				<crewTarget>ORIGINAL_ALLIES</crewTarget>
				<droneTarget>CREW</droneTarget>

				<extraConditions type="or">
					<suffocating>true</suffocating>
				</extraConditions>
			</statBoost>
		</statBoosts>
		<icon>rk_icon_choking_is_fine</icon>
    </aug>
