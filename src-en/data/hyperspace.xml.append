<!-- Custom Races

\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\ Syntax \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\

<crew>
	(default human values v5.2.3)
	<race name="newRace">
		<canFight>true</canFight>
		<canRepair>true</canRepair>
		<canSuffocate>true</canSuffocate>
		<canSabotage>true</canSabotage>
		<canBurn>true</canBurn>
