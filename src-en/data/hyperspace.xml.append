<!--
REF: Bag of Dumb Fixed:
<mod:findLike type="events" limit="1">
	<mod-append:eventFile>mithra</mod-append:eventFile>
-->
<mod:findLike type="events" limit="1">
	<!-- 
	******************************************************************************************************************
	Sector stuff - start
	******************************************************************************************************************
	-->

	<!-- REF MV v5.5.1:
	<eventFile>sector_hektar</eventFile> -->
	<mod-append:eventFile>sector_radikal</mod-append:eventFile>	

	<!-- (As in) REF: Bag of Dumb Fixed for MV 5.5.1 -->
	<mod-append:variable name="coords_radikal" op="set" val="0"/>
	<mod:findName type="req" name="COORDS">
		<mod-append:name>coords_radikal</mod-append:name>
	</mod:findName>
	<!-- Can reroute to RKS on sector 7 exit: WORKS ONLY IF 2+ TOTAL COORDS!
	Seems one of them MUST be RK coords too? 
	Something must be missing or wrong. 
	TEST: Add the extra findLike as in DD.
	WORKS! YES!
	-->
	<mod:findName type="req" name="COORDS_BOSS">
		<!-- THE TAG BELOW FIXES "Can't reroute anywhere end of S7 without RKS coords +another coord" 
		 BY COUNTERING THE FACT THAT COORDS_BOSS is an "ALL" list, not an "ANY" list like "COORDS". -->
		<mod:findLike type="req" start="0" limit="1">
			<!-- <mod-append:name>coords_enlightened</mod-append:name> -->
			<mod-append:name>coords_radikal</mod-append:name>
		</mod:findLike>
	</mod:findName>
	<!-- This does the "There's no more time for other sectors!" at end of S8 REROUTE when you warp to Flasgship directly. -->
	<mod:findName type="req" name="COORDS_BOSS_TOOLATE">
		<mod:findLike type="req" start="0" limit="1">
			<mod-append:name>coords_radikal</mod-append:name>
		</mod:findLike>
	</mod:findName>
	
	<!-- COORDS_BOSS & COORDS_BOSS_TOOLATE are new in v5.5.1 (or at least, after v5.2.3) and in a sub-tag,
	  not directly in the coords block.
	UNNECESSARY - Bag Of Dumb Fixed (for MV 5.5.1) only does the name="COORDS" block above.
	
	Uncomment this to see if fixes S7 end reroute needing 2+ coords? I expect it to say you can't reroute instead.
	<mod:findName type="req" name="COORDS_BOSS_TOOLATE">
		<mod-append:name>coords_radikal</mod-append:name>
	</mod:findName>
	-->

	<!-- REF: Darkest Desire v4.1.4 for MV v5.5.1:

	<mod:findName type="req" name="COORDS">
		<mod-append:name>coords_enlightened</mod-append:name>
		<mod-append:name>coords_dddeepone</mod-append:name>
	</mod:findName>
	<mod:findName type="req" name="COORDS_BOSS">
		<mod:findLike type="req" start="0" limit="1">
			<mod-append:name>coords_enlightened</mod-append:name>
		</mod:findLike>
	</mod:findName>
	<mod:findName type="req" name="COORDS_BOSS_TOOLATE">
		<mod:findLike type="req" start="0" limit="1">
			<mod-append:name>coords_enlightened</mod-append:name>
		</mod:findLike>
	</mod:findName> -->

	<!-- Prevent return to sector to avoid crash. -->
	<mod-append:variable name="visited_radikal_sector" op="set" val="0"/>

	<!-- Labs progress. -->
	<mod-append:variable name="rks_lab_coords_bam" op="set" val="0"/>
	<mod-append:variable name="rks_lab_coords_punk" op="set" val="0"/>
	<mod-append:variable name="rks_lab_coords_scorch" op="set" val="0"/>

