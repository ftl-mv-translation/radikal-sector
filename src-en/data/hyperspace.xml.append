	<!-- <mod-append:ship name="PLAYER_SHIP_DJMOD_PUNKER" b="true" c="false" secret="true"> -->
	<mod-append:ship name="PLAYER_SHIP_DJMOD_PUNKER" a="true" b="true" c="false">
	<splitVictoryAchievement>true</splitVictoryAchievement>
	<!-- type is the unlock method 
	(0 = beat flagship, 1 = reach sector, 2 = any victory, 3 = other ship unlocks, 4 = for event unlocks, 5 = other ship victories)
	shipReq is the ship that you have to do it with to unlock it
	value is only used for 'reach sector' currently which defines which sector the player has to reach -->
		<unlock variant="a" silent="false">
			<type>1</type>
			<shipReq>PLAYER_SHIP_DJMOD_RAMMER</shipReq>
            <value>8</value>
		</unlock>
		<!-- you can also put multiple unlock methods which will let the player do ANY of them to unlock the ship -->
		<unlock variant="a" silent="false">
            <type>5</type>
            <victories>
				<victory>PLAYER_SHIP_DJMOD_SCORCH</victory>
				<!-- <victory type="flagship">PLAYER_SHIP_BAR</victory>      (specifically a flagship kill)
				<victory type="secretending">PLAYER_SHIP_BAZ</victory>  (specifically a custom victory of achievement type "secretending") -->
			</victories>
			<silent/>
        </unlock>

		<unlock variant="b" silent="false">
            <type>5</type>
            <victories>
				<victory>PLAYER_SHIP_DJMOD_PUNKER</victory>
			</victories>
			<silent/>
        </unlock>
	</mod-append:ship>

