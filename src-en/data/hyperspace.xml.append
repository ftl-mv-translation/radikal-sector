        <mod-append:empty/>
        <mod-append:empty/>
        <mod-append:empty/>
        <mod-append:empty/>
        <mod-append:empty/>
        <mod-append:empty/>
    </mod:findLike>
</mod:findLike>

<!-- FOR UNLOCKS:
variant attribute is what variant you want the unlock method for (a, b or c)
silent attribute says whether or not it will show up in the top right and if it plays the sound etc

type is the unlock method (0 is beat flagship, 1 is reach sector, 2 is any victory, 3 is other ship unlocks, 4 is for event unlocks) (also i haven't tested beat flagship but reach sector works)
shipReq is the ship that you have to do it with to unlock it
value is only used for reach sector right now which says which sector the player has to reach

for the achievement icon that appears on the top right when you unlock the ship, you will need to add an icon in img/achievements 
it will use whatever the layoutFile is with "_1" put on the end
so for the engi ship, the layoutFile is mup_engi_b, so the icon would be img/achievements/mup_engi_b_1.png

you can also put multiple unlock methods which will let the player do ANY of them to unlock the ship -->


<!-- 
REFS:
LIST_CHECK_AUGMENTS no longer in autoblueprints.xml.append (since HS v1.00 / MV v5.2.3) nor with a blueprintList type, 
now in hyperspace.xml as a req list, inside the huge <events> tag (which is why the append below is like it is).
-->


<!--
REF: Bag of Dumb Fixed does this.
<mod:findLike type="events" limit="1">
	<mod-append:eventFile>mithra</mod-append:eventFile>
-->

<!-- <mod:findLike type="events"> -->
<mod:findLike type="events" limit="1">
	<!-- in v5.5.1, needed again! WORKS. but file doesn't ... -->
	<!-- <mod-append:eventFile>radikal</mod-append:eventFile> -->

	<!-- ... So try this to see if it recognizes events_sector_radikal.xml
	RESULT: now sector doesn't crash, but guard pirate choice does! because RKS_PIRATE_TRINITY does.

	REF:
	<eventFile>sector_hektar</eventFile> -->
	<mod-append:eventFile>sector_radikal</mod-append:eventFile>	

	<!-- 
	**************************************
	Sector stuff - start
	**************************************
	-->

	<!-- Just like in Bag of Dumb Fixed (for MV 5.5.1). -->
	<mod-append:variable name="coords_radikal" op="set" val="0"/>
	<mod:findName type="req" name="COORDS">
		<mod-append:name>coords_radikal</mod-append:name>
	</mod:findName>
	<!-- These are new in v5.5.1 (or at least, after v5.2.3) and in a sub-tag, not directly in the coords block.
	UNNECESSARY - Bag Of Dumb Fixed (for MV 5.5.1) only does the "COORDS" block above.
	<mod:findName type="req" name="COORDS_BOSS">
		<mod-append:name>coords_radikal</mod-append:name>
	</mod:findName>
	<mod:findName type="req" name="COORDS_BOSS_TOOLATE">
		<mod-append:name>coords_radikal</mod-append:name>
	</mod:findName>
	 -->

	<!-- makes Shipvore Ram not be disintegrated for 1 Full Power use. -->
	<mod-append:variable name="shipvore_ram_reinforcement" op="set" val="0"/>

	<!-- Prevent return to sector to avoid crash. -->
	<mod-append:variable name="visited_radikal_sector" op="set" val="0"/>
	
	<!-- Pirate Trinity beacon progress. -->
	<mod-append:variable name="rks_pirate_trinity_active" op="set" val="0"/>
	<mod-append:variable name="rks_pirate_trinity_visited" op="set" val="0"/>
	<mod-append:variable name="rks_pirate_trinity_count" op="set" val="0"/>
	<mod-append:variable name="rks_pirate_trinity_met_slaver" op="set" val="0"/>
	<mod-append:variable name="rks_pirate_trinity_met_mercenary" op="set" val="0"/>
	<mod-append:variable name="rks_pirate_trinity_met_smuggler" op="set" val="0"/>

	<!-- Police confiscation for raid. -->
	<mod-append:variable name="seized_shipvoreram" op="set" val="0"/>
	<mod-append:variable name="seized_crewarebombs" op="set" val="0"/>
	<mod-append:variable name="seized_autosysrepair" op="set" val="0"/>
	
	<mod-append:variable name="seized_hackfleet" op="set" val="0"/>
	<mod-append:variable name="seized_offensedisabler" op="set" val="0"/>
	<mod-append:variable name="seized_ownharmony" op="set" val="0"/>
	<mod-append:variable name="seized_superdefenders" op="set" val="0"/>
	<mod-append:variable name="seized_defenseremover" op="set" val="0"/>
	
	<mod-append:variable name="seized_enemiescanburn" op="set" val="0"/>
	<mod-append:variable name="seized_oxygenizer" op="set" val="0"/>
	<mod-append:variable name="seized_scorchself" op="set" val="0"/>
	<mod-append:variable name="seized_scorchself2" op="set" val="0"/>
	<mod-append:variable name="seized_scorchself3" op="set" val="0"/>
	<mod-append:variable name="seized_scorchenemy" op="set" val="0"/>
	
	<mod-append:variable name="seized_bam_fissurebeam" op="set" val="0"/>

	<mod-append:variable name="seized_rainofion" op="set" val="0"/>

	<mod-append:variable name="seized_rainoffire" op="set" val="0"/>
	
	<mod-append:variable name="seized_laserbps" op="set" val="0"/>

	<!-- v5.5.1 Now useless.
	<mod-append:event name="JUMP_TO_RADIKAL" recursive="true">
		<secretSectorWarp>SECRET_RADIKAL</secretSectorWarp>
	</mod-append:event>
	-->

	<!-- 
	**************************************
	Sector stuff - end
	**************************************
	-->
	
	
	
	<mod:findName type="event" name="START_BEACON">
		<!-- This tells the game to give the hidden augment associated with your addon being installed to the player
			right at the beginning of the game. v5.5.1 IS THIS STILL A THING? -->
		<mod-append:hiddenAug>ADDON_INSTALLED_DJ0ZAUGMENTS</mod-append:hiddenAug>
	</mod:findName>
		
	<!-- Fix "Use an augment" for MV 5.2.3+ and HS 1.0+. DJMOD_CREW_ARE_BOMBS_OFF seems no work? -->
	<mod:findName name = "LIST_CHECK_AUGMENTS">
		<mod-append:name>DJMOD_COMBAT_SHIPVORE_RAM</mod-append:name>
		<mod-append:name>DJMOD_COMBAT_SELF_FIRE_UPGRADABLE</mod-append:name>
		<mod-append:name>DJMOD_CREW_ARE_BOMBS_OFF</mod-append:name>
    </mod:findName>

	<!-- FOR INTERNAL AUGMENTS -->
	<mod:findName type="req" name="LIST_UPG_ALL">
		<!-- REF Darkest Desires for MV 5.5.1
		<mod-append:name>DD_INTERNAL_AUGMENT1</mod-append:name> -->
		<mod-append:name>INTERNAL_DJMOD_DEMICLONER</mod-append:name>
		<mod-append:name>INTERNAL_DJMOD_MC_PARALYZER</mod-append:name>
		<mod-append:name>INTERNAL_DJMOD_MC_IMMUNE_FROM_FIRE</mod-append:name>
	</mod:findName>
</mod:findLike>


