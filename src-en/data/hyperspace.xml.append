<!-- 
///////////////////////////////////////////////////////////////////////////////////////////////////////
///////////////////////////////////////////////////////////////////////////////////////////////////////
						AUGMENT ICONS (+text) and SHIP HANGAR ORDER
///////////////////////////////////////////////////////////////////////////////////////////////////////
///////////////////////////////////////////////////////////////////////////////////////////////////////
-->

<mod:findLike type="ships">
	<mod:findLike type="shipIcons">
		<mod-append:shipIcon>
			<name>rk_icon_radikal_ship</name>
			<tooltip>RADIKAL SHIP:
			Probably dangerous, maybe also to itself and/or its crew.
			Probably has lootable RadiKal gear: unlocks internal upgrades and RK sector blue options or coordinates.</tooltip>
		</mod-append:shipIcon>
	</mod:findLike>


	<mod:findLike type="shipIcons">
		<mod-append:shipIcon>
			<name>rk_icon_lead_titans</name>
			<tooltip>LEAD TITANS:
			This ship's Crystals, Lanius, Rockmen and Saltmen have: 2.5x resistance to everything, 2.5x damage to everything, they create breaches while walking, and can't repair.
			The other crew get a flat +75% repair speed.
			All of this ship's crew gain a flat +40% movement speed</tooltip>
		</mod-append:shipIcon>
	</mod:findLike>
	<mod:findLike type="shipIcons">
		<mod-append:shipIcon>
			<name>rk_icon_persistence_shield</name>
			<tooltip>PERSISTENCE SHIELD:
			This enemy is protected by an Energy Shield. Hacking, Mind Control, Teleportation, Boarding Drones, and all hull-damaging or ion weapons will all be blocked until disabled.
			This specific shield also increased shield recharge rate, and the enemy is capable of regenerating their Energy Shield once!</tooltip>
		</mod-append:shipIcon>
	</mod:findLike>
	<mod:findLike type="shipIcons">
		<mod-append:shipIcon>
			<name>icon_rk_calibrator</name>
			<tooltip>CALIBRATOR:
			This ship's weapons have +10% accuracy and 4% increased fire rate.</tooltip>
		</mod-append:shipIcon>
	</mod:findLike>
	<mod:findLike type="shipIcons">
		<mod-append:shipIcon>
			<name>rk_icon_choking_is_fine</name>
			<tooltip>CHOKING F.I.N.E.:
			This ship's crew take 0.75x suffocation damage.
			While suffocating, they move, sabotage, repair and fight 1.5x better. Suffocation immune can't suffocate.</tooltip>
		</mod-append:shipIcon>
	</mod:findLike>
	
	<mod:findLike type="shipIcons">
		<mod-append:shipIcon>
			<name>rk_icon_arrogance_shield</name>
			<tooltip>ARROGANCE SHIELD:
			This enemy is protected by an Energy Shield. Hacking, Mind Control, Teleportation, Boarding Drones, and all hull-damaging or ion weapons will all be blocked until disabled.
			This specific shield also makes shield recharge and  weapon charge worse, but heals friendly drones and damages enemy drones.</tooltip>
		</mod-append:shipIcon>
	</mod:findLike>
	<mod:findLike type="shipIcons">
		<mod-append:shipIcon>
			<name>icon_rk_dread_deck</name>
			<tooltip>DREAD DECK:
			Enemies invading this ship take 1.7x damage from everything.
			This ship's crew have 2.5x healing from most sources, 2x cloning speed, and lose no skills from cloning.
			[style[color:ff3377]]WARNING: All crew in the same room as any of this ship's crew has 0.5x healing (does not stack) and cannot be cloned![[/style]] [This debuff is purple smoke]
			</tooltip>
		</mod-append:shipIcon>
	</mod:findLike>
	<mod:findLike type="shipIcons">
		<mod-append:shipIcon>
			<name>rk_icon_punk_harmony</name>
			<tooltip>PUNK HARMONY:
			This ship's Engis are more resistant and immune to Mind Control.
			They're also exponentially better at repairs, faster and stronger for each active level of Hacking and Mind Control on their ship!
		</tooltip>
		</mod-append:shipIcon>
	</mod:findLike>
	<mod:findLike type="shipIcons">
		<mod-append:shipIcon>
			<name>rk_icon_super_defenders</name>
			<tooltip>DEFENSE KITS:
			On their ship, this ship's crew resist combat damage, repair and move faster, and heal over time if they are idle (and not manning).</tooltip>
		</mod-append:shipIcon>
	</mod:findLike>
	<mod:findLike type="shipIcons">
		<mod-append:shipIcon>
			<name>rk_icon_demicloner</name>
			<tooltip>DEMICLONERS:
			Dark energies try to resurrect this ship's crew if they die (not in events) without a real Clonebay.
			At best, they become their own lesser version (Soldier = default Human, etc.) If no lesser version exists, they become Morphs. When Morphs die, nothing happens.</tooltip>
		</mod-append:shipIcon>
	</mod:findLike>

    <mod:findLike type="shipIcons">
		<mod-append:shipIcon>
			<name>rk_icon_plasma_teleporter</name>
			<tooltip>PLASMA TELEPORTER:
			This ship can instantly set its enemy on fire when a fight starts!</tooltip>
		</mod-append:shipIcon>
	</mod:findLike>
	<mod:findLike type="shipIcons">
		<mod-append:shipIcon>
			<name>rk_icon_scorch_preigniter</name>
			<tooltip>SCORCH PRE-IGNITER:
			This ship's weapons are made immediately available after an FTL jump but they light a fire in the Weapons room every time they shoot a projectile or beam!</tooltip>
		</mod-append:shipIcon>
	</mod:findLike>
	<mod:findLike type="shipIcons">
		<mod-append:shipIcon>
			<name>rk_icon_scorch_self1</name>
			<tooltip>SCORCHED EARTH:
			This ship's crew resists fire, and heals while extinguishing.</tooltip>
		</mod-append:shipIcon>
	</mod:findLike>
	<mod:findLike type="shipIcons">
		<mod-append:shipIcon>
			<name>rk_icon_scorch_self2</name>
			<tooltip>BLAZING EARTH:
			This ship's crew resists fire, is boosted in it and generates O2 in fire, and heals while extinguishing.</tooltip>
		</mod-append:shipIcon>
	</mod:findLike>
	<mod:findLike type="shipIcons">
		<mod-append:shipIcon>
			<name>rk_icon_scorch_self3</name>
			<tooltip>ERUPTING EARTH:
			This ship's crew resists fire, is boosted in it and generates much O2 in fire, and heals while extinguishing.</tooltip>
		</mod-append:shipIcon>
	</mod:findLike>
	<mod:findLike type="shipIcons">
		<mod-append:shipIcon>
			<name>rk_icon_enemies_can_burn</name>
			<tooltip>FLAMMABILIZER-I:
			Your crew's fire immunity, resistance or direct healing from fire (not extinguishing) are removed! Your crew also move slower in fire, even more for each active level of Life Support (O2) on this ship!</tooltip>
		</mod-append:shipIcon>
	</mod:findLike>
	<mod:findLike type="shipIcons">
		<mod-append:shipIcon>
			<name>rk_icon_enemies_burn_more</name>
			<tooltip>FLAMMABILIZER-D:
			Your crew takes more fire damage and move slower in fire. These effects are stronger for each active level of Life Support (O2) on this ship!</tooltip>
		</mod-append:shipIcon>
	</mod:findLike>
	<mod:findLike type="shipIcons">
		<mod-append:shipIcon>
			<name>rk_icon_weapons_on_fire</name>
			<tooltip>WEAPONS ON FIRE:
			The fire rate of this ship's Weapons and Artilleries is improved by 25%. It gains an extra 1% fire rate every time they shoot a projectile or beam (up to 10%), but at the same time there's a 10% chance to light a fire in the Weapon Control and any Artillery rooms.
			COMBO: Scorch Preigniter increases max extra bonus to 20%.</tooltip>
		</mod-append:shipIcon>
	</mod:findLike>

	<!-- 
	//////////////////////////////////////////////////////////////////////////////////////////////
							SHIP HANGAR ORDER
	//////////////////////////////////////////////////////////////////////////////////////////////
	-->
	<mod:findLike type="shipOrder">
        <mod-append:ship>PLAYER_SHIP_DJMOD_RAMMER</mod-append:ship>
        <mod-append:ship>PLAYER_SHIP_DJMOD_PUNKER</mod-append:ship>
        <mod-append:ship>PLAYER_SHIP_RK_SCORCHER</mod-append:ship>
		<mod-append:empty/>

        <mod-append:empty/>
        <mod-append:ship>PLAYER_SHIP_RK_LEAD_TITANS_USER</mod-append:ship>
        <mod-append:empty/>
        <mod-append:empty/>

        <mod-append:empty/>
        <mod-append:ship>PLAYER_SHIP_DJMOD_SCORCH</mod-append:ship>
    </mod:findLike>
</mod:findLike>

<!-- FOR UNLOCKS:
variant attribute is what variant you want the unlock method for (a, b or c)
silent attribute says whether or not it will show up in the top right and if it plays the sound etc

type is the unlock method (0 is beat flagship, 1 is reach sector, 2 is any victory, 3 is other ship unlocks, 4 is for event unlocks) (also i haven't tested beat flagship but reach sector works)
shipReq is the ship that you have to do it with to unlock it
value is only used for reach sector right now which says which sector the player has to reach

for the achievement icon that appears on the top right when you unlock the ship, you will need to add an icon in img/achievements 
it will use whatever the layoutFile is with "_1" put on the end
so for the engi ship, the layoutFile is mup_engi_b, so the icon would be img/achievements/mup_engi_b_1.png

you can also put multiple unlock methods which will let the player do ANY of them to unlock the ship -->



