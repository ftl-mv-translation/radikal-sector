<!--
/////////////////////////////////////////////////////////////////////////////////////////////////////////
/////////////////////////////////////////////////////////////////////////////////////////////////////////
				SCORCH ENEMY SHIP (PLASMA TELEPORTER)
/////////////////////////////////////////////////////////////////////////////////////////////////////////
/////////////////////////////////////////////////////////////////////////////////////////////////////////
TODO:
.
REF (Hyperspace 1.0 changelog) : -Events: <choiceRequiresCrew/> to make a choice greyed out if the crew loss/transform event cannot find a valid target of the specified race.

-->

<event name="DJMOD_COMBAT_CHECK_SCORCH_ENEMY">
	<text>Are you sure you want to do this? (Requires a source of fire)
	[Creates fire in your ship and O2 room, then teleports some to the enemy ship. Uses {]</text>
	
	<choice req="DJMOD_COMBAT_SELF_FIRE" lvl="0" max_lvl="0" hidden="true" blue="false">
		<text>You do not have any tier of the Scorched Earth augment.</text>
		<event load="OPTION_INVALID"/>
	</choice>
	
	<choice req="DJMOD_SELF_SCORCH_MOVER_COMBO" hidden ="false">
		<text>(Scorched Earth) Yes! [A few fires in the enemy ship]</text>
		<event load="DJMOD_COMBAT_SCORCH_ENEMY_EFFECT"/>
	</choice>
	<choice req="DJMOD_SELF_SCORCH_MOVER_COMBO" hidden ="false">
		<text>(Scorched Earth) Yes! [Many fires in both ships]</text>
		<event load="DJMOD_COMBAT_SCORCH_BOTH_EFFECT"/>
	</choice>
	
	<choice req="DJMOD_COMBAT_SCORCH_ENEMY" hidden ="false" blue="false">
		<text>Yes [Requires a fire source which may be consumed]</text>
		<event load="DJMOD_SCORCH_ENEMY_PAY"/>
	</choice>
	
	<choice>
        <text>Do something else instead.</text>
        <event load="COMBAT_CHECK"/>
    </choice>
	<choice>
		<text>Nevermind, let's fight!</text>
		<event>
			<text>You decide not to do anything and prepare to fight.</text>
		</event>
	</choice>
</event>

<!-- Payment options -->
<!-- DEPRECATE MOST OF THIS - TOO MUCH MAINTENANCE NEEDED especially regarding ADD-ONS
EXCEPT for RK GEAR since i'll always know what's in it, and it's possible to have unwanted dupes,
AND the CREW_ARE_BOMBS option,
AND relevant Unique crew, that's easier to keep track of and we can always pretend the newer ones just refused. -->

<event name="DJMOD_SCORCH_ENEMY_PAY">
	<text>What fire source shall we use?</text>

	<choice req="DJMOD_HAS_FIRE_ITEMS" hidden="true"> 
		<text>Fire equipment. [50% chance to be consumed]</text>
		<event load="DJMOD_SCORCH_ENEMY_PAY_FIRE_WEAPON"/>
	</choice>

	<choice req="DJMOD_HAS_COMBUSTIBLE_CREW" hidden="true"> 
		<text>Fire-starting crew. [Will be consumed, can be cloned]</text>
		<event load="DJMOD_SCORCH_ENEMY_PAY_CREW"/>
	</choice>
	
	<choice hidden="true" blue="false"> 
		<text>3 }. Inefficient, but it will do.</text>
		<event>
			<text>You insert the missiles...</text>
			<item_modify>
				<item type="missiles" min="-5" max="-5"/>
			</item_modify>
			
			<choice hidden="true" blue="false"> 
				<text>Continue...</text>
				<event load="DJMOD_COMBAT_SCORCH_ENEMY_EFFECT"/>
			</choice>
		</event>
	</choice>
	
	<choice>
        <text>Do something else instead.</text>
        <event load="COMBAT_CHECK"/>
    </choice>
	<choice>
		<text>Nevermind, let's fight!</text>
		<event>
			<text>You decide not to do anything and prepare to fight.</text>
		</event>
	</choice>	
</event>

<!-- Keep this list reasonably short for UI reasons. No need to subdivide into categories.
	Player will NORMALLY have at most 8 weapons at any time 
	(4 equipped, 4 stored - but Lily's "cargo expander / increased capacity" can make it 12+) 
	And if they're all fire, player's probably got bigger problems.
	So they'll never see all of these at once!
	
	Also just make 2 lists with strictly identical texts (one fail, one survive) instead of 1 eventList per weapon. 
	
REF:
	
<text>What weapon? [50% chance to be consumed]</text>

<choice req="LASER_FIRE" hidden="true"> 
	<text>Fire laser</text>
	<event>
		<text>The equipment melts, activating the augment!</text>
		<remove name="LASER_FIRE"/>
		
		<choice hidden="true"> 
			<text>Continue...</text>
			<event load="DJMOD_COMBAT_SCORCH_ENEMY_EFFECT"/>
		</choice>
	</event>
	<event>
		<text>The weapon resists, activating the augment!</text>
		<choice hidden="true"> 
			<text>Continue...</text>
			<event load="DJMOD_COMBAT_SCORCH_ENEMY_EFFECT"/>
		</choice>
	</event>
</choice>
-->

<eventList name="DJMOD_SCORCH_ENEMY_PAY_FIRE_WEAPON">
	<event load="DJMOD_SCORCH_ENEMY_PAY_FIRE_WEAPON_BAD"/>
	<event load="DJMOD_SCORCH_ENEMY_PAY_FIRE_WEAPON_GOOD"/>
</eventList>

<event name="DJMOD_SCORCH_ENEMY_PAY_FIRE_WEAPON_BAD">
	<text>What equipment? [50% chance to be consumed]</text>
	
	<choice req="MODULE_FIRE" hidden="true"> 
		<text>Fire module</text>
		<event>
			<text>The equipment melts, activating the augment!</text>
			<remove name="MODULE_FIRE"/>
			
			<choice hidden="true">
				<text>Continue...</text>
				<event load="DJMOD_COMBAT_SCORCH_ENEMY_EFFECT"/>
			</choice>
		</event>
	</choice>

	<!-- *******************************
	Strong (big both ships fire) options 
	******************************* 
	-->
	<choice req="DJMOD_RAIN_OF_FIRE" hidden="true"> 
		<text>Rain of Fire</text>
		<event>
			<text>The equipment melts, strongly activating the augment!</text>
			<remove name="DJMOD_RAIN_OF_FIRE"/>
			
			<choice hidden="true">
				<text>Continue...</text>
				<event load="DJMOD_COMBAT_SCORCH_BOTH_EFFECT"/>
			</choice>
		</event>
	</choice>
	
	<choice req="DJMOD_ENEMIES_CAN_BURN" hidden="true"> 
		<text>Flammabilizer-Immune</text>
		<event>
			<text>The equipment melts, strongly activating the augment!</text>
			<remove name="DJMOD_ENEMIES_CAN_BURN"/>
			
			<choice hidden="true">
				<text>Continue...</text>
				<event load="DJMOD_COMBAT_SCORCH_BOTH_EFFECT"/>
			</choice>
		</event>
	</choice>
	<choice req="DJMOD_ENEMIES_BURN_MORE" hidden="true"> 
		<text>Flammabilizer-Damage</text>
		<event>
			<text>The equipment melts, strongly activating the augment!</text>
			<remove name="DJMOD_ENEMIES_BURN_MORE"/>
			
			<choice hidden="true">
				<text>Continue...</text>
				<event load="DJMOD_COMBAT_SCORCH_BOTH_EFFECT"/>
			</choice>
		</event>
	</choice>
	
	<choice>
        <text>Do something else instead.</text>
        <event load="COMBAT_CHECK"/>
    </choice>
</event>

<event name="DJMOD_SCORCH_ENEMY_PAY_FIRE_WEAPON_GOOD">
