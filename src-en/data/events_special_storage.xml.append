<!-- Outcome amounts based on the actual MV augments they mention in text. See MV's hyperspace.xml . 
Resource outcomes add scrap to make their value equal: min 35 scrap worth, max 75. (fuel=3 missi=6 dronep=7)  -->
<event name="SHIPVORE_RAM_FP_OWN_OUTCOME_GETHEAL">
	<text>The debris is perfect for quick but extensive repairs!</text>
	<damage amount="-8"/>
	<choice>
		<text>Good!</text>
		<event/>
	</choice>
</event>

<event name="SHIPVORE_RAM_FP_OWN_OUTCOME_GETSCRAP">
	<text>Looks like we broke open a Scrap Crate!</text>
	<damage amount="-3"/>
	<choice>
		<text>Good!</text>
		<event>
			<item_modify>
				<item type="scrap" min="30" max="45"/>
			</item_modify>
		</event>
	</choice>
</event>
<event name="SHIPVORE_RAM_FP_OWN_OUTCOME_GETSCRAP_2">
	<text>Bad news, we didn't get any repairs.
	Good news, we broke open a Huge Scrap Crate!! A fantastic outcome, even though some of the scrap was lost in space.</text>
	<!-- <damage amount="-2"/> -->
	<choice>
		<text>Good!</text>
		<event>
			<item_modify>
				<item type="scrap" min="69" max="150"/>	<!-- Huge Scrap Crate = 175 scrap. -->
			</item_modify>
		</event>
	</choice>
</event>
<event name="SHIPVORE_RAM_FP_OWN_OUTCOME_GETSCRAP_SCALING">
	<text>Much of the debris is good scrap!</text>
	<damage amount="-2"/>
	<choice>
		<text>Good!</text>
		<event>
			<autoReward level="MED">standard</autoReward>
		</event>
	</choice>
</event>

<event name="SHIPVORE_RAM_FP_OWN_OUTCOME_GETFUEL">
	<text>Looks like we broke open a Fuel Crate!</text>
	<damage amount="-2"/>
	<choice>
		<text>Good!</text>
		<event>
			<item_modify>
				<item type="fuel" min="5" max="10"/>
				<item type="scrap" min="20" max="45"/>
			</item_modify>
		</event>
	</choice>
</event>
<event name="SHIPVORE_RAM_FP_OWN_OUTCOME_GETFUEL_SCALING">
	<text>As luck would have it, there's fuel among the debris!</text>
	<damage amount="-2"/>
	<choice>
		<text>Good!</text>
		<event>
			<autoReward level="MED">fuel</autoReward>
		</event>
	</choice>
</event>

<event name="SHIPVORE_RAM_FP_OWN_OUTCOME_GETMISSILES">
	<text>Looks like we broke open an Ammo Crate!</text>
	<damage amount="-2"/>
	<choice>
		<text>Good!</text>
		<event>
			<item_modify>
				<item type="missiles" min="5" max="10"/>
				<item type="scrap" min="5" max="15"/>
			</item_modify>
		</event>
	</choice>
</event>
<event name="SHIPVORE_RAM_FP_OWN_OUTCOME_GETMISSILES_SCALING">
	<text>Some of the debris is intact ammunition!</text>
	<damage amount="-2"/>
	<choice>
		<text>Good!</text>
		<event>
			<autoReward level="MED">missiles</autoReward>
		</event>
	</choice>
</event>

<event name="SHIPVORE_RAM_FP_OWN_OUTCOME_GETDRONEPARTS">
	<text>Looks like we broke open a Droneparts Crate!</text>
	<damage amount="-2"/>
	<choice>
		<text>Good!</text>
		<event>
			<item_modify>
				<item type="drones" min="5" max="10"/>
				<item type="scrap" min="0" max="5"/>
			</item_modify>
		</event>
	</choice>
</event>
<event name="SHIPVORE_RAM_FP_OWN_OUTCOME_GETDRONEPARTS_SCALING">
	<text>Some of the debris is functional droneparts!</text>
	<damage amount="-2"/>
	<choice>
		<text>Good!</text>
		<event>
			<autoReward level="MED">droneparts</autoReward>
		</event>
	</choice>
</event>

<event name="SHIPVORE_RAM_FP_OWN_OUTCOME_GETWEAPON">
	<text>There was a backup weapon in a crate among the debris!</text>
	<damage amount="-2"/>
	<choice>
		<text>Good!</text>
		<event>
			<weapon name="GIFTLIST_SHIPVORE_RAM_FP"/>
			<autoReward level="MED">standard</autoReward>
			
			<item_modify>
				<item type="scrap" min="10" max="15"/>
			</item_modify>
		</event>
	</choice>
</event>
<event name="SHIPVORE_RAM_FP_OWN_OUTCOME_GETWEAPON_2">
	<text>We randomly found a weapon in a crate among the debris!</text>
	<damage amount="-2"/>
	<choice>
		<text>Good!</text>
		<event>
			<autoReward level="LOW">weapon</autoReward>
		</event>
	</choice>
</event>

<!-- FULL POWER BAD OUTCOMES -->

<event name="SHIPVORE_RAM_FP_OWN_OUTCOME_BAD_NOTHING">
	<text>Ramming at full power unfortunately scattered the debris very far... we got nothing back.</text>
	<damage amount="1" system="engines" effect="breach" force="false"/>
	<damage amount="-1"/>
	
	<choice>
		<text>Better luck next time.</text>
		<event/>
	</choice>
</event>

<event name="SHIPVORE_RAM_FP_OWN_OUTCOME_BAD_FUEL_DAMAGE">
	<text>In the end we found a little fuel but lost more hull than we repaired.</text>
	<damage amount="1" system="engines" effect="breach" force="false"/>
	<damage amount="1" system="random" effect="breach" force="false"/>
	<damage amount="-1"/>
	
	<choice>
		<text>Not good.</text>
		<event>
			<item_modify>
				<item type="fuel" min="2" max="3"/>
			</item_modify>
		</event>
	</choice>
</event>

<event name="SHIPVORE_RAM_FP_OWN_OUTCOME_BAD_CRITICAL">
	<text>There was a very low chance for this happen but we struck them at a bad angle at full power, damaging our ship in many places!</text>
	<damage amount="1" system="engines" effect="breach" force="false"/>
	<damage amount="2" system="random" effect="all" force="false"/>
	<damage amount="1" system="random" effect="random" force="false"/>
	<damage amount="1" system="room" effect="random" force="false"/>
	<damage amount="-3"/>
	
	<choice>
		<text>Repairs! Quickly!</text>
		<event/>
	</choice>
</event>

<event name="SHIPVORE_RAM_FP_OWN_OUTCOME_BAD_TRAITOR">	
	<text>Captain... through very bad luck, our ship took a terrible shock and our crew was absolutely yeeted into space!</text>
	<damage amount="1" system="engines" effect="breach" force="false"/>
	<damage amount="1" system="random" effect="breach" force="false"/>
	<damage amount="-1"/>

	<choice req="DJMOD_CAN_TELEPORT_EJECTED_CREW" lvl="1" hidden="false">
		<text>(Teleporter 3 + Reconstructive) Emergency teleport!</text>
		<event>
			<text>Your preparation pays off as you easily teleport them back in good health.</text>

			<choice>
				<text>Crisis averted!</text>
				<event/>
			</choice>
		</event>
	</choice>
	<choice req="DJMOD_CAN_TELEPORT_EJECTED_CREW" lvl="0" max_lvl="0" hidden="true" blue="false">
		<text>Your teleportation equipment is insufficient.</text>
		<event load="OPTION_INVALID"/>
	</choice>
	
	<choice req="DJMOD_SUFFICIENT_PILOTING_AND_SENSORS" hidden="false">
		<text>(Piloting 3, Sensors 2) Do a barrel roll!</text>
		<event>
			<text>A precise AI-assisted maneuver puts your crew back in through the same breach!</text>
			<item_modify>
				<item type="fuel" min="-3" max="-3"/>
			</item_modify>

			<choice>
				<text>Crisis averted!</text>
				<event/>
			</choice>
		</event>
	</choice>
	<choice req="DJMOD_SUFFICIENT_PILOTING_AND_SENSORS" lvl="0" max_lvl="0" hidden="true" blue="false">
		<text>Your Piloting or Sensors system is too weak.</text>
		<event load="OPTION_INVALID"/>
	</choice>

	<choice req="engines" lvl="6" hidden="false">
		<text>(Engines 6) Quick, swerve!</text>
		<event>
			<text>With great speed you catch your crew mid-flight!</text>
			<item_modify>
				<item type="fuel" min="-2" max="-2"/>
			</item_modify>

			<choice>
				<text>Crisis averted!</text>
				<event/>
			</choice>
		</event>
	</choice>
	<choice req="engines" max_lvl="5" hidden="true" blue="false">
		<text>Your Engines system is too weak.</text>
		<event load="OPTION_INVALID"/>
	</choice>

	<choice req="DJMOD_CAN_DO_DRONE_RESCUE" hidden="false">
		<text>(Doctor Drone) Quick, drone rescue!</text>
		<event>
			<text>Your Dr. Drone quickly swiftly brings back the crew while protecting their vital organs!</text>
			<item_modify>
				<item type="drones" min="-2" max="-1"/>
			</item_modify>

			<choice>
				<text>Crisis averted!</text>
				<event/>
			</choice>
		</event>
	</choice>
	<choice req="DJMOD_CAN_DO_DRONE_RESCUE" max_lvl="0" hidden="true" blue="false">
		<text>You do not have the appropriate crew drone.</text>
		<event load="OPTION_INVALID"/>
	</choice>

	<choice req="DJMOD_ANY_RESCUE_ARM" hidden="false">
		<text>(Appropriate ship Arm) Grab them with a makeshift lasso!</text>
		<event>
			<text>With dubious logic, you get your crew back in through the same breach!</text>
			<item_modify>
				<item type="scrap" min="-30" max="-20"/>
			</item_modify>

			<choice>
				<text>Crisis averted!</text>
				<event/>
			</choice>
		</event>
	</choice>
	<choice req="DJMOD_ANY_RESCUE_ARM" lvl="0" max_lvl="0" hidden="true" blue="false">
		<text>Your ship does not have an appropriate Arm.</text>
		<event load="OPTION_INVALID"/>
	</choice>

	<choice req="DJMOD_SUM_ENGINEERS" lvl="2" hidden="false">	<!-- 2 engineers because one might be the ejected. -->
		<text>(At least 2 engineers) Quick, jury-rig them a space ride!</text>
		<event>
			<text>With dubious logic, you get your crew back in through the same breach! But also take some hull damage.</text>
			<damage amount="1"/>
			<item_modify>
				<item type="missiles" min="-3" max="-2"/>
				<item type="drones" min="-1" max="-1"/>
			</item_modify>

			<choice>
				<text>Crisis averted!</text>
				<event/>
			</choice>
		</event>
	</choice>
	<choice req="DJMOD_SUM_ENGINEERS" max_lvl="1" hidden="true" blue="false">
		<text>You do not have enough engineer-class crew.</text>
		<event load="OPTION_INVALID"/>
	</choice>

	<choice hidden="true" blue="false">
		<text>...There's nothing we can do about it, focus on the fight!</text>
		<event>
			<text>As your crew is lost alone in the void, the others look terrified!</text>

			<choice req="mind" lvl="1" hidden="true">
				<text>(Mind Control) Prepare for the worst...</text>
				<event>
					<text>What's more, a friend of the victim has lost all trust in you!
					This could have been worse, but your Mind Control system prevented treason.</text>
					<choice>
						<text>Not good, but not terrible either.</text>
						<event/>
					</choice>
				</event>
			</choice>
			
			<choice req="mind" lvl="0" max_lvl="0" hidden="true" blue="false">
			<!-- <choice> -->
				<text>This is bad...</text>
				<event>
					<text>What's more, a friend of the victim, red with rage and adrenaline, turns to violence!
					This could probably have been avoided with the appropriate control system...</text>
					<!-- This exact combination turns a crewmember hostile. Implies they can't be cloned. Also might kill more crew. -->
					<crewMember amount="-1" class="traitor"/>
					<choice>
						<text>This has to be the worst that could happen!</text>
						<event/>
					</choice>
				</event>
			</choice>
		</event>
	</choice>

	<!-- <choice req="mind" lvl="1" hidden="true" blue="true">
		<text>(Mind Control) Prepare for the worst...</text>
		<event>
			<text>What's more, a friend of the victim has lost all trust in you!
			This could have been worse, but your Mind Control system prevented treason.</text>
			<choice>
				<text>Not good, but not terrible either.</text>
				<event/>
			</choice>
		</event>
	</choice>
	
	<choice req="mind" lvl="0" max_lvl="0" hidden="true" blue="false">
		<text>This is bad...</text>
		<event>
			<text>What's more, a friend of the victim has lost all trust in you, and turns to violence!
			This could probably have been avoided with the appropriate control system...</text>
			
			<crewMember amount="-1" class="traitor"/>
			<choice>
				<text>This has to be the worst that could happen!</text>
				<event/>
			</choice>
		</event>
	</choice> -->
</event>

<!-- 
/////////////////////////////////////////////////////////////////////////////////////////////////////////////////////
REPEAT STRIKE(S):
-Can't be done if Full Power was used this fight.
-No Emergency Generator (it's balanced for 1 augment per fight).
TODO: disable if enemy current hull == 0 (TEST Lua!)
/////////////////////////////////////////////////////////////////////////////////////////////////////////////////////
 -->

<event name="DJMOD_COMBAT_SHIPVORE_RAM_REPEAT">
	<text>Prepare to ram again?
	[Ram the enemy ship, high chance to repair your ship. Warning: may go wrong!]</text>
	
	<variable name="shipvore_ram_full_power" op="set" val="0"/>
	<variable name="locked_shipvore_ram_full_power" op="set" val="0"/>
	<variable name="shipvore_ram_used_fuel" op="set" val="0"/>
	
	<!-- Repeat strike: This choice needs the req because the augment might have disintegrated.
	All paths leading to here already check it though. -->
	 <!-- <choice> -->
	<choice req="DJMOD_COMBAT_SHIPVORE_RAM_ANY" lvl="1" hidden="false" blue="false">
		<text>Yes [Needs 10 seconds.]</text>
		<event>
			<text>You activate the augment...</text>
			
			<item_modify>
				<item type="fuel" min="-1" max="-1"/>	<!--The min -1 and max -2 order is tested, and though wrong (-2 < -1), works as intended. min -0 and max -1 does Not work. -->
			</item_modify>       
			<variable name="shipvore_ram_used_fuel" op="set" val="1"/>
			
			<choice>
				<text>Continue...</text>
				<event load="DJMOD_COMBAT_SHIPVORE_RAM_TIMER_START"/>
			</choice>
		</event>
	</choice>

	<!-- This is a repeat strike. Emergency Generator was designed to work only once per fight. 
	Fuel conserver is weaker and much more specific so that's fine. -->
	<choice req="FUEL_CONSERVER">
		<text>(Fuel Conserver) Yes, using no fuel.</text>
		<event load="DJMOD_COMBAT_SHIPVORE_RAM_TIMER_START"/>
	</choice>

	<choice req="DJMOD_COMBAT_SHIPVORE_RAM_REINFORCED" blue="true"> 
		<text>(Reinforced Shipvore Ram) Yes, at full power!
		[Lose the reinforcement. Can't ram again until next jump. Needs 7 seconds.]</text>
		<event>
			<text>You activate the augment at full power...</text>
			
			<item_modify>
				<item type="fuel" min="-4" max="-4"/>
			</item_modify>
			<variable name="shipvore_ram_used_fuel" op="set" val="4"/>
			<variable name="shipvore_ram_full_power" op="set" val="1"/>

			<!-- <variable name="shipvore_ram_reinforcement" op="add" val="-1"/> -->
			
			<choice>
				<text>Continue to the fight!</text>
				<event load="DJMOD_COMBAT_SHIPVORE_RAM_TIMER_START_FULL_POWER"/>
			</choice>
		</event>
	</choice>
	<choice req="DJMOD_COMBAT_SHIPVORE_RAM_NOT_REINFORCED" blue="false"> 
		<text>Yes, at full power!
		[The augment will disintegrate. Needs 7 seconds.]</text>
		<event>
			<text>You activate the augment at full power...</text>
			
			<item_modify>
				<item type="fuel" min="-4" max="-4"/>
			</item_modify>
			<variable name="shipvore_ram_used_fuel" op="set" val="4"/>
			<variable name="shipvore_ram_full_power" op="set" val="1"/>
			
			<choice>
				<text>Continue to the fight!</text>
				<event load="DJMOD_COMBAT_SHIPVORE_RAM_TIMER_START_FULL_POWER"/>
			</choice>
		</event>
	</choice>
	<choice req="LOCKED_DJMOD_COMBAT_SHIPVORE_RAM" blue="false">  
		<text>Yes, at full power!
		[Can't ram again until next jump. Needs 7 seconds.]</text>
		<event>
			<text>You activate the augment at full power...</text>
			
			<item_modify>
				<item type="fuel" min="-4" max="-4"/>
			</item_modify>
			<variable name="shipvore_ram_used_fuel" op="set" val="4"/>
			<variable name="locked_shipvore_ram_full_power" op="set" val="1"/>
			
			<choice>
				<text>Continue to the fight!</text>
				<event load="DJMOD_COMBAT_SHIPVORE_RAM_TIMER_START_FULL_POWER"/>
			</choice>
		</event>
	</choice>

	<choice>
		<text>That's enough.</text>
		<event/>
	</choice>
</event>

<!-- To remove "go again when enemy has 0 hull" awkwardness. See Lua scripts. -->
<event name="DJMOD_COMBAT_SHIPVORE_CANT_REPEAT_ENEMY_DEAD">
	<text>Enemy destroyed, nothing left to ram.</text>
	
	<variable name="shipvore_ram_full_power" op="set" val="0"/>
	<variable name="shipvore_ram_used_fuel" op="set" val="0"/>
	
	<choice>
		<text>Okay.</text>
		<event/>
	</choice>
</event>

<!-- 
///////////////////////////////////////////////////////////
		Storage check reinforcement
///////////////////////////////////////////////////////////
-->

<event name="DJMOD_COMBAT_SHIPVORE_RAM_REINFORCE">
	<text>Are you sure you want to reinforce this augment?
	[When choosing the "Full Power" strike, reinforcement will be lost instead of the augment. 
	You can still do something at the empty beacon after this.]</text>
	
	<choice req="shipvore_ram_reinforcement" lvl="0" max_lvl="0" hidden="false" blue="false">
		<text>Yes</text>
		<event>
			<text>You reinforce the augment.</text>
			<item_modify>
				<item type="scrap" min="-18" max="-18"/>
			</item_modify>
			
			<variable name="shipvore_ram_reinforcement" op="add" val="1"/>
			<choice>
				<text>This will give us an edge!</text>
				<!-- <event/> -->
				<event load="STORAGE_CHECK"/>
			</choice>
		</event>
	</choice>
	<choice req="shipvore_ram_reinforcement" lvl="1" hidden="true" blue="false">
		<text>Your Shipvore Ram has reinforcement.</text>
		<event load="OPTION_INVALID"/>
	</choice>
	<choice>
		<text>Nevermind, do something else.</text>
		<event load="STORAGE_CHECK"/>
	</choice>
</event>
<!--
/////////////////////////////////////////////////////////////////////////////////////////////////////////
/////////////////////////////////////////////////////////////////////////////////////////////////////////
				SCORCH SELF SHIP (SCORCHED EARTH & ALL ITS UPGRADES - but not combos, they're lower down)
/////////////////////////////////////////////////////////////////////////////////////////////////////////
/////////////////////////////////////////////////////////////////////////////////////////////////////////
TODO:
-

Defensive, masochistic combat augment by fire on your own ship.
MV v5.2.3 (outdated?): Tests reveal that Extinguishers augment pretty much nullifies this effect, 
and there's no way to fix that (not even same function with negative value). -->

<!-- Toggle menu method (WORKS) 
Problem: The "randomly chosen" ignited tiles are always the same at any given beacon, 
even on repeat activations, even using a loader function like MV's Gambling Machine, even with an 
eventlist, see RK Sector v5.65k to witness (FIXED? NOPE.)
It's an issue when a room never gets ignited and that's where you get boarded, defeating the whole point of the augment.
So we spam fires.
-->
 <event name="DJMOD_TOGGLEMENU_SCORCH_SELF">
	<text>Are you sure you want to do this?
	[Set your own ship on fire! Usually to repel boarders.]</text>
	
	<choice req="artillery" hidden="true" blue="false">
		<text>Burn them out of the Artillery room!</text>
		<event load="DJMOD_SPAWN_FIRES_OWN_SHIP_ARTILLERY"/>
	</choice>
	<choice req="battery" hidden="true" blue="false">
		<text>Burn them out of the Battery room!</text>
		<event load="DJMOD_SPAWN_FIRES_OWN_SHIP_BATTERY"/>
	</choice>
	<choice req="cloaking" hidden="true" blue="false">
		<text>Burn them out of the Cloaking room!</text>
		<event load="DJMOD_SPAWN_FIRES_OWN_SHIP_CLOAKING"/>
	</choice>
	<choice req="clonebay" hidden="true" blue="false">
		<text>Burn them out of the Clonebay!</text>
		<event load="DJMOD_SPAWN_FIRES_OWN_SHIP_CLONEBAY"/>
	</choice>
	<choice req="doors" hidden="true" blue="false">
		<text>Burn them out of the Door Control room!</text>
		<event load="DJMOD_SPAWN_FIRES_OWN_SHIP_DOORS"/>
	</choice>
	<choice req="drones" hidden="true" blue="false">
		<text>Burn them out of the Drone Control room!</text>
		<event load="DJMOD_SPAWN_FIRES_OWN_SHIP_DRONES"/>
	</choice>
	<choice req="engines" hidden="true" blue="false">
		<text>Burn them out of the Engines room!</text>
		<event load="DJMOD_SPAWN_FIRES_OWN_SHIP_ENGINES"/>
	</choice>
	<choice req="hacking" hidden="true" blue="false">
		<text>Burn them out of the Hacking room!</text>
		<event load="DJMOD_SPAWN_FIRES_OWN_SHIP_HACKING"/>
	</choice>
	<choice req="medbay" hidden="true" blue="false">
		<text>Burn them out of the Medbay!</text>
		<event load="DJMOD_SPAWN_FIRES_OWN_SHIP_MEDBAY"/>
	</choice>
	<choice req="mind" hidden="true" blue="false">
		<text>Burn them out of the Mind Control room!</text>
		<event load="DJMOD_SPAWN_FIRES_OWN_SHIP_MIND"/>
	</choice>
	<choice req="oxygen" hidden="true" blue="false">
		<text>Burn them out of the Life Support (O2) room!</text>
		<event load="DJMOD_SPAWN_FIRES_OWN_SHIP_OXYGEN"/>
	</choice>
	<choice req="pilot" hidden="true" blue="false">
		<text>Burn them out of the Piloting room!</text>
		<event load="DJMOD_SPAWN_FIRES_OWN_SHIP_PILOT"/>
	</choice>
	<choice req="sensors" hidden="true" blue="false">
		<text>Burn them out of the Sensors room!</text>
		<event load="DJMOD_SPAWN_FIRES_OWN_SHIP_SENSORS"/>
	</choice>
	<choice req="shields" hidden="true" blue="false">
		<text>Burn them out of the Shields room!</text>
		<event load="DJMOD_SPAWN_FIRES_OWN_SHIP_SHIELDS"/>
	</choice>
	<choice req="teleporter" hidden="true" blue="false">
		<text>Burn them out of the Teleporter room!</text>
		<event load="DJMOD_SPAWN_FIRES_OWN_SHIP_TELEPORTER"/>
	</choice>
	<choice req="temporal" hidden="true" blue="false">
		<text>Burn them out of the Temporal room!</text>
		<event load="DJMOD_SPAWN_FIRES_OWN_SHIP_TEMPORAL"/>
	</choice>
	<choice req="weapons" hidden="true" blue="false">
		<text>Burn them out of the Weapons room!</text>
		<event load="DJMOD_SPAWN_FIRES_OWN_SHIP_WEAPONS"/>
	</choice>
	
	<choice hidden="true">
		<text>Too many enemies. Light up the WHOLE ship!!</text>

		<event>
			<!-- loadEvent MUST be inside an <event> tag else CRASH ON PRESSING TOGGLE MENU event WITHOUT the augment. -->
			<!-- These still aren't random at same beacon:
			<loadEvent seeded="false">DJMOD_SPAWN_FIRES_OWN_SHIP</loadEvent>
			<loadEvent ignoreUnique="true" seeded="false" generate="false">DJMOD_SPAWN_FIRES_OWN_SHIP</loadEvent>
			<loadEvent seeded="false">DJMOD_SPAWN_FIRES_OWN_SHIP_EVENTLIST</loadEvent>
			-->
			
			<loadEvent>DJMOD_SPAWN_FIRES_OWN_SHIP_NUCLEAR</loadEvent>
		</event>

		<!-- <event load="DJMOD_SPAWN_FIRES_OWN_SHIP_LOADER"/> -->

		<!-- 
		REFS from MV:

		<loadEvent ignoreUnique="true" seeded="false" generate="false">ORCHID_CHILDREN_MAYEB_LOOP</loadEvent>
		
		<eventList name="GAMBLING_MACHINE_DRONES">
			<event>
				<text>You await your reward, but the machine buzzes and an X flashes on the screen. Better luck next time...</text>
				<choice hidden="true">
					<text>Gamble again.</text>
					<event load="STORAGE_CHECK_GAMBLING_LOADER"/>
				</choice>
				<choice hidden="true">
					<text>That's enough for now.</text>
					<event/>
				</choice>
			</event>
			<event>
				<text>You await your reward, but the machine buzzes and an X flashes on the screen. Better luck next time...</text>
				<choice hidden="true">
					<text>Gamble again.</text>
					<event load="STORAGE_CHECK_GAMBLING_LOADER"/>
				</choice>
				<choice hidden="true">
					<text>That's enough for now.</text>
					<event/>
				</choice>
			</event>
			<event>
				<text>The machine beeps and 3 golden 7's flash on the screen, and a drone schematic is dispensed from the machine! What kind of casino was this place anyways?</text>
				<drone name="RANDOM"/>
			</event>
		</eventList>
		<event name="STORAGE_CHECK_GAMBLING_LOADER">
			<loadEvent seeded="false">STORAGE_CHECK_AUG_GAMBLING_MACHINE</loadEvent>
		</event>
		-->
	</choice>

	<choice hidden="true">
		<text>Return to the toggle menu.</text>
		<event load="COMBAT_CHECK_TOGGLE_LOAD"/>
	</choice>	
</event>

