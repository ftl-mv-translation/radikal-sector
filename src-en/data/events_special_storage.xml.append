				<text>Your clonebay successfully revived your crew.</text>
			</removeCrew>
			
			<choice hidden="true">
				<text>Continue...</text>
				<event load="DJMOD_COMBAT_SCORCH_BOTH_EFFECT"/>
			</choice>
		</event>
	</choice>
	
	<choice>
        <text>Do something else instead.</text>
        <event load="COMBAT_CHECK"/>
    </choice>
</event>



<event name="DJMOD_COMBAT_SCORCH_ENEMY_EFFECT">
	<text>You make fire that the Plasma Teleporter immediately moves to the enemy.
	Their ship is ablaze!</text>
	<playSound>dj_plasmaTeleporter</playSound>
	
	<item_modify>
		<item type="fuel" min="-1" max="-1"/>
	</item_modify>
	
	<damage amount="0" system="oxygen" effect="fire"/>
		
	<choice>
		<text>It's awful, but it will give us an edge. Continue to the fight!</text>
		<event>
			<enemyDamage amount="0" system="random" effect="fire"/>
			<enemyDamage amount="0" system="random" effect="fire"/>
			<enemyDamage amount="0" system="random" effect="fire"/>
		</event>
	</choice>	
</event>
<event name="DJMOD_COMBAT_SCORCH_BOTH_EFFECT">
	<text>A lot of fire is produced and mostly funneled through the Plasma Teleporter onto the enemy ship.
	Both ships are ablaze!</text>
	<playSound>dj_plasmaTeleporter_S</playSound>
	
	<item_modify>
		<item type="fuel" min="-1" max="-1"/>
	</item_modify>
	
	<damage amount="0" system="oxygen" effect="fire"/>
	
	<damage amount="0" system="room" effect="fire"/>
	<damage amount="0" system="room" effect="fire"/>
		 
	<choice>
		<text>Deal with the fire, but keep an eye on the enemy. Continue to the fight!</text>
		<event>
			<enemyDamage amount="0" system="random" effect="fire"/>
			<enemyDamage amount="0" system="random" effect="fire"/>
			<enemyDamage amount="0" system="random" effect="fire"/>
			<enemyDamage amount="0" system="random" effect="fire"/>
			<enemyDamage amount="0" system="random" effect="fire"/>
			
			<enemyDamage amount="0" system="random" effect="fire"/>
			<enemyDamage amount="0" system="random" effect="fire"/>
			<enemyDamage amount="0" system="random" effect="fire"/>	
		</event>
	</choice>
</event>

<!-- Spawns the "O2 Atmosphere" hazard to make fires unventable. MV Lua code means must change background.
See events_imageList.xml.append -->
<event name="DJMOD_OXYGENIZER_ACTIVATE">
	<text>Are you sure you want to do this?
	[Will envelop both ships in an O2 atmosphere, protecting fires and crew from venting and breaches. Costs 2}]</text>
	<choice req="loc_environment_atmosphere" lvl="0" max_lvl="0" blue="false" hidden="false">
		<text>Yes.</text>
		<event>
			<text>You fire the flash-release ultracompressed O2 grenades, enveloping the whole area in just enough atmosphere to breathe... or sustain fires!</text>
			<!-- <environment type="sun"/> It's Lua, not an "environment type". -->
			<changeBackground>BACK_DJMOD_OXYGENIZER_ACTIVATE</changeBackground>
			<item_modify>
				<item type="missiles" min="-2" max="-2"/>
			</item_modify>
			
			<!-- Extra pop-up screen needed for the O2 atmo to actually trigger. -->
			<choice>
				<text>This will give us the advantage!</text>
				<event/>
			</choice>
		</event>
	</choice>
	<choice req="loc_environment_atmosphere" blue="false" hidden="true">
		<text>You're already in atmosphere!</text>
		<event load="OPTION_INVALID" />
	</choice>
	<choice>
        <text>Do something else instead.</text>
        <event load="COMBAT_CHECK"/>
    </choice>
	<choice>
		<text>Nevermind, let's fight!</text>
		<event/>
	</choice>
</event> 
<!-- REF MV 5.5.1: SOLAR PANELS
<event name="STORAGE_CHECK_SOLAR_PANELS">
	<text>Are you sure you want to do this? 
	[Will spawn a sun and start fires, gives 3{ and 6}]</text>
	<choice req="loc_environment_atmosphere" lvl="0" max_lvl="0" blue="false" hidden="true">
		<text>Yes.</text>
		<event>
			<text>You draw closer to the nearest star, powering up the solar panels. In the meantime, you busy yourself with putting out the fires.</text>
			<environment type="sun"/>
			<damage amount="0" effect="fire" system="random"/>
			<damage amount="0" effect="fire" system="room"/>
			<item_modify>
				<item type="fuel" min="3" max="3"/>
				<item type="missiles" min="6" max="6"/>
			</item_modify>
		</event>
	</choice>
	<choice req="loc_environment_atmosphere" blue="false" hidden="true">
		<text>You cannot search for a star while in atmosphere.</text>
		<event load="OPTION_INVALID" />
	</choice>
	<choice>
		<text>Nevermind, do something else.</text>
		<event load="STORAGE_CHECK"/>
	</choice>
</event> -->


<!--
/////////////////////////////////////////////////////////////////////////////////////////////////////////
/////////////////////////////////////////////////////////////////////////////////////////////////////////
				EMERGENCY AUTO-REPAIR = A.E.R.A Second Wind
/////////////////////////////////////////////////////////////////////////////////////////////////////////
/////////////////////////////////////////////////////////////////////////////////////////////////////////
TODO
-Visual reminder that it's activated, for people who load the game into a fight.
-Fix calling this event, since tests revealed it works just fine when called from console with LOADEVENT. (wtf did i mean here?)
-->

<event name="DJMOD_COMBAT_CHECK_AUTO_SYS_REPAIR">
	<text>Are you sure you want to do this?
	[If hull reaches 5 points or less, you get repairs and lose the augment. Uses 1 power.]</text>
	
	<choice req="reactor" lvl="1" hidden="true" blue="false"> <!--It will require reserved reactor bars, so reactor needs at least this many bars.-->
		<text>Yes</text>
		<event>
			<text>You activate the augment...</text>
			<status type="loss" target="player" system="reactor" amount="1"/>
			<!--
			<variable name="autorepair_active" op="set" val="1"/>
			-->
			
			<!--<triggeredEvent event="CALLIE_PROBLEM" seeded="false" thisFight="true" clearOnJump="true" minTime="20.0" maxTime="20.0" loops="999"/>-->
			<triggeredEvent event="DJMOD_AUTO_SYS_REPAIR_TRIGGERED" thisFight="true">
				<!-- TODO : visual reminder that it's active, for people who load the game into a fight where this is On. -->
				<playerHull amount="5"/>
			</triggeredEvent>
			
			<choice>
				<text>Continue...</text>
				<event/>
			</choice>
		</event>
	</choice>
	
	<!-- An option for the Emergency Generator. 
	Reduces the power limited for the player (if any) and the Fuel consumption. (TEST) -->
	<choice req="DEBUG_GENERATOR">  
		<text>Power the augment with the Emergency Generator.</text>
		<event>
			<text>You activate the augment, fully powered by the Emergency Generator...</text>
			
			<triggeredEvent event="DJMOD_AUTO_SYS_REPAIR_TRIGGERED" thisFight="true">
				<!-- TODO : visual reminder that it's active, for people who load the game into a fight. -->
				<playerHull amount="5"/>
			</triggeredEvent>
			
			<choice>
				<text>Continue...</text>
				<event/>
			</choice>
		</event>
	</choice>
	
	<choice>
        <text>Do something else instead.</text>
        <event load="COMBAT_CHECK"/>
    </choice>
	<choice>
		<text>Nevermind, let's fight!</text>
		<event>
			<text>You decide not to do anything and prepare to fight.</text>
		</event>
	</choice>
</event>

<!-- v5.5.1 STILL WORKS. 
But test what happens if it DOESN'T trigger this fight and you don't reactivate before next fight (intended: no trigger) -->
<event name="DJMOD_AUTO_SYS_REPAIR_TRIGGERED">
	<text>All throughout your ship, you suddenly hear the reassuring sound of nanomachine bursts instantly repairing your systems!</text>
	
	<repairAllSystems/>
	<status type="clear" target="player" system="reactor" amount="100"/>
	
	<choice req="pilot" lvl="1" hidden="true" blue="false">
		<text>That's good.</text>
		
		<event>
			<text>The rest of the nanomachines hastily patch up your hull before ceasing to function.</text>

			<damage amount="-8"/>
			<remove name="DJMOD_AUG_AUTO_SYS_REPAIR"/>
			
			<choice>
				<text>Continue to the fight!</text>
				<event/>
			</choice>
			
		</event>
	</choice>
</event>


<!--
/////////////////////////////////////////////////////////////////////////////////////////////////////////
/////////////////////////////////////////////////////////////////////////////////////////////////////////
				HACK FLEET (ENIGMASHIN)
/////////////////////////////////////////////////////////////////////////////////////////////////////////
/////////////////////////////////////////////////////////////////////////////////////////////////////////
-->

<event name="DJMOD_HACK_FLEET">
	<text>Are you sure you want to do this?
	[Attempt special hacking to delay the fleet, cancelled by dealing more than 2 hull damage. Needs 17 seconds. Uses 2 |]</text>
	
	<!-- Choice hiding based on system presence and level WORKS! use as reference. -->
	<choice req="hacking" lvl="0" max_lvl="0" hidden="true" blue="false">
		<text>This requires a level 2 Hacking system installed on your ship.</text>
		<event load="OPTION_INVALID"/>
	</choice>
	
	<choice req="hacking" max_lvl="1" hidden="true" blue="false">
		<text>Your hacking system is too weak.</text>
		<event load="OPTION_INVALID"/>
	</choice>
	
	<choice req="hacking" lvl="2" hidden="true" blue="true">
		<text>(Hacking level 2) Yes</text>
		<event>
			<text>You activate the augment...</text>
			<item_modify>
				<item type="drones" min="-2" max="-2"/>
			</item_modify>
			
			<status type="loss" target="player" system="hacking" amount="2"/>
			
			<choice>
				<text>Continue...</text>
				<event load="DJMOD_HACK_FLEET_TIMER_START"/>
			</choice>
		</event>
	</choice>
	
	<choice>
        <text>Do something else instead.</text>
        <event load="COMBAT_CHECK"/>
    </choice>	
	<choice>
		<text>Nevermind, let's fight!</text>
		<event>
			<text>You decide not to do anything and prepare to fight.</text>
		</event>
	</choice>
</event>

<event name="DJMOD_HACK_FLEET_TIMER_START">
	<text>You start breaking into the enemy's comms. Now survive without damaging the enemy's hull too much...</text>
	
	<triggeredEvent event="DJMOD_HACK_FLEET_TIMER_END" time="17" thisFight="true"> <!--intended delay is 17s-->
		<triggeredEventBox load="DEFAULT_SMALL">
			<image r="255" g="50" b="255" a="0.6"/>
			<image2  r="255" g="50" b="255" a="0.6"/>
			<tooltip>The fleet delaying hack succeeds or fails in this amount of time. Cancelled if you deal 3 hull damage.</tooltip>
		</triggeredEventBox>
		<timerSounds load="DEFAULT_TIMER_SOUNDS"/>
	</triggeredEvent>
	
	<triggeredEvent event="DJMOD_HACK_FLEET_STOP" thisFight="true">
		<enemyDamage amount="3" countRepairs="true"/>
	</triggeredEvent>
	
	<playSound>dj_hackingZap2</playSound>
	
	<choice>
		<text>Continue to the fight!</text>
		<event/>
	</choice>
</event>
<event name="DJMOD_HACK_FLEET_TIMER_END">
	<text>The process is complete!</text>
	<clearTriggeredEvent name="DJMOD_HACK_FLEET_STOP"/>
	
	<status type="clear" target="player" system="hacking" amount="100"/>
	
	<choice hidden="true">
		<text> Let's see if it worked...</text>
		<event load="DJMOD_HACK_FLEET_OUTCOMES"/>
	</choice>
</event>

<eventList name="DJMOD_HACK_FLEET_OUTCOMES">
	<!-- Total good = -17 fleet chances / 13 -->
	<event load="DJMOD_HACK_FLEET_OUTCOME_GOOD"/>
	<event load="DJMOD_HACK_FLEET_OUTCOME_GOOD"/>
	<event load="DJMOD_HACK_FLEET_OUTCOME_GOOD"/>
	<event load="DJMOD_HACK_FLEET_OUTCOME_GOOD"/>
	<event load="DJMOD_HACK_FLEET_OUTCOME_GOOD"/>

	<event load="DJMOD_HACK_FLEET_OUTCOME_GOOD"/>
	<event load="DJMOD_HACK_FLEET_OUTCOME_GOOD"/>
	<event load="DJMOD_HACK_FLEET_OUTCOME_GOOD"/>
	<event load="DJMOD_HACK_FLEET_OUTCOME_GOOD"/>

	<event load="DJMOD_HACK_FLEET_OUTCOME_GOOD_CRITICAL"/>
	<event load="DJMOD_HACK_FLEET_OUTCOME_GOOD_CRITICAL"/>
	<event load="DJMOD_HACK_FLEET_OUTCOME_GOOD_CRITICAL"/>
	<event load="DJMOD_HACK_FLEET_OUTCOME_GOOD_CRITICAL"/>
	<!-- Total bad = +2 fleet chances / 7 -->
	<event load="DJMOD_HACK_FLEET_OUTCOME_NEUTRAL"/>
	<event load="DJMOD_HACK_FLEET_OUTCOME_NEUTRAL"/>
	<event load="DJMOD_HACK_FLEET_OUTCOME_NEUTRAL"/>
	<event load="DJMOD_HACK_FLEET_OUTCOME_NEUTRAL"/>
	<event load="DJMOD_HACK_FLEET_OUTCOME_NEUTRAL"/>
	
	<event load="DJMOD_HACK_FLEET_OUTCOME_BAD"/>
	<event load="DJMOD_HACK_FLEET_OUTCOME_BAD"/>
	<!-- Average = -15 fleet chances / 20 = 75% success -->
</eventList>
<event name="DJMOD_HACK_FLEET_OUTCOME_GOOD_CRITICAL">
	<text>Hehe, they really bought it! This hack gives us a solid advance.</text>
	<modifyPursuit amount="-2"/>
	<choice>
		<text>Continue to the fight!</text>
		<event/>
	</choice>
</event>
<event name="DJMOD_HACK_FLEET_OUTCOME_GOOD">
	<text>They fell for it! At least we get some rest out of this.</text>
	<modifyPursuit amount="-1"/>
	<choice>
		<text>Continue to the fight!</text>
		<event/>
	</choice>
</event>
<event name="DJMOD_HACK_FLEET_OUTCOME_NEUTRAL">
	<text>Unfortunately, they didn't fall for the hack this time.</text>
	<choice>
		<text>Continue to the fight!</text>
		<event/>
	</choice>
</event>
<event name="DJMOD_HACK_FLEET_OUTCOME_BAD">
	<text>This hack went terribly wrong, and their comms countered by giving away our location!</text>
	<modifyPursuit amount="1"/>
	<choice>
		<text>Continue to the fight!</text>
		<event/>
	</choice>
</event>

<event name="DJMOD_HACK_FLEET_STOP">
	<text>Excess damage to the enemy's hull ruined our hacking attempt to delay the rebel fleet. These things require subtlety!</text>
	<clearTriggeredEvent name="DJMOD_HACK_FLEET_TIMER_END"/>
	
	<status type="clear" target="player" system="hacking" amount="100"/>
	
	<choice>
		<text>Such a waste. But continue to the fight!</text>
		<event/>
	</choice>
</event>



