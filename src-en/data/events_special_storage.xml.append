NB- Console "EVENT" loads an event but also teleports you away. use "LOADEVENT" to test combat augments.

These automatically find the combat check event. Seems to NOT WORK unless placed at the top of this file. 

To avoid the SILENT BUG where the choice doesn't appear ingame even while we have the augment,
DO NOT make COMBAT_CHECK "Are you sure..." sentences too long. 
DO NOT use two sets of [] brackets.
DO NOT use the " symbol in the augment name or any of the event sentences.
One of these can make the choice never appear in the combat augment activation dialog,
and this isn't detected by Slipstream and doesn't cause a crash! -->


<!-- 
/////////////////////////////////////////////////////////////////////////////////////////////////////////
///////////////////////////////////////////// COMBAT CHECKS 
///////////////////////////////////////////// NB: COMBAT_CHECK_FAIL_REAL also exists but doesn't seem necessary.
/////////////////////////////////////////////////////////////////////////////////////////////////////////
-->

<mod:findName type = "event" name = "COMBAT_CHECK_REAL">
<mod-append:choice req="DJMOD_COMBAT_SHIPVORE_RAM_ANY" blue="false" max_group="0">			<!--adds the choice to the menu, "req" is the Blueprints name of the augment-->
	<text>(Shipvore Ram) Ram the enemy for repairs!</text> 
	<event load="DJMOD_COMBAT_CHECK_SHIPVORE_RAM"/>  <!--Loads the event you want to happen next. Using load can make code more organized, as well as saving a trace amount of loading time each sector-->
</mod-append:choice>
</mod:findName>
<!-- LOCKED_ version code is only different for disintegration. -->


<!-- INSTANT FIRE -->
<mod:findName type = "event" name = "COMBAT_CHECK_REAL">
<mod-append:choice req="DJMOD_COMBAT_SCORCH_ENEMY" blue="false">
	<text>(Plasma Teleporter) Set the enemy ship on fire!</text>
	<event load="DJMOD_COMBAT_CHECK_SCORCH_ENEMY"/>
</mod-append:choice>
</mod:findName>

<mod:findName type = "event" name = "COMBAT_CHECK_REAL">
<mod-append:choice req="DJMOD_OXYGENIZER" blue="false">
	<text>(Oxygenizer) Create an atmosphere!</text>
	<event load="DJMOD_OXYGENIZER_ACTIVATE"/>
</mod-append:choice>
</mod:findName>


<mod:findName type = "event" name = "COMBAT_CHECK_REAL">
<mod-append:choice req="DJMOD_AUG_AUTO_SYS_REPAIR" blue="false">
	<text>(AERA Second Wind) Activate the emergency autorepair!</text>
	<event load="DJMOD_COMBAT_CHECK_AUTO_SYS_REPAIR"/>
</mod-append:choice>
</mod:findName>

<mod:findName type = "event" name = "COMBAT_CHECK_REAL">
<mod-append:choice req="DJMOD_HACK_FLEET" blue="false">
	<text>(Enigmashin) Try to delay the rebels!</text>
