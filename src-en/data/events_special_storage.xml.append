<!--
\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\
\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\
				FLAMMABILIZER
\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\
\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\
-->

<event name="DJMOD_TOGGLE_FLAMMABILIZER_IMMUNE">
	<text>What power do you want to set the augment to?
	Current mode: Removes fire immunity</text>
	<choice hidden="true">
		<text>Set the augment to Damage Mode. [Enemies take more fire damage]</text>
		<event>
			<text>You start calibrating the augment...</text>
			<remove name="DJMOD_ENEMIES_CAN_BURN"/>
			<choice hidden="true">
				<text>Continue...</text>
				<event>
					<text>You finish calibrating the augment successfully.</text>
					<augment name="DJMOD_ENEMIES_BURN_MORE"/>
					<choice hidden="true">
						<text>Continue...</text>
						<event load="COMBAT_CHECK_TOGGLE_LOAD"/>
					</choice>
					<!--
					<text>You finish calibrating the augment successfully.</text>
					<augment name="DJMOD_ENEMIES_BURN_MORE"/>
					<choice blue="false" req="loc_flagship" lvl="0" max_group="1">
						<text>Continue...</text>
						<event load="COMBAT_CHECK"/>
					</choice>
					-->
				</event>
			</choice>
		</event>
	</choice>
	<choice hidden="true">
		<text>Return to the toggle menu.</text>
		<event load="COMBAT_CHECK_TOGGLE_LOAD"/>
	</choice>
</event>
<event name="DJMOD_TOGGLE_FLAMMABILIZER_DAMAGE">
	<text>What power do you want to set the augment to?
	Current mode: Enemies take more fire damage</text>
	<choice hidden="true">
		<text>Set the augment to Immune Mode. [Removes fire immunity]</text>
		<event>
			<text>You start calibrating the augment...</text>
			<remove name="DJMOD_ENEMIES_BURN_MORE"/>
			<choice hidden="true">
				<text>Continue...</text>
				<event>
					<text>You finish calibrating the augment successfully.</text>
					<augment name="DJMOD_ENEMIES_CAN_BURN"/>
					<choice hidden="true">
						<text>Continue...</text>
						<event load="COMBAT_CHECK_TOGGLE_LOAD"/>
					</choice>
					<!--
					<text>You finish calibrating the augment successfully.</text>
					<augment name="DJMOD_ENEMIES_CAN_BURN"/>
					<choice blue="false" req="loc_flagship" lvl="0" max_group="1">
						<text>Continue...</text>
						<event load="COMBAT_CHECK"/>
					</choice>
					-->
				</event>
			</choice>
		</event>
	</choice>
	<choice hidden="true">
		<text>Return to the toggle menu.</text>
		<event load="COMBAT_CHECK_TOGGLE_LOAD"/>
	</choice>
</event>



<!--
\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\
\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\
				PUNK HARMONY
\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\
\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\
-->

<event name="DJMOD_TOGGLE_HARMONY_ON">
	<text>What power do you want to set the augment to?
	Current mode: Enabled (On)</text>
	<choice hidden="true">
		<text>Turn off the augment.</text>
		<event>
			<text>You start calibrating the augment...</text>
			<remove name="DJMOD_OWN_HARMONY_ON"/>
			<choice hidden="true">
				<text>Continue...</text>
				<event>
					<text>You finish calibrating the augment successfully.</text>
					<augment name="DJMOD_OWN_HARMONY_OFF"/>
					<choice hidden="true">
						<text>Continue...</text>
						<event load="COMBAT_CHECK_TOGGLE_LOAD"/>
					</choice>
				</event>
			</choice>
		</event>
	</choice>

	<choice hidden="true">
		<text>Return to the toggle menu.</text>
		<event load="COMBAT_CHECK_TOGGLE_LOAD"/>
	</choice>	
</event>
<event name="DJMOD_TOGGLE_HARMONY_OFF">
	<text>What power do you want to set the augment to?
	Current mode: Disabled (Off)</text>
	<choice hidden="true">
		<text>Turn on the augment.</text>
		<event>
			<text>You start calibrating the augment...</text>
			<remove name="DJMOD_OWN_HARMONY_OFF"/>
			<choice hidden="true">
				<text>Continue...</text>
				<event>
					<text>You finish calibrating the augment successfully.</text>
					<augment name="DJMOD_OWN_HARMONY_ON"/>
					<choice hidden="true">
						<text>Continue...</text>
						<event load="COMBAT_CHECK_TOGGLE_LOAD"/>
					</choice>
				</event>
			</choice>
		</event>
	</choice>
	
	<choice hidden="true">
		<text>Return to the toggle menu.</text>
		<event load="COMBAT_CHECK_TOGGLE_LOAD"/>
	</choice>
</event>


<!--
\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\
\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\
				CREW ARE BOMBS aka CHARGED BELTS - Half a toggle, Half an empty beacon action.
\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\
\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\
-->

<event name="DJMOD_TOGGLE_CREW_ARE_BOMBS_OFF">
	<text>Are you sure to want to turn On this augment? WARNING: It cannot be turned Off, but can scrap itself at an empty beacon, or be sold normally.
	Current mode: Disabled (Off)</text>
	<choice hidden="true">
		<text>Turn on the augment.</text>
		<event>
			<text>You start calibrating the augment...</text>
			<remove name="DJMOD_CREW_ARE_BOMBS_OFF"/>
			<choice hidden="true">
				<text>Continue...</text>
				<event>
					<text>You finish calibrating the augment successfully.</text>
					<augment name="DJMOD_CREW_ARE_BOMBS_ON"/>
					<choice hidden="true">
						<text>Continue...</text>
						<event load="COMBAT_CHECK_TOGGLE_LOAD"/>
					</choice>
				</event>
			</choice>
		</event>
	</choice>
	
	<choice hidden="true">
		<text>Return to the toggle menu.</text>
		<event load="COMBAT_CHECK_TOGGLE_LOAD"/>
	</choice>
</event>

<event name="DJMOD_CREW_ARE_BOMBS_ON_SELFSCRAP">
	<text>Are you sure you want to scrap this augment for half value?
	[Only way to turn it Off if you can't sell or discard it right now.]</text>
	
	<choice req="DJMOD_CREW_ARE_BOMBS_ON" hidden="false" blue="false">
		<text>Yes, it's too dangerous.</text>
		<event>
			<!-- textless -->
			<item_modify>
				<item type="scrap" min="25" max="25"/>
			</item_modify>
			
			<remove name="DJMOD_CREW_ARE_BOMBS_ON"/>
		</event>
	</choice>
	<choice req="DJMOD_CREW_ARE_BOMBS_ON" hidden="false" blue="false">
		<text>Yes, but turn it into explosives.</text>
		<event>
			<item_modify>
				<item type="missiles" min="4" max="4"/>
			</item_modify>
			
			<remove name="DJMOD_CREW_ARE_BOMBS_ON"/>
		</event>
	</choice>
	<choice>
		<text>Nevermind, do something else.</text>
		<event load="STORAGE_CHECK"/>
	</choice>
</event>

