<event name="DJMOD_COMBAT_CHECK_DEFENSE_REMOVER">
	<text>Are you sure you want to do this?
	[Reduces enemy defenses at random intervals. Uses 3 reactor power]</text>
		
	<choice req="DEBUG_GENERATOR">
		<text>Power the augment with the Emergency Generator, for 40 seconds.</text>
		<event>
			<text>You activate the augment...</text>
			<item_modify>
				<item type="drones" min="-2" max="-2"/>
			</item_modify>
			
			<choice>
				<text>Continue...</text>
				<event load="DJMOD_DEFENSE_REMOVER_TIMER_START_LOW"/>
			</choice>
		</event>
	</choice>
	<choice req="reactor" lvl="3" hidden="false" blue="false">
		<text>Yes, for 40 seconds</text>
		<event>
			<text>You activate the augment...</text>
			<item_modify>
				<item type="drones" min="-2" max="-2"/>
			</item_modify>
			
			<status type="loss" target="player" system="reactor" amount="3"/>
			
			<choice>
				<text>Continue...</text>
				<event load="DJMOD_DEFENSE_REMOVER_TIMER_START_LOW"/>
			</choice>
		</event>
	</choice>
	
	<choice req="DEBUG_GENERATOR">
		<text>Power the augment with the Emergency Generator, for 75 seconds.</text>
		<event>
			<text>You activate the augment...</text>
			<item_modify>
				<item type="drones" min="-4" max="-4"/>
			</item_modify>
			
			<choice>
				<text>Continue...</text>
				<event load="DJMOD_DEFENSE_REMOVER_TIMER_START_HIGH"/>
			</choice>
		</event>
	</choice>
	<choice req="reactor" lvl="3" hidden="false" blue="false">
		<text>Yes, for 75 seconds</text>
		<event>
			<text>You activate the augment...</text>
			<item_modify>
				<item type="drones" min="-4" max="-4"/>
			</item_modify>
			
			<status type="loss" target="player" system="reactor" amount="3"/>
			
			<choice>
				<text>Continue...</text>
				<event load="DJMOD_DEFENSE_REMOVER_TIMER_START_HIGH"/>
			</choice>
		</event>
	</choice>
	
	<choice>
        <text>Do something else instead.</text>
        <event load="COMBAT_CHECK"/>
    </choice>
	<choice>
		<text>Nevermind, let's fight!</text>
		<event>
			<text>You decide not to do anything and prepare to fight.</text>
		</event>
	</choice>
</event>

<event name="DJMOD_DEFENSE_REMOVER_TIMER_START_LOW">
	<text>The enemy's defense will slowly be removed. Survive!</text>
	
	<triggeredEvent event="DJMOD_DEFENSE_REMOVER_STEP_FINAL" time="40" thisFight="true">		<!-- worst effect 7*6s = 42s -->
	<!-- <triggeredEvent event="CALLIE_PROBLEM" seeded="false" thisFight="true" clearOnJump="true" minTime="20.0" maxTime="20.0" loops="999"/> -->
		<triggeredEventBox load="DEFAULT_SMALL">
			<image r="255" g="50" b="255" a="0.6"/>
			<image2  r="255" g="50" b="255" a="0.6"/>
			<tooltip>The enemy's defenses stop being limited in this amount of time.</tooltip>
		</triggeredEventBox>
		<timerSounds load="DEFAULT_TIMER_SOUNDS"/>
		
		<!-- <warningMessage image="_image_" id="test_id" x="0" y="0" time="5.0" centerText="true" flash="true" r="253" g="84" b="70" sound="_sound_"((see sounds.xml)) useWarningLine="true">Text</warningMessage> -->
		<warningMessage id="warning_defense_remover_end" x="392" y="84" time="7.0" centerText="true" flash="true" r="255" g="50" b="255" useWarningLine="false"/>
	</triggeredEvent>
	
	<choice hidden="true">
		<text>Continue to the fight!</text>
		<event>
			<!-- <triggeredEvent event="DJMOD_DEFENSE_REMOVER_STEP_OUTCOMES" time="10" thisFight="true" loops="5"/> -->
			<triggeredEvent event="DJMOD_DEFENSE_REMOVER_STEP_BOTH_1" minTime="3.0" maxTime="7.0" thisFight="true"/>
		</event>
	</choice>
</event>
<event name="DJMOD_DEFENSE_REMOVER_TIMER_START_HIGH">
	<text>The enemy's defense will slowly be removed. Survive!</text>
		
	<triggeredEvent event="DJMOD_DEFENSE_REMOVER_STEP_FINAL" time="75" thisFight="true">		<!-- worst effect 7*11s = 77s -->
	<!-- <triggeredEvent event="CALLIE_PROBLEM" seeded="false" thisFight="true" clearOnJump="true" minTime="20.0" maxTime="20.0" loops="999"/> -->
		<triggeredEventBox load="DEFAULT_SMALL">
			<image r="255" g="50" b="255" a="0.6"/>
			<image2  r="255" g="50" b="255" a="0.6"/>
			<tooltip>The enemy's defenses stop being limited in this amount of time.</tooltip>
		</triggeredEventBox>
		<timerSounds load="DEFAULT_TIMER_SOUNDS"/>
		
		<!-- <warningMessage image="_image_" id="test_id" x="0" y="0" time="5.0" centerText="true" flash="true" r="253" g="84" b="70" sound="_sound_"((see sounds.xml)) useWarningLine="true">Text</warningMessage> -->
		<warningMessage id="warning_defense_remover_end" x="392" y="84" time="7.0" centerText="true" flash="true" r="255" g="50" b="255" useWarningLine="true"/>
	</triggeredEvent>
	
	<choice hidden="true">
		<text>Continue to the fight!</text>
		<event>
			<!-- <triggeredEvent event="DJMOD_DEFENSE_REMOVER_STEP_OUTCOMES" time="10" thisFight="true" loops="10"/> Try seeded="false" -->
			<triggeredEvent event="DJMOD_DEFENSE_REMOVER_STEP_BOTH_1" minTime="3.0" maxTime="7.0" thisFight="true"/>
		</event>
	</choice>
</event>

