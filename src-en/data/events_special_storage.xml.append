<event name="STORAGE_CHECK_SYSTEM_DJMOD_RADIKAL_INTERNAL_DJMOD_DEMICLONER">
	<text>You are about to install the Demicloner upgrade.
	[Effects: The RadiKal Punk infused these backpack-clonebay prototypes with dark energies. These try to resurrect your crew if they die (not in events) when you don't have a real Clonebay.
		At best, crew resurrect as their own lesser version (Soldier = default Human, etc.) If no lesser version exists, they become Morphs. When Morphs die, nothing happens.]
	</text>

	<choice req="EX_DJMOD_DEMICLONER" blue="true" hidden="true">
		<text>Install the External Augment internally.</text>
		<event>
			<text>You install the upgrade.</text>
			<remove name="EX_DJMOD_DEMICLONER"/>
			<choice hidden="true">
				<text>Continue...</text>
				<event load="INSTALL_INTERNAL_DJMOD_DEMICLONER"/>
			</choice>
		</event>
	</choice>
	
	<choice req="DJMOD_HAS_RADIKAL_PUNK_GEAR" lvl="0" max_lvl="0" blue="false" hidden="true">
		<text>This upgrade is unavailable. You need any RadiKal Punk (or BPS) weapon or augment.</text>
		<event load="OPTION_INVALID"/>
	</choice>
	
	<choice req="DJMOD_HAS_RADIKAL_PUNK_GEAR" lvl="1" blue="false" hidden="true">
		<text>Perform the upgrade. [Cost: 50~, 1{]</text>
		<event>
			<text>You install the upgrade.</text>
			<item_modify>
				<item type="scrap" min="-50" max="-50"/>
				<item type="fuel" min="-1" max="-1"/>
			</item_modify>
			<choice hidden="true">
				<text>Continue...</text>
				<event load="INSTALL_INTERNAL_DJMOD_DEMICLONER"/>
			</choice>
		</event>
	</choice>
	<choice req="pilot" lvl="1" max_group="2" blue="false" hidden="true">
		<text>Nevermind.</text>
		<event load="STORAGE_CHECK_SYSTEM_LOAD"/>
	</choice>
</event>
<event name="INSTALL_INTERNAL_DJMOD_DEMICLONER">
	<variable name="loc_internal_upgrades" op="add" val="1"/>
	<hiddenAug>INTERNAL_DJMOD_DEMICLONER</hiddenAug>
	<loadEvent>STORAGE_CHECK_SYSTEM</loadEvent>
</event>


