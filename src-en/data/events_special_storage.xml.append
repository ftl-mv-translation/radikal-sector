From events_special_multiverse.xml (v5.5.1)
Only "DEFAULT_TIMER" became "DEFAULT_SMALL", but i took more context this time.

<event>
	<text>You raise your weapons against Sylvan, ready to battle. "Ssstranger, ssso it'sss come to thisss? A true ssshame... and to think I thought we could be friendsss..."</text>
	<playMusic>sylvan</playMusic>
	<variable name="loc_sylvanattacked" op="set" val="1"/>
	<deathEvent thisFight="true">DEATH_TO_SYLVAN</deathEvent>
	<boarders min="3" max="3" class="slug_clansman"/>
	<triggeredEvent event="STOP_MUSIC" jumps="1"/>

	<triggeredEvent event="SHIELD_SURGE_SYLVAN" seeded="false" loops="999999999" thisFight="true" minTime="60.0" maxTime="60.0">
		<warningMessage id="warning_shield_surge_player" x="692" y="84" time="5.0" centerText="true" flash="true" sound="surgeWarning" useWarningLine="true"/>
		<triggeredEventBox load="DEFAULT_SMALL" pos="combat">
			<warning time="10.0" flash="true"/>
			<tooltip>Sylvan's shields will regenerate in this long.</tooltip>
		</triggeredEventBox>
	</triggeredEvent>

	<ship hostile="true"/>
	<choice hidden="true">
		<text>Continue...</text>
		<event load="COMBAT_CHECK"/>
	</choice>
</event>

