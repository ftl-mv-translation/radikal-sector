<!--
/////////////////////////////////////////////////////////////////////////////////////////////////////////
/////////////////////////////////////////////////////////////////////////////////////////////////////////
				SHIPVORE RAM
/////////////////////////////////////////////////////////////////////////////////////////////////////////
/////////////////////////////////////////////////////////////////////////////////////////////////////////

The Shipvore Ram COMBAT_ augment tries to eat the enemy ship (deals damage) after a delay, 
and usually repairs yours or finds something useful.
This can promote a stalling playstyle followed by a supposedly finisher move, to benefit from the free repairs and goodies.

Effects on player ship can't be done in the same step as effects on the enemy, so split them.
Events need unique names, else it might crash the game!

TODO: 
-Debug the Lua checking for enemy HP before asking for repeat ram. It causes the random outcome to always be BAD CREW 2.
-Make outcomes more influenced by ship composition (levels of Engines, Doors, Cloaking, Piloting. Clonebay and MC already included.)
-->

<event name="DJMOD_COMBAT_CHECK_SHIPVORE_RAM">
	<text>Are you sure you want to do this?
	[Ram the enemy ship, high chance to repair your ship. WARNING: may go wrong!]</text>
	
	<variable name="shipvore_ram_full_power" op="set" val="0"/>
	<variable name="locked_shipvore_ram_full_power" op="set" val="0"/>
	<variable name="shipvore_ram_used_fuel" op="set" val="0"/>
	
	<choice>
		<text>Yes [Needs 10 seconds.]</text>
		<event>
			<text>You activate the augment...</text>
			
			<item_modify>
				<item type="fuel" min="-1" max="-1"/>	<!--The min -1 and max -2 order is tested, and though wrong (-2 < -1), works as intended. min -0 and max -1 does Not work. -->
			</item_modify>       
			<variable name="shipvore_ram_used_fuel" op="set" val="1"/>
			
			<choice>
				<text>Continue...</text>
				<event load="DJMOD_COMBAT_SHIPVORE_RAM_TIMER_START"/>
			</choice>
		</event>
	</choice>

	<choice req="DEBUG_GENERATOR">
		<text>(Emergency generator) Yes, using no fuel.</text>
		<event load="DJMOD_COMBAT_SHIPVORE_RAM_TIMER_START"/>
	</choice>
	<choice req="FUEL_CONSERVER" hidden="true">  
		<text>(Fuel Conserver) Yes, using no fuel.</text>
		<event load="DJMOD_COMBAT_SHIPVORE_RAM_TIMER_START"/>
	</choice>


	<choice req="DJMOD_COMBAT_SHIPVORE_RAM_REINFORCED" blue="true"> 
		<text>(Reinforced Shipvore Ram) Yes, at full power!
		[You'll lose the reinforcement. Can't ram again until next jump. Needs 7 seconds.]</text>
		<event>
			<text>You activate the augment at full power...</text>
			
			<item_modify>
				<item type="fuel" min="-4" max="-4"/>
			</item_modify>
			<variable name="shipvore_ram_used_fuel" op="set" val="4"/>
			<variable name="shipvore_ram_full_power" op="set" val="1"/>
			
			<choice>
				<text>Continue to the fight!</text>
				<event load="DJMOD_COMBAT_SHIPVORE_RAM_TIMER_START_FULL_POWER"/>
			</choice>
		</event>
	</choice>
	<choice req="DJMOD_COMBAT_SHIPVORE_RAM_NOT_REINFORCED" blue="false"> 
		<text>Yes, at full power!
		[The augment will disintegrate. Needs 7 seconds.]</text>
		<event>
			<text>You activate the augment at full power...</text>
			
			<item_modify>
				<item type="fuel" min="-4" max="-4"/>
			</item_modify>
			<variable name="shipvore_ram_used_fuel" op="set" val="4"/>
			<variable name="shipvore_ram_full_power" op="set" val="1"/>
			
			<choice>
				<text>Continue to the fight!</text>
				<event load="DJMOD_COMBAT_SHIPVORE_RAM_TIMER_START_FULL_POWER"/>
			</choice>
		</event>
	</choice>
	<choice req="LOCKED_DJMOD_COMBAT_SHIPVORE_RAM" blue="false">  
		<text>Yes, at full power!
		[Can't ram again until next jump. Needs 7 seconds.]</text>
		<event>
			<text>You activate the augment at full power...</text>
			
			<item_modify>
				<item type="fuel" min="-4" max="-4"/>
			</item_modify>
			<variable name="shipvore_ram_used_fuel" op="set" val="3"/>
			
			<variable name="locked_shipvore_ram_full_power" op="set" val="1"/>
			
			<choice>
				<text>Continue to the fight!</text>
				<event load="DJMOD_COMBAT_SHIPVORE_RAM_TIMER_START_FULL_POWER"/>
			</choice>
		</event>
	</choice>
	
	<choice>
        <text>Do something else instead.</text>
        <event load="COMBAT_CHECK"/>
    </choice>
	<choice>
		<text>Nevermind, let's fight!</text>
		<event>
			<text>You decide not to do anything and prepare to fight.</text>
		</event>
	</choice>
</event>

<!-- Now textless! -->
<event name="DJMOD_COMBAT_SHIPVORE_RAM_TIMER_START">
	<!--Timer that triggers another event when it reaches 0, such as how the MV combat augments expire after a certain time-->
	<triggeredEvent event="DJMOD_COMBAT_SHIPVORE_RAM_TIMER_END" time="10" thisFight="true"> <!--intended delay is 20s-->
	<!-- <triggeredEvent event="CALLIE_PROBLEM" seeded="false" thisFight="true" clearOnJump="true" minTime="20.0" maxTime="20.0" loops="999"/> -->
		<triggeredEventBox load="DEFAULT_SMALL">
			<image r="255" g="127" b="0" a="0.6"/>
			<image2  r="255" g="127" b="0" a="0.6"/>
			<tooltip>You will be ready to ram the enemy ship in this amount of time.</tooltip>
		</triggeredEventBox>
		<timerSounds load="DEFAULT_TIMER_SOUNDS"/>
		<!-- <warningMessage image="_image_" id="test_id" x="0" y="0" time="5.0" centerText="true" flash="true" r="253" g="84" b="70" sound="_sound_"((see sounds.xml)) useWarningLine="true">Text</warningMessage> -->
		<warningMessage id="warning_shipvore_ram_almost" x="692" y="84" time="1.7" centerText="true" flash="false" sound="dj_enginesChargingUp" useWarningLine="false"/>
	</triggeredEvent>
</event>
<event name="DJMOD_COMBAT_SHIPVORE_RAM_TIMER_START_FULL_POWER">
	<!-- <text>Your ship starts lining up with the enemy...</text> -->
		
	<triggeredEvent event="DJMOD_COMBAT_SHIPVORE_RAM_TIMER_END_FULL_POWER" time="7" thisFight="true">
		<triggeredEventBox load="DEFAULT_SMALL">
			<image r="255" g="127" b="0" a="0.6"/>
			<image2  r="255" g="127" b="0" a="0.6"/>
			<tooltip>You will be fully powered to ram the enemy ship in this amount of time.</tooltip>
		</triggeredEventBox>
		<timerSounds load="DEFAULT_TIMER_SOUNDS"/>
		<warningMessage id="warning_shipvore_ram_almost" x="692" y="84" time="1.7" centerText="true" flash="false" sound="dj_enginesChargingUp" useWarningLine="false"/>
	</triggeredEvent>
	
	<!-- <choice>
		<text>Continue to the fight!</text>
		<event/>
	</choice> -->
</event>


<event name="DJMOD_COMBAT_SHIPVORE_RAM_TIMER_END">
	<text>Ready to ram! Proceed?</text>

	<choice hidden="true">
		<text>Let's go!</text>
		<event load="SHIPVORE_RAM_ATTACK_OUTCOMES"/>
	</choice>
	
	<choice req="shipvore_ram_used_fuel" lvl="0" max_lvl="0" blue="false">
		<text>Abort. (No { was used)</text>
		<event>			
			<variable name="shipvore_ram_full_power" op="set" val="0"/>
			<variable name="locked_shipvore_ram_full_power" op="set" val="0"/>
		</event>
	</choice>
	<choice req="shipvore_ram_used_fuel" lvl="1" max_lvl="1" blue="false">
		<text>Abort, and retrieve any non consumed {.</text>
		<event>
			<item_modify>
				<item type="fuel" min="+1" max="+1"/>
			</item_modify>
			
			<variable name="shipvore_ram_full_power" op="set" val="0"/>
			<variable name="locked_shipvore_ram_full_power" op="set" val="0"/>
		</event>
	</choice>
</event>

<event name="DJMOD_COMBAT_SHIPVORE_RAM_TIMER_END_FULL_POWER">
	<text>Fully ready to ram! Proceed?</text>
	
	<choice req="DJMOD_COMBAT_SHIPVORE_RAM_REINFORCED_AT_FULL_POWER" lvl="1" hidden="true">
		<text>(Full power) Give it your all! [You'll lose reinforcement on the augment.]</text>
		
		<event>
			<text>Your augment's reinforcement melts away...</text>
			<playSound>dj_enginesChargingUp_FP</playSound>
			
			<variable name="shipvore_ram_reinforcement" op="add" val="-1"/>
			<variable name="shipvore_ram_full_power" op="set" val="0"/>

			<choice>
				<text>Continue...</text>
				<event load="SHIPVORE_RAM_ATTACK_OUTCOMES_FULL_POWER"/>
			</choice>
		</event>
	</choice>
	<choice req="DJMOD_COMBAT_SHIPVORE_RAM_NOT_REINFORCED_AT_FULL_POWER" lvl="1" hidden="false">
		<text>(Full power) Give it your all! [Reinforce the augment at empty beacons so it doesn't disintegrate.]</text>
		
		<event>
			<text>Your augment disintegrates...</text>
			<playSound>dj_enginesChargingUp_FP</playSound>
			
			<remove name="DJMOD_COMBAT_SHIPVORE_RAM"/>
			<variable name="shipvore_ram_full_power" op="set" val="0"/>

			<choice>
				<text>Continue...</text>
				<event load="SHIPVORE_RAM_ATTACK_OUTCOMES_FULL_POWER"/>
			</choice>
		</event>
	</choice>

	<choice req="locked_shipvore_ram_full_power" lvl="1" hidden="true">
		<text>(Full power) It's us or them! [Cannot ram again until you jump.]</text>
		
		<event>
			<text>You strongly feel your engines charging up...</text>
			<playSound>dj_enginesChargingUp_FP</playSound>

			<variable name="locked_shipvore_ram_full_power" op="set" val="0"/>
			
			<choice hidden="true">
				<text>Continue...</text>
				<event load="SHIPVORE_RAM_ATTACK_OUTCOMES_FULL_POWER"/>
			</choice>
		</event>
	</choice>
	
	<choice>
		<text>Abort, and retrieve any non consumed {.</text>
		<event>
			<item_modify>
				<item type="fuel" min="+1" max="+4"/>	<!-- must never be more than Full Power costed. -->
			</item_modify>
			
			<variable name="shipvore_ram_full_power" op="set" val="0"/>
			<variable name="locked_shipvore_ram_full_power" op="set" val="0"/>
		</event>
	</choice>
</event>


<!-- ===========================================================================================================
============================     ENEMY OUTCOMES    =============================================================
================================================================================================================

NB: damageHull="false" DOES NOT WORK on player damage, only the Hyperspace tag <enemyDamage>. The hull is still damaged.
Instead we use jank like this, which DOES NOT KILL ships if the damage brings them below 1 HP before the heal happens, as long as it's in the SAME PROMPT! :
<event name="MV_DRIVE_EXPLODE">
    <damage amount="1" system="engines"/>
    <damage amount="-1"/>
</event>

An event list can be used to add randomness, the game will attempt to pick 
any one of these events from the list if it is loaded by a previous event.
Adding multiple copies of an outcome increases its likelihood!-->
<eventList name="SHIPVORE_RAM_ATTACK_OUTCOMES">
	<event load="SHIPVORE_RAM_ATTACK_OUTCOME_GOOD_1"/>
	<event load="SHIPVORE_RAM_ATTACK_OUTCOME_GOOD_1"/>
	
	<event load="SHIPVORE_RAM_ATTACK_OUTCOME_GOOD_2"/>

	<event load="SHIPVORE_RAM_ATTACK_OUTCOME_GOOD_3"/>
	
	<event load="SHIPVORE_RAM_ATTACK_OUTCOME_BAD_1"/>

	<event load="SHIPVORE_RAM_ATTACK_OUTCOME_BAD_2"/>
</eventList>

<!-- Full power outcomes on the enemy don't need to be separate, they're just greater. -->
<eventList name="SHIPVORE_RAM_ATTACK_OUTCOMES_FULL_POWER">
	<event load="SHIPVORE_RAM_ATTACK_FP_OUTCOME_GOOD_1"/>
	<event load="SHIPVORE_RAM_ATTACK_FP_OUTCOME_GOOD_1"/>
	
	<event load="SHIPVORE_RAM_ATTACK_FP_OUTCOME_GOOD_2"/>
	<event load="SHIPVORE_RAM_ATTACK_FP_OUTCOME_GOOD_2"/>

	<event load="SHIPVORE_RAM_ATTACK_FP_OUTCOME_GOOD_3"/>
	
	<event load="SHIPVORE_RAM_ATTACK_FP_OUTCOME_GOOD_3B"/>

	<event load="SHIPVORE_RAM_ATTACK_FP_OUTCOME_GOOD_4"/>

	<event load="SHIPVORE_RAM_ATTACK_FP_OUTCOME_GOOD_4B"/>
</eventList>


<event name="SHIPVORE_RAM_ATTACK_OUTCOME_GOOD_1">
	<text>You rip out a small part of the enemy ship, dealing 3 damage...</text>
	<enemyDamage amount="3" system="random" effect="breach" force="true"/>
	<!-- <enemyDamage amount="1" system="sys" effect="eff" force="false" damageHull="true"/>
	Same syntax as vanilla's <damage> but afflicts the enemy ship. If force="true" then bypasses all system damage resistances.
	If damageHull="false" then do not inflict hull damage.-->
	<choice hidden="true">
		<text>...with this result on your own ship (75% chance good)...</text>
		<event load="SHIPVORE_RAM_OWN_OUTCOMES"/>
	</choice>
</event>
<event name="SHIPVORE_RAM_ATTACK_OUTCOME_GOOD_2">
	<text>You tear through the enemy ship's hull for a solid 4 damage...</text>
	<enemyDamage amount="4" system="room" effect="breach" force="true"/>
	
	<choice hidden="true">
		<text>...with this result on your own ship (75% chance good).</text>
		<event load="SHIPVORE_RAM_OWN_OUTCOMES"/>
	</choice>
</event>
<event name="SHIPVORE_RAM_ATTACK_OUTCOME_GOOD_3">
