<event name="DJMOD_SCORCH_SELF_UPGRADE">
	<text>Are you sure you want to upgrade this augment?
	[More fire resistance. In fire: x2 movement and sabotage speed, x2 damage.]</text>
	
	<choice req="DJMOD_COMBAT_SCORCH_SELF" hidden="true" blue="false">
		<text>Yes [-19~, -2}, -2 |]</text>
		<event>
			<text>You start upgrading the augment...</text>
			<item_modify>
				<item type="scrap" min="-19" max="-19"/>
				<item type="missiles" min="-2" max="-2"/>
				<item type="drones" min="-2" max="-2"/>
			</item_modify>
			
			<remove name="DJMOD_COMBAT_SCORCH_SELF"/>
			<choice hidden="true">
				<text>Continue...</text>
				<event>
					<text>You finish upgrading the augment successfully.</text>
					<augment name="DJMOD_COMBAT_SCORCH_SELF_2"/>
					<choice>
						<text>Success!</text>
						<event/>
					</choice>
				</event>
			</choice>
		</event>
	</choice>
	<choice>
		<text>Nevermind, do something else.</text>
		<event load="STORAGE_CHECK"/>
	</choice>
</event>

<event name="DJMOD_SCORCH_SELF_UPGRADE_2">
	<text>Are you sure you want to upgrade this augment?
	[More fire resistance. In fire: your crew produce O2 like 2 Orchids, and enemy crew and drones lose 7 HP/second.]</text>
	
	<choice req="DJMOD_COMBAT_SCORCH_SELF_2" hidden="true" blue="false">
		<text>Yes [-36~, -2}, -1 |, the fleet advances for 1 turn]</text>
		<event>
			<text>You start upgrading the augment...</text>
			<item_modify>
				<item type="scrap" min="-36" max="-36"/>
				<item type="missiles" min="-2" max="-2"/>
				<item type="drones" min="-1" max="-1"/>
			</item_modify>
			<modifyPursuit amount="1"/>
			
			<remove name="DJMOD_COMBAT_SCORCH_SELF_2"/>
			<choice hidden="true">
				<text>Continue...</text>
				<event>
					<text>You finish upgrading the augment successfully.</text>
					<augment name="DJMOD_COMBAT_SCORCH_SELF_3"/>
					<choice>
						<text>Success!</text>
						<event/>
					</choice>
				</event>
			</choice>
		</event>
	</choice>
	<choice>
		<text>Nevermind, do something else.</text>
		<event load="STORAGE_CHECK"/>
	</choice>
</event>

