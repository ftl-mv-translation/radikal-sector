	[Effects: Corruptor system heals all Soulplague-aligned crew in the target room for 8 HP each time it spawns a Soulplague Tide.]</text>
	<choice req="dd_corruptor" lvl="1" max_group="0" blue="false" hidden="true">
		<text>Perform the upgrade. [Cost: 45~, 3{]</text>
		<event>
			<text>You install the upgrade.</text>
			<item_modify>
				<item type="fuel" min="-3" max="-3"/>
				<item type="scrap" min="-45" max="-45"/>
			</item_modify>
			<choice hidden="true">
				<text>Continue...</text>
				<event load="INSTALL_DDCORRUPTOR_MATTERDISPERSER"/>
			</choice>
		</event>
	</choice>
	<choice req="pilot" lvl="1" max_group="2" blue="false" hidden="true">
		<text>Nevermind.</text>
		<event load="STORAGE_CHECK_SYSTEM_LOAD"/>
	</choice>
</event>
<event name="INSTALL_DDCORRUPTOR_MATTERDISPERSER">
	<variable name="loc_internal_upgrades" op="add" val="1"/>
	<hiddenAug>DD_INTERNAL_AUGMENT1</hiddenAug>
	<loadEvent>STORAGE_CHECK_SYSTEM</loadEvent>
</event>
-->
<mod:findName type="event" name="STORAGE_CHECK_SYSTEM">
	<mod-append:choice req="pilot" hidden="true" blue="true">
		<text>RadiKal tech.</text>
		<event load="STORAGE_CHECK_SYSTEM_DJMOD_RADIKAL"/>
	</mod-append:choice>
</mod:findName>


<mod:findName type="event" name="STORAGE_CHECK_INVENTORY_UPGRADES">
	<mod-append:choice hidden="true" req="INTERNAL_DJMOD_MC_IMMUNE_FROM_FIRE" lvl="1" blue="false">
		<text>Mind Heater [Installed]</text>
		<event load="STORAGE_CHECK_SYSTEM_DJMOD_RADIKAL"/>
	</mod-append:choice>
	<mod-append:choice hidden="true" req="INTERNAL_DJMOD_MC_IMMUNE_FROM_FIRE" lvl="0" max_lvl="0" blue="false">
		<text>Mind Heater [Not Installed]</text>
		<event load="OPTION_INVALID"/>
	</mod-append:choice>

	<mod-append:choice hidden="true" req="INTERNAL_DJMOD_DEMICLONER" lvl="1" blue="false">
		<text>Demicloners [Installed]</text>
		<event load="STORAGE_CHECK_SYSTEM_DJMOD_RADIKAL"/>
	</mod-append:choice>
	<mod-append:choice hidden="true" req="INTERNAL_DJMOD_DEMICLONER" lvl="0" max_lvl="0" blue="false">
		<text>Demicloners [Not Installed]</text>
		<event load="OPTION_INVALID"/>
	</mod-append:choice>
</mod:findName>


<event name="STORAGE_CHECK_SYSTEM_DJMOD_RADIKAL">
	<text>What upgrade do you want to install?</text>
	
	<choice req="INTERNAL_DJMOD_MC_IMMUNE_FROM_FIRE" lvl="1" blue="false" hidden="true">
		<text>RK Scorch "Mind Heater": In fire, your crew are immune to Mind Control and stunned 50% shorter, on both ships. [ALREADY INSTALLED]</text>
		<event load="OPTION_INVALID"/>
	</choice>
	<choice req="INTERNAL_DJMOD_MC_IMMUNE_FROM_FIRE" lvl="0" max_lvl="0" blue="false" hidden="true">
		<text>Mind Heater. [Cost: 25~, 1{]</text>
		<event load="STORAGE_CHECK_SYSTEM_DJMOD_RADIKAL_INTERNAL_DJMOD_MC_IMMUNE_FROM_FIRE"/>
	</choice>

	<choice req="INTERNAL_DJMOD_DEMICLONER" lvl="1" blue="false" hidden="true">
		<text>RK Punk "Demicloners": With no Clonebay, your dying crew resurrect as a lesser version (Soldier = default Human, etc.)
			If none exists, they become Morphs. When Morphs die, nothing happens. Does not work for event deaths. [ALREADY INSTALLED]
		</text>
		<event load="OPTION_INVALID"/>
	</choice>
	<choice req="INTERNAL_DJMOD_DEMICLONER" lvl="0" max_lvl="0" blue="false" hidden="true">
		<text>Demicloners. [Cost: 50~, 1{]</text>
		<event load="STORAGE_CHECK_SYSTEM_DJMOD_RADIKAL_INTERNAL_DJMOD_DEMICLONER"/>
	</choice>

	<choice>
		<text>Nevermind.</text>
		<event load="STORAGE_CHECK_SYSTEM_LOAD"/>
	</choice>
</event>
