</event>


<event name="DJMOD_SCORCH_ENEMY_PAY_CREW">
	<text>What type of crew? [Will be consumed, can be cloned]</text>
	
	<choice req="DJMOD_HAS_CREW_ARE_BOMBS_AND_CREW" hidden="true"> 
		<text>(Charged Belts) Anyone!</text>
		<event>
			<text>The closest crew is consumed for the greater good, activating the augment!</text>
			<removeCrew>														<!--No class argument means it's a random crewmember.-->
				<clone>true</clone>
				<text>Your clonebay successfully revived your crew.</text>		<!--Since this is event-based, it's instant. There is still a cost in the skill loss though.-->
			</removeCrew>
			
			<choice hidden="true">
				<text>Continue...</text>
				<event load="DJMOD_COMBAT_SCORCH_ENEMY_EFFECT"/>
			</choice>
		</event>
	</choice>
	<choice req="DJMOD_HAS_DEATH_VESTS_AND_CREW" hidden="true"> 
		<text>(Martyr Vests) Anybody!</text>
		<event>
			<text>The closest crew is consumed for the greater good, activating the augment!</text>
			<removeCrew>														<!--No class argument means it's a random crewmember.-->
				<clone>true</clone>
				<text>Your clonebay successfully revived your crew.</text>		<!--Since this is event-based, it's instant. There is still a cost in the skill loss though.-->
			</removeCrew>
			
			<choice hidden="true">
				<text>Continue...</text>
				<event load="DJMOD_COMBAT_SCORCH_ENEMY_EFFECT"/>
			</choice>
		</event>
	</choice>
	
	<!-- *******************************
	Sub-lists
	******************************* -->
	<choice req="LIST_CREW_SHELL" hidden="true"> 
		<text>A shell...</text>
		<event load="DJMOD_SCORCH_ENEMY_PAY_CREW_SHELLS"/>
	</choice>
	<choice req="LIST_CREW_ZOLTAN" hidden="true"> 
		<text>A zoltan...</text>
		<event load="DJMOD_SCORCH_ENEMY_PAY_CREW_ZOLTANS"/>
	</choice>
	
	<!-- *******************************
	Strong (big both ships fire) options 
	******************************* 
	-->
	<choice req="rock_commando" hidden="true"> 
		<text>A random Lost Sun Commando</text>
		<event>
			<text>The crew is consumed for the greater good, strongly activating the augment!</text>
			<removeCrew class="rock_commando">
				<clone>true</clone>
				<text>Your clonebay successfully revived your crew.</text>
			</removeCrew>
			
			<choice hidden="true">
				<text>Continue...</text>
				<event load="DJMOD_COMBAT_SCORCH_BOTH_EFFECT"/>
			</choice>
		</event>
	</choice>
	<choice req="phantom_goul" hidden="true"> 
		<text>A random Goul</text>
		<event>
			<text>The crew is consumed for the greater good, strongly activating the augment!</text>
			<removeCrew class="phantom_goul">
				<clone>true</clone>
				<text>Your clonebay successfully revived your crew.</text>
			</removeCrew>
			
			<choice hidden="true">
				<text>Continue...</text>
				<event load="DJMOD_COMBAT_SCORCH_BOTH_EFFECT"/>
			</choice>
		</event>
	</choice>
	<!-- *******************************
	Strong (big, both ships fire) options 
	******************************* -->
	<choice req="phantom_goul_alpha" hidden="true"> 
		<text>An Alpha Goul</text>
		<event>
			<text>The Alpha Goul is consumed for the greater good, strongly activating the augment!</text>
			<removeCrew class="phantom_goul_alpha">
				<clone>true</clone>
				<text>Your clonebay successfully revived your crew.</text>
			</removeCrew>
			
			<choice hidden="true">
				<text>Continue...</text>
				<event>
					<text>A normal Goul is also produced!</text>
					<crewMember amount="1" class="phantom_goul"/>

					<choice hidden="true">
						<text>Continue...</text>
						<event load="DJMOD_COMBAT_SCORCH_BOTH_EFFECT"/>
					</choice>
				</event>
			</choice>
		</event>
	</choice>
	
	
	<choice>
        <text>Do something else instead.</text>
        <event load="COMBAT_CHECK"/>
    </choice>	
</event>

