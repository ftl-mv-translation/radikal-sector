	====================================================================================================
	=============== COMBAT CHECKS
	====================================================================================================

<event name="COMBAT_CHECK_FAIL">
    <loadEvent>COMBAT_CHECK_FAIL_REAL</loadEvent>
</event>

<event name="COMBAT_CHECK_FAIL_REAL">
	<text>You get ready for combat. What do you want to do?</text>
	<choice req="SCRAP_HULL">
		<text>(Greed) Repair 5 hull.</text>
		<event>
			<damage amount="-5"/>		
		</event>
	</choice>
	<choice req="ROCK_ARMOR">
		<text>(Rock Plating) Ram the bastards!</text>
		<event>
			<damage amount="1"/>
			<enemyDamage amount="4" system="random" effect="eff"/>             
		</event>
	</choice>
	<choice req="COMBAT_PANIC_BUTTON">
		<text>(Panic Button) Push the button.</text>
		<event load="COMBAT_CHECK_PANIC"/>
	</choice>


<event name="COMBAT_CHECK">
    <loadEvent>COMBAT_CHECK_REAL</loadEvent>
</event>
<event name="COMBAT_CHECK_REAL">
	<text>You get ready for combat. What do you want to do?</text>
	<choice req="SHIP_PROPHET">
		<text>Make a prayer to the eye.</text>
		<event load="COMBAT_CHECK_PROPHET"/>
	</choice>
	<choice req="SCRAP_HULL">
		<text>(Greed) Repair 5 hull.</text>
		<event name="COMBAT_CHECK_SCRAPHULL">
			<damage amount="-5"/>
		</event>
	</choice>
	<choice req="ROCK_ARMOR">
		<text>(Rock Plating) Ram the bastards!</text>
		<event name="COMBAT_CHECK_RAM">
			<damage amount="1"/>
			<enemyDamage amount="4" system="random" effect="eff"/>             
		</event>
	</choice>

	<event name="COMBAT_CHECK_GENERIC">
    <text>As the enemy ship approaches, you look for what you can do.</text>
    <choice>
        <text>Nevermind, let's fight!</text>
        <event>
            <text>You decide not to do anything and prepare to fight.</text>
        </event>
    </choice>
    <choice>
        <text>Do something else instead.</text>
        <event load="COMBAT_CHECK"/>
    </choice>
    <choice>
        <text>Make last minute repairs. [1$]</text>
        <event>
            <text>Success, time for battle!</text>
            <damage amount="-1"/>
            <item_modify>
                <item type="scrap" min="-4" max="-4"/>
            </item_modify>
        </event>
    </choice>
    <choice>
        <text>Craft a last minute missile.</text>
        <event>
            <text>Success, time for battle!</text>
            <item_modify>
                <item type="missiles" min="1" max="1"/>
                <item type="scrap" min="-8" max="-8"/>
            </item_modify>
        </event>
    </choice>


	====================================================================================================
	=============== BLOCK AGAINST FLAGSHIP/STORM
	====================================================================================================
	 
	<choice req="EMP_CHECK">
		<text>(EMP) Cripple the enemy reactor.</text>
		<event load="COMBAT_CHECK_JAM_REACTOR"/>
	</choice>
	<choice hidden="true" req="EMP_BLOCKED_STORM">
		<text>(EMP) The ion storm appears to be interferring with the EMP field!</text>
		<event load="OPTION_INVALID"/>
	</choice>
	<choice hidden="true" req="EMP_BLOCKED_FLAGSHIP">
		<text>(EMP) The Flagship's reactor appears to be immune to the EMP field!</text>
		<event load="OPTION_INVALID"/>
	</choice>

