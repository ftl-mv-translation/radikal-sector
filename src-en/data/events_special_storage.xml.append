<!-- ***************************************
BAD OUTCOMES
*************************************** -->

<event name="SHIPVORE_RAM_OWN_OUTCOME_BAD_1">
	<text>This debris is too bad for repairs, and our engines overheated.</text>
	<damage amount="0" system="engines" effect="fire"/>
		
	<choice req="DJMOD_COMBAT_SHIPVORE_RAM_ANY" blue="false">
		<text>(Shipvore Ram) Maybe we can go again.</text>
		<event load="DJMOD_COMBAT_SHIPVORE_RAM_REPEAT"/>
	</choice>
	<choice>
		<text>That's enough.</text>
		<event/>
	</choice>
</event>
<event name="SHIPVORE_RAM_OWN_OUTCOME_BAD_HULL_ENGINE">
	<text>Hitting a strong part of the enemy hull leaves us at a net loss. Ramming IS risky after all...</text>
	<damage amount="1" system="engines" force="false"/>
		
	<choice req="DJMOD_COMBAT_SHIPVORE_RAM_ANY" blue="false">
		<text>(Shipvore Ram) Maybe we can go again.</text>
		<event load="DJMOD_COMBAT_SHIPVORE_RAM_REPEAT"/>
	</choice>
	<choice>
		<text>That's enough.</text>
		<event/>
	</choice>
</event>
<event name="SHIPVORE_RAM_OWN_OUTCOME_BAD_ENGINES">
	<text>A last second dodging attempt made this very straining for our engines, but we did avoid hull damage.</text>
	<damage amount="2" system="engines" effect="all" force="false"/>
	<damage amount="-2"/>
	
	<choice req="DJMOD_COMBAT_SHIPVORE_RAM_ANY" blue="false">
		<text>(Shipvore Ram) Maybe we can go again.</text>
		<event load="DJMOD_COMBAT_SHIPVORE_RAM_REPEAT"/>
	</choice>
	<choice>
		<text>That's enough.</text>
		<event/>
	</choice>
</event>

<event name="SHIPVORE_RAM_OWN_OUTCOME_BAD_HULL_2">
	<text>This strike was so bad, we might have damaged our ship as much as the enemy's.</text>
	<damage amount="1" system="engines" force="false"/>
	<damage amount="2" system="room" effect="random" force="false"/>	<!-- system="room" for systemless, system="random" for truly any. In theory. -->
	<damage amount="-1"/>
		
	<choice req="DJMOD_COMBAT_SHIPVORE_RAM_ANY" blue="false">
		<text>(Shipvore Ram) Maybe we can go again.</text>
		<event load="DJMOD_COMBAT_SHIPVORE_RAM_REPEAT"/>
	</choice>
	<choice>
		<text>That's enough.</text>
		<event/>
	</choice>
</event>

<event name="SHIPVORE_RAM_OWN_OUTCOME_BAD_MISSILES">
	<text>Some ammo in our cargo was tossed out through a breach...</text>
	<damage amount="0" system="room" effect="breach" force="false"/>

	<item_modify steal="true">
		<item type="missiles" min="-1" max="-2"/>
	</item_modify>
		
	<choice req="DJMOD_COMBAT_SHIPVORE_RAM_ANY" blue="false">
		<text>(Shipvore Ram) Maybe we can go again.</text>
		<event load="DJMOD_COMBAT_SHIPVORE_RAM_REPEAT"/>
	</choice>
	<choice>
		<text>That's enough.</text>
		<event/>
	</choice>
</event>

<event name="SHIPVORE_RAM_OWN_OUTCOME_BAD_DRONEPARTS">
	<text>A dronepart in our cargo was tossed out through a breach...</text>
	<damage amount="0" system="room" effect="breach" force="false"/>

	<item_modify steal="true">
		<item type="drones" min="-1" max="-1"/>
	</item_modify>
		
	<choice req="DJMOD_COMBAT_SHIPVORE_RAM_ANY" blue="false">
		<text>(Shipvore Ram) Maybe we can go again.</text>
		<event load="DJMOD_COMBAT_SHIPVORE_RAM_REPEAT"/>
	</choice>
	<choice>
		<text>That's enough.</text>
		<event/>
	</choice>
</event>


<event name="SHIPVORE_RAM_OWN_OUTCOME_BAD_CREW">	
	<text>The shock was terrible... It seems our crew was thrown into space through a breach!</text>
	<damage amount="1" system="engines" effect="breach" force="false"/>
	<damage amount="1" system="room" effect="breach" force="false"/>
	<damage amount="-1"/>

	<choice req="DJMOD_CAN_TELEPORT_EJECTED_CREW" lvl="1" hidden="false">
		<text>(Teleporter 3 + Reconstructive) Emergency teleport!</text>
		<event>
			<text>Your preparation pays off as you easily teleport them back in good health.</text>

			<choice req="DJMOD_COMBAT_SHIPVORE_RAM_ANY" blue="false">
				<text>Easy! Maybe we can go again?</text>
				<event load="DJMOD_COMBAT_SHIPVORE_RAM_REPEAT"/>
			</choice>
		</event>
	</choice>
	<choice req="DJMOD_CAN_TELEPORT_EJECTED_CREW" lvl="0" max_lvl="0" hidden="true" blue="false">
		<text>Your teleportation equipment is insufficient.</text>
		<event load="OPTION_INVALID"/>
	</choice>
	
	<choice req="DJMOD_SUFFICIENT_PILOTING_AND_SENSORS" hidden="false">
		<text>(Piloting 3, Sensors 2) Do a barrel roll!</text>
		<event>
			<text>A precise AI-assisted maneuver puts your crew back in through the same breach!</text>
			<item_modify>
				<item type="fuel" min="-2" max="-2"/>
			</item_modify>

			<choice req="DJMOD_COMBAT_SHIPVORE_RAM_ANY" blue="false">
				<text>That was close! Maybe we can go again?</text>
				<event load="DJMOD_COMBAT_SHIPVORE_RAM_REPEAT"/>
			</choice>
		</event>
	</choice>
	<choice req="DJMOD_SUFFICIENT_PILOTING_AND_SENSORS" lvl="0" max_lvl="0" hidden="true" blue="false">
		<text>Your Piloting or Sensors system is too weak.</text>
		<event load="OPTION_INVALID"/>
	</choice>

	<choice req="engines" lvl="5" hidden="false">
		<text>(Engines 5) Quick, swerve!</text>
		<event>
			<text>With great speed you catch your crew mid-flight!</text>
			<item_modify>
				<item type="fuel" min="-1" max="-1"/>
			</item_modify>

			<choice req="DJMOD_COMBAT_SHIPVORE_RAM_ANY" blue="false">
				<text>That was close! Maybe we can go again?</text>
				<event load="DJMOD_COMBAT_SHIPVORE_RAM_REPEAT"/>
			</choice>
		</event>
	</choice>
	<choice req="engines" max_lvl="4" hidden="true" blue="false">
		<text>Your Engines system is too weak.</text>
		<event load="OPTION_INVALID"/>
	</choice>

	<choice req="DJMOD_CAN_DO_DRONE_RESCUE" hidden="false">
		<text>(Doctor Drone) Quick, drone rescue!</text>
		<event>
			<text>Your Dr. Drone quickly swiftly brings back the crew while protecting their vital organs!</text>
			<item_modify>
				<item type="drones" min="-1" max="-1"/>
			</item_modify>

			<choice req="DJMOD_COMBAT_SHIPVORE_RAM_ANY" blue="false">
				<text>That was close! Maybe we can go again?</text>
				<event load="DJMOD_COMBAT_SHIPVORE_RAM_REPEAT"/>
			</choice>
		</event>
	</choice>
	<choice req="DJMOD_CAN_DO_DRONE_RESCUE" max_lvl="0" hidden="true" blue="false">
		<text>You do not have the appropriate crew drone.</text>
		<event load="OPTION_INVALID"/>
	</choice>

	<choice req="DJMOD_ANY_RESCUE_ARM" hidden="false">
		<text>(Appropriate ship Arm) Grab them with a makeshift lasso!</text>
		<event>
			<text>With dubious logic, you get your crew back in through the same breach!</text>
			<item_modify>
				<item type="scrap" min="-20" max="-10"/>
			</item_modify>

			<choice req="DJMOD_COMBAT_SHIPVORE_RAM_ANY" blue="false">
				<text>That was close! Maybe we can go again?</text>
				<event load="DJMOD_COMBAT_SHIPVORE_RAM_REPEAT"/>
			</choice>
		</event>
	</choice>
	<choice req="DJMOD_ANY_RESCUE_ARM" lvl="0" max_lvl="0" hidden="true" blue="false">
		<text>Your ship does not have an appropriate Arm.</text>
		<event load="OPTION_INVALID"/>
	</choice>

	<choice req="DJMOD_SUM_ENGINEERS" lvl="2" hidden="false">	<!-- 2 engineers because one might be the ejected. -->
		<text>(At least 2 engineers) Quick, jury-rig them a space ride!</text>
		<event>
			<text>With dubious logic, you get your crew back in through the same breach! But also take some hull damage.</text>
			<damage amount="1"/>
			<item_modify>
				<item type="missiles" min="-2" max="-1"/>
				<item type="drones" min="-1" max="-1"/>
			</item_modify>

			<choice req="DJMOD_COMBAT_SHIPVORE_RAM_ANY" blue="false">
				<text>That was close! Maybe we can go again?</text>
				<event load="DJMOD_COMBAT_SHIPVORE_RAM_REPEAT"/>
			</choice>
		</event>
	</choice>
	<choice req="DJMOD_SUM_ENGINEERS" max_lvl="1" hidden="true" blue="false">
		<text>You do not have enough engineer-class crew.</text>
		<event load="OPTION_INVALID"/>
	</choice>

	<choice hidden="true" blue="false">
		<text>...There's nothing we can do about it, focus on the fight!</text>
		<event>
			<text>As your crew is lost alone in the void, the others refuse to ram that ship again!</text>

			<removeCrew>	<!--No class argument means it's a random crewmember. 
				Unique crew are naturally immune as long as there are non-uniques. Simple Human lab upgrade protects other races. -->
				<clone>true</clone>
				<text>Your clonebay successfully revived your crew.</text>
			</removeCrew>
			
			<choice req="mind" lvl="1" hidden="true">
				<text>(Mind Control) Obey your captain!</text>
				<event>
					<text>The pre-programmed mind pulse is released and the crew stops complaining. Your methods are unethical but effective.</text>
					<choice req="DJMOD_COMBAT_SHIPVORE_RAM_ANY" blue="false">
						<text>That's more like it.</text>
						<event load="DJMOD_COMBAT_SHIPVORE_RAM_REPEAT"/>
					</choice>
					
					<choice>
						<text>Actually I'm feeling bad about this now, forget it.</text>
						<event/>
					</choice>
				</event>
			</choice>
			<choice req="mind" lvl="0" max_lvl="0" hidden="true" blue="false">
				<text>Some way to control the crew's minds would help us in cases like this...</text>
				<event/>
			</choice>
		</event>
	</choice>
</event>
