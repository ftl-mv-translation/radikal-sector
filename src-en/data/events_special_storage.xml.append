<event name="SHIPVORE_RAM_OWN_OUTCOME_BAD_BREACHES">	
	<text>We tore open our hull on a sharp piece of debris!
	The damage is superficial but the crew is now very afraid of getting spaced through a breach...</text>
	<damage amount="1" system="engines" effect="breach" force="false"/>
	<damage amount="0" system="random" effect="breach" force="true"/>
	<damage amount="0" system="room" effect="breach" force="true"/>
	<damage amount="-1"/>
	
	<choice>
		<text>(Shipvore Ram) Maybe we can go again.</text>
		<event load="DJMOD_COMBAT_SHIPVORE_RAM_REPEAT"/>
	</choice>
	
