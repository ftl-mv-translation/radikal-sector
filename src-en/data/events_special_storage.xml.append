<event name="DJMOD_COMBAT_CHECK_OFFENSE_DISABLER">
	<text>Are you sure you want to do this?
	[Disables enemy offense, they get it back increasingly quickly. Uses 3 | and 3 reactor power]</text>
		
	<choice req="reactor" lvl="3" blue="false">
		<text>Yes</text>
		<event>
			<text>You activate the augment...</text>
			<item_modify>
				<item type="drones" min="-3" max="-3"/>
			</item_modify>
			
			<status type="loss" target="player" system="reactor" amount="3"/>
			
			<choice>
				<text>Continue...</text>
				<event load="DJMOD_OFFENSE_DISABLER_TIMER_START"/>
			</choice>
		</event>
	</choice>
	<choice req="DEBUG_GENERATOR">
		<text>Power the augment with the Emergency Generator.</text>
		<event>
			<text>You activate the augment...</text>
			<item_modify>
				<item type="drones" min="-3" max="-3"/>
			</item_modify>
			
			<choice>
				<text>Continue...</text>
				<event load="DJMOD_OFFENSE_DISABLER_TIMER_START"/>
			</choice>
		</event>
	</choice>
	
	<choice>
        <text>Do something else instead.</text>
        <event load="COMBAT_CHECK"/>
    </choice>
	<choice>
		<text>Nevermind, let's fight!</text>
		<event>
			<text>You decide not to do anything and prepare to fight.</text>
		</event>
	</choice>
</event>

<event name="DJMOD_OFFENSE_DISABLER_TIMER_START">
	<text>The enemy's offense is disabled, make it count...</text>
	<playSound>dj_hackingZap1</playSound>
	<!-- <playSound>dj_lightningWithFade</playSound> -->
		
	<!--OPTIONAL add a timer that triggers another event when it reaches 0, such as how the MV combat augments expire after a certain time-->
	<triggeredEvent event="DJMOD_OFFENSE_DISABLER_STEP_FINAL" time="18.1" thisFight="true"> <!--intended delay is 6+5+4+ 3 = 18 s -->
	<!-- <triggeredEvent event="CALLIE_PROBLEM" seeded="false" thisFight="true" clearOnJump="true" minTime="20.0" maxTime="20.0" loops="999"/> -->
		<triggeredEventBox load="DEFAULT_SMALL">
			<image r="255" g="50" b="255" a="0.6"/>
			<image2  r="255" g="50" b="255" a="0.6"/>
			<tooltip>The enemy's offense is fully restored in this amount of time.</tooltip>
		</triggeredEventBox>
		<timerSounds load="DEFAULT_TIMER_SOUNDS"/>
		
		<!-- <warningMessage image="_image_" id="test_id" x="0" y="0" time="5.0" centerText="true" flash="true" r="253" g="84" b="70" sound="_sound_"((see sounds.xml)) useWarningLine="true">Text</warningMessage> -->
		<warningMessage id="warning_offense_disabler_end" x="392" y="84" time="7.0" centerText="true" flash="true" r="255" g="50" b="255" useWarningLine="true"/>
	</triggeredEvent>
	
	<choice>
		<text>Continue to the fight!</text>
		<event load="DJMOD_OFFENSE_DISABLER_STEP_1"/>
	</choice>
</event>


<event name="DJMOD_OFFENSE_DISABLER_STEP_1">
	<status type="limit" target="enemy" system="weapons" amount="0"/>
	<status type="limit" target="enemy" system="drones" amount="0"/>
	<status type="limit" target="enemy" system="hacking" amount="0"/>
	<status type="limit" target="enemy" system="mind" amount="0"/>
	<status type="limit" target="enemy" system="artillery" amount="0"/>
	
	<status type="limit" target="enemy" system="teleporter" amount="0"/>
	
	<triggeredEvent event="DJMOD_OFFENSE_DISABLER_STEP_2" time="6" thisFight="true"/>
</event>

<event name="DJMOD_OFFENSE_DISABLER_STEP_2">
	<status type="limit" target="enemy" system="weapons" amount="1"/>
	<status type="limit" target="enemy" system="drones" amount="1"/>
	<status type="limit" target="enemy" system="hacking" amount="1"/>
	<status type="limit" target="enemy" system="mind" amount="1"/>
	<status type="limit" target="enemy" system="artillery" amount="1"/>
	
	<status type="limit" target="enemy" system="teleporter" amount="1"/>
	<playSound>dj_hackingZap1</playSound>
	<triggeredEvent event="DJMOD_OFFENSE_DISABLER_STEP_3" time="5" thisFight="true"/>
</event>

<event name="DJMOD_OFFENSE_DISABLER_STEP_3">
	<status type="limit" target="enemy" system="weapons" amount="2"/>
	<status type="limit" target="enemy" system="drones" amount="2"/>
	<status type="limit" target="enemy" system="hacking" amount="2"/>
	<status type="limit" target="enemy" system="mind" amount="2"/>
	<status type="limit" target="enemy" system="artillery" amount="2"/>
	
	<status type="limit" target="enemy" system="teleporter" amount="2"/>
	<playSound>dj_hackingZap1</playSound>
	<triggeredEvent event="DJMOD_OFFENSE_DISABLER_STEP_4" time="4" thisFight="true"/>
</event>

<event name="DJMOD_OFFENSE_DISABLER_STEP_4">
	<status type="limit" target="enemy" system="weapons" amount="4"/>
	<status type="limit" target="enemy" system="drones" amount="4"/>
	<status type="limit" target="enemy" system="artillery" amount="4"/>
	
	<status type="clear" target="enemy" system="hacking" amount="100"/>
	<status type="clear" target="enemy" system="mind" amount="100"/>
	
	<status type="clear" target="enemy" system="teleporter" amount="100"/>
	<playSound>dj_hackingZap1</playSound>
	<!-- <triggeredEvent event="DJMOD_OFFENSE_DISABLER_STEP_FINAL" time="3" thisFight="true"/> 		Initial timer does it. -->
</event>

<!-- Clear everything in case for some reason a clearing step above is skipped. -->
<event name="DJMOD_OFFENSE_DISABLER_STEP_FINAL">
	<status type="clear" target="enemy" system="weapons" amount="100"/>
	<status type="clear" target="enemy" system="drones" amount="100"/>
	<status type="clear" target="enemy" system="artillery" amount="100"/>

	<status type="clear" target="enemy" system="hacking" amount="100"/>
	<status type="clear" target="enemy" system="mind" amount="100"/>
	
	<status type="clear" target="enemy" system="teleporter" amount="100"/>
	
	<status type="clear" target="player" system="reactor" amount="100"/>
</event>


