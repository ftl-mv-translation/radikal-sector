<!-- SYLVAN_TRADES_CHOICE is base MV! -->
<mod:findName type="eventList" name="SYLVAN_TRADES_CHOICE" panic="true">
    <mod-append:event name="SYLVAN_TRADES_CHOICE_RK"/>
</mod:findName>
<event name="SYLVAN_TRADES_CHOICE_RK">
    <text id="text_sylvan_boon"/>
	<choice hidden="true">
		<text>Shop for Lasers.</text>
		<event load="SYLVAN_LASERS"/>
	</choice>
	<choice hidden="true">
		<text>Shop for Beams.</text>
		<event load="SYLVAN_BEAM"/>
	</choice>
	<choice hidden="true">
		<text>Shop for Missiles.</text>
		<event load="SYLVAN_MISSILES"/>
	</choice>
    <choice hidden="true">
        <text>Shop for RadiKal tech.</text>
        <event load="SYLVAN_RK_ONE_LINE_EACH_CATEGORY"/>
    </choice>
</event>
