</mod:findName>

<!-- Awards for Equipment -->
<event name="JUDGE_AWARD_RK_BAM_EQUIPMENT">
	<text>"Oh my... RADIKAL BAM Tech? Sure. This is tribute, I suppose. Great for DESTRUCTION! And ENDURANCE, and asphyxiation. Not much else. HOW MANY ships have you DESTROYED that you would have spared without this tech?... but I DIGRESS. I shall BLESS you with the BLESSING OF RADIKAL TOUGHNESS. But have PATIENCE. It is not for now, but for LATER!"</text>
	<achievement>ACH_BOON_RK_BAM_EQUIPMENT</achievement>
	<metaVariable name="prof_r_boon_rk_bam_equipment" op="set" val="1"/>
	<variable name="ach_boon_rk_bam_equipment" op="set" val="1"/>
	<choice hidden="true">
		<text>Continue...</text>
		<event load="THE_JUDGES_ROCK_ADVICE"/>
	</choice>
</event>
<event name="JUDGE_AWARD_RK_PUNK_EQUIPMENT">
	<text>"Oh my... RADIKAL PUNK Tech? Sure. This is tribute, I suppose. OUTSMARTING your opponents. Turning your OWN crew into mere MURDER tools. HOW MANY creatures have you KILLED that you would have spared without this tech?... but I DIGRESS. I shall BLESS you with the BLESSING OF RADIKAL CUNNING. But have PATIENCE. It is not for now, but for LATER!"</text>
	<achievement>ACH_BOON_RK_PUNK_EQUIPMENT</achievement>
	<metaVariable name="prof_r_boon_rk_punk_equipment" op="set" val="1"/>
	<variable name="ach_boon_rk_punk_equipment" op="set" val="1"/>
	<choice hidden="true">
		<text>Continue...</text>
		<event load="THE_JUDGES_ROCK_ADVICE"/>
	</choice>
</event>
<event name="JUDGE_AWARD_RK_SCORCH_EQUIPMENT">
	<text>"Oh my... RADIKAL SCORCH Tech? Sure. This is tribute, I suppose. I know the power of FIRE very well. ALL power turns to heat, but THIS, only causes MAYHEM. HOW MANY things BURNED in your wake to which you would have given a QUICK end without this tech?... but I DIGRESS. I shall BLESS you with the BLESSING OF RADIKAL FEVER. But have PATIENCE. It is not for now, but for LATER!"</text>
	<achievement>ACH_BOON_RK_SCORCH_EQUIPMENT</achievement>
	<metaVariable name="prof_r_boon_rk_scorch_equipment" op="set" val="1"/>
	<variable name="ach_boon_rk_scorch_equipment" op="set" val="1"/>
	<choice hidden="true">
		<text>Continue...</text>
		<event load="THE_JUDGES_ROCK_ADVICE"/>
	</choice>
</event>
<event name="JUDGE_AWARD_RK_BPS_EQUIPMENT">
	<text>"Oh my... RADIKAL BPS Tech? Sure. This is tribute, I suppose. MULTIPLE strengths, hoping to EXPLOIT one of the enemy's WEAKNESSES. Because ONE is all it takes. Do you even CARE about the pain AND destruction, to create THAT? For your sake, you better NOT... but I DIGRESS. I shall BLESS you with the BLESSING OF RADIKAL PROJECTS. But have PATIENCE. It is not for now, but for LATER!"</text>
	<achievement>ACH_BOON_RK_BPS_EQUIPMENT</achievement>
	<metaVariable name="prof_r_boon_rk_bps_equipment" op="set" val="1"/>
	<variable name="ach_boon_rk_bps_equipment" op="set" val="1"/>
	<choice hidden="true">
		<text>Continue...</text>
		<event load="THE_JUDGES_ROCK_ADVICE"/>
	</choice>
</event>

<mod:findName type="event" name="THE_JUDGES_VARIABLE_CLEAR">
    <mod-append:metaVariable name="prof_z_boon_rk_bam_crew" op="set" val="0"/>
	<mod-append:metaVariable name="prof_z_boon_rk_punk_crew" op="set" val="0"/>
	<mod-append:metaVariable name="prof_z_boon_rk_scorch_crew" op="set" val="0"/>
	<mod-append:metaVariable name="prof_r_boon_rk_bam_equipment" op="set" val="0"/>
	<mod-append:metaVariable name="prof_r_boon_rk_punk_equipment" op="set" val="0"/>
    <mod-append:metaVariable name="prof_r_boon_rk_scorch_equipment" op="set" val="0"/>
	<mod-append:metaVariable name="prof_r_boon_rk_bps_equipment" op="set" val="0"/>
</mod:findName>

