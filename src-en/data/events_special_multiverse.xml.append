			<variable name="ach_boon_rk_bam_crew" op="set" val="1"/>
			<choice hidden="true">
				<text>Continue...</text>
				<event load="THE_JUDGES_ZOLTAN_ADVICE"/>
			</choice>
		</event> -->
	</mod-append:choice>
	<mod-append:choice req="ACH_BOON_RK_BAM_CREW_REPEAT" blue="false">
		<text>Present your RadiKal Bam crew.</text>
		<event load="JUDGE_AWARD_RK_BAM_CREW"/>
	</mod-append:choice>

	<mod-append:choice req="ACH_BOON_RK_PUNK_CREW_FIRST" blue="true">
		<text>Present your RadiKal Punk crew.</text>
		
		<event load="JUDGE_AWARD_RK_PUNK_CREW"/>
	</mod-append:choice>
	<mod-append:choice req="ACH_BOON_RK_PUNK_CREW_REPEAT" blue="false">
		<text>Present your RadiKal Punk crew.</text>
		<event load="JUDGE_AWARD_RK_PUNK_CREW"/>
	</mod-append:choice>

	<mod-append:choice req="ACH_BOON_RK_SCORCH_CREW_FIRST" blue="true">
		<text>Present your RadiKal Scorch crew.</text>
		<event load="JUDGE_AWARD_RK_SCORCH_CREW"/>
	</mod-append:choice>
	<mod-append:choice req="ACH_BOON_RK_SCORCH_CREW_REPEAT" blue="false">
		<text>Present your RadiKal Scorch crew.</text>
		<event load="JUDGE_AWARD_RK_SCORCH_CREW"/>
	</mod-append:choice>
</mod:findName>

<!-- Awards for Crew -->
<event name="JUDGE_AWARD_RK_BAM_CREW">
	<text>"On the surface... technological pursuit. Beneath, violent creatures... with simplistic methods. Still they are... efficient and reliable. Well done, traveler. Expect... rewards before your next journey."</text>
	<achievement>ACH_BOON_RK_BAM_CREW</achievement>
	<metaVariable name="prof_z_boon_rk_bam_crew" op="set" val="1"/>
	<variable name="ach_boon_rk_bam_crew" op="set" val="1"/>
	<choice hidden="true">
		<text>Continue...</text>
		<event load="THE_JUDGES_ZOLTAN_ADVICE"/>
	</choice>
</event>
<event name="JUDGE_AWARD_RK_PUNK_CREW">
	<text>"Twisted minds with a knack... for disrupting life and energy. I wouldn't want to meet... any of them. But their genius... impresses me. Well done, traveler. Expect... rewards before your next journey."</text>
	<achievement>ACH_BOON_RK_PUNK_CREW</achievement>
	<metaVariable name="prof_z_boon_rk_punk_crew" op="set" val="1"/>
	<variable name="ach_boon_rk_punk_crew" op="set" val="1"/>
	<choice hidden="true">
		<text>Continue...</text>
		<event load="THE_JUDGES_ZOLTAN_ADVICE"/>
	</choice>
</event>
<event name="JUDGE_AWARD_RK_SCORCH_CREW">
	<text>"Sadists... obsessed with heat and speed. They can't be trusted... to not burn everything down. But the results... are valuable. Well done, traveler. Expect... rewards before your next journey."</text>
	<achievement>ACH_BOON_RK_SCORCH_CREW</achievement>
	<metaVariable name="prof_z_boon_rk_scorch_crew" op="set" val="1"/>
	<variable name="ach_boon_rk_scorch_crew" op="set" val="1"/>
	<choice hidden="true">
		<text>Continue...</text>
		<event load="THE_JUDGES_ZOLTAN_ADVICE"/>
	</choice>
</event>

