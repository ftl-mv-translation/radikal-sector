<?xml version="1.0" encoding="UTF-8"?>

<!-- 
"Bag of Dumb Fixed" & "Darkest Desire" don't use any FTL tags in this file. 
Lily's Beam Emporium doesn't even have the file.
Remove in case of bug.
-->
<FTL>

<!-- 
RK Coords are obtained in events_special_standard.xml.append , random shops, or revisit event append.
MV coords are from an event or event chain. Ghost sector might also be baked into Spook Chaser ship?

Fix bug "On S7->S8 jump, this add-on disables rerouting to any sectors at all."
SEEMS FIXED BY REMOVING THE DREADED "max_group" FROM REROUTE_MENU_LASTSTAND and REROUTE_MENU!

TODO: Fix bug "On S7->S8 jump, this add-on disables rerouting to any sectors at all unless you have 2+ coords ready, 
1 of which might need to be RK coords." DONE.
-->

<!-- 
//////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////
//////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////
////////		"ATLAS" SECTION - Not to be confused with "REROUTE" SECTION BELOW
HAS: "ATLAS_MENU", "ATLAS_MENU_NOEQUIPMENT", "ENTER_..." and "..._WARP" events.
ALSO CALLS: "LOAD_ATLAS_MARKER" and "START_..." events.

Seems needed to fix "On S7->S8 jump, this add-on disables rerouting to any sectors, unless you have 2+ coords ready,
and 1 of them might need to be RK coords."
//////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////
//////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////
-->

<!-- . -->
<mod:findName type="event" name="ATLAS_MENU">
	<mod-append:choice hidden="true" req="SEC SECRET_RADIKAL" blue="false">
		<text>Proceed to the RadiKal Sector.</text>
		<event load="RADIKAL_WARP"/>
	</mod-append:choice>
</mod:findName>
<mod:findName type="event" name="ATLAS_MENU_NOEQUIPMENT">
	<mod-append:choice hidden="true" req="SEC SECRET_RADIKAL" blue="false">
		<text>Proceed to the RadiKal Sector.</text>
		<event load="RADIKAL_WARP"/>
	</mod-append:choice>
</mod:findName>
