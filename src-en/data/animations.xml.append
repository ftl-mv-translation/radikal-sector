<!-- NB: The block for chaining, starting with "<animSheet name="BLABLA_charge ..." must be ABOVE the block for the weapon body!
Just like in MV in fact.

REF v5.5.1
<animSheet name="ion_phase_chaingun_charge" w="168" h="73" fw="42" fh="73">weapon_ion/ion_phase_chain_chargeglow.png</animSheet>
<anim name="ion_phase_chaingun_charge">
	<sheet>ion_phase_chaingun_charge</sheet>
	<desc length="4" x="0" y="0"/>
	<time>1.0</time>
</anim>
<animSheet name="ion_phase_chaingun" w="420" h="73" fw="42" fh="73">weapon_ion/ion_phase_chain.png</animSheet>
<weaponAnim name="ion_phase_chaingun">
	<sheet>ion_phase_chaingun</sheet>
	<desc length="10" x="0" y="0"/>
	<chargedFrame>1</chargedFrame>
	<fireFrame>7</fireFrame>
	<firePoint  x="21" y="18"/>
	<mountPoint x="3" y="44"/>
	<chargeImage>weapon_ion/ion_phase_chain_glow.png</chargeImage>
	<boost>ion_phase_chaingun_charge</boost>
</weaponAnim>
-->
