<?xml version="1.0" encoding="UTF-8"?>

<!-- HOW TO READ
In animSheet's fw and fh, f stands for "frame". w is "width" and h "height" ofc.
The x and y coordinates in sheets are SPRITES not pixels, starting BOTTOM LEFT. x horizontal, y vertical.
-->

