</anim>
<anim name="human_soldier_operative_walk_left">
	<sheet>human_soldier_operative</sheet>
	<desc length="4" x="4" y="11"/>
	<time>1.0</time>
</anim>
<anim name="human_soldier_operative_shoot_down">
	<sheet>human_soldier_operative</sheet>
	<desc length="3" x="0" y="10"/>
	<time>1.0</time>
</anim>
<anim name="human_soldier_operative_shoot_right">
	<sheet>human_soldier_operative</sheet>
	<desc length="3" x="3" y="10"/>
	<time>1.0</time>
</anim>
<anim name="human_soldier_operative_shoot_up">
	<sheet>human_soldier_operative</sheet>
	<desc length="3" x="6" y="10"/>
	<time>1.0</time>
</anim>
<anim name="human_soldier_operative_shoot_left">
	<sheet>human_soldier_operative</sheet>
	<desc length="3" x="0" y="1"/>
	<time>1.0</time>
</anim>
<anim name="human_soldier_operative_fire_down">
	<sheet>human_soldier_operative</sheet>
	<desc length="4" x="0" y="9"/>
	<time>1.0</time>
</anim>
<anim name="human_soldier_operative_fire_right">
	<sheet>human_soldier_operative</sheet>
	<desc length="4" x="4" y="9"/>
	<time>1.0</time>
</anim>
<anim name="human_soldier_operative_fire_up">
	<sheet>human_soldier_operative</sheet>
	<desc length="4" x="0" y="8"/>
	<time>1.0</time>
</anim>
<anim name="human_soldier_operative_fire_left">
	<sheet>human_soldier_operative</sheet>
	<desc length="4" x="4" y="8"/>
	<time>1.0</time>
</anim>
<anim name="human_soldier_operative_repair">
	<sheet>human_soldier_operative</sheet>
	<desc length="9" x="0" y="7"/>
	<time>1.0</time>
</anim>
<anim name="human_soldier_operative_punch_up">
	<sheet>human_soldier_operative</sheet>
	<desc length="6" x="3" y="1"/>
	<time>1.0</time>
</anim>
<anim name="human_soldier_operative_punch_down">
	<sheet>human_soldier_operative</sheet>
	<desc length="6" x="0" y="6"/>
	<time>1.0</time>
</anim>
<anim name="human_soldier_operative_teleport">
	<sheet>human_soldier_operative</sheet>
	<desc length="9" x="0" y="3"/>
	<time>0.5</time>
</anim>
<anim name="human_soldier_operative_type_right">
	<sheet>human_soldier_operative</sheet>
	<desc length="4" x="0" y="5"/>
	<time>0.75</time>
</anim>
<anim name="human_soldier_operative_type_left">
	<sheet>human_soldier_operative</sheet>
	<desc length="4" x="4" y="5"/>
	<time>0.75</time>
</anim>
<anim name="human_soldier_operative_type_up">
	<sheet>human_soldier_operative</sheet>
	<desc length="4" x="0" y="4"/>
	<time>0.75</time>
</anim>
<anim name="human_soldier_operative_type_down">
	<sheet>human_soldier_operative</sheet>
	<desc length="4" x="4" y="4"/>
	<time>0.75</time>
</anim>
<anim name="human_soldier_operative_portrait">
	<sheet>human_soldier_operative</sheet>
	<desc length="1" x="0" y="0"/>
	<time>1</time>
</anim>
</FTL>

