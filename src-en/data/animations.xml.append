<!-- RADIKAL MYSTERIOUS OPERATIVE SOLDIER -->
<FTL>
<animSheet name="human_soldier_operative" w="315" h="455" fw="35" fh="35">people/human_soldier_operative_base.png</animSheet>
<anim name="human_soldier_operative_clone">
	<sheet>human_soldier_operative</sheet>
	<desc length="6" x="0" y="2"/>
	<time>0.75</time>
</anim>
<anim name="human_soldier_operative_death_right">
	<sheet>human_soldier_operative</sheet>
	<desc length="5" x="3" y="0"/>
	<time>0.75</time>
</anim>
<anim name="human_soldier_operative_death_left">
	<sheet>human_soldier_operative</sheet>
	<desc length="5" x="0" y="2"/>
	<time>0.75</time>
</anim>
<anim name="human_soldier_operative_walk_down">
	<sheet>human_soldier_operative</sheet>
	<desc length="4" x="0" y="12"/>
	<time>1.0</time>
</anim>
<anim name="human_soldier_operative_walk_right">
	<sheet>human_soldier_operative</sheet>
	<desc length="4" x="4" y="12"/>
	<time>1.0</time>
</anim>
<anim name="human_soldier_operative_walk_up">
	<sheet>human_soldier_operative</sheet>
	<desc length="4" x="0" y="11"/>
