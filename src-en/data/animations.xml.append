<!-- <anim name="rk_weaponlike_death_right">
	<sheet>rk_weaponlike</sheet>
	<desc length="5" x="0" y="0"/>
	<time>1.0</time>
</anim>
Below, modified sheet to accomodate added projectile.
-->
<anim name="rk_weaponlike_death_right">
	<sheet>rk_weaponlike</sheet>
	<desc length="4" x="2" y="0"/>
	<time>1.0</time>
</anim>
<anim name="rk_weaponlike_teleport">
	<sheet>rk_weaponlike</sheet>
	<desc length="6" x="0" y="2"/>
	<time>0.5</time>
</anim>
<anim name="rk_weaponlike_walk_down">
	<sheet>rk_weaponlike</sheet>
	<desc length="4" x="0" y="2"/>
	<time>1.0</time>
</anim>
<anim name="rk_weaponlike_walk_right">
	<sheet>rk_weaponlike</sheet>
	<desc length="2" x="4" y="2"/>
	<time>0.5</time>
</anim>
<anim name="rk_weaponlike_walk_up">
	<sheet>rk_weaponlike</sheet>
	<desc length="4" x="0" y="1"/>
	<time>1.0</time>
</anim>
<anim name="rk_weaponlike_walk_left">
	<sheet>rk_weaponlike</sheet>
	<desc length="2" x="4" y="1"/>
	<time>0.5</time>
</anim>

<!-- added manning: First frame of shooting anims -->
<anim name="rk_weaponlike_type_down">
	<sheet>rk_weaponlike</sheet>
	<desc length="1" x="0" y="6"/>
	<time>0.75</time>
</anim>
<anim name="rk_weaponlike_type_right">
	<sheet>rk_weaponlike</sheet>
	<desc length="1" x="2" y="6"/>
	<time>0.75</time>
</anim>
<anim name="rk_weaponlike_type_up">
	<sheet>rk_weaponlike</sheet>
	<desc length="1" x="0" y="5"/>
	<time>0.75</time>
</anim>
<anim name="rk_weaponlike_type_left">
	<sheet>rk_weaponlike</sheet>
	<desc length="1" x="2" y="5"/>
	<time>0.75</time>
</anim>

<anim name="rk_weaponlike_portrait">
	<sheet>rk_weaponlike</sheet>
	<desc length="1" x="0" y="0"/>
	<time>1</time>
</anim>
</FTL>

