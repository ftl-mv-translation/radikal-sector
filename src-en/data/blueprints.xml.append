<!-- Laser with plenty thematic effects. -->
<weaponBlueprint name="DJMOD_LASER_BPS">
	<type>LASER</type>
	<title>'BPS Messenger'</title>
	<short>'BPS Mess.'</short>
	<desc>(RK BPS gear) A Piercing Heavy Laser boosted in the RadiKal Sector: the Bam gave it hullbust and better stun, the Punk added ion and crew damage, and the Scorch replaced breach chance with guaranteed fire and chaining.</desc>
	<tip>RK_lore_DJMOD_LASER_BPS</tip>
	<damage>2</damage>
	<sysDamage>0</sysDamage>			<!-- Adding any of this makes it an Ancient Ion = Plasma! OP against shields. -->
	<ion>1</ion>						<!-- ION_1: 1ion/9s, ION_3: 1ion/5s (2pow), Heavy Ion: 3ion/15s -->
	<persDamage>2</persDamage>
	<hullBust>1</hullBust>
	<speed>45</speed>					<!-- ref speeds: mine=15 ion=30 missile=50 -->

	<mv-stealth/>
	
	<shots>1</shots>
	<fireTime>0.35</fireTime>		<!-- Default is 1.0: bombs & charge weapons. 0.25: other weapons. Beams unaffected -->
	<sp>1</sp>
	
	<fireChance>10</fireChance>
	<breachChance>0</breachChance>
	<!-- <stunChance>9</stunChance> 	"Negates stun duration if you declare this."-->
	<stun>4</stun>					<!-- Duration. Implies 100% stunChance. Heavy Stunner & Neural Laser: 12s -->

	<!-- max chained intended : 5s = 1 ion dissipation time. 
	Non-chain REFS: Pierce Heavy 11s (1 pow),
	Fully chained REFS: LASER_HEAVY_CHAINGUN 13s->4s (1 pow) -->
	<cooldown>12.5</cooldown>
	<power>2</power>
	<cost>100</cost>
	<bp>2</bp>
	<rarity>5</rarity>
	<boost>
		<type>cooldown</type>
		<amount>2.5</amount>
		<count>3</count>
	</boost>
	<!-- <projectiles> and <image> are mutually exclusive. If you declare one, 
	DO NOT ! ! ! ! ! ! ! ! declare the other, or they will interfere with each other and 
	either break the weapon or CRASH THE GAME.-->
	<image>djmod_laser_superheavy</image>
	
	<launchSounds>
		<sound>heavyLaser1</sound>
		<sound>heavyLaser2</sound>
		<sound>heavyLaser3</sound>
	</launchSounds>
	<hitShipSounds>
		<sound>hitHull1</sound>
	</hitShipSounds>
	<hitShieldSounds>
		<sound>hitShield1</sound>
		<sound>hitShield2</sound>
		<sound>hitShield3</sound>
	</hitShieldSounds>
	<missSounds>
		<sound>miss</sound>
	</missSounds>
	<weaponArt>djmod_laser_bps</weaponArt>
	<iconImage>heavyL</iconImage>
</weaponBlueprint>

