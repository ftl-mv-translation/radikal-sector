<weaponBlueprint name="DJMOD_RAIN_OF_ION">
	<type>BURST</type>
	<flavorType>Ion Blast</flavorType>
	<title>Rain of Ions</title>
	<short>RainIons</short>
	<tip>tip_phase</tip>
	<locked>1</locked>			<!-- what's that? -->
	<desc>This RadiKal Punk inaccurate shotgun fires an accelerated phase ion, a heavy ion, a fire ion, a normal ion, a stun ion, and a radion (from fastest to slowest) all at once. Chains cooldown up to 8 times.
		Many weapons worth of blue options!
	</desc>
	<tooltip>Fires all 6 common ions in a radius; Cooldown 12 seconds.</tooltip>

	<radius>55</radius>
	<damage>0</damage>
	<ion>1</ion>
	<!-- Non-stun Heavy Ion & Fire Ion 40 speed. Others 30. Default Phase Ion is slowest at 25.
	OTHER REFS: Most lasers & missiles have no speed field (so they have the same default speed). Hull laser II has 75. -->
	<speed>55</speed>
	<shots>1</shots>
	<sp>10</sp>
	<fireChance>0</fireChance>
	<breachChance>0</breachChance>
	<stunChance>0</stunChance>
	<cooldown>12</cooldown>
	<power>4</power>
	<cost>120</cost>
	<bp>3</bp>
	<rarity>4</rarity>
	<!-- REF Trifecta technique for shooting multiple types of stuff:
	<projectiles>
		<projectile count="1" fake="false" blueprint="TRIFECTA_LASER">laser_heavy</projectile>
		<projectile count="2" fake="false">debris_med</projectile>
		<projectile count="3" fake="true">debris_small</projectile>
	</projectiles> -->
	<projectiles>
		<projectile count="1" fake="false">ion_phase</projectile>
		<projectile count="1" fake="false" blueprint="ION_1">ion_barrage</projectile>
		<projectile count="1" fake="false" blueprint="ION_HEAVY">ion_heavy</projectile>
		<projectile count="1" fake="false" blueprint="ION_STUN">ion_stun_shot</projectile>

		<projectile count="1" fake="false" blueprint="ION_BIO">ion_bio</projectile>
		<projectile count="1" fake="false" blueprint="ION_FIRE">ion_fire</projectile>
	</projectiles>

	<image>ion_phase</image>
	<explosion>explosion_small_phase</explosion>

	<!-- intended fully chained: 8s -->
	<boost>
		<type>cooldown</type>
		<amount>0.5</amount>
		<count>8</count>
	</boost>
	<launchSounds>
		<sound>ionShoot1</sound>
		<sound>ionShoot2</sound>
		<sound>ionShoot3</sound>
	</launchSounds>
	<hitShipSounds>
		<sound>ionHit1</sound>
		<sound>ionHit2</sound>
		<sound>ionHit3</sound>
	</hitShipSounds>
	<hitShieldSounds>
		<sound>ionShields1</sound>
		<sound>ionShields2</sound>
		<sound>ionShields3</sound>
	</hitShieldSounds>
	<missSounds>
		<sound>miss</sound>
	</missSounds>
	<weaponArt>djmod_rain_of_ion</weaponArt>
	<iconImage>ion</iconImage>
</weaponBlueprint>

