<!-- RadiKal OPERATIVE SOLDIER. Only purpose is to provide RK sector's coords, and die. Not in that order. -->
<crewBlueprint name="human_soldier_operative">
    <desc>Elite Human Crew. A highly trained human soldier, whose armor protects them from damage. Seems in pain?</desc>
    <cost>39</cost>
    <title>Human Soldier</title>
    <short>Soldier</short>
    <rarity>0</rarity>
    <powerList>
        <power>Inflicts 1.2x damage in combat</power>
		<power>Takes 0.7x damage from combat and 0.6x from fires</power>
        <power>Learns skills much faster</power>
    </powerList>
</crewBlueprint>

<!-- 
===================================================================================================
RK Bam crew
===================================================================================================
-->

<!-- RK_WEAPONLIKE based on technoboarderion aka "Technopath morph imitating an ion boarder drone".
REF MV v5.5.1:
<crewBlueprint name="technoboarderion">
	<desc id="crew_techno_desc"/>
	<cost>50</cost>
	<title id="crew_techno_title"/>
	<short id="crew_techno_title"/>
	<rarity>0</rarity>
	<powerList>
		<power>Currently mimicking: Ion Intruder</power>
		<power id="crew_techno_power_1"/>
		<power id="crew_morph_power_2"/>
		<power id="crew_morph_power_3"/>
	</powerList>
</crewBlueprint> 
-->
<crewBlueprint name="rk_weaponlike">
    <desc>(RK Bam) Made by applying electroshocks to a technopath bathed in acid and stuffed with a bomb, making it mad and unable to change shape, but able to launch bombs.
		No longer counts as a Technopath or Morph.

	Inherited stats: takes 0.5 crew slot, immune to suffocation, 75% resistance to fire damage and stun, 0.8x movement speed.</desc>
    <cost>55</cost>
    <title>Squyrt</title>
    <short>Squyrt</short>
    <rarity>0</rarity>
    <powerList>
		<power>Active Ability: Teleport a bomb to the enemy ship, once per jump</power>
		<power>Active Ability: Detonate a bomb right here, once per jump</power>
        <power>Max Health is 75. Is cloned at 2x speed.</power>
		<power>Can only move, man, fight, sabotage, teleport</power>
		<power>Learns Weapons extremely fast</power>
    </powerList>
    <colorList>
        <layer>
            <color r="255" g="255" b="255" a="1"/>
        </layer>
    </colorList>
</crewBlueprint>

<!-- 
===================================================================================================
RK Punk crew
===================================================================================================
-->

<!-- Based on MV v5.5.1 blobrock aka "Morph imitating a Rockman"
<crewBlueprint name="unique_rk_engilanius_rockmorph"> -->
<crewBlueprint name="unique_rk_defromorius">
    <desc>(RK Punk) An Engi Defender accidentally amalgamed itself with Rockman-Morph goo and Lanius flesh. Became a RadiKal to escape Harmony torture, all while gasping for air.
		Counts as a rogue Engi Defender.

	Inherited stats: 0.5x stun and movement speed, 2.7x repair speed, drains oxygen.</desc>
    <cost>200</cost>
    <title>Defromorius</title>
    <short>Defromorius</short>
    <rarity>0</rarity>
    <powerList>
		<power>Active Ability: It and allies on the same ship take 0.65x damage from hazards and combat, and deal 1.5x damage. [Lasts 10 seconds. Cooldown 3 seconds. Only recharges while suffocating.]</power>
        <power>Health increased to 200, Is cloned at 0.5x speed</power>
		<power>Takes 0.2x damage from hazards</power>
		<power>Attacks in melee combat at 2x speed</power>
    </powerList>
    <colorList>
        <layer>
            <color r="255" g="255" b="255" a="1"/>
        </layer>
    </colorList>
</crewBlueprint>

<!-- 
===================================================================================================
RK Scorch crew
===================================================================================================
-->

<crewBlueprint name="rk_fireghost">
    <desc>(RK Scorch) An Uptor is made of Alpha Gouls megapressed together. They are Ghosts but no longer Gouls or Vagabonds.
		On your ship, makes the system they're in immune to fire. On the enemy ship, the system takes 2x fire damage.
		Can cause solar yoctoflares from its own body often.

	Inherited Alpha Goul stats: hazard immune, ignores doors, 2x sabotage speed.</desc>
    <cost>135</cost>
    <title>Uptor</title>
    <short>Uptor</short>
    <rarity>0</rarity>
    <powerList>
		<power>Active Ability: Start a fire in a random room on both ships. Short cooldown</power>
        <power>Max Health is increased to 220</power>
		<power>Can't split, repair or extinguish</power>
		<power>Movement speed 1.2x</power>
		<power>Inflicts 1.5x damage in crew combat</power>
    </powerList>
    <colorList>
        <layer>
            <color r="255" g="255" b="255" a="1"/>
        </layer>
    </colorList>
</crewBlueprint>

