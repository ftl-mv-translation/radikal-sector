<weaponBlueprint name="DJMOD_BAM_FISSUREBEAM">
	<type>BEAM</type>
	<!-- <tip>tip_tile_beam</tip> Error if TRC isnt patched in. -->
	<title>'Bada' Fissure Beam</title>
	<short>'Bada' Beam</short>
	<desc>(RK Bam gear) Can hit 3-5 tiles, hard enough to destroy systems or ships.
		Fissure Beams deal damage per tile rather than per room.</desc>
	<tip>RK_lore_DJMOD_BAM_FISSUREBEAM</tip>
	<damage>2</damage>
	<sysDamage>0</sysDamage>

	<mv-tileDamage method="2"/>
	<sp>0</sp>
	<fireChance>3</fireChance>
	<breachChance>8</breachChance>
	<stunChance>5</stunChance>
	
	<erosionChance>10</erosionChance>
	<erosion>
		<speed>2.125</speed>
		<maxSpeed>2.125</maxSpeed>
		<time>3</time>
		<maxTime>12</maxTime>
		<systemRepairMultiplier>1</systemRepairMultiplier>
		<erodeShields>true</erodeShields>
		<roomAnim renderLayer="2">
			<anim animType="default" animBorder="0">invisible</anim>
            <tileAnim>erosion_tile</tileAnim>
			<wallAnim>erosion_wall</wallAnim>
		</roomAnim>
	</erosion>

	<speed>5</speed>
	<cooldown>19.5</cooldown>
	<hullBust>1</hullBust>
	<power>3</power>
	<cost>110</cost>
	<bp>5</bp>
	<rarity>4</rarity>
	<image>beam_contact</image>
	
	<!-- REFS: Spetum 45, Spontoon 65, Voulge 100, TRC Fangtian 128, Pike 170. -->
	<length>61</length>
	<launchSounds>
		<sound>beam1</sound>
		<sound>beam1_2</sound>
	</launchSounds>
	<weaponArt>djmod_bam_fissurebeam</weaponArt>
	<iconImage>beamH</iconImage>

	<iconScale>0.9</iconScale>		<!-- Scales the weapon icon in equipment/store/hangar screens. Smaller numbers mean the image will be smaller there. -->
</weaponBlueprint>

