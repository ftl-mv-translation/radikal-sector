<!-- Based on MV v5.5.1 blobrock aka "Morph imitating a Rockman"
<crewBlueprint name="unique_rk_engilanius_rockmorph"> -->
<crewBlueprint name="unique_rk_defromorius">
    <desc>(RK Punk) An Engi Defender accidentally merged themselves with Rockman-Morph goo and Lanius bits. Became a RadiKal to escape Harmony torture. The body drains the air the head needs.
		Counts as a rogue Engi Defender.

	Inherited stats: 0.5x stun and movement speed, 2.7x repair speed, drains oxygen.</desc>
    <cost>200</cost>
    <title>Tormented Amalgam</title>
    <short>Amalgam</short>
    <rarity>0</rarity>
    <powerList>
		<power>Active Ability: It and allies on the same ship take 0.7x damage from everything, and deal 1.5x damage. [Lasts 10 seconds. Cooldown 10 seconds.]</power>
        <power>Health increased to 311. Is cloned at 0.5x speed</power>
		<power>Takes 0.2x damage from hazards</power>
		<power>Attacks in melee combat at 2x speed</power>
		<power>Remains controllable with Punk Harmony</power>
    </powerList>
    <colorList>
        <layer>
            <color r="255" g="255" b="255" a="1"/>
        </layer>
    </colorList>
</crewBlueprint>

