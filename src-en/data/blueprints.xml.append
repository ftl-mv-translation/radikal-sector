<FTL>

<!-- RadiKal OPERATIVE SOLDIER. Only purpose is to provide RK sector's coords, and die. Not in that order. -->
<crewBlueprint name="human_soldier_operative">
    <desc>Elite Human Crew. A highly trained human soldier, whose armor protects them from damage. Seems in pain?</desc>
    <cost>39</cost>
    <title>Human Soldier</title>
    <short>Soldier</short>
    <rarity>0</rarity>
    <powerList>
        <power>Inflicts 1.2x damage in combat</power>
		<power>Takes 0.7x damage from combat and 0.6x from fires</power>
        <power>Learns skills much faster</power>
    </powerList>
</crewBlueprint>

<crewBlueprint name="rk_fireghost">
    <desc>Uptors are Alpha Gouls stabilized in special RadiKal Scorch pressure cookers, changing their properties.
		Your system in the current room is immune to fire. Any enemy system in the current room takes 100% more fire damage.
		Can cause yoctoflares from its own body often. That's a very small solar flare, but it's also very close.

	Inherited phantom stats: takes no damage from hazards, has door phasing properties.</desc>
    <cost>135</cost>
    <title>Uptor</title>
    <short>Uptor</short>
    <rarity>0</rarity>
    <powerList>
		<power>Active Ability: Start a fire in a random room on both ships. Short cooldown</power>
        <power>Max Health is increased to 220</power>
		<power>Can't split, repair or extinguish. No sabotage bonus</power>
		<power>Movement speed is increased to 1.2x</power>
		<power>Inflicts 1.5x damage in crew combat</power>
    </powerList>
    <colorList>
        <layer>
            <color r="255" g="255" b="255" a="1"/>
        </layer>
    </colorList>
</crewBlueprint>

</FTL>


