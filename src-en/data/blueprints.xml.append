	<radius>55</radius>
	<damage>0</damage>
	<ion>1</ion>
	<!-- Non-stun Heavy Ion & Fire Ion 40 speed. Others 30. Default Phase Ion is slowest at 25.
	OTHER REFS: Most lasers & missiles have no speed field (so they have the same default speed). Hull laser II has 75. -->
	<speed>55</speed>
	<shots>1</shots>
	<sp>10</sp>
	<fireChance>0</fireChance>
	<breachChance>0</breachChance>
	<stunChance>0</stunChance>
	<cooldown>16</cooldown>
	<power>4</power>
	<cost>120</cost>
	<bp>3</bp>
	<rarity>5</rarity>
	<!-- REF Trifecta from TRC. -->
	<projectiles>
		<projectile count="1" fake="false">ion_phase</projectile>
		<projectile count="1" fake="false" blueprint="ION_1">ion_barrage</projectile>
		<projectile count="1" fake="false" blueprint="ION_HEAVY">ion_heavy</projectile>
