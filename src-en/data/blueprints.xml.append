<weaponBlueprint name="RK_RAIN_OF_ION">
	<type>BURST</type>
	<flavorType>Ion Blast</flavorType>
	<title>Rain of Ions</title>
	<short>Rain Ions</short>
	<locked>1</locked>			<!-- what's that? -->
	<desc>(RK Punk gear) This heavy duty shotgun fires an accelerated phase ion, a heavy ion, a fire ion, a normal ion, a stun ion, and a radion (from fastest to slowest) all at once. Chains cooldown.
		Many weapons worth of blue options!</desc>
	<!-- <tooltip>Fires all 6 common ions in a radius; Cooldown 12 seconds.</tooltip>	Tooltips don't show if <tip> set EXCEPT artillery. -->
	<tip>lore_RK_RAIN_OF_ION</tip>

	<radius>55</radius>			<!-- REFS: Flak 2 = 45, Trion = 60 -->
	<damage>0</damage>
	<ion>1</ion>
    <mv-aiSystemTarget system="weapons"/>

	<!-- Non-stun Heavy Ion & Fire Ion 40 speed. Others 30. Default Phase Ion is slowest at 25.
	OTHER REFS: Most lasers & missiles have no speed field (so they have the same default speed). Hull laser II has 75. -->
	<speed>55</speed>
	<shots>1</shots>
	<sp>10</sp>
	<fireChance>0</fireChance>
	<breachChance>0</breachChance>
	<stunChance>0</stunChance>
