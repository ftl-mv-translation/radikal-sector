<!-- Missile weapon staggered just right so that the 100% chance fire they create never ends.
Small targeting radius to allow for rare collateral fires on O2 ships when targeting smaller than 2x2 tile rooms.

DO NOT remove the EnemyFix version, they shoot multiple rooms with each cooldown so it's very different for them. -->
<weaponBlueprint name="DJMOD_RAIN_OF_FIRE">
	<type>BURST</type>
	<flavorType>Rain of Fire</flavorType>
	<title>Rain of Fire</title>
	<short>Rain Fire</short>
	<desc>(RK Scorch gear) This launcher roasts so well, it can keep airless rooms on fire when fully chained.
		No damage but pierces shields and supershields.</desc>
	<tip>RK_lore_DJMOD_RAIN_OF_FIRE</tip>
	<drone_targetable>1</drone_targetable>
	<radius>30</radius>
	<damage>0</damage>

	<missiles>1</missiles>
	<freeMissileChance>80</freeMissileChance>

	<shots>3</shots>
	<fireTime>0.58</fireTime>		<!-- Default is 1.0: bombs & charge weapons. 0.25: other weapons. Beams unaffected -->

	<sp>10</sp>
	<fireChance>10</fireChance>
	<breachChance>0</breachChance>
	<stunChance>0</stunChance>
	<cooldown>18.5</cooldown>
	<power>2</power>
	<cost>80</cost>
	<bp>6</bp>
	<rarity>3</rarity>
	<projectiles>
		<projectile count="1" fake="false">rk_napalm_missile</projectile>
	</projectiles>
	<!-- <projectiles> and <image> are mutually exclusive. If you declare one, 
	DO NOT ! ! ! ! ! ! ! ! declare the other, or they will interfere with each other and 
	either break the weapon or CRASH THE GAME.-->
