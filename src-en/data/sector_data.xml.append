	<priorityEvent name="ANOMALY_SPAWNER" min="1" max="1" priority="1" req="ANOMALY_SPAWN_CHECK" lvl="1"/>	<!-- TEST -->
	<removeFirstBeaconNebula/>
	
	<!--
	CONSOLE EVERY EVENT (AGAIN for 5.5.1) BEFORE ADDING IT HERE. 
	If console can't start it, IT WILL CRASH THE GAME ON ENTERING SECTOR! Or even on first hyperspeed jump to anywhere.
	Also, any event with unique = true, if given more than max="1" here, same crash.
	
	v5.4+ IMPORTANT: Sectors in FTL have a randomized number of beacons from 19 to 24, independent of 
	how many events you attempt to set for your sector. 
	This means adding up the "minimum" value for every eventList should never be less than 24, 
	or you will occasionally have rare crashes. This also means you should try to have at LEAST 24 unique events for your sector, 
	as you ideally want players to only rarely encounter piracy or filler events or else your sector will feel generic.
	-->

	
	<!-- ===============================================================================
	uniques, make SURE to check numbers. Apply scorched earth method if problems. 
	CURRENT CRASH WAS FROM SOMETHING IN HERE.
	Not from: PHILO, RK STORES, POLICECHECK, MV travelers, PIRACY_LIST, ... 
	FROM: LEAH ( = NEMESIS), customFleet, ...
	CURRENT CRASH (v5.69) MIGHT BE FROM SOMETHING IN HERE.
	Not from: RK GEAR BUYERS, Scorch shop spawning, ... 
	FROM:  ...

	NB: Guard can spawn up to 3 quests.
	=============================================================================== -->
	<event name="RADIKAL_PHILO" min="1" max="1"/>
	<event name="ZOLTAN_POLICECHECK_RK" min="1" max="1"/> <!-- Counts for 2, may spawn quest. -->
	<event name="RADIKAL_ENSLAVED" min="1" max="1"/>
	<event name="THIEVES_RK_LASERS" min="1" max="1"/>
	<event name="RK_GEAR_BUYERS" min="1" max="2"/>

	<event name="RKS_STORE_SNIPER_SIEGED" min="1" max="1"/>
	<event name="EVENT_STORE_RADIKAL" min="3" max="4"/>

	<event name="EMPTY_RADIKAL" min="1" max="2"/>

	<event name="MV_TRAVELER" min="2" max="2"/>
	
	<!-- Mercs, Slavers, Smugglers. They can give bad rep (or good with Piracy is Poggers) or threaten. Accepts 999 instances. -->
	<event name="PIRACY_LIST" min="3" max="5"/> 

	<!--
	
	<event name="THIEVES_RK_MISSILES" min="0" max="1"/>
	<event name="THIEVES_RK_IONS" min="0" max="1"/>
	<event name="THIEVES_RK_BEAMS" min="0" max="1"/>
	

	v
	<event name="NEBULA_EMPTY_RADIKAL" min="1" max="2"/>
	
	<event name="DISTRESS" min="2" max="3"/>

	<event name="empty" min="0" max="0"/> -->

	<!-- Bad filler event - never allows use of Combat augments.
	<event name="HOSTILE_PIRATE" min="999" max="999"/> -->

	<!-- Temp filler from generic sectors - However any extra beacons will (in theory) auto-fill with generic events. -->
	<!-- <event name="EVENTS_CLEARING" min="1" max="3"/>-->
	<event name="FILLER_LIST" min="999" max="999"/>

	<!-- <event name="NEMESIS_ENCOUNTER" min="1" max="1"/> LEAH CRASHING GAME !!!!!!!!!!!!!!!!!!!!!!!!!!!!!! -->
</sectorDescription>
</FTL>

