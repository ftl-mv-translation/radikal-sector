<!-- Sniper girl merchant under attack by stealth ship. Rescue for store which sells mv-stealth weapons and cloak. -->
<event name="RKS_STORE_SNIPER_SIEGED">
	<preventQuest/>
	<beaconType id="map_icon_hostilestore" global="false">
		<color r="215" g="175" b="175" a="1"/>
	</beaconType>
	<text>Looks like an EXTREME-ly deadly stealth ship is attacking the nearby market owned by a certain "Sniper Girl". If you can stop them, you should be able to access the store.
		The specialized store looks ready to provide fire support.
	</text>
	<ship load="SHIP_RKS_STORE_SNIPER_EXTREME" hostile="false"/>
	<choice hidden="true">
		<text>Rescue the store.</text>
		<event>
			<text>You prepare for combat.</text>
			<environment type="PDS" target="enemy"/>
			<ship hostile="true"/>
			<choice hidden="true">
				<text>Continue...</text>
				<event load="COMBAT_CHECK"/>
			</choice>
		</event>
	</choice>
	<choice hidden="true">
		<text>Ignore the merchant.</text>
		<event>
			<text>You are pretty sure they noticed your presence, but they seem too busy to care.</text>
			<choice>
				<text>Do something onboard the ship.</text>
				<event load="STORAGE_CHECK"/>
			</choice>
			<choice>
				<text>Do nothing.</text>
				<event/>
			</choice>
		</event>
	</choice>
</event>

<!-- <ship name="SHIP_MTBOSS_ANGEL_B_EXTREME" auto_blueprint="MTS_BOSS_ANGEL_EXTREME"> -->
<ship name="SHIP_RKS_STORE_SNIPER_EXTREME" auto_blueprint="MTS_BOSS_ANGEL_EXTREME">
	<destroyed>
		<text>The stealth ship breaks apart and you quickly salvage what you can.</text>
		<autoReward level="MED">standard</autoReward>
		<choice hidden="true">
			<text>Continue...</text>
			<event load="RKS_STORE_SNIPER_WIN"/>
		</choice>
	</destroyed>
	<deadCrew>
		<text>With the crew dead you quickly salvage what you can from the stealth ship.</text>
		<autoReward level="HIGH">standard</autoReward>
		<choice hidden="true">
			<text>Continue...</text>
			<event load="RKS_STORE_SNIPER_WIN"/>
		</choice>
