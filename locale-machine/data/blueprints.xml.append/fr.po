#: src-en/data/blueprints.xml.append:96
msgid "data/blueprints.xml.append$//crewBlueprint[@name=\"rk_weaponlike\"]/desc"
msgstr ""
"(RK Bam) Créé en appliquant des électrochocs à un technopathe baigné dans l'acide et rempli d'une bombe, le rendant fou et incapable de changer de forme, mais capable de lancer des bombes.\n"
"\t\tNe compte plus comme un Technopathe ou un Morphe.\n"
"\n"
"\tStats. héritées : occupe 0,5 emplacement d'équipage, immunisé à la suffocation, 75% de résistance aux dégâts de feu et à l'étourdissement, vitesse de déplacement 0,8x."

#: src-en/data/blueprints.xml.append:101
msgid "data/blueprints.xml.append$//crewBlueprint[@name=\"rk_weaponlike\"]/title"
msgstr "Squyrt"

#: src-en/data/blueprints.xml.append:102
