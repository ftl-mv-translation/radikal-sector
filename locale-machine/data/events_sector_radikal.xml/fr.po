msgid ""
"data/events_sector_radikal.xml$//event[@name=\"RKS_QUEST_DEFROMORIUS_2\"]/choice[1]/event/choice[2]/event/text"
msgstr ""
"\"Les Fédéraux sont là pour se venger ! Je t'avais dit que nous aurions dû sauter, Lisa.\"\n"
"\t\t\t\t\t\t\n"
"\t\t\t\t\t\t\"Mais pourquoi ? Nous sommes innocents ! Pourquoi serions-nous encore là, dis-leur ça, espèce d'idiot !\"\n"
"\n"
"\t\t\t\t\t\t\"Hah! Comme s'ils nous croiraient, pourquoi es-tu toujours aussi naïve ? Charge le générateur SPL déjà !\"\n"
"\n"
"\t\t\t\t\t\tSi vous pensez vraiment qu'ils pourraient être innocents, vous devrez malmener leur coque sans les tuer pour obtenir des réponses.\""

#: src-en/data/events_sector_radikal.xml:460
