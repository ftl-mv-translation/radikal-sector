msgid ""
"data/events_sector_radikal.xml$//event[@name=\"RKS_QUEST_DEFROMORIUS\"]/choice[6]/text"
msgstr "Nous ne pouvons rien faire, démantelons simplement ce qu'il reste."

#: src-en/data/events_sector_radikal.xml:1016
msgid ""
"data/events_sector_radikal.xml$//event[@name=\"RKS_QUEST_DEFROMORIUS\"]/choice[6]/event/text"
msgstr ""
"Vous attendez que le vaisseau finisse d'exploser, puis profitez de la "
"ferraille gratuite."

#: src-en/data/events_sector_radikal.xml:1020
