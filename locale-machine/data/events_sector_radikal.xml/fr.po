#: src-en/data/events_sector_radikal.xml:591
msgid ""
"data/events_sector_radikal.xml$//ship[@name=\"SHIP_RKS_HIDEOUT_UNLOCKER\"]/surrender/text"
msgstr ""
"\"Capitaine, nous sommes du même côté ! Arrêtez tout simplement et prenez "
"tout- ... hrhmmrmh!... MHMRrMPH!!\" Le capitaine essayait certainement de se"
" rendre, mais soudain ses lèvres et sa bouche... disparurent, et son corps "
"commença à danser comme une marionnette ridicule suspendue à des ficelles !"

#: src-en/data/events_sector_radikal.xml:595
msgid ""
"data/events_sector_radikal.xml$//ship[@name=\"SHIP_RKS_HIDEOUT_UNLOCKER\"]/surrender/choice[1]/text"
msgstr ""
"Annulez, quelque chose ne va pas ici ! Est-ce ce qui arrive aux "
"propriétaires de repaires qui essaient de se rendre quand un envahisseur "
"veut prendre le contrôle ? Sommes-nous les prochains ?..."

#: src-en/data/events_sector_radikal.xml:600
