msgstr ""

#: src-en/data/events.xml.append:438
msgid ""
"data/events.xml.append$//event[@name=\"RADIKAL_ENSLAVED\"]/choice[1]/event/text"
msgstr ""
"\" Des Feds ici ? Vous avez sûrement besoin de main-d'œuvre, et c'est peut-"
"être votre jour de chance ! Nous avons un guerrier d'élite pour faire le "
"gros du travail pour vous, fortement réduit parce que nous devons commercer "
"vite et partir pour... des raisons. Qu'en dites-vous ? \" Vous remarquez que"
" la réduction est effectivement assez solide, peut-être trop belle."

#: src-en/data/events.xml.append:440
msgid ""
"data/events.xml.append$//event[@name=\"RADIKAL_ENSLAVED\"]/choice[1]/event/choice[1]/text"
msgstr "Acheter l'esclave d'élite."

#: src-en/data/events.xml.append:442
