#: src-en/data/events.xml.append:1671
msgid "data/events.xml.append$//event[@name=\"THIEVES_RK_LASERS_END\"]/text"
msgstr ""
"\"Le classique, technologie locale. Sûrement vous comprenez que nous ne "
