#: src-en/data/events.xml.append:1119
msgid ""
"data/events.xml.append$//event[@name=\"RADIKAL_PHILO_INTEL_REAL\"]/choice[4]/event/text"
msgstr ""
"\"Il faut beaucoup d'équipement spécialisé pour obtenir discrètement autant "
"de matériaux de fabrication dans un secteur caché, c'est ce que mes fils "
"m'ont dit. Cela conduit à des prix élevés, mais pas pour la production "
"locale bien sûr !\""

