msgid ""
"data/events.xml.append$//event[@name=\"RADIKAL_PHILO_INTEL_REAL\"]/choice[1]/event/choice[2]/event/text"
msgstr "Vous prenez vos affaires."

#: src-en/data/events.xml.append:1056
msgid ""
"data/events.xml.append$//event[@name=\"RADIKAL_PHILO_INTEL_REAL\"]/choice[1]/event/choice[2]/event/choice/text"
msgstr "D'accord, nous allons partir maintenant. Merci pour le thé."

#: src-en/data/events.xml.append:1064
msgid ""
"data/events.xml.append$//event[@name=\"RADIKAL_PHILO_INTEL_REAL\"]/choice[2]/text"
msgstr "... à propos des noms des sous-factions."

#: src-en/data/events.xml.append:1066
msgid ""
"data/events.xml.append$//event[@name=\"RADIKAL_PHILO_INTEL_REAL\"]/choice[2]/event/text"
msgstr ""
"\"C'est quoi ces noms ? RadiKal Bam ? Punk ? Scorch ? Ça vient d'une émission pour enfants ou quoi ?\" demandez-vous.\n"
"\t\t\t\n"
"\t\t\t\"Il n'y a pas grand-chose derrière, vraiment. Comme beaucoup de gens les appelaient des radicaux depuis le début de cette petite opération, mes fils et leurs petits amis l'ont simplement adopté. Les sous-factions avaient juste besoin d'un petit quelque chose en plus pour se distinguer, et les gens n'aiment pas trop parler par ici. Alors ils ont fait court et simple. J'ai aussi entendu parler de variables ? Je suis l'exception, discuter est tellement agréable !\""

#: src-en/data/events.xml.append:1072
msgid ""
"data/events.xml.append$//event[@name=\"RADIKAL_PHILO_INTEL_REAL\"]/choice[2]/event/choice[1]/text"
msgstr "Demandez-lui autre chose."

