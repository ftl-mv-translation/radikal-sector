#: src-en/data/events.xml.append:1061
msgid ""
"data/events.xml.append$//event[@name=\"RK_GEAR_BUYER_ZOLTAN\"]/choice[1]/event/choice/event/choice/event/choice[@req=\"DJMOD_HAS_RADIKAL_GEAR\"]/event/text"
msgstr ""
"\"D'accord d'accord, pas besoin de recourir à la violence. Nous y allons.\""

#: src-en/data/events.xml.append:1064
msgid ""
"data/events.xml.append$//event[@name=\"RK_GEAR_BUYER_ZOLTAN\"]/choice[1]/event/choice/event/choice/event/choice[@req=\"DJMOD_HAS_RADIKAL_GEAR\"]/event/choice[1]/text"
msgstr ""
"...Eh bien cela signifie qu'ils sont aussi faibles qu'ils l'ont dit, faisons"
" de la ferraille facile !"

#: src-en/data/events.xml.append:1066
msgid ""
"data/events.xml.append$//event[@name=\"RK_GEAR_BUYER_ZOLTAN\"]/choice[1]/event/choice/event/choice/event/choice[@req=\"DJMOD_HAS_RADIKAL_GEAR\"]/event/choice[1]/event/text"
msgstr ""
"\"Attendez... Attendez ! Ce-ceci était juste une demande de commerce. Comment en est-on arrivé là ? S'il vous plaît !\"\n"
"\t\t\t\t\t\t\t\t\t\t\tComme vous vous en doutiez à cause de la nature secrète de leur mission, ils n'envoient aucun message pour vous dénoncer, ils allument simplement leurs moteurs pour s'échapper ! On dirait que vous avez trouvé un endroit où le crime peut rester impuni..."

#: src-en/data/events.xml.append:1070
