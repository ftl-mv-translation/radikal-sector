#: src-en/data/events.xml.append:1266
msgid ""
"data/events.xml.append$//event[@name=\"RADIKAL_PHILO_INTEL_REAL\"]/choice[4]/event/text"
msgstr ""
"\"Cela demande beaucoup d'équipement spécialisé pour faire entrer "
