#: src-en/data/events.xml.append:1032
msgid ""
"data/events.xml.append$//event[@name=\"RADIKAL_PHILO_INTEL_REAL\"]/choice[2]/text"
msgstr "... à propos des noms de sous-factions."

#: src-en/data/events.xml.append:1034
msgid ""
"data/events.xml.append$//event[@name=\"RADIKAL_PHILO_INTEL_REAL\"]/choice[2]/event/text"
msgstr ""
"\"Quel genre de noms sont-ce là ? RadiKal Bam ? Punk ? Scorch ? Est-ce tiré d'une émission pour enfants ou quelque chose comme ça ?\" demandez-vous.\n"
"\t\t\t\n"
"\t\t\t\"Pas grand-chose en fait. Comme beaucoup de gens les ont appelés des radicaux depuis le début de cette petite opération, mes fils et leurs petits amis l'ont simplement adopté. Les sous-factions avaient juste besoin d'un petit quelque chose en plus pour se distinguer, et les gens n'aiment pas trop parler par ici. Alors ils ont fait court et concis. J'ai aussi entendu parler de variables ? Je suis l'exception, bavarder est tellement agréable !\""

#: src-en/data/events.xml.append:1040
msgid ""
"data/events.xml.append$//event[@name=\"RADIKAL_PHILO_INTEL_REAL\"]/choice[2]/event/choice[1]/text"
