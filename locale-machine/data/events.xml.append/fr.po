#: src-en/data/events.xml.append:871
msgid ""
"data/events.xml.append$//event[@name=\"RK_GEAR_BUYER_ZOLTAN\"]/choice[1]/event/choice/event/choice/event/choice[1]/event/choice[7]/event/choice[2]/text"
