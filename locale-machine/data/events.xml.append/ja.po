#: src-en/data/events.xml.append:912
msgid ""
"data/events.xml.append$//event[@name=\"RK_GEAR_BUYER_ZOLTAN\"]/choice[1]/event/choice/event/choice/event/choice[@req=\"DJMOD_HAS_RADIKAL_GEAR\"]/text"
msgstr "(ラジカル装備) 彼らが貴方の装備を力ずくで奪う前に、兵器を起動せよ。"

#: src-en/data/events.xml.append:914
msgid ""
"data/events.xml.append$//event[@name=\"RK_GEAR_BUYER_ZOLTAN\"]/choice[1]/event/choice/event/choice/event/choice[@req=\"DJMOD_HAS_RADIKAL_GEAR\"]/event/text"
msgstr "「わかったわかった、暴力に訴える必要はない。立ち去らせてもらう。」"

#: src-en/data/events.xml.append:917
msgid ""
"data/events.xml.append$//event[@name=\"RK_GEAR_BUYER_ZOLTAN\"]/choice[1]/event/choice/event/choice/event/choice[@req=\"DJMOD_HAS_RADIKAL_GEAR\"]/event/choice[1]/text"
msgstr "…彼らは自ら認めるほど弱いということだ。楽にスクラップを稼がせてもらおう！"

#: src-en/data/events.xml.append:919
msgid ""
"data/events.xml.append$//event[@name=\"RK_GEAR_BUYER_ZOLTAN\"]/choice[1]/event/choice/event/choice/event/choice[@req=\"DJMOD_HAS_RADIKAL_GEAR\"]/event/choice[1]/event/text"
msgstr ""
"「待て…待て！こ、これはただの取引の願いだったんだ。なぜこうなる！頼む！」\n"
"\t\t\t\t\t\t\t\t\t\t\t任務の性質から察した通り、彼らはあなたを告発するメッセージを送ることもせず、ただ逃亡のためにエンジンを点火している！犯罪が罰せられない場所を見つけたようだ…"

