#: src-en/data/events_special_guards.xml.append:144
msgid ""
"data/events_special_guards.xml.append$//event[@name=\"GUARD_RADIKAL\"]/choice[1]/event/choice[3]/event/choice[1]/event/choice[2]/text"
msgstr "Choisissez \" Punk \"."

#: src-en/data/events_special_guards.xml.append:146
msgid ""
"data/events_special_guards.xml.append$//event[@name=\"GUARD_RADIKAL\"]/choice[1]/event/choice[3]/event/choice[1]/event/choice[2]/event/text"
msgstr ""
"\" Un choix opportun, j'ai entendu dire qu'ils avaient de nouvelles choses "
"disponibles. \" Le garde vous transmet les coordonnées, puis coupe "
"rapidement les communications avant que vous ne puissiez répondre."

#: src-en/data/events_special_guards.xml.append:154
