msgid ""
"data/events_special_guards.xml.append$//event[@name=\"NEBULA_REINFORCEMENTS_RADIKAL\"]/text"
msgstr "「誰かがガードにならなければならない、奴らは仕事をしていてリスクも承知だった。だが、お前もな！」RadiKalの船が攻撃してくる！"

#: src-en/data/events_special_guards.xml.append:357
msgid ""
