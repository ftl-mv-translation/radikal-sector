#: src-en/data/text_misc.xml.append:55
msgid "data/text_misc.xml.append$//text[@name=\"RK_lore_DJMOD_BAM_FISSUREBEAM\"]"
msgstr ""
"Tampon de qualité : \"A réussi à abattre en un coup un transport civil "
"ÉLÉPHANT-CLASS complet !\""

#: src-en/data/text_misc.xml.append:56
msgid "data/text_misc.xml.append$//text[@name=\"RK_lore_RK_HEAVY_POPPER_2\"]"
msgstr ""
"Tampon de qualité : \"L'influenceuse 'BL2Forever420' a dit 'Amitié TERMINÉE "
"avec les lasers rafale' à ses MILLIARDS d'abonnés !\""

#: src-en/data/text_misc.xml.append:57
msgid "data/text_misc.xml.append$//text[@name=\"lore_RK_UNLOADER\"]"
msgstr ""
"Tampon de qualité : \"A démoli TOUS les vaisseaux de test récalcitrants qui "
"manquaient de drones de défense puissants ! Et les finances de tous les "
"utilisateurs.\""

#: src-en/data/text_misc.xml.append:59
msgid ""
"data/text_misc.xml.append$//text[@name=\"RK_lore_RK_MISSLAUNCHER_2_BATTERY\"]"
msgstr ""
"Tampon de qualité : \"A SAUVÉ la mise quand les autorités ont tenté de "
"neutraliser les armes de KILLER LEE. Ils sont morts à la place !\""

#: src-en/data/text_misc.xml.append:60
msgid "data/text_misc.xml.append$//text[@name=\"lore_RK_KILLALL_BEAM\"]"
msgstr ""
"Tampon de qualité : \"Les capitaines de test sous-traités ont rapporté "
"d'INNOMBRABLES victimes ! Mais les mutineries ont coûté la vie à 89% d'entre"
" eux.\""

#: src-en/data/text_misc.xml.append:61
msgid "data/text_misc.xml.append$//text[@name=\"lore_RK_RAIN_OF_ION\"]"
msgstr ""
"Tampon de qualité : \"42 VICTIMES CONFIRMÉES des races de la Fédération par "
"asphyxie, crises et autres causes !\""

#: src-en/data/text_misc.xml.append:62
msgid "data/text_misc.xml.append$//text[@name=\"lore_RK_SHOTPHASER\"]"
msgstr ""
"Tampon de qualité : \"A aidé à la pacification d'un ancien concurrent Limace"
" EXTRÊMEMENT BLINDÉ !\""

#: src-en/data/text_misc.xml.append:64
msgid "data/text_misc.xml.append$//text[@name=\"lore_RK_BOMBLAUNCHER_OXYBOTTLE\"]"
msgstr ""
"Tampon de qualité : \"A aidé des esclavagistes recherchés à éviter "
"l'asphyxie ET à se venger des Lanius qui en étaient la cause !\""

#: src-en/data/text_misc.xml.append:65
msgid ""
"data/text_misc.xml.append$//text[@name=\"RK_lore_RK_OXY_FIREFILL_MISSILES\"]"
msgstr ""
"Tampon de qualité : \"Beaucoup ont déclaré que c'était un 'CRIME DE GUERRE "
"ODIEUX'. D'autres, principalement des Rocailleux, ont épousé les leurs !\""

#: src-en/data/text_misc.xml.append:66
msgid "data/text_misc.xml.append$//text[@name=\"RK_lore_RK_FOCUS_FIRE\"]"
msgstr ""
"Tampon de qualité : \"Élue 'Arme du cycle' par 'INFERNAL NEWS' et 'SCORCHING"
" STONES' !\""

#: src-en/data/text_misc.xml.append:67
msgid "data/text_misc.xml.append$//text[@name=\"RK_lore_DJMOD_RAIN_OF_FIRE\"]"
msgstr ""
"Tampon de qualité : \"Propulsé par des Orchidées d'ÉLITE liquéfiées ! A "
"brûlé des vaisseaux Fantômes ET Rocailleux !\""

#: src-en/data/text_misc.xml.append:68
msgid "data/text_misc.xml.append$//text[@name=\"RK_lore_DJMOD_LASER_BPS\"]"
msgstr ""
"Tampon de qualité : \"A démontré la performance RK en éliminant un vaisseau "
"piloté de CHAQUE faction naturelle et surnaturelle !\""
