#: src-en/data/text_misc.xml.append:55
msgid "data/text_misc.xml.append$//text[@name=\"RK_lore_DJMOD_BAM_FISSUREBEAM\"]"
msgstr ""
"Tampon de qualité : \"A éliminé en un coup un transport civil classe "
"Éléphant complet\""

#: src-en/data/text_misc.xml.append:56
msgid "data/text_misc.xml.append$//text[@name=\"lore_RK_UNLOADER\"]"
msgstr ""
"Tampon de qualité : \"A démoli tous les vaisseaux tests récalcitrants qui "
"manquaient de drones de défense puissants, ainsi que les finances de tous "
"les utilisateurs.\""

#: src-en/data/text_misc.xml.append:57
msgid "data/text_misc.xml.append$//text[@name=\"lore_RK_KILLALL_BEAM\"]"
msgstr ""
"Tampon de qualité : \"Les capitaines de test sous-traités ont rapporté "
"d'innombrables éliminations, mais les mutineries ont coûté la vie à 89% "
"d'entre eux.\""

#: src-en/data/text_misc.xml.append:58
msgid "data/text_misc.xml.append$//text[@name=\"lore_RK_RAIN_OF_ION\"]"
msgstr ""
"Tampon de qualité : \"42 éliminations confirmées de races de la Fédération "
"par suffocation, crises d'épilepsie et autres causes\""

#: src-en/data/text_misc.xml.append:59
msgid "data/text_misc.xml.append$//text[@name=\"lore_RK_SHOTPHASER\"]"
msgstr ""
"Tampon de qualité : \"A assisté à la pacification d'un ancien concurrent "
"Limace extrêmement protégé\""

#: src-en/data/text_misc.xml.append:60
msgid "data/text_misc.xml.append$//text[@name=\"RK_lore_DJMOD_RAIN_OF_FIRE\"]"
msgstr ""
"Tampon de qualité : \"Alimenté par des Orchidées d'élite liquéfiées. A brûlé"
" des vaisseaux Lanius et Rocailleux\""

#: src-en/data/text_misc.xml.append:61
msgid "data/text_misc.xml.append$//text[@name=\"RK_lore_DJMOD_LASER_BPS\"]"
msgstr ""
"Tampon de qualité : \"A démontré les performances RK en éliminant un "
"vaisseau piloté de chaque faction naturelle et non naturelle\""
